// Test while loop
متغیر گنتی = 1;
جبکہ (گنتی <= 5) {
    لکھو(گنتی);
    گنتی += 1;
}

// While with break
متغیر ن = 0;
جبکہ (سچ) {
    ن += 1;
    اگر (ن >= 3) {
        ٹوٹنا;
    }
}
لکھو(`ٹوٹا: ${ن}`);

// While with continue
متغیر ج = 0;
جبکہ (ج < 10) {
    ج += 1;
    اگر (ج % 2 == 0) {
        جاری;
    }
    لکھو(ج);
}

// Do-while
متغیر د = 1;
کرو {
    لکھو(`کرو: ${د}`);
    د += 1;
} جبکہ (د <= 3);
