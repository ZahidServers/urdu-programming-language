// اردو/تاریخ — verified API
درآمد { تاریخ, مدت, وقت } سے "اردو/تاریخ";

// آج کی تاریخ
متغیر آج = تاریخ.آج();
لکھو("آج:", متن(آج));
لکھو("سال:", آج.سال);
لکھو("مہینہ:", آج.مہینہ);
لکھو("دن:", آج.دن);
لکھو("دن نام:", آج.دن_نام);
لکھو("مہینہ نام:", آج.مہینہ_نام);
لکھو("فارمیٹ:", آج.فارمیٹ("%d %B %Y"));
لکھو("اردو فارمیٹ:", آج.اردو_فارمیٹ());
لکھو("کبیسہ:", آج.کبیسہ);

// مدت
متغیر ایک_ہفتہ = نیا مدت(ہفتے=1);
لکھو("ہفتے کے دن:", ایک_ہفتہ.کل_دن);
متغیر ڈیڑھ_گھنٹہ = نیا مدت(گھنٹے=1, منٹ=30);
لکھو("منٹ:", ڈیڑھ_گھنٹہ.کل_منٹ);

// تاریخ حساب با + اور - آپریٹرز
متغیر اگلا_ہفتہ = آج + ایک_ہفتہ;
لکھو("اگلا ہفتہ:", متن(اگلا_ہفتہ));

// مخصوص تاریخ
متغیر یوم_آزادی = نیا تاریخ(1947, 8, 14);
لکھو("یوم آزادی:", متن(یوم_آزادی));

// فرق دو تاریخوں میں
متغیر فرق = آج - یوم_آزادی;
لکھو("آزادی سے دن:", عدد(فرق.کل_دن));

// پارس
متغیر ت = تاریخ.پارس("2026-01-01");
لکھو("پارس:", متن(ت));

// وقت
متغیر ابھی = نیا وقت(14, 30, 0);
لکھو("وقت:", ابھی.فارمیٹ("%H:%M"));
لکھو("گھنٹہ:", ابھی.گھنٹہ);
لکھو("منٹ:", ابھی.منٹ);
