درآمد { ڈجانگو, ڈجانگو_ماڈل, متن_خانہ, عدد_خانہ, بولین_خانہ, سب_حاصل, بنائیں, فلٹر } سے "اردو/ویب";

متغیر ایپ = نیا ڈجانگو({
    ڈیبگ: سچ,
    ڈیٹا_بیس: ":memory:"
});

ایپ.ترتیب_دیں();

کلاس کتاب توسیع ڈجانگو_ماڈل {
    جامد عنوان = متن_خانہ(200);
    جامد سال = عدد_خانہ(ڈیفالٹ=2024);
    جامد دستیاب = بولین_خانہ(ڈیفالٹ=سچ);
}

ایپ.میزیں_بنائیں();

بنائیں(کتاب, عنوان="اردو کا سفر", سال=2025);
بنائیں(کتاب, عنوان="پروگرامنگ گائیڈ", سال=2024);

متغیر سب = سب_حاصل(کتاب);
لکھو(لمبائی(سب));

متغیر قدیم = فلٹر(کتاب, سال=2024);
لکھو(لمبائی(قدیم));

لکھو("Django ٹھیک");
