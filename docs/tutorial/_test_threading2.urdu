درآمد { دھاگہ, قطار, تالہ, واقعہ, سیمافور, ٹائمر, وقفہ_ٹائمر } سے "اردو/دھاگہ";
درآمد { نیند } سے "اردو/تاریخ";

// ── Producer-consumer with queue ──
متغیر ق = نیا قطار();
متغیر نتائج = [];

فنکشن پیدا_کار() {
    متغیر ا = 0;
    جبکہ (ا < 3) {
        ق.ڈالو(ا + 1);
        ا = ا + 1;
    }
    ق.ڈالو(خالی);    // stop signal
}

فنکشن صارف() {
    جبکہ (سچ) {
        متغیر آئٹم = ق.نکالو();
        اگر (آئٹم == خالی) { ٹوٹنا; }
        نتائج.شامل(آئٹم * 10);
    }
}

متغیر د_پ = نیا دھاگہ(پیدا_کار);
متغیر د_ص = نیا دھاگہ(صارف);
د_پ.شروع();
د_ص.شروع();
د_پ.انتظار();
د_ص.انتظار();
لکھو(نتائج);    // [10, 20, 30]

// ── Lock for shared counter ──
متغیر شمار = [0];
متغیر ل = نیا تالہ();

فنکشن بڑھاؤ() {
    متغیر ا = 0;
    جبکہ (ا < 100) {
        ل.قبضہ();
        شمار[0] = شمار[0] + 1;
        ل.چھوڑو();
        ا = ا + 1;
    }
}

متغیر د1 = نیا دھاگہ(بڑھاؤ);
متغیر د2 = نیا دھاگہ(بڑھاؤ);
د1.شروع();
د2.شروع();
د1.انتظار();
د2.انتظار();
لکھو(شمار[0]);    // 200

// ── Event signaling ──
متغیر واق = نیا واقعہ();
متغیر پیغام = [""];

فنکشن منتظر_کام() {
    واق.انتظار(2.0);    // wait up to 2 seconds
    لکھو(`پیغام ملا: ${پیغام[0]}`);
}

فنکشن بھیجنے_والا() {
    نیند(0.1);
    پیغام[0] = "آمادہ";
    واق.مقرر();
}

متغیر د_م = نیا دھاگہ(منتظر_کام);
متغیر د_ب = نیا دھاگہ(بھیجنے_والا);
د_م.شروع();
د_ب.شروع();
د_م.انتظار();
د_ب.انتظار();

// ── One-shot timer ──
متغیر ہوا = [جھوٹ];
فنکشن کال_بیک() { ہوا[0] = سچ; }
متغیر ٹ = نیا ٹائمر(0.1, کال_بیک);
ٹ.شروع();
نیند(0.3);
لکھو(ہوا[0]);    // True

// ── Semaphore — limit concurrent threads ──
متغیر س = نیا سیمافور(2);
متغیر فعال = [0];
متغیر تعداد = [0];

فنکشن محدود_کام(شناخت) {
    س.حاصل();
    فعال[0] = فعال[0] + 1;
    تعداد[0] = تعداد[0] + 1;
    نیند(0.05);
    فعال[0] = فعال[0] - 1;
    س.چھوڑو();
}

متغیر دھاگے = [];
متغیر ب = 0;
جبکہ (ب < 4) {
    متغیر د = نیا دھاگہ(محدود_کام, ب);
    دھاگے.شامل(د);
    د.شروع();
    ب = ب + 1;
}

کے_لیے (متغیر د میں دھاگے) { د.انتظار(); }
لکھو(تعداد[0]);    // 4

لکھو("سب ٹھیک");
