// Purely async script — transpiler wraps everything in asyncio.run()
غیر_متزامن فنکشن ڈیٹا_لائیں() {
    انتظار تاخیر(50);
    واپس { نام: "احمد", عمر: 25 };
}

غیر_متزامن فنکشن مرکزی() {
    لکھو("لوڈ ہو رہا ہے...");
    متغیر ڈیٹا = انتظار ڈیٹا_لائیں();
    لکھو("نام:", ڈیٹا.نام);
    لکھو("عمر:", ڈیٹا.عمر);
    لکھو("مکمل!");
}

انتظار مرکزی();
