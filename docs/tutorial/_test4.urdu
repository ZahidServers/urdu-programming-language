// Test object destructuring
مستقل شخص = { نام: "عمر", عمر: 28, شہر: "کراچی" };
متغیر { نام, عمر } = شخص;
لکھو(نام, عمر);

// Test array destructuring
مستقل رنگ = ["سرخ", "سبز", "نیلا"];
متغیر [پہلا, دوسرا] = رنگ;
لکھو(پہلا, دوسرا);

// Test rest in array
متغیر [سر, ...دم] = [1,2,3,4,5];
لکھو(سر, دم);

// Test swap
متغیر الف = "A", ب = "B";
[الف, ب] = [ب, الف];
لکھو(الف, ب);

// Test for..of destructuring
مستقل لوگ = [{نام:"علی",عمر:20},{نام:"سارہ",عمر:25}];
کے_لیے (متغیر {نام, عمر} کا لوگ) {
    لکھو(نام, عمر);
}
