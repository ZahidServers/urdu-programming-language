// === VARIABLES ===
متغیر نام = "احمد";
مستقل زبان = "اردو";
لکھو("متغیر:", نام);
لکھو("مستقل:", زبان);

// === DATA TYPES ===
متغیر عدد_صحیح = 42;
متغیر اعشاری = 3.14;
متغیر صحیح_غلط = سچ;
متغیر خالی_قدر = خالی;
لکھو("عدد:", عدد_صحیح);
لکھو("اعشاری:", اعشاری);
لکھو("بولین:", صحیح_غلط);
لکھو("خالی:", خالی_قدر);

// === ARITHMETIC ===
لکھو("جمع:", 10 + 3);
لکھو("تفریق:", 10 - 3);
لکھو("ضرب:", 10 * 3);
لکھو("تقسیم:", 10 / 3);
لکھو("باقی:", 10 % 3);
لکھو("قوت:", 2 ** 8);

// === TEMPLATE STRING ===
متغیر عمر = 25;
لکھو(`نام: ${نام}، عمر: ${عمر}`);

// === IF/ELSE ===
اگر (عمر >= 18) {
    لکھو("بالغ");
} ورنہ {
    لکھو("نابالغ");
}

// === FOR LOOP ===
کے_لیے (متغیر ی کا [1, 2, 3]) {
    لکھو("عنصر:", ی);
}

// === WHILE LOOP ===
متغیر گنتی = 0;
جبکہ (گنتی < 3) {
    لکھو("گنتی:", گنتی);
    گنتی = گنتی + 1;
}

// === FUNCTION ===
فنکشن جمع_کریں(الف, ب) {
    واپس الف + ب;
}
لکھو("جمع فنکشن:", جمع_کریں(5, 7));
