// filter/map/reduce with named functions work
متغیر اعداد = [3,1,4,1,5,9,2,6,8,7];

فنکشن بڑا_ہے(x) { واپس x > 4; }
فنکشن دوگنا(x) { واپس x * 2; }
فنکشن جمع(s, x) { واپس s + x; }
فنکشن مثبت(x) { واپس x > 0; }
فنکشن نو_سے_بڑا(x) { واپس x > 9; }

لکھو("filter:", اعداد.filter(بڑا_ہے));
لکھو("map:", اعداد.map(دوگنا));
لکھو("reduce:", اعداد.reduce(جمع, 0));
لکھو("find:", اعداد.find(بڑا_ہے));
لکھو("every:", اعداد.every(مثبت));
لکھو("some:", اعداد.some(نو_سے_بڑا));
لکھو("join:", اعداد.join("-"));

// Default sort (no comparator) works
لکھو("sort numbers:", [...اعداد].sort());
لکھو("sort strings:", ["زید","احمد","باقر"].sort());
لکھو("reverse:", [...اعداد].reverse());
لکھو("slice:", اعداد.slice(2, 5));

// String methods
متغیر متن = "السلام علیکم، اردو پروگرامنگ!";
لکھو("length:", متن.length);
لکھو("split:", متن.split(" "));
لکھو("includes:", متن.includes("اردو"));
لکھو("startsWith:", متن.startsWith("السلام"));
لکھو("endsWith:", متن.endsWith("!"));
لکھو("indexOf:", متن.indexOf("علیکم"));
لکھو("slice:", متن.slice(0, 9));
لکھو("replace:", متن.replace("اردو", "نئی"));
لکھو("trim:", "  خالی  ".trim());
لکھو("repeat:", "ہا".repeat(3));
لکھو("padStart:", "7".padStart(4, "0"));
لکھو("toUpper:", "hello".toUpperCase());
لکھو("toLower:", "HELLO".toLowerCase());

// Math built-ins
درآمد * بطور ریاضی سے "math";
لکھو("pi:", ریاضی.pi);
لکھو("ceil:", ریاضی.ceil(4.1));
لکھو("floor:", ریاضی.floor(4.9));
لکھو("sqrt:", ریاضی.sqrt(25));
لکھو("abs:", ریاضی.fabs(-9));
لکھو("pow:", ریاضی.pow(2, 10));
لکھو("log10:", ریاضی.log10(1000));
لکھو("log2:", ریاضی.log2(8));
لکھو("sin:", گول(ریاضی.sin(ریاضی.pi/2), 4));
لکھو("cos:", گول(ریاضی.cos(0), 4));

// max/min/round
لکھو("max:", زیادہ_سے_زیادہ(1, 5, 3, 9, 2));
لکھو("min:", کم_سے_کم(1, 5, 3, 9, 2));
لکھو("round:", گول(3.7));
لکھو("round2:", گول(3.14159, 2));

// Type conversion
لکھو("int:", عدد("42"));
لکھو("float:", اعشاریہ("3.14"));
لکھو("str:", تار(100));
لکھو("bool:", منطقی(1));
لکھو("bool0:", منطقی(0));
لکھو("type:", قسم(42));
لکھو("type:", قسم("hi"));
لکھو("type:", قسم([]));
لکھو("type:", قسم({}));
لکھو("type:", قسم(سچ));
