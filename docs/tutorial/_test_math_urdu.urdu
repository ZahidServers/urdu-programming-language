// Test all Urdu math method names

// Constants
لکھو(ریاضی.پائی);          // 3.14159...
لکھو(ریاضی.قدرتی);         // 2.71828...
لکھو(ریاضی.جذر_دو);        // 1.41421...
لکھو(ریاضی.دائرہ);         // 6.28318...
لکھو(ریاضی.لن_دو);         // 0.69314...
لکھو(ریاضی.لن_دس);         // 2.30258...

// Roots / powers
لکھو(ریاضی.جذر(9));            // 3.0
لکھو(ریاضی.جذر_مربع(16));      // 4.0
لکھو(ریاضی.جذر_مکعب(27));      // 3.0
لکھو(ریاضی.طاقت(2, 8));        // 256.0
لکھو(ریاضی.مرتفع(1));          // 2.718...

// Rounding
لکھو(ریاضی.مطلق(-7));          // 7
لکھو(ریاضی.چھت(2.1));          // 3
لکھو(ریاضی.فرش(2.9));          // 2
لکھو(ریاضی.گول(3.5));          // 4
لکھو(ریاضی.تراش(3.9));         // 3
لکھو(ریاضی.علامت(-5));         // -1
لکھو(ریاضی.علامت(0));          // 0
لکھو(ریاضی.علامت(5));          // 1

// Logarithms
لکھو(گول(ریاضی.لاگ(ریاضی.قدرتی), 5));   // 1.0
لکھو(ریاضی.لاگ2(8));           // 3.0
لکھو(ریاضی.لاگ10(1000));       // 3.0

// Trigonometry — Urdu names
لکھو(ریاضی.سائن(0));                         // 0.0
لکھو(ریاضی.کوسائن(0));                       // 1.0
لکھو(ریاضی.ٹینجنٹ(0));                       // 0.0
لکھو(گول(ریاضی.سائن(ریاضی.پائی / 2), 5));   // 1.0
لکھو(گول(ریاضی.کوسائن(ریاضی.پائی), 5));     // -1.0

// Degrees ↔ Radians
لکھو(گول(ریاضی.ریڈین(180), 5));    // 3.14159
لکھو(گول(ریاضی.درجے(ریاضی.پائی), 2));  // 180.0

// Trig with degree conversion
متغیر زاویہ_30 = ریاضی.ریڈین(30);
لکھو(گول(ریاضی.سائن(زاویہ_30), 5));        // 0.5
لکھو(گول(ریاضی.کوسائن(زاویہ_30), 5));      // 0.86603

// Inverse trig
لکھو(گول(ریاضی.معکوس_سائن(1), 5));         // 1.5708 (π/2)
لکھو(گول(ریاضی.معکوس_کوسائن(0), 5));       // 1.5708
لکھو(گول(ریاضی.معکوس_ٹینجنٹ(1), 5));       // 0.7854 (π/4)
لکھو(گول(ریاضی.ٹینجنٹ2(1, 1), 5));         // 0.7854

// Geometry
لکھو(گول(ریاضی.وتر(3, 4), 5));     // 5.0

// Combinatorics
لکھو(ریاضی.ضربی(5));              // 120
لکھو(ریاضی.مشترک_قسم(12, 8));    // 4

// Random (just check it's in range)
متغیر ع = ریاضی.اتفاقی();
لکھو(ع >= 0 اور ع < 1);    // True

لکھو("سب ٹھیک");
