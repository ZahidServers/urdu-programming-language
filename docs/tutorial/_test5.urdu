// Array destructuring
مستقل رنگ = ["سرخ", "سبز", "نیلا"];
متغیر [پہلا, دوسرا, تیسرا] = رنگ;
لکھو("Array destructure:", پہلا, دوسرا, تیسرا);

// Skip elements
مستقل اعداد = [10, 20, 30, 40, 50];
متغیر [ع1, , ع3, , ع5] = اعداد;
لکھو("Skip:", ع1, ع3, ع5);

// Rest in array
متغیر [سر, ...دم] = [1,2,3,4,5];
لکھو("head:", سر, "tail:", دم);

// Swap
متغیر الف = "A", ب = "B";
[الف, ب] = [ب, الف];
لکھو("swap:", الف, ب);

// Array methods in detail
متغیر ل = [3,1,4,1,5,9,2,6];
لکھو("sort:", [...ل].sort(فنکشن(x,y){ واپس x-y; }));
لکھو("filter:", ل.filter(فنکشن(x){ واپس x>3; }));
لکھو("map:", ل.map(فنکشن(x){ واپس x*2; }));
لکھو("reduce:", ل.reduce(فنکشن(s,x){ واپس s+x; }, 0));
لکھو("find:", ل.find(فنکشن(x){ واپس x>4; }));
لکھو("every:", ل.every(فنکشن(x){ واپس x>0; }));
لکھو("some:", ل.some(فنکشن(x){ واپس x>8; }));
لکھو("join:", ل.join("-"));
لکھو("reverse:", [...ل].reverse());
لکھو("flat:", [[1,2],[3,4]].flat());

// String methods
متغیر متن = "السلام علیکم اردو";
لکھو("length:", متن.length);
لکھو("split:", متن.split(" "));
لکھو("includes:", متن.includes("اردو"));
لکھو("startsWith:", متن.startsWith("السلام"));
لکھو("endsWith:", متن.endsWith("اردو"));
لکھو("indexOf:", متن.indexOf("علیکم"));
لکھو("slice(0,7):", متن.slice(0, 7));
لکھو("replace:", متن.replace("اردو", "دنیا"));
لکھو("trim:", "  خالی  ".trim());
لکھو("repeat:", "ہا".repeat(3));
لکھو("padStart:", "5".padStart(3, "0"));
لکھو("padEnd:", "5".padEnd(3, "0"));

// Math
درآمد * بطور ریاضی سے "math";
لکھو("pi:", ریاضی.pi);
لکھو("ceil:", ریاضی.ceil(4.1));
لکھو("floor:", ریاضی.floor(4.9));
لکھو("sqrt:", ریاضی.sqrt(25));
لکھو("abs:", ریاضی.fabs(-9));
لکھو("pow:", ریاضی.pow(3,3));
لکھو("max:", زیادہ_سے_زیادہ(1,5,3));
لکھو("min:", کم_سے_کم(1,5,3));
لکھو("round:", گول(3.7));
لکھو("log:", ریاضی.log10(1000));

// Type conversion
لکھو("int:", عدد("42"));
لکھو("float:", اعشاریہ("3.14"));
لکھو("str:", تار(100));
لکھو("bool:", منطقی(1));
لکھو("type:", قسم(42));
لکھو("type:", قسم("متن"));
لکھو("type:", قسم([]));
لکھو("type:", قسم({}));
