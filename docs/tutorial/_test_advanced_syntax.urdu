// === SWITCH/CASE ===
متغیر دن = "پیر";
منتخب (دن) {
    صورت "پیر":
        لکھو("ہفتے کا پہلا دن");
        توڑو;
    صورت "جمعہ":
        لکھو("ہفتے کا آخری دن");
        توڑو;
    ڈیفالٹ:
        لکھو("کوئی اور دن");
}

// === ARRAYS ===
متغیر پھل = ["سیب", "کیلا", "آم"];
لکھو("پہلا:", پھل[0]);
لکھو("لمبائی:", لمبائی(پھل));
پھل.دھکیلو("انگور");
لکھو("شامل کے بعد:", پھل);
متغیر آخری = پھل.نکالو();
لکھو("نکالا:", آخری);

// === FOR..OF loop ===
کے_لیے (متغیر ف کا پھل) {
    لکھو("پھل:", ف);
}

// === OBJECTS ===
متغیر طالب = { نام: "علی", عمر: 20, شہر: "کراچی" };
لکھو("نام:", طالب.نام);
لکھو("عمر:", طالب["عمر"]);
طالب.شہر = "لاہور";
لکھو("نیا شہر:", طالب.شہر);

// === BREAK / CONTINUE ===
کے_لیے (متغیر ع کا [1,2,3,4,5,6]) {
    اگر (ع == 4) { ٹوٹنا; }
    اگر (ع % 2 == 0) { جاری; }
    لکھو("طاق:", ع);
}

// === STRING METHODS ===
متغیر جملہ = "  السلام علیکم  ";
لکھو(جملہ.trim());
لکھو("اردو".toUpperCase());
لکھو("URDU".toLowerCase());
متغیر حصے = "ایک،دو،تین".split("،");
لکھو("حصے:", حصے);
لکھو("شامل:", "ایک،دو،تین".includes("دو"));
لکھو("تبدیل:", "ہیلو ورلڈ".replace("ورلڈ", "اردو"));

// === TYPE CONVERSION ===
لکھو("عدد:", عدد("42"));
لکھو("اعشاریہ:", اعشاریہ("3.14"));
لکھو("تار:", تار(100));
لکھو("قسم:", قسم(42));
