// === CLASSES ===
کلاس حیوان {
    تعمیر(نام, آواز) {
        یہ.نام = نام;
        یہ.آواز = آواز;
    }
    بولو() {
        لکھو(`${یہ.نام} کہتا ہے: ${یہ.آواز}`);
    }
    متن() {
        واپس `حیوان(${یہ.نام})`;
    }
}

متغیر بلی = نیا حیوان("بلی", "میاؤں");
متغیر کتا = نیا حیوان("کتا", "بھونکنا");
بلی.بولو();
کتا.بولو();
لکھو(بلی.نام);
لکھو(بلی.متن());

// === INHERITANCE ===
کلاس پالتو_جانور توسیع حیوان {
    تعمیر(نام, آواز, مالک) {
        سپر(نام, آواز);
        یہ.مالک = مالک;
    }
    تعارف() {
        لکھو(`${یہ.نام} کا مالک ${یہ.مالک} ہے`);
    }
}

متغیر میرا_کتا = نیا پالتو_جانور("شیرو", "وف وف", "احمد");
میرا_کتا.بولو();
میرا_کتا.تعارف();
لکھو(نمونہ(پالتو_جانور, میرا_کتا));
لکھو(نمونہ(حیوان, میرا_کتا));

// === STATIC METHODS ===
کلاس ریاضی_مددگار {
    جامد جمع(الف, ب) { واپس الف + ب; }
    جامد ضرب(الف, ب) { واپس الف * ب; }
}
لکھو(ریاضی_مددگار.جمع(5, 3));
لکھو(ریاضی_مددگار.ضرب(4, 7));

// === ERROR HANDLING ===
کوشش {
    پھینکو نیا غلطی("یہ ایک جانچ غلطی ہے");
} پکڑو (غ) {
    لکھو("پکڑا:", غ.پیغام);
} آخر {
    لکھو("آخر میں چلا");
}

// nested try/catch
کوشش {
    متغیر نتیجہ = عدد("abc");
    اگر (نان_ہے(نتیجہ)) {
        پھینکو نیا رینج_غلطی("عدد نہیں");
    }
} پکڑو (غ) {
    لکھو("قسم:", غ.پیغام);
}

// === ADVANCED FUNCTIONS ===
// Default parameters
فنکشن سلام(نام, لقب = "جناب") {
    لکھو(`السلام علیکم، ${لقب} ${نام}!`);
}
سلام("احمد");
سلام("فاطمہ", "محترمہ");

// Rest parameters
فنکشن جمع_سب(...اعداد) {
    واپس مجموع(اعداد);
}
لکھو(جمع_سب(1, 2, 3, 4, 5));
لکھو(جمع_سب(10, 20));

// Closure
فنکشن گنتی_بنائیں(شروع = 0) {
    متغیر گنتی = شروع;
    واپس فنکشن() {
        گنتی = گنتی + 1;
        واپس گنتی;
    };
}
متغیر اگلا = گنتی_بنائیں(0);
لکھو(اگلا());
لکھو(اگلا());
لکھو(اگلا());

// Higher-order function
فنکشن ضرب_دہندہ(ن) {
    واپس فنکشن(x) { واپس x * ن; };
}
متغیر تین_گنا = ضرب_دہندہ(3);
لکھو(تین_گنا(5));
لکھو(تین_گنا(10));

// Recursive function
فنکشن فیکٹوریل(ن) {
    اگر (ن <= 1) واپس 1;
    واپس ن * فیکٹوریل(ن - 1);
}
لکھو(فیکٹوریل(5));
لکھو(فیکٹوریل(10));
