// === TYPE CONVERSION ===
لکھو(عدد("42"));
لکھو(اعشاریہ("3.14"));
لکھو(متن(100));
لکھو(بولین(1));
لکھو(بولین(0));
لکھو(قسم(42));
لکھو(قسم("سلام"));
لکھو(قسم([]));
لکھو(قسم({}));
لکھو(قسم(سچ));
لکھو(قسم(خالی));

// === COLLECTIONS ===
متغیر ف = فہرست(1, 2, 3, 4, 5);
لکھو(ف);
متغیر ت = ٹپل(10, 20, 30);
لکھو(ت);
متغیر م = مجموعہ([1, 2, 2, 3, 3]);
لکھو(م);

// === AGGREGATION ===
لکھو(مجموع([1,2,3,4,5]));
لکھو(کم([5, 3, 8, 1, 9]));
لکھو(زیادہ([5, 3, 8, 1, 9]));
لکھو(کم(10, 5, 15));
لکھو(زیادہ(10, 5, 15));

// === MATH ===
لکھو(مطلق(-7));
لکھو(گول(3.7));
لکھو(گول(3.14159, 2));
لکھو(طاقت(2, 10));

// === ترتیب (sorted) ===
متغیر ل = [3,1,4,1,5,9,2,6];
لکھو(ترتیب(ل));
لکھو(ترتیب(ل, الٹا=سچ));
متغیر الفاظ = ["کیلا", "آم", "انگور", "سیب"];
لکھو(ترتیب(الفاظ, کلید=لمبائی));

// === ریورس ===
لکھو(ریورس([1,2,3,4,5]));

// === نقشہ / فلٹر (named functions) ===
فنکشن دوگنا(x) { واپس x * 2; }
فنکشن بڑا_تین_سے(x) { واپس x > 3; }
لکھو(نقشہ(دوگنا, [1,2,3,4,5]));
لکھو(فلٹر(بڑا_تین_سے, [1,2,3,4,5,6]));

// === گنو (enumerate) — uses میں ===
کے_لیے (متغیر [i, ق] میں گنو(["الف","ب","ج"])) {
    لکھو(i, ق);
}

// === زپ (zip) ===
متغیر نام = ["احمد","فاطمہ"];
متغیر عمر = [20, 22];
کے_لیے (متغیر [ن, ع] میں زپ(نام, عمر)) {
    لکھو(ن, ع);
}

// === STRING built-ins ===
لکھو(ربط(", ", ["ایک","دو","تین"]));
لکھو(تقسیم("ایک دو تین"));
لکھو(تقسیم("ا،ب،ج", "،"));
لکھو(شامل("اردو پروگرامنگ", "پروگرامنگ"));

// === OBJECT HELPERS ===
متغیر شے_مثال = { نام: "علی", عمر: 25, شہر: "لاہور" };
لکھو(Object.مفاتیح(شے_مثال));
لکھو(Object.اقدار(شے_مثال));
کے_لیے (متغیر [ک, ق] کا Object.اندراج(شے_مثال)) {
    لکھو(ک, ":", ق);
}

// === RANDOM ===
متغیر پانسہ = اتفاقی_عدد(1, 6);
لکھو("پانسہ:", پانسہ);
لکھو("اتفاقی:", گول(اتفاقی(0, 10), 2));

// === JSON ===
متغیر json_متن = JSON_لکھو({ نام: "زید", عمر: 30 });
لکھو(json_متن);
متغیر واپسی = JSON_پڑھو(json_متن);
لکھو(واپسی["نام"]);

// === PARSING ===
لکھو(صحیح_پارس("42"));
لکھو(صحیح_پارس("ff", 16));
لکھو(اعشاریہ_پارس("3.14"));
لکھو(نان_ہے(عدد("xyz")));

// === Array helpers ===
لکھو(Array.سے(حد(5)));
لکھو(Array.ہے([1,2,3]));
لکھو(Array.ہے("متن"));

// === String helpers ===
لکھو(String.کوڈ("ا"));
لکھو(String.حرف(1575));
