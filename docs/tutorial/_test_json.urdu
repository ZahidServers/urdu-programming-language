// JSON built-in — no import needed

// Object to JSON string
متغیر شخص = { نام: "احمد", عمر: 25 };
لکھو(JSON_لکھو(شخص));

// Pretty print with indent
متغیر ڈیٹا = {
    طلباء: [
        { نام: "احمد", نمبر: 85 },
        { نام: "فاطمہ", نمبر: 92 }
    ]
};
لکھو(JSON_لکھو(ڈیٹا, 2));

// JSON string to object
متغیر json_م = JSON_لکھو({ نام: "علی", عمر: 30 });
متغیر آبجیکٹ = JSON_پڑھو(json_م);
لکھو(آبجیکٹ["نام"]);
لکھو(آبجیکٹ["عمر"]);

// List to JSON
لکھو(JSON_لکھو([1, 2, 3, "اردو", سچ, خالی]));

// Round-trip
متغیر اصل = { زبان: "اردو", نسخہ: 1 };
متغیر json_s = JSON_لکھو(اصل);
متغیر بحال = JSON_پڑھو(json_s);
لکھو(بحال["زبان"]);
