درآمد { بلبلہ_ترتیب, انتخاب_ترتیب, اندراج_ترتیب, ضم_ترتیب, تیز_ترتیب, ڈھیر_ترتیب, خطی_تلاش, دوئی_تلاش, ہیش_جدول, اعظم_مشترک_قاسم, اقل_مشترک_ضرب, فیبوناچی, فیبوناچی_سلسلہ, فیکٹوریل, عدد_زائی_ہے, اعداد_زائیہ, لیوینشٹین_فاصلہ, کے_ایم_پی_تلاش } سے "اردو/الگورتھم";

متغیر فہرست_م = [5, 2, 8, 1, 9, 3];
لکھو(بلبلہ_ترتیب(فہرست_م));
لکھو(انتخاب_ترتیب(فہرست_م));
لکھو(اندراج_ترتیب(فہرست_م));
لکھو(ضم_ترتیب(فہرست_م));
لکھو(تیز_ترتیب(فہرست_م));
لکھو(ڈھیر_ترتیب(فہرست_م));

متغیر ترتیب_م = [1, 3, 5, 7, 9];
لکھو(خطی_تلاش(فہرست_م, 8));
لکھو(دوئی_تلاش(ترتیب_م, 7));
لکھو(دوئی_تلاش(ترتیب_م, 4));

// Hash table
متغیر ہج = نیا ہیش_جدول();
ہج["نام"] = "احمد";
ہج["عمر"] = 25;
لکھو(ہج["نام"]);
لکھو(ہج["عمر"]);
لکھو(ہج.موجود_ہے("نام"));

// Math algorithms
لکھو(اعظم_مشترک_قاسم(12, 8));
لکھو(اقل_مشترک_ضرب(4, 6));
لکھو(فیبوناچی(10));
لکھو(فیبوناچی_سلسلہ(8));
لکھو(فیکٹوریل(5));
لکھو(عدد_زائی_ہے(17));
لکھو(عدد_زائی_ہے(18));
لکھو(اعداد_زائیہ(20));

// String algorithms
لکھو(لیوینشٹین_فاصلہ("kitten", "sitting"));
لکھو(کے_ایم_پی_تلاش("ab", "ababab"));

لکھو("سب ٹھیک");