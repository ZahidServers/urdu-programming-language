درآمد { ایس_کیو_لائٹ } سے "اردو/ڈیٹا_بیس";

غیر_متزامن فنکشن مرکزی() {
    متغیر ڈب = نیا ایس_کیو_لائٹ(":memory:");
    انتظار ڈب.جوڑیں();

    // Create table
    انتظار ڈب.چلائیں("CREATE TABLE طلباء (شناخت INTEGER PRIMARY KEY, نام TEXT, نمبر INTEGER)");

    // Insert rows
    انتظار ڈب.چلائیں("INSERT INTO طلباء (نام, نمبر) VALUES (?, ?)", ["احمد", 85]);
    انتظار ڈب.چلائیں("INSERT INTO طلباء (نام, نمبر) VALUES (?, ?)", ["فاطمہ", 92]);
    انتظار ڈب.چلائیں("INSERT INTO طلباء (نام, نمبر) VALUES (?, ?)", ["علی", 78]);

    // SELECT all
    متغیر صفوف = انتظار ڈب.سوال("SELECT * FROM طلباء");
    لکھو(لمبائی(صفوف));
    لکھو(صفوف[0].نام);
    لکھو(صفوف[1].نمبر);

    // SELECT with WHERE
    متغیر بہترین = انتظار ڈب.سوال("SELECT * FROM طلباء WHERE نمبر > ?", [80]);
    لکھو(لمبائی(بہترین));

    // UPDATE
    متغیر تبدیل = انتظار ڈب.چلائیں("UPDATE طلباء SET نمبر = ? WHERE نام = ?", [90, "احمد"]);
    لکھو(تبدیل);

    // DELETE
    انتظار ڈب.چلائیں("DELETE FROM طلباء WHERE نمبر < 80");
    متغیر باقی = انتظار ڈب.سوال("SELECT * FROM طلباء");
    لکھو(لمبائی(باقی));

    // Transaction
    انتظار ڈب.لین_دین_شروع();
    انتظار ڈب.چلائیں("INSERT INTO طلباء (نام, نمبر) VALUES (?, ?)", ["زید", 88]);
    انتظار ڈب.کمٹ();
    متغیر سب = انتظار ڈب.سوال("SELECT * FROM طلباء");
    لکھو(لمبائی(سب));

    // جدول_بنائیں convenience method
    انتظار ڈب.جدول_بنائیں("کورسز", { شناخت: "INTEGER PRIMARY KEY", عنوان: "TEXT" });
    لکھو("جدول بنا");

    انتظار ڈب.منقطع();
    لکھو("سب ٹھیک");
}

انتظار مرکزی();