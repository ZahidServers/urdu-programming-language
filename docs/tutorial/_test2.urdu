// === SWITCH/CASE with correct keywords ===
متغیر دن = 3;
منتخب (دن) {
    صورت 1:
        لکھو("پیر");
        ٹوٹنا;
    صورت 3:
        لکھو("بدھ");
        ٹوٹنا;
    بصورت_دیگر:
        لکھو("اور دن");
}

// === ARRAYS - methods ===
متغیر فہرست = [10, 20, 30, 40, 50];
لکھو("لمبائی:", لمبائی(فہرست));
لکھو("پہلا:", فہرست[0]);
لکھو("آخری:", فہرست[فہرست.length - 1]);
فہرست.push(60);
لکھو("push کے بعد:", فہرست);
متغیر نکالا = فہرست.pop();
لکھو("pop:", نکالا);
لکھو("slice:", فہرست.slice(1, 3));
لکھو("includes:", فہرست.includes(30));
لکھو("indexOf:", فہرست.indexOf(30));

// === OBJECTS ===
متغیر شخص = { نام: "ذیشان", عمر: 28, شہر: "لاہور" };
لکھو("Object:", شخص);
لکھو("نام:", شخص.نام);
لکھو("keys:", Object.keys(شخص));
لکھو("values:", Object.values(شخص));
شخص.پیشہ = "ڈویلپر";
لکھو("پیشہ شامل:", شخص);

// === TYPE CONVERSION ===
لکھو(عدد("42"));
لکھو(اعشاریہ("3.14"));
لکھو(تار(100));
لکھو(قسم(42));
لکھو(قسم("متن"));
لکھو(قسم(سچ));
لکھو(قسم([]));

// === MATH ===
درآمد * بطور ریاضی سے "math";
لکھو("pi:", ریاضی.pi);
لکھو("چھت:", ریاضی.ceil(4.2));
لکھو("فرش:", ریاضی.floor(4.9));
لکھو("گول:", ریاضی.sqrt(16));
لکھو("قدر:", ریاضی.fabs(-5));
لکھو("زیادہ:", ریاضی.pow(2, 10));
