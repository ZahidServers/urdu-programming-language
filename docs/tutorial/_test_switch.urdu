// Test switch/case
متغیر دن = 3;

منتخب (دن) {
    صورت 1:
        لکھو("پیر");
        ٹوٹنا;
    صورت 2:
        لکھو("منگل");
        ٹوٹنا;
    صورت 3:
        لکھو("بدھ");
        ٹوٹنا;
    صورت 4:
        لکھو("جمعرات");
        ٹوٹنا;
    صورت 5:
        لکھو("جمعہ");
        ٹوٹنا;
    بصورت_دیگر:
        لکھو("ہفتہ/اتوار");
}

// String switch
متغیر رنگ = "سبز";
منتخب (رنگ) {
    صورت "سرخ":
        لکھو("خطرہ");
        ٹوٹنا;
    صورت "پیلا":
        لکھو("احتیاط");
        ٹوٹنا;
    صورت "سبز":
        لکھو("جائیں");
        ٹوٹنا;
    بصورت_دیگر:
        لکھو("نامعلوم رنگ");
}

// Fallthrough (no break)
متغیر درجہ = "B";
منتخب (درجہ) {
    صورت "A":
    صورت "B":
        لکھو("اچھا نتیجہ");
        ٹوٹنا;
    صورت "C":
        لکھو("ٹھیک ہے");
        ٹوٹنا;
    بصورت_دیگر:
        لکھو("بہتری کی ضرورت");
}
