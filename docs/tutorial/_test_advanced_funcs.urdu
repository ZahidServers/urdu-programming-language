// Test advanced function patterns

// Rest parameters
فنکشن جمع_سب(...اعداد) {
    متغیر کل = 0;
    کے_لیے (متغیر ن میں اعداد) {
        کل += ن;
    }
    واپس کل;
}
لکھو(جمع_سب(1, 2, 3));
لکھو(جمع_سب(1, 2, 3, 4, 5));

// Spread operator
متغیر الف = [1, 2, 3];
متغیر ب = [4, 5, 6];
متغیر ج = [...الف, ...ب];
لکھو(ج);

فنکشن جمع3(x, y, z) { واپس x + y + z; }
لکھو(جمع3(...الف));

// Higher order functions
متغیر اعداد = [1, 2, 3, 4, 5];

// تبدیل (map)
فنکشن دوگنا(ن) { واپس ن * 2; }
متغیر دوگنے = اعداد.تبدیل(دوگنا);
لکھو(دوگنے);

// چھانو (filter) - use named function, not arrow with >
فنکشن بڑا_سے_تین(ن) { واپس ن > 3; }
متغیر بڑے = اعداد.چھانو(بڑا_سے_تین);
لکھو(بڑے);

// اکٹھا (reduce)
فنکشن جوڑو(کل, ن) { واپس کل + ن; }
متغیر مجموع_ن = اعداد.اکٹھا(جوڑو, 0);
لکھو(مجموع_ن);

// Closures with mutable container
فنکشن گنتی_بنائیں(شروع = 0) {
    متغیر حالت = [شروع];
    واپس فنکشن() {
        حالت[0] = حالت[0] + 1;
        واپس حالت[0];
    };
}

متغیر گنتی = گنتی_بنائیں();
لکھو(گنتی());
لکھو(گنتی());
لکھو(گنتی());
