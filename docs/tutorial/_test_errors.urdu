// Test error handling
کوشش {
    لکھو("شروع");
    پھینکو نیا غلطی("کچھ غلط ہوا");
    لکھو("یہ نہیں چلے گا");
} پکڑو (غ) {
    لکھو(`پکڑی: ${غ.message}`);
} آخر {
    لکھو("آخر — ہمیشہ چلتا ہے");
}

// Catching specific errors
فنکشن تقسیم(الف, ب) {
    اگر (ب == 0) {
        پھینکو نیا غلطی("صفر سے تقسیم ممنوع");
    }
    واپس الف / ب;
}

کوشش {
    لکھو(تقسیم(10, 2));
    لکھو(تقسیم(10, 0));
} پکڑو (غ) {
    لکھو(`خطا: ${غ.message}`);
}

// No error
کوشش {
    لکھو(تقسیم(10, 5));
} پکڑو (غ) {
    لکھو("یہ نہیں چلے گا");
} آخر {
    لکھو("مکمل");
}
