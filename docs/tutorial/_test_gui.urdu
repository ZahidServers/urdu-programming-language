درآمد { گوئی, لیبل, بٹن, ان_پٹ, فریم, ڈراپ_ڈاؤن, چیک_بکس, ریڈیو, پروگریس_بار, جدول, الرٹ, کینوس } سے "اردو/گوئی";

متغیر ایپ = نیا گوئی("ٹیسٹ ایپ", 400, 300);

متغیر ل = نیا لیبل(ایپ, "سلام اردو");
لکھو(ل.حاصل_کریں());

متغیر ان = نیا ان_پٹ(ایپ);
ان.مقرر_کریں("احمد");
لکھو(ان.حاصل_کریں());

متغیر چ = نیا چیک_بکس(ایپ, "قبول کریں");
چ.مقرر_کریں(سچ);
لکھو(چ.حاصل_کریں());

متغیر ر = نیا ریڈیو(ایپ, ["الف", "ب", "ج"]);
لکھو(ر.حاصل_کریں());

متغیر پ = نیا پروگریس_بار(ایپ);
پ.مقرر_کریں(75);
لکھو(پ.حاصل_کریں());

متغیر ج = نیا جدول(ایپ, ["نام", "نمبر"]);
ج.شامل_کریں(["احمد", 85]);
ج.شامل_کریں(["فاطمہ", 92]);
لکھو(لمبائی(ج.حاصل_کریں()));

متغیر ک = نیا کینوس(ایپ, چوڑائی=300, اونچائی=200);
ک.دائرہ(100, 100, 50, "blue");
ک.مستطیل(10, 10, 80, 60, "green");
ک.لکیر(0, 0, 300, 200, "red");
ک.متن(150, 150, "اردو", "black", 14);
لکھو("کینوس ٹھیک");

ایپ.بند_کریں();
لکھو("گوئی ٹھیک");
