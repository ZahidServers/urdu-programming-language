// Test classes with correct keywords
کلاس جانور {
    تعمیر(نام, آواز) {
        یہ.نام = نام;
        یہ.آواز = آواز;
    }

    بولو() {
        لکھو(`${یہ.نام} کہتا ہے: ${یہ.آواز}`);
    }

    توضیح() {
        واپس `${یہ.نام} ایک جانور ہے`;
    }
}

متغیر کتا = نیا جانور("کتا", "بھونک");
کتا.بولو();
لکھو(کتا.توضیح());

// Inheritance with توسیع
کلاس کتا_نسل توسیع جانور {
    تعمیر(نام, نسل) {
        سپر(نام, "بھونک");
        یہ.نسل = نسل;
    }

    توضیح() {
        واپس `${یہ.نام} (${یہ.نسل}) ایک کتا ہے`;
    }
}

متغیر لیبرا = نیا کتا_نسل("میکس", "لیبراڈور");
لیبرا.بولو();
لکھو(لیبرا.توضیح());
لکھو(لیبرا.نام);
لکھو(لیبرا.نسل);
