// Test array methods
متغیر ف = [3, 1, 4, 1, 5, 9, 2, 6];

// join - use ربط() not .join()
متغیر الف = [1, 2, 3];
لکھو(ربط("-", الف));

// reverse
متغیر ف4 = [1, 2, 3, 4, 5];
ف4.reverse();
لکھو(ف4);

// sort with ترتیب
متغیر ف5 = [3, 1, 4, 1, 5, 9, 2, 6];
لکھو(ترتیب(ف5));
لکھو(ترتیب(ف5, الٹا=سچ));

// flat
متغیر ف6 = [[1, 2], [3, 4], [5, 6]];
لکھو(ف6.flat());

// find / findIndex
فنکشن بڑا_5(ن) { واپس ن > 5; }
لکھو(ف.find(بڑا_5));
لکھو(ف.findIndex(بڑا_5));

// every / some
فنکشن مثبت(ن) { واپس ن > 0; }
لکھو([1, 2, 3].every(مثبت));
لکھو([-1, 2, 3].some(مثبت));

// concat
متغیر ف7 = [1, 2].concat([3, 4]);
لکھو(ف7);

// slice
لکھو([10, 20, 30, 40, 50].slice(1, 3));

// spread for copy
متغیر اصل = [1, 2, 3];
متغیر نقل = [...اصل];
نقل.push(4);
لکھو(اصل);    // unchanged
لکھو(نقل);    // has 4
