// Test function patterns

// Basic function
فنکشن سلام(نام) {
    لکھو(`السلام علیکم، ${نام}!`);
}
سلام("احمد");

// Return value
فنکشن جمع(الف, ب) {
    واپس الف + ب;
}
لکھو(جمع(3, 4));

// Default parameters
فنکشن پیغام(متن, بار = 1) {
    کے_لیے (متغیر i میں حد(بار)) {
        لکھو(متن);
    }
}
پیغام("سلام");
پیغام("سلام", 3);

// Multiple return values via list
فنکشن کم_زیادہ(فہرست) {
    واپس [کم(فہرست), زیادہ(فہرست)];
}
متغیر نتیجہ = کم_زیادہ([5, 1, 9, 3]);
لکھو(نتیجہ[0], نتیجہ[1]);

// Recursive function
فنکشن فیکٹوریل(ن) {
    اگر (ن <= 1) { واپس 1; }
    واپس ن * فیکٹوریل(ن - 1);
}
لکھو(فیکٹوریل(5));

// Arrow function
متغیر دوگنا = (ن) => ن * 2;
لکھو(دوگنا(7));

// Arrow with block
متغیر مربع = (ن) => {
    واپس ن * ن;
};
لکھو(مربع(6));

// Function stored in variable
متغیر جوڑو = فنکشن(الف, ب) {
    واپس الف + ب;
};
لکھو(جوڑو(10, 20));
