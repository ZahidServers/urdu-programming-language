// Test objects
متغیر شخص = {
    نام: "احمد",
    عمر: 25,
    شہر: "کراچی"
};

لکھو(شخص.نام);
لکھو(شخص["عمر"]);
شخص.پیشہ = "انجینیر";
لکھو(شخص.پیشہ);

// Object helpers
لکھو(Object.مفاتیح(شخص));
لکھو(Object.اقدار(شخص));
لکھو(Object.اندراج(شخص));

// Nested object
متغیر طالب = {
    نام: "فاطمہ",
    نمبرات: {
        ریاضی: 90,
        سائنس: 85,
        اردو: 92
    }
};

لکھو(طالب.نمبرات.ریاضی);
لکھو(طالب["نمبرات"]["سائنس"]);

// Loop over object
کے_لیے (متغیر کلید میں Object.مفاتیح(شخص)) {
    لکھو(`${کلید}: ${شخص[کلید]}`);
}
