درآمد { مربوط_فہرست, ڈھیر, قطار, دوطرفہ_قطار, ترجیحی_قطار, بائنری_تلاش_درخت, گراف } سے "اردو/ڈھانچے";

// مربوط_فہرست
متغیر مف = نیا مربوط_فہرست();
مف.شامل_کریں(10);
مف.شامل_کریں(20);
مف.شامل_کریں(30);
مف.شروع_میں_شامل(5);
لکھو(مف.فہرست());
لکھو(مف.موجود_ہے(20));
مف.نکالیں(20);
لکھو(مف.فہرست());
مف.الٹا_کریں();
لکھو(مف.فہرست());

// ڈھیر (Stack)
متغیر ڈ = نیا ڈھیر();
ڈ.دھکیلیں(1);
ڈ.دھکیلیں(2);
ڈ.دھکیلیں(3);
لکھو(ڈ.جھانکیں());
لکھو(ڈ.نکالیں());
لکھو(ڈ.نکالیں());
لکھو(ڈ.خالی_ہے());

// قطار (Queue)
متغیر ق = نیا قطار();
ق.شامل_کریں("الف");
ق.شامل_کریں("ب");
ق.شامل_کریں("ج");
لکھو(ق.اگلا());
لکھو(ق.نکالیں());
لکھو(ق.نکالیں());

// دوطرفہ_قطار
متغیر دق = نیا دوطرفہ_قطار();
دق.دائیں_شامل(1);
دق.دائیں_شامل(2);
دق.بائیں_شامل(0);
لکھو(دق.بائیں_نکالیں());
لکھو(دق.دائیں_نکالیں());

// ترجیحی_قطار (min-heap)
متغیر تق = نیا ترجیحی_قطار();
تق.شامل_کریں("کام الف", 3);
تق.شامل_کریں("کام ب", 1);
تق.شامل_کریں("کام ج", 2);
لکھو(تق.نکالیں());
لکھو(تق.نکالیں());

// بائنری_تلاش_درخت
متغیر بت = نیا بائنری_تلاش_درخت();
بت.داخل_کریں(5);
بت.داخل_کریں(3);
بت.داخل_کریں(7);
بت.داخل_کریں(1);
بت.داخل_کریں(4);
لکھو(بت.ترتیب_سے());
لکھو(بت.موجود_ہے(3));
لکھو(بت.موجود_ہے(6));
لکھو(بت.سب_سے_چھوٹا());
لکھو(بت.سب_سے_بڑا());

// گراف
متغیر گ = نیا گراف();
گ.کنارہ_شامل_کریں("الف", "ب");
گ.کنارہ_شامل_کریں("الف", "ج");
گ.کنارہ_شامل_کریں("ب", "د");
لکھو(گ.چوڑائی_تلاش("الف"));
لکھو(گ.گہرائی_تلاش("الف"));
لکھو(گ.راستہ_ہے("الف", "د"));

لکھو("سب ٹھیک");