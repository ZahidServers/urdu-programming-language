// Closure with mutable container (workaround for reassignment)
فنکشن گنتی_بنائیں(شروع = 0) {
    متغیر حالت = [شروع];
    واپس فنکشن() {
        حالت[0] = حالت[0] + 1;
        واپس حالت[0];
    };
}
متغیر اگلا = گنتی_بنائیں(0);
لکھو(اگلا());
لکھو(اگلا());
لکھو(اگلا());

// Read-only closure (no reassignment — works fine)
فنکشن ضرب_دہندہ(ن) {
    واپس فنکشن(x) { واپس x * ن; };
}
متغیر تین_گنا = ضرب_دہندہ(3);
لکھو(تین_گنا(5));
لکھو(تین_گنا(10));

// Recursive function
فنکشن فیکٹوریل(ن) {
    اگر (ن <= 1) واپس 1;
    واپس ن * فیکٹوریل(ن - 1);
}
لکھو(فیکٹوریل(5));
لکھو(فیکٹوریل(10));

// Fibonacci
فنکشن فبوناچی(ن) {
    اگر (ن <= 1) واپس ن;
    واپس فبوناچی(ن-1) + فبوناچی(ن-2);
}
کے_لیے (متغیر i کا حد(10)) {
    لکھو(فبوناچی(i), sep="", end=" ");
}
لکھو("");

// === GENERATORS (پیداوار) ===
فنکشن* حد_جنریٹر(ن) {
    متغیر i = 0;
    جبکہ (i < ن) {
        پیداوار i;
        i = i + 1;
    }
}
کے_لیے (متغیر قدر کا حد_جنریٹر(5)) {
    لکھو(قدر, end=" ");
}
لکھو("");
