درآمد { صفحہ_بناؤ } سے "اردو/کھرچنی";

متغیر html = "<html><head><title>ٹیسٹ صفحہ</title></head><body><h1 id=main>سلام دنیا</h1><p class=info>یہ اردو ہے</p><a href=/گھر>گھر</a><a href=/بارے>بارے</a></body></html>";
متغیر ص = صفحہ_بناؤ(html);

لکھو(ص.عنوان);

متغیر ہیڈنگ = ص.تلاش("h1");
لکھو(ہیڈنگ.صاف_متن);
لکھو(ہیڈنگ["id"]);

متغیر پیرا = ص.تلاش("p");
لکھو(پیرا.صاف_متن);
لکھو(پیرا["class"]);

متغیر لنکس = ص.سب_تلاش("a");
لکھو(لمبائی(لنکس));
لکھو(لنکس[0]["href"]);
لکھو(لنکس[1]["href"]);

متغیر چنو_م = ص.چنو("a");
لکھو(لمبائی(چنو_م));

متغیر ایک = ص.ایک_چنو("#main");
لکھو(ایک.صاف_متن);

لکھو(ص.بچے[0].ٹیگ);

لکھو("کھرچنی ٹھیک");