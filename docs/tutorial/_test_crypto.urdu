درآمد { ہیش, تصادفی, بنیاد64 } سے "اردو/رمز";

// Hash functions
لکھو(ہیش.sha256("اردو"));
لکھو(ہیش.ہیش_256("اردو"));
لکھو(لمبائی(ہیش.sha256("test")));
لکھو(ہیش.md5("hello"));
لکھو(ہیش.sha512("hello").حصہ(0, 20));
لکھو(ہیش.hmac("پیغام", "کلید"));

// Secure random
متغیر ٹ = تصادفی.ٹوکن(16);
لکھو(لمبائی(ٹ));
متغیر otp = تصادفی.OTP(6);
لکھو(لمبائی(otp));
متغیر ع = تصادفی.عدد(1, 100);
لکھو(ع >= 1 اور ع < 100);

// Base64
متغیر کوڈ_شدہ = بنیاد64.کوڈ("اردو");
لکھو(کوڈ_شدہ);
لکھو(بنیاد64.ڈی_کوڈ(کوڈ_شدہ));

لکھو("سب ٹھیک");