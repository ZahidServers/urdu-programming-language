درآمد { دھاگہ, قطار, تالہ, واقعہ, سیمافور, ترجیحی_قطار, ٹائمر, وقفہ_ٹائمر, دھاگہ_تالاب, مقامی_ذخیرہ } سے "اردو/دھاگہ";
درآمد { نیند } سے "اردو/تاریخ";

// ── Basic thread ──
فنکشن سلام() {
    لکھو("دھاگہ: سلام!");
}

متغیر د = نیا دھاگہ(سلام);
د.شروع();
د.انتظار();
لکھو("دھاگہ مکمل");

// ── Thread with argument ──
فنکشن عنوان(نام) {
    لکھو(`دھاگہ: ${نام}`);
}

متغیر د2 = نیا دھاگہ(عنوان, "احمد");
د2.شروع();
د2.انتظار();

// ── Thread count ──
لکھو(دھاگہ.گنتی());    // at least 1

// ── Lock ──
متغیر ت = نیا تالہ();
ت.قبضہ();
لکھو("تالہ حاصل");
ت.چھوڑو();
لکھو("تالہ چھوڑا");

// ── Queue ──
متغیر ق = نیا قطار();
ق.ڈالو("پہلا");
ق.ڈالو("دوسرا");
ق.ڈالو("تیسرا");
لکھو(ق.خالی());                  // False
لکھو(ق.نکالو_نہ_رکو());         // پہلا
لکھو(ق.نکالو_نہ_رکو());         // دوسرا

// ── Priority queue ──
متغیر ترق = نیا ترجیحی_قطار();
ترق.ڈالو(3, "کم اہم");
ترق.ڈالو(1, "اہم");
ترق.ڈالو(2, "درمیانی");
لکھو(ترق.نکالو());    // (1, 'اہم')
لکھو(ترق.نکالو());    // (2, 'درمیانی')

// ── Thread pool — map ──
فنکشن مربع(ن) { واپس ن * ن; }
متغیر تالاب = نیا دھاگہ_تالاب(2);
متغیر نتائج = تالاب.نقشہ(مربع, [1, 2, 3, 4, 5]);
لکھو(نتائج);    // [1, 4, 9, 16, 25]
تالاب.بند();

// ── Thread pool — future ──
متغیر تالاب2 = نیا دھاگہ_تالاب(2);
متغیر م = تالاب2.جمع_کرو_مستقبل(مربع, 7);
لکھو(م.نتیجہ());    // 49
لکھو(م.مکمل());     // True
تالاب2.بند();

// ── Event ──
متغیر واق = نیا واقعہ();
لکھو(واق.لگا_ہوا());    // False
واق.مقرر();
لکھو(واق.لگا_ہوا());    // True
واق.صاف();
لکھو(واق.لگا_ہوا());    // False

// ── Thread-local storage ──
متغیر ذخیرہ = نیا مقامی_ذخیرہ();
ذخیرہ.مقرر("صارف", "احمد");
لکھو(ذخیرہ.حاصل("صارف"));          // احمد
لکھو(ذخیرہ.حاصل("ناموجود", "N/A")); // N/A

لکھو("سب ٹھیک");
