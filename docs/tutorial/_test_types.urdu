// Test all type conversion functions

// To number
لکھو(عدد("42"));           // 42
لکھو(عدد("  100  "));      // 100
لکھو(عدد(3.9));             // 3  (truncates)
لکھو(عدد(سچ));              // 1
لکھو(عدد(جھوٹ));            // 0
لکھو(عدد("abc"));           // nan  (failed)

// To float
لکھو(اعشاریہ("3.14"));      // 3.14
لکھو(اعشاریہ("10"));        // 10.0
لکھو(اعشاریہ(5));            // 5.0

// To string
لکھو(متن(42));               // "42"
لکھو(متن(3.14));             // "3.14"
لکھو(متن(سچ));               // "True"
لکھو(متن(خالی));             // "None"
لکھو(متن([1, 2, 3]));        // "[1, 2, 3]"

// To boolean
لکھو(بولین(0));              // False
لکھو(بولین(""));             // False
لکھو(بولین([]));             // False
لکھو(بولین(خالی));           // False
لکھو(بولین(1));              // True
لکھو(بولین("اردو"));         // True
لکھو(بولین([1, 2]));         // True

// Type checking
لکھو(قسم(42));               // عدد
لکھو(قسم(3.14));             // عدد
لکھو(قسم("اردو"));           // متن
لکھو(قسم(سچ));               // بولین
لکھو(قسم(خالی));             // خالی
لکھو(قسم([1, 2]));           // فہرست
لکھو(قسم({ ک: "ق" }));      // شے

// NaN check
متغیر ن = عدد("xyz");
لکھو(نان_ہے(ن));             // True
لکھو(نان_ہے(42));            // False

// Safe conversion pattern
فنکشن محفوظ_عدد(م) {
    متغیر ق = عدد(م);
    اگر (نان_ہے(ق)) { واپس خالی; }
    واپس ق;
}
لکھو(محفوظ_عدد("100"));     // 100
لکھو(محفوظ_عدد("abc"));     // None
