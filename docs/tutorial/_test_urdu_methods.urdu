// Test all Urdu method aliases

// === STRING METHODS ===
متغیر م = "  السلام علیکم  ";
لکھو(م.چھاٹو());              // trim
لکھو(م.شروع_چھاٹو());         // trimStart
لکھو(م.آخر_چھاٹو());          // trimEnd
لکھو("hello".بڑے_حروف());     // toUpperCase
لکھو("HELLO".چھوٹے_حروف());   // toLowerCase
لکھو("اردو".شروع_ہے("ا"));    // startsWith
لکھو("اردو".ختم_ہے("و"));     // endsWith
لکھو("اردو پروگرامنگ".مقام("پروگرامنگ"));   // indexOf
لکھو("اردو اردو".آخری_مقام("اردو"));         // lastIndexOf
لکھو("ہا".دہراؤ(3));           // repeat
لکھو("اردو پروگرامنگ".شامل_ہے("اردو"));     // includes
لکھو("اردو پروگرامنگ".بدلو("اردو", "Urdu"));  // replaceAll
لکھو("اردو پروگرامنگ زبان".حصہ(5, 15));     // slice

// === ARRAY METHODS ===
متغیر ف = [1, 2, 3];

ف.شامل(4);              // push
لکھو(ف);

متغیر آخری = ف.نکالو();  // pop
لکھو(آخری);
لکھو(ف);

ف.پہلے_شامل(0);         // unshift
لکھو(ف);

متغیر پہلا = ف.پہلا_نکالو();  // shift
لکھو(پہلا);
لکھو(ف);

لکھو(ف.جوڑو("-"));      // join
لکھو(ف.حصہ(0, 2));      // slice
لکھو(ف.ملاؤ([10, 20])); // concat
لکھو(ف.پھیلاؤ());        // flat (on 1D it does nothing)

// Functional methods
متغیر اعداد = [1, 2, 3, 4, 5, 6, 7, 8];

فنکشن دوگنا(ن) { واپس ن * 2; }
فنکشن جفت(ن) { واپس ن % 2 == 0; }
فنکشن جمع_ک(ک, ن) { واپس ک + ن; }
فنکشن بڑا_5(ن) { واپس ن > 5; }
فنکشن مثبت(ن) { واپس ن > 0; }
فنکشن پرنٹ_ن(ن) { لکھو(`عنصر: ${ن}`); }

لکھو(اعداد.تبدیل(دوگنا));      // map
لکھو(اعداد.چھانو(جفت));        // filter
لکھو(اعداد.اکٹھا(جمع_ک, 0));   // reduce
لکھو(اعداد.تلاش(بڑا_5));       // find
لکھو(اعداد.تلاش_مقام(بڑا_5));  // findIndex
لکھو(اعداد.سب(مثبت));          // every
لکھو(اعداد.کوئی(بڑا_5));       // some
اعداد.ہر_ایک(پرنٹ_ن);          // forEach

// reverse
متغیر ف2 = [1, 2, 3, 4, 5];
ف2.پلٹاؤ();
لکھو(ف2);

// لمبائی property
لکھو(ف2.لمبائی);

// flat
متغیر ف3 = [[1, 2], [3, 4]];
لکھو(ف3.پھیلاؤ());

// splice / کاٹو
متغیر ف4 = [1, 2, 3, 4, 5];
ف4.کاٹو(1, 2);
لکھو(ف4);
