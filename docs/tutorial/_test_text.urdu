درآمد {
    بڑے_حروف, چھوٹے_حروف, عنوانی, الٹا_کریں,
    تراشو, تقسیم, سطر_تقسیم, ملائیں, بدلیں,
    گنو, موجود_ہے, شروع_سے, آخر_سے,
    خالی_ہے, صرف_اعداد, صرف_حروف,
    پیڈ_بائیں, پیڈ_وسط,
    ذیل_متن, تلاش_کریں, فارمیٹ,
    ریجیکس_تلاش, ریجیکس_بدلیں, ریجیکس_تمام,
    دہرائیں,
    اعراب_ہٹائیں, نستعلیق_معیاری, الفاظ,
    اردو_حروف_ہیں, ہندی_اعداد, ہندی_اعداد_میں,
    اردو_میں_گنتی, مماثلت, ایک_جیسا_ہے, حروف_گنو
} سے "اردو/متن";

لکھو(بڑے_حروف("hello"));
لکھو(چھوٹے_حروف("WORLD"));
لکھو(عنوانی("احمد علی"));
لکھو(الٹا_کریں("اردو"));
لکھو(تراشو("  سلام  "));
متغیر الف = تقسیم("ا ب ج", " ");
لکھو(لمبائی(الف));
لکھو(ملائیں("-", الف));
لکھو(گنو("اردو اردو", "اردو"));
لکھو(موجود_ہے("پاکستان", "پاک"));
لکھو(شروع_سے("اردو", "ار"));
لکھو(آخر_سے("اردو", "دو"));
لکھو(خالی_ہے("   "));
لکھو(صرف_اعداد("123"));
لکھو(پیڈ_بائیں("5", 4, "0"));
لکھو(پیڈ_وسط("سلام", 11, "-"));
لکھو(ذیل_متن("اردو پروگرامنگ", 0, 4));
لکھو(تلاش_کریں("اردو پروگرامنگ", "پرو"));
لکھو(فارمیٹ("سلام {}!", "احمد"));
لکھو(ریجیکس_تمام("[0-9]+", "عمر 25 ہے"));
لکھو(ریجیکس_بدلیں("[0-9]+", "X", "abc 123 def 456"));
لکھو(الفاظ("اردو پروگرامنگ زبان"));
لکھو(اردو_حروف_ہیں("اردو"));
لکھو(اردو_حروف_ہیں("hello"));
لکھو(ہندی_اعداد("۵۳"));
لکھو(ہندی_اعداد_میں("53"));
لکھو(اردو_میں_گنتی(25));
لکھو(اردو_میں_گنتی(1000));
لکھو(مماثلت("اردو", "اردو"));
لکھو(مماثلت("سلام", "کلام"));
لکھو(ایک_جیسا_ہے("اردو", "اردو", جھوٹ));
لکھو("متن ٹھیک");