درآمد { تاریخ, مدت, وقت } سے "اردو/تاریخ";

// Basic date
متغیر آج = تاریخ.آج();
لکھو(آج.سال);
لکھو(آج.مہینہ);
لکھو(آج.دن);
لکھو(آج.دن_نام);

// Format
لکھو(آج.فارمیٹ("%d/%m/%Y"));
لکھو(آج.فارمیٹ("%B %Y"));
لکھو(متن(آج));    // ISO format

// Arithmetic
متغیر بعد_میں = آج + نیا مدت(ہفتے=2);
لکھو(متن(بعد_میں));

متغیر پہلے = آج - نیا مدت(دن=30);
لکھو(متن(پہلے));

// Comparison
لکھو(آج > پہلے);

// Difference between dates — use .دن property not .days
متغیر فرق = بعد_میں - آج;
لکھو(فرق.دن);
لکھو(فرق.کل_دن);

// Specific date
متغیر تاریخ_م = نیا تاریخ(2024, 3, 15);
لکھو(متن(تاریخ_م));

// Time
متغیر ابھی = وقت.ابھی();
لکھو(ابھی.گھنٹہ);
لکھو(ابھی.منٹ);
لکھو(ابھی.سیکنڈ);
لکھو(ابھی.فارمیٹ("%H:%M:%S"));
