// Test if/else patterns
متغیر ن = 15;

اگر (ن > 10) {
    لکھو("دس سے بڑا");
}

اگر (ن > 10) {
    لکھو("بڑا");
} ورنہ {
    لکھو("چھوٹا");
}

اگر (ن < 5) {
    لکھو("پانچ سے کم");
} ورنہ_اگر (ن < 10) {
    لکھو("پانچ سے دس کے درمیان");
} ورنہ_اگر (ن < 20) {
    لکھو("دس سے بیس کے درمیان");
} ورنہ {
    لکھو("بیس یا زیادہ");
}

// Nested if
متغیر عمر = 25;
متغیر شہری = سچ;
اگر (عمر >= 18) {
    اگر (شہری) {
        لکھو("ووٹ دے سکتے ہیں");
    } ورنہ {
        لکھو("عمر ٹھیک لیکن شہری نہیں");
    }
} ورنہ {
    لکھو("عمر کم");
}

// Truthy/falsy
متغیر نام = "";
اگر (نام) {
    لکھو(`نام: ${نام}`);
} ورنہ {
    لکھو("نام خالی ہے");
}

متغیر فہرست = [1, 2, 3];
اگر (فہرست) {
    لکھو("فہرست میں کچھ ہے");
}
