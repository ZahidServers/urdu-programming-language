درآمد { فاسٹ_اے_پی_آئی, راؤٹر, جیسن_جواب, ایچ_ٹی_ایم_ایل_جواب, سادہ_جواب, جالی_خطا } سے "اردو/ویب";

متغیر ایپ = نیا فاسٹ_اے_پی_آئی({ عنوان: "ٹیسٹ API", نسخہ: "1.0.0" });

@ایپ.حاصل("/")
غیر_متزامن فنکشن گھر(درخواست) {
    واپس { پیغام: "سلام" };
}

@ایپ.حاصل("/صارف/{شناخت}")
غیر_متزامن فنکشن صارف(شناخت) {
    واپس { شناخت: شناخت, نام: "احمد" };
}

@ایپ.بھیجیں("/صارفیں")
غیر_متزامن فنکشن نیا_صارف(درخواست) {
    متغیر ڈیٹا = انتظار درخواست_باڈی(درخواست);
    واپس { بنایا: سچ, ڈیٹا: ڈیٹا };
}

لکھو("FastAPI ٹھیک");

متغیر ر = نیا راؤٹر({ سابقہ: "/اشیاء", ٹیگ: ["اشیاء"] });

@ر.حاصل("/فہرست")
غیر_متزامن فنکشن فہرست_حاصل(درخواست) {
    واپس [{ شناخت: 1, نام: "کتاب" }];
}

ایپ.شامل_کریں(ر);
لکھو("Router ٹھیک");
