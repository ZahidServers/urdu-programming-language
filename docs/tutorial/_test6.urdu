// Test sort (no comparator first)
متغیر ل = [3,1,4,1,5,9,2,6];
متغیر ترتیب_شدہ = [...ل].sort();
لکھو("sort default:", ترتیب_شدہ);

// sort with named comparator
فنکشن مقابلہ(x, y) { واپس x - y; }
لکھو("sort asc:", [...ل].sort(مقابلہ));

فنکشن مقابلہ_گھٹتا(x, y) { واپس y - x; }
لکھو("sort desc:", [...ل].sort(مقابلہ_گھٹتا));

// filter/map/reduce - using named functions
فنکشن بڑا_ہے(x) { واپس x > 3; }
فنکشن دوگنا(x) { واپس x * 2; }
فنکشن جمع(s, x) { واپس s + x; }

لکھو("filter:", ل.filter(بڑا_ہے));
لکھو("map:", ل.map(دوگنا));
لکھو("reduce:", ل.reduce(جمع, 0));

فنکشن بڑا_چار_سے(x) { واپس x > 4; }
لکھو("find:", ل.find(بڑا_چار_سے));

فنکشن مثبت(x) { واپس x > 0; }
لکھو("every:", ل.every(مثبت));
فنکشن آٹھ_سے_بڑا(x) { واپس x > 8; }
لکھو("some:", ل.some(آٹھ_سے_بڑا));
لکھو("join:", ل.join("-"));
لکھو("flat:", [[1,2],[3,[4,5]]].flat());

// String methods (continued from test5)
متغیر متن = "السلام علیکم اردو";
لکھو("split:", متن.split(" "));
لکھو("includes:", متن.includes("اردو"));
لکھو("startsWith:", متن.startsWith("السلام"));
لکھو("endsWith:", متن.endsWith("اردو"));
لکھو("indexOf:", متن.indexOf("علیکم"));
لکھو("slice:", متن.slice(0, 7));
لکھو("replace:", متن.replace("اردو", "دنیا"));
لکھو("trim:", "  خالی  ".trim());
لکھو("repeat:", "ہا".repeat(3));
لکھو("padStart:", "5".padStart(3, "0"));

// Math
درآمد * بطور ریاضی سے "math";
لکھو("pi:", ریاضی.pi);
لکھو("ceil:", ریاضی.ceil(4.1));
لکھو("floor:", ریاضی.floor(4.9));
لکھو("sqrt:", ریاضی.sqrt(25));
لکھو("abs:", ریاضی.fabs(-9));
لکھو("pow:", ریاضی.pow(3,3));
لکھو("log10:", ریاضی.log10(1000));

// Type conversion
لکھو("int:", عدد("42"));
لکھو("float:", اعشاریہ("3.14"));
لکھو("str:", تار(100));
لکھو("bool:", منطقی(1));
لکھو("type of int:", قسم(42));
لکھو("type of str:", قسم("متن"));
لکھو("type of list:", قسم([]));
لکھو("type of dict:", قسم({}));
لکھو("type of bool:", قسم(سچ));

// max/min/round
لکھو("max:", زیادہ_سے_زیادہ(1, 5, 3, 9, 2));
لکھو("min:", کم_سے_کم(1, 5, 3, 9, 2));
لکھو("round:", گول(3.7));
لکھو("round2:", گول(3.14159, 2));
