درآمد { فلاسک, بلیو_پرنٹ, فلاسک_جیسن, فلاسک_درخواست } سے "اردو/ویب";

متغیر ایپ = نیا فلاسک();

@ایپ.راستہ("/", طریقے=["GET"])
فنکشن گھر() {
    واپس فلاسک_جیسن({ پیغام: "سلام" });
}

@ایپ.حاصل("/پنگ")
فنکشن پنگ() {
    واپس فلاسک_جیسن({ نتیجہ: "پونگ" });
}

لکھو("Flask ٹھیک");

متغیر بی = نیا بلیو_پرنٹ("صارف", سابقہ="/صارف");

@بی.حاصل("/فہرست")
فنکشن صارف_فہرست() {
    واپس فلاسک_جیسن(["احمد", "فاطمہ"]);
}

ایپ.بلیو_پرنٹ_شامل(بی);
لکھو("Blueprint ٹھیک");
