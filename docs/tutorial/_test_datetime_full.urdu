درآمد {
    تاریخ, وقت, تاریخ_وقت, مدت, ہجری, ٹائمر,
    آج, ابھی, مہر_وقت, کبیسہ_سال, دنوں_کا_فرق,
    عیسوی_سے_ہجری, مہینہ_نام, دن_نام,
    ہجری_مہینے, عیسوی_مہینے, ہفتے_کے_دن, نیند
} سے "اردو/تاریخ";

// === تاریخ class ===
متغیر آج_ت = تاریخ.آج();
لکھو(آج_ت.سال, آج_ت.مہینہ, آج_ت.دن);
لکھو(آج_ت.دن_نام);
لکھو(آج_ت.مہینہ_نام);
لکھو(آج_ت.کبیسہ);
لکھو(آج_ت.فارمیٹ("%d/%m/%Y"));
لکھو(آج_ت.اردو_فارمیٹ());

// Parse a date
متغیر ت2 = تاریخ.پارس("2024-03-15");
لکھو(متن(ت2));

// Arithmetic — مدت takes: دن, گھنٹے, منٹ, سیکنڈ, ہفتے only (no مہینہ)
متغیر بعد = آج_ت + نیا مدت(دن=10);
لکھو(متن(بعد));
متغیر پہلے = آج_ت - نیا مدت(دن=30);
لکھو(متن(پہلے));

// === مدت class ===
متغیر م = نیا مدت(ہفتے=2, دن=3);
لکھو(م.دن);
لکھو(م.کل_دن);
لکھو(م.کل_سیکنڈ);

// === وقت class ===
متغیر و = وقت.ابھی();
لکھو(و.گھنٹہ, و.منٹ, و.سیکنڈ);
لکھو(و.فارمیٹ("%H:%M:%S"));
لکھو(و.اردو_فارمیٹ());

// === تاریخ_وقت class ===
متغیر ٹ = تاریخ_وقت.ابھی();
لکھو(ٹ.سال, ٹ.مہینہ, ٹ.دن);
لکھو(ٹ.گھنٹہ, ٹ.منٹ);
لکھو(ٹ.فارمیٹ("%Y-%m-%d %H:%M:%S"));
لکھو(ٹ.اردو_فارمیٹ());
لکھو(ٹ.مہر_وقت());

// ہجری convert from تاریخ
متغیر ہ = آج_ت.ہجری_میں();
لکھو(ہ.سال, ہ.مہینہ, ہ.دن);
لکھو(ہ.مہینہ_نام);
لکھو(ہ.اردو_فارمیٹ());
لکھو(ہ.کیا_رمضان());

// Convert back
متغیر ت_میں = ہ.عیسوی_میں();
لکھو(متن(ت_میں));

// ہجری.آج()
متغیر ہ_آج = ہجری.آج();
لکھو(ہ_آج.اردو_فارمیٹ());

// Direct conversion functions
متغیر ہ2 = عیسوی_سے_ہجری(2026, 5, 30);
لکھو(ہ2.اردو_فارمیٹ());

// === Free functions ===
لکھو(متن(آج()));
لکھو(مہر_وقت());
لکھو(کبیسہ_سال(2024));
لکھو(کبیسہ_سال(2025));
لکھو(دنوں_کا_فرق(تاریخ.پارس("2026-01-01"), تاریخ.پارس("2026-12-31")));
لکھو(مہینہ_نام(5));
لکھو(مہینہ_نام(9, سچ));
لکھو(دن_نام(4));

// Constants
لکھو(عیسوی_مہینے);
لکھو(ہجری_مہینے);
لکھو(ہفتے_کے_دن);

// ٹائمر
متغیر ٹ2 = نیا ٹائمر();
ٹ2.شروع();
نیند(0.1);
ٹ2.روکو();
لکھو(گول(ٹ2.گزرا_وقت, 2));
لکھو(گول(ٹ2.ملی_سیکنڈ, 0));
