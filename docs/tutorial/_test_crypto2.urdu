درآمد { متناسق, پاس_ورڈ, AES } سے "اردو/رمز";

// Symmetric encryption (Fernet)
متغیر رمز = نیا متناسق();
متغیر خفیہ = رمز.خفیہ_کریں("راز");
لکھو(رمز.ظاہر_کریں(خفیہ));

// AES-256-GCM
متغیر اے_ای_ایس = نیا AES();
متغیر خ = اے_ای_ایس.خفیہ_کریں("اردو پیغام");
لکھو(اے_ای_ایس.ظاہر_کریں(خ));

// Password hashing
متغیر ہ = پاس_ورڈ.ہیش("میراپاس");
لکھو(پاس_ورڈ.جانچیں("میراپاس", ہ));
لکھو(پاس_ورڈ.جانچیں("غلط", ہ));

لکھو("سب ٹھیک");