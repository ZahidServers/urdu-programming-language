// Test all updated string method names from 07-strings.md and 05-string-methods.md

متغیر س = "  السلام علیکم اردو  ";

// .چھاٹو()
لکھو(س.چھاٹو());

// .بڑے_حروف() / .چھوٹے_حروف()
لکھو("hello".بڑے_حروف());
لکھو("WORLD".چھوٹے_حروف());

// .شامل_ہے()
لکھو("اردو پروگرامنگ".شامل_ہے("اردو"));
لکھو("اردو پروگرامنگ".شامل_ہے("جاوا"));

// .شروع_ہے() / .ختم_ہے()
لکھو("اردو پروگرامنگ".شروع_ہے("اردو"));
لکھو("اردو پروگرامنگ".ختم_ہے("نگ"));

// .مقام()
لکھو("اردو پروگرامنگ".مقام("پروگرامنگ"));

// .بدلو()
لکھو("السلام علیکم".بدلو("علیکم", "اردو"));

// .دہراؤ()
لکھو("ہا".دہراؤ(3));

// تقسیم() built-in
لکھو(تقسیم("احمد فاطمہ علی"));
لکھو(تقسیم("ایک,دو,تین", ","));
لکھو(تقسیم("a|b|c", "|"));

// Practical example from 07-strings.md
فنکشن نام_فارمیٹ(پورا_نام) {
    متغیر حصے = تقسیم(پورا_نام.چھاٹو());
    اگر (لمبائی(حصے) < 2) {
        واپس پورا_نام.چھاٹو();
    }
    متغیر پہلا = حصے[0];
    متغیر آخری = حصے[لمبائی(حصے) - 1];
    واپس آخری + "، " + پہلا;
}

لکھو(نام_فارمیٹ("محمد احمد"));
لکھو(نام_فارمیٹ("فاطمہ علی خان"));

// break-continue: .شامل() for push
متغیر اعداد = [1, 5, 3, 8, 2, 9, 4, 7, 6];
متغیر بڑے = [];
کے_لیے (متغیر ن میں اعداد) {
    اگر (ن < 5) { جاری; }
    بڑے.شامل(ن);
}
لکھو(بڑے);

لکھو("سب ٹھیک");
