// Test arithmetic operators for docs
متغیر الف = 10;
متغیر ب = 3;

لکھو(الف + ب);
لکھو(الف - ب);
لکھو(الف * ب);
لکھو(الف / ب);
متغیر تقسیم_صحیح = الف // ب;
لکھو(تقسیم_صحیح);
لکھو(الف % ب);
لکھو(الف ** ب);

لکھو(-الف);

لکھو(7 / 2);
متغیر س = 7 // 2;
لکھو(س);
لکھو(7 % 2);

لکھو(2 ** 10);
لکھو(9 ** 0.5);

لکھو(مطلق(-5));
لکھو(گول(3.7));
لکھو(گول(3.14159, 2));
لکھو(چھت(2.1));
لکھو(فرش(2.9));
لکھو(گول(22 / 7, 4));
