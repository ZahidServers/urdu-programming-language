// Fix join test — needs string elements
متغیر الفاظ = ["احمد", "فاطمہ", "علی"];
لکھو(الفاظ.جوڑو("-"));       // احمد-فاطمہ-علی
لکھو(الفاظ.جوڑو(", "));      // احمد, فاطمہ, علی

// Continue rest of tests
متغیر اعداد = [1, 2, 3, 4, 5, 6, 7, 8];

فنکشن دوگنا(ن) { واپس ن * 2; }
فنکشن جفت(ن) { واپس ن % 2 == 0; }
فنکشن جمع_ک(ک, ن) { واپس ک + ن; }
فنکشن بڑا_5(ن) { واپس ن > 5; }
فنکشن مثبت(ن) { واپس ن > 0; }

لکھو(اعداد.تبدیل(دوگنا));
لکھو(اعداد.چھانو(جفت));
لکھو(اعداد.اکٹھا(جمع_ک, 0));
لکھو(اعداد.تلاش(بڑا_5));
لکھو(اعداد.تلاش_مقام(بڑا_5));
لکھو(اعداد.سب(مثبت));
لکھو(اعداد.کوئی(بڑا_5));

// reverse in place
متغیر ف2 = [1, 2, 3, 4, 5];
ف2.پلٹاؤ();
لکھو(ف2);

// لمبائی property
لکھو(ف2.لمبائی);

// flat
متغیر ف3 = [[1, 2], [3, 4]];
لکھو(ف3.پھیلاؤ());

// splice / کاٹو
متغیر ف4 = [1, 2, 3, 4, 5];
ف4.کاٹو(1, 2);
لکھو(ف4);

// ترتیب_دو (sort in place)
متغیر ف5 = [3, 1, 4, 1, 5, 9];
ف5.ترتیب_دو();
لکھو(ف5);

// fill
متغیر ف6 = [0, 0, 0, 0, 0];
ف6.بھرو(7);
لکھو(ف6);

// flatMap
فنکشن دوگنا_فہرست(ن) { واپس [ن, ن * 2]; }
لکھو([1, 2, 3].پھیلا_تبدیل(دوگنا_فہرست));
