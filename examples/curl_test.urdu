// ══════════════════════════════════════════════════════════════
// کرل مکمل جانچ — GET | POST | PUT | PATCH | DELETE | Auth | pycurl
// ══════════════════════════════════════════════════════════════

درآمد { کرل, پائی_کرل, کرل_حاصل, بھیجو_کرو, تازہ_کرو, جزوی_تازہ_کرو, مٹاؤ_کرو } سے "اردو/کرل";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

متغیر API  = "https://jsonplaceholder.typicode.com";
متغیر BIN  = "https://httpbin.org";

غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════════╗");
    لکھو("║  کرل مکمل جانچ                           ║");
    لکھو("╚══════════════════════════════════════════╝");

    // ─── 1. GET — سادہ ──────────────────────────────────────
    لکھو("\n─── GET ───");
    کوشش {
        متغیر جواب = انتظار کرل_حاصل(`${API}/posts/1`);
        جانچ("GET حالت 200", جواب.حالت == 200);
        جانچ("GET ٹھیک", جواب.ٹھیک == سچ);
        متغیر ڈیٹا = جواب.جے_سون();
        جانچ("GET id درست", ڈیٹا["id"] == 1);
        جانچ("GET body موجود", لمبائی(ڈیٹا["body"]) > 0);
        لکھو(`  ⓘ عنوان: ${ڈیٹا["title"].slice(0, 40)}`);
    } پکڑو (غ) {
        لکھو(`  ✗ GET غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 2. GET — پیرامیٹر ──────────────────────────────────
    لکھو("\n─── GET + پیرامیٹر ───");
    کوشش {
        متغیر جواب = انتظار کرل_حاصل(`${API}/posts`, { "userId": 1, "_limit": 3 });
        جانچ("پیرامیٹر GET 200", جواب.حالت == 200);
        متغیر فہرست = جواب.جے_سون();
        جانچ("3 نتائج ملے", لمبائی(فہرست) == 3);
        جانچ("پہلا userId=1", فہرست[0]["userId"] == 1);
    } پکڑو (غ) {
        لکھو(`  ✗ پیرامیٹر غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 3. POST ─────────────────────────────────────────────
    لکھو("\n─── POST ───");
    کوشش {
        متغیر جواب = انتظار بھیجو_کرو(`${API}/posts`, {
            "title":  "اردو HTTP جانچ",
            "body":   "یہ اردو پروگرامنگ زبان سے POST ہے",
            "userId": 1
        });
        جانچ("POST حالت 201", جواب.حالت == 201);
        متغیر بنائی = جواب.جے_سون();
        جانچ("POST id ملا", بنائی["id"] > 0);
        جانچ("POST title واپس", بنائی["title"] == "اردو HTTP جانچ");
        لکھو(`  ⓘ نیا ID: ${بنائی["id"]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ POST غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 4. PUT ──────────────────────────────────────────────
    لکھو("\n─── PUT ───");
    کوشش {
        متغیر جواب = انتظار تازہ_کرو(`${API}/posts/1`, {
            "id":     1,
            "title":  "تازہ عنوان",
            "body":   "تازہ مواد",
            "userId": 1
        });
        جانچ("PUT حالت 200", جواب.حالت == 200);
        متغیر تازہ = جواب.جے_سون();
        جانچ("PUT title تازہ", تازہ["title"] == "تازہ عنوان");
    } پکڑو (غ) {
        لکھو(`  ✗ PUT غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 5. PATCH ────────────────────────────────────────────
    لکھو("\n─── PATCH ───");
    کوشش {
        متغیر جواب = انتظار جزوی_تازہ_کرو(`${API}/posts/1`, {
            "title": "جزوی تازہ عنوان"
        });
        جانچ("PATCH حالت 200", جواب.حالت == 200);
        متغیر پیچ = جواب.جے_سون();
        جانچ("PATCH title بدلا", پیچ["title"] == "جزوی تازہ عنوان");
    } پکڑو (غ) {
        لکھو(`  ✗ PATCH غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 6. DELETE ───────────────────────────────────────────
    لکھو("\n─── DELETE ───");
    کوشش {
        متغیر جواب = انتظار مٹاؤ_کرو(`${API}/posts/1`);
        جانچ("DELETE حالت 200", جواب.حالت == 200);
        جانچ("DELETE ٹھیک", جواب.ٹھیک == سچ);
    } پکڑو (غ) {
        لکھو(`  ✗ DELETE غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 7. کرل کلاس — custom headers ───────────────────────
    لکھو("\n─── کرل کلاس + سرخط ───");
    کوشش {
        متغیر c = نیا کرل({
            "سرخط": {
                "User-Agent":   "UrduZaban/1.0",
                "Accept":       "application/json",
                "X-Custom":     "urdu-test"
            },
            "ختمی": 15
        });
        متغیر جواب = انتظار c.حاصل(`${BIN}/headers`);
        جانچ("custom headers 200", جواب.حالت == 200);
        متغیر ڈیٹا = جواب.جے_سون();
        جانچ("User-Agent پہنچا", ڈیٹا["headers"]["User-Agent"] == "UrduZaban/1.0");
        جانچ("X-Custom پہنچا", ڈیٹا["headers"]["X-Custom"] == "urdu-test");
    } پکڑو (غ) {
        لکھو(`  ✗ headers غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 8. Bearer Token Auth ────────────────────────────────
    لکھو("\n─── Bearer Token ───");
    کوشش {
        متغیر c = نیا کرل();
        c.ٹوکن_مقرر("urdu-secret-token-12345");
        متغیر جواب = انتظار c.حاصل(`${BIN}/bearer`);
        جانچ("Bearer 200", جواب.حالت == 200);
        متغیر ڈیٹا = جواب.جے_سون();
        جانچ("authenticated سچ", ڈیٹا["authenticated"] == سچ);
        جانچ("token درست", ڈیٹا["token"] == "urdu-secret-token-12345");
    } پکڑو (غ) {
        لکھو(`  ✗ Bearer غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 9. Basic Auth ───────────────────────────────────────
    لکھو("\n─── Basic Auth ───");
    کوشش {
        متغیر c = نیا کرل();
        c.بنیادی_توثیق("zahid", "pass123");
        متغیر جواب = انتظار c.حاصل(`${BIN}/basic-auth/zahid/pass123`);
        جانچ("Basic Auth 200", جواب.حالت == 200);
        متغیر ڈیٹا = جواب.جے_سون();
        جانچ("authenticated سچ", ڈیٹا["authenticated"] == سچ);
        جانچ("user درست", ڈیٹا["user"] == "zahid");
    } پکڑو (غ) {
        لکھو(`  ✗ Basic Auth غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 10. POST via httpbin — JSON تصدیق ──────────────────
    لکھو("\n─── POST JSON echo ───");
    کوشش {
        متغیر c = نیا کرل();
        متغیر جواب = انتظار c.بھیجو(`${BIN}/post`, {
            "نام":   "احمد",
            "عمر":   25,
            "شہر":   "کراچی"
        });
        جانچ("POST echo 200", جواب.حالت == 200);
        متغیر ڈیٹا = جواب.جے_سون();
        جانچ("JSON نام پہنچا", ڈیٹا["json"]["نام"] == "احمد");
        جانچ("JSON عمر پہنچی", ڈیٹا["json"]["عمر"] == 25);
    } پکڑو (غ) {
        لکھو(`  ✗ POST echo غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 11. حالت کوڈ جانچ ──────────────────────────────────
    لکھو("\n─── حالت کوڈ ───");
    کوشش {
        متغیر r404 = انتظار کرل_حاصل(`${BIN}/status/404`);
        جانچ("404 حالت", r404.حالت == 404);
        جانچ("404 ٹھیک نہیں", r404.ٹھیک == جھوٹ);

        متغیر r201 = انتظار کرل_حاصل(`${BIN}/status/201`);
        جانچ("201 حالت", r201.حالت == 201);
        جانچ("201 ٹھیک", r201.ٹھیک == سچ);
    } پکڑو (غ) {
        لکھو(`  ✗ حالت کوڈ غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 12. HEAD request ────────────────────────────────────
    لکھو("\n─── HEAD ───");
    کوشش {
        متغیر c = نیا کرل();
        متغیر جواب = انتظار c.سر(`${API}/posts/1`);
        جانچ("HEAD 200", جواب.حالت == 200);
        جانچ("HEAD متن خالی", لمبائی(جواب.متن) == 0);
        جانچ("HEAD Content-Type موجود", "Content-Type" میں_ہے جواب.سرخط);
    } پکڑو (غ) {
        لکھو(`  ✗ HEAD غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 13. base URL + زنجیر ────────────────────────────────
    لکھو("\n─── base URL + زنجیر ───");
    کوشش {
        متغیر c = نیا کرل({ "بنیادی_url": API });
        متغیر جواب = انتظار c.حاصل("/users/1");
        جانچ("base URL GET 200", جواب.حالت == 200);
        متغیر صارف = جواب.جے_سون();
        جانچ("user id=1", صارف["id"] == 1);
        لکھو(`  ⓘ صارف: ${صارف["name"]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ base URL غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 14. pycurl ──────────────────────────────────────────
    لکھو("\n─── pycurl ───");
    کوشش {
        جانچ("pycurl دستیاب", پائی_کرل.دستیاب() == سچ);
        متغیر خام = انتظار پائی_کرل.حاصل(`${API}/posts/1`);
        جانچ("pycurl GET bytes", لمبائی(خام) > 0);
        لکھو(`  ⓘ پہلے 50 bytes: ${متن(خام).slice(0, 50)}`);

        متغیر خام_post = انتظار پائی_کرل.بھیجو(
            `${BIN}/post`,
            "{\"پیغام\": \"pycurl سے\"}",
            ["Content-Type: application/json"]
        );
        جانچ("pycurl POST bytes", لمبائی(خام_post) > 0);
    } پکڑو (غ) {
        لکھو(`  ✗ pycurl غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    لکھو(`\n══════════════════════════════════════════`);
    لکھو(`  کرل جانچ — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════════`);
}

انتظار مرکز();
