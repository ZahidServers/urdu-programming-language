// ══════════════════════════════════════════════════════
// جدید خصوصیات جانچ
// ══════════════════════════════════════════════════════

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// ─── 1. باقی فہرست طریقے ─────────────────────────────
لکھو("\n─── باقی فہرست طریقے ───");

// شامل / نکالو
متغیر ف = [1, 2, 3];
ف.شامل(4);
جانچ("شامل (push)", ف.لمبائی == 4 && ف[3] == 4);

ف.نکالو();
جانچ("نکالو (pop)", ف.لمبائی == 3);

// پہلے_شامل / پہلا_نکالو
ف.پہلے_شامل(0);
جانچ("پہلے_شامل (unshift)", ف[0] == 0 && ف.لمبائی == 4);

ف.پہلا_نکالو();
جانچ("پہلا_نکالو (shift)", ف[0] == 1 && ف.لمبائی == 3);

// پھیلاؤ (flat)
متغیر گہری = [[1, 2], [3, 4], [5]];
متغیر سادہ = گہری.پھیلاؤ();
جانچ("پھیلاؤ (flat)", سادہ[0] == 1 && سادہ.لمبائی == 5);

متغیر گہرا = [[1, [2, 3]], [4]];
جانچ("پھیلاؤ عمیق (flat 2)", گہرا.پھیلاؤ(2).لمبائی == 4);

// پھیلا_تبدیل (flatMap)
متغیر نتیجہ = [1, 2, 3].پھیلا_تبدیل(x => [x, x * 2]);
جانچ("پھیلا_تبدیل (flatMap)", نتیجہ.لمبائی == 6 && نتیجہ[0] == 1 && نتیجہ[1] == 2);

// بھرو (fill)
متغیر بھری = [0, 0, 0, 0, 0];
_urdu_fill(بھری, 7, 1, 4);
جانچ("بھرو (fill)", بھری[0] == 0 && بھری[1] == 7 && بھری[4] == 0);

// کاٹو (splice)
متغیر ک = [1, 2, 3, 4, 5];
متغیر نکالے = _urdu_splice(ک, 1, 2);
جانچ("کاٹو (splice) — نکالے", نکالے[0] == 2 && نکالے[1] == 3);
جانچ("کاٹو (splice) — باقی", ک.لمبائی == 3 && ک[1] == 4);

// تلاش_مقام (findIndex)
متغیر فہرست = [10, 20, 30, 40];
متغیر جگہ = فہرست.تلاش_مقام(x => x > 25);
جانچ("تلاش_مقام (findIndex)", جگہ == 2);

// ہر_ایک (forEach)
متغیر جمع = 0;
متغیر جمع_ڈبہ = { "قدر": 0 };
[1, 2, 3, 4].ہر_ایک(x => { جمع_ڈبہ["قدر"] = جمع_ڈبہ["قدر"] + x; });
جانچ("ہر_ایک (forEach)", جمع_ڈبہ["قدر"] == 10);

// ─── 2. اردو اعداد ─────────────────────────────────────
لکھو("\n─── اردو اعداد ───");

جانچ("اردو اعداد بنیادی",  ۱۰ + ۲۰ == 30);
جانچ("اردو × انگریزی",    ۵ * 5 == 25);
جانچ("اعشاری اردو",        ۳.۱۴ * ۲ > 6);
جانچ("عربی انڈک اعداد",   ١٠٠ - ٢٥ == 75);
جانچ("اردو لوپ",
    [۱,۲,۳,۴,۵].اکٹھا((a,b) => a + b, ۰) == 15);

// ─── 3. Promise ───────────────────────────────────────
لکھو("\n─── Promise جانچ ───");

غیر_متزامن فنکشن promise_test() {
    // resolve + then chain
    متغیر ر = انتظار Promise.resolve(10)
        .then(x => x * 3)
        .then(x => x - 5);
    جانچ("resolve زنجیر", ر == 25);

    // reject + catch
    متغیر غلطی_پکڑی = جھوٹ;
    کوشش {
        انتظار Promise.reject(نیا Error("جانچ"));
    } پکڑو (غ) {
        غلطی_پکڑی = سچ;
    }
    جانچ("reject پکڑو", غلطی_پکڑی == سچ);

    // Promise.all
    متغیر سب = انتظار Promise.all([
        Promise.resolve(1),
        Promise.resolve(2),
        Promise.resolve(3)
    ]);
    جانچ("Promise.all", سب[0] == 1 && سب[1] == 2 && سب[2] == 3);
}

انتظار promise_test();

// ─── 4. غلطی پیغامات اردو میں ────────────────────────
لکھو("\n─── اردو غلطی پیغامات ───");

فنکشن غلطی_جانچ(نام, فن) {
    متغیر پکڑا = جھوٹ;
    کوشش {
        فن();
    } پکڑو (غ) {
        پکڑا = سچ;
        لکھو(`  ✓ ${نام}: ${غ.پیغام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    }
    اگر (!پکڑا) {
        لکھو(`  ✗ ${نام}: غلطی نہیں آئی`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

غلطی_جانچ("صفر تقسیم",  () => { متغیر x = 1 / 0; });
غلطی_جانچ("اشاریہ باہر", () => { متغیر x = [1][5]; });
غلطی_جانچ("کلید نہیں",  () => { متغیر x = {}; واپس x["ندارد"]["کچھ"]; });

// ─── 5. اختیاری زنجیر گہری ───────────────────────────
لکھو("\n─── گہری اختیاری زنجیر ───");

متغیر ڈیٹا = {
    صارف: {
        پتہ: {
            شہر: "کراچی",
            پن: 75500
        }
    }
};

جانچ("گہری ?.  موجود",   ڈیٹا?.صارف?.پتہ?.شہر == "کراچی");
جانچ("گہری ?.  غائب",    ڈیٹا?.صارف?.فون?.نمبر == خالی);
جانچ("?.  پر کام",       ڈیٹا?.صارف?.پتہ?.پن > 0);

// ─── 6. BiDi اور اردو آؤٹ پٹ ─────────────────────────
لکھو("\n─── BiDi آؤٹ پٹ ───");
لکھو("اردو متن اور English text ایک ساتھ!");
لکھو("رقم: 1,234 روپے — Amount: Rs 1,234");
لکھو(`عمر ۲۵ سال — Age: 25 years`);
جانچ("BiDi آؤٹ پٹ ٹھیک", سچ);

// ─── نتیجہ ────────────────────────────────────────────
لکھو(`\n══════════════════════════════════════`);
لکھو(`  جدید جانچ — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
لکھو(`══════════════════════════════════════`);
