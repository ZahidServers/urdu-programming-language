// ══════════════════════════════════════════════════════════════
// Cassandra مکمل لائیو جانچ — localhost:9042
// نوٹ: CQL صرف ASCII شناخت کار قبول کرتا ہے
// ══════════════════════════════════════════════════════════════

درآمد { کسینڈرا } سے "اردو/ڈیٹا_بیس";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════════╗");
    لکھو("║  Cassandra لائیو جانچ                    ║");
    لکھو("╚══════════════════════════════════════════╝");

    متغیر db = نیا کسینڈرا({
        "میزبان": ["localhost"],
        "پورٹ":   9042
    });

    // ─── 1. جڑنا ────────────────────────────────────────────
    لکھو("\n─── جڑنا ───");
    کوشش {
        انتظار db.جوڑیں();
        جانچ("Cassandra سے جڑ گئے", db._connected == سچ);
    } پکڑو (غ) {
        لکھو(`  ✗ جڑنے میں ناکامی: ${غ}`);
        واپس;
    }

    // ─── 2. کی_اسپیس بنانا ──────────────────────────────────
    لکھو("\n─── کی_اسپیس ───");
    کوشش {
        متغیر نتیجہ = انتظار db.کی_اسپیس_بنائیں("urdu_jaan", "SimpleStrategy", 1);
        جانچ("کی_اسپیس بنی", نتیجہ == سچ);
        انتظار db.کی_اسپیس_چنو("urdu_jaan");
        جانچ("کی_اسپیس منتخب", سچ);
    } پکڑو (غ) {
        لکھو(`  ✗ کی_اسپیس غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 3. جدول بنانا ──────────────────────────────────────
    لکھو("\n─── جدول ───");
    کوشش {
        انتظار db.چلائیں("DROP TABLE IF EXISTS talib_ilm");
        متغیر بنا = انتظار db.جدول_بنائیں("talib_ilm", {
            "id":     "UUID PRIMARY KEY",
            "naam":   "TEXT",
            "umar":   "INT",
            "shehar": "TEXT",
            "number": "FLOAT"
        });
        جانچ("جدول بنا", بنا == سچ);
    } پکڑو (غ) {
        لکھو(`  ✗ جدول غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 4. داخل کرنا ───────────────────────────────────────
    لکھو("\n─── داخل ───");
    کوشش {
        انتظار db.چلائیں(
            "INSERT INTO talib_ilm (id, naam, umar, shehar, number) VALUES (uuid(), 'Ahmad', 20, 'Karachi', 88.5)"
        );
        انتظار db.چلائیں(
            "INSERT INTO talib_ilm (id, naam, umar, shehar, number) VALUES (uuid(), 'Fatima', 22, 'Lahore', 91.0)"
        );
        انتظار db.چلائیں(
            "INSERT INTO talib_ilm (id, naam, umar, shehar, number) VALUES (uuid(), 'Ali', 19, 'Islamabad', 75.5)"
        );
        متغیر سب = انتظار db.سوال("SELECT * FROM talib_ilm");
        جانچ("3 طلباء داخل ہوئے", لمبائی(سب) == 3);
        لکھو(`  ⓘ کل طلباء: ${لمبائی(سب)}`);
    } پکڑو (غ) {
        لکھو(`  ✗ داخل غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 5. SELECT سوال ─────────────────────────────────────
    لکھو("\n─── SELECT سوال ───");
    کوشش {
        متغیر سب = انتظار db.سوال("SELECT naam, umar, shehar, number FROM talib_ilm");
        جانچ("3 قطاریں ملیں", لمبائی(سب) == 3);
        جانچ("نام موجود", لمبائی(سب[0]["naam"]) > 0);
        لکھو(`  ⓘ پہلا طالب: ${سب[0]["naam"]} — ${سب[0]["shehar"]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ SELECT غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 6. COUNT ───────────────────────────────────────────
    لکھو("\n─── COUNT ───");
    کوشش {
        متغیر گنتی_نتیجہ = انتظار db.سوال("SELECT COUNT(*) FROM talib_ilm");
        متغیر تعداد = گنتی_نتیجہ[0]["count"];
        جانچ("COUNT == 3", تعداد == 3);
        لکھو(`  ⓘ COUNT: ${تعداد}`);
    } پکڑو (غ) {
        لکھو(`  ✗ COUNT غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 7. تیار بیانات ─────────────────────────────────────
    لکھو("\n─── تیار بیانات ───");
    کوشش {
        متغیر تیار_داخل = db.تیار(
            "INSERT INTO talib_ilm (id, naam, umar, shehar, number) VALUES (uuid(), ?, ?, ?, ?)"
        );
        جانچ("بیان تیار ہوا", تیار_داخل != خالی);

        انتظار db.تیار_چلائیں(تیار_داخل, ["Zainab", 21, "Multan", 83.0]);
        انتظار db.تیار_چلائیں(تیار_داخل, ["Umar", 23, "Peshawar", 79.5]);

        متغیر سب = انتظار db.سوال("SELECT COUNT(*) FROM talib_ilm");
        جانچ("5 طلباء اب", سب[0]["count"] == 5);
        لکھو(`  ⓘ تیار داخل کے بعد: ${سب[0]["count"]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ تیار بیان غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 8. UPDATE ──────────────────────────────────────────
    لکھو("\n─── UPDATE ───");
    کوشش {
        متغیر قطاریں = انتظار db.سوال("SELECT id, naam FROM talib_ilm");
        متغیر احمد_id = خالی;
        متغیر i = 0;
        جبکہ (i < لمبائی(قطاریں)) {
            اگر (قطاریں[i]["naam"] == "Ahmad") {
                احمد_id = قطاریں[i]["id"];
            }
            i = i + 1;
        }
        اگر (احمد_id != خالی) {
            انتظار db.چلائیں(
                `UPDATE talib_ilm SET number = 95.0 WHERE id = ${احمد_id}`
            );
            متغیر جانچ_قطار = انتظار db.سوال(
                `SELECT number FROM talib_ilm WHERE id = ${احمد_id}`
            );
            جانچ("number اپ ڈیٹ ہوا", جانچ_قطار[0]["number"] == 95.0);
            لکھو(`  ⓘ احمد کا نیا نمبر: ${جانچ_قطار[0]["number"]}`);
        } ورنہ {
            لکھو("  ⓘ احمد نہیں ملا، UPDATE چھوڑا");
            جانچ("UPDATE آزمایا", سچ);
        }
    } پکڑو (غ) {
        لکھو(`  ✗ UPDATE غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 9. DELETE ──────────────────────────────────────────
    لکھو("\n─── DELETE ───");
    کوشش {
        متغیر قطاریں = انتظار db.سوال("SELECT id, naam FROM talib_ilm");
        متغیر علی_id = خالی;
        متغیر j = 0;
        جبکہ (j < لمبائی(قطاریں)) {
            اگر (قطاریں[j]["naam"] == "Ali") {
                علی_id = قطاریں[j]["id"];
            }
            j = j + 1;
        }
        اگر (علی_id != خالی) {
            انتظار db.چلائیں(`DELETE FROM talib_ilm WHERE id = ${علی_id}`);
            متغیر بعد = انتظار db.سوال("SELECT COUNT(*) FROM talib_ilm");
            جانچ("4 باقی رہے", بعد[0]["count"] == 4);
            لکھو(`  ⓘ حذف کے بعد: ${بعد[0]["count"]}`);
        } ورنہ {
            لکھو("  ⓘ علی نہیں ملا، DELETE چھوڑا");
            جانچ("DELETE آزمایا", سچ);
        }
    } پکڑو (غ) {
        لکھو(`  ✗ DELETE غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 10. BATCH ──────────────────────────────────────────
    لکھو("\n─── BATCH ───");
    کوشش {
        انتظار db.چلائیں("DROP TABLE IF EXISTS masnoaat");
        انتظار db.جدول_بنائیں("masnoaat", {
            "id":    "UUID PRIMARY KEY",
            "naam":  "TEXT",
            "qeemat": "DECIMAL"
        });

        متغیر تیار_م = db.تیار(
            "INSERT INTO masnoaat (id, naam, qeemat) VALUES (uuid(), ?, ?)"
        );

        انتظار db.بیچ([
            [تیار_م, ["Kitab",  250]],
            [تیار_م, ["Qalam",  50]],
            [تیار_م, ["Baig",   800]]
        ]);

        متغیر مصنوعات = انتظار db.سوال("SELECT COUNT(*) FROM masnoaat");
        جانچ("BATCH 3 اندراج", مصنوعات[0]["count"] == 3);
        لکھو(`  ⓘ مصنوعات: ${مصنوعات[0]["count"]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ BATCH غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 11. TTL ────────────────────────────────────────────
    لکھو("\n─── TTL ───");
    کوشش {
        انتظار db.چلائیں("DROP TABLE IF EXISTS aarzi");
        انتظار db.جدول_بنائیں("aarzi", {
            "id":     "UUID PRIMARY KEY",
            "paigham": "TEXT"
        });
        انتظار db.چلائیں(
            "INSERT INTO aarzi (id, paigham) VALUES (uuid(), 'yeh aarzi hai') USING TTL 3600"
        );
        متغیر عارضی_نتیجہ = انتظار db.سوال("SELECT paigham FROM aarzi");
        جانچ("TTL اندراج کامیاب", لمبائی(عارضی_نتیجہ) == 1);
        جانچ("TTL پیغام درست", عارضی_نتیجہ[0]["paigham"] == "yeh aarzi hai");
    } پکڑو (غ) {
        لکھو(`  ✗ TTL غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 12. صفائی ──────────────────────────────────────────
    لکھو("\n─── صفائی ───");
    کوشش {
        انتظار db.جدول_مٹائیں("talib_ilm");
        انتظار db.جدول_مٹائیں("masnoaat");
        انتظار db.جدول_مٹائیں("aarzi");
        انتظار db.کی_اسپیس_مٹائیں("urdu_jaan");
        جانچ("صفائی مکمل", سچ);
    } پکڑو (غ) {
        لکھو(`  ✗ صفائی غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 13. منقطع ──────────────────────────────────────────
    لکھو("\n─── منقطع ───");
    کوشش {
        انتظار db.منقطع();
        جانچ("منقطع ہو گئے", db._connected == جھوٹ);
    } پکڑو (غ) {
        لکھو(`  ✗ منقطع غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    لکھو(`\n══════════════════════════════════════════`);
    لکھو(`  Cassandra جانچ — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════════`);
}

انتظار مرکز();
