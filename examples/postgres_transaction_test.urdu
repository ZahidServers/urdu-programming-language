// ══════════════════════════════════════════════════════
// اردو پروگرامنگ لینگویج — پوسٹ_گریس لین دین جانچ
// COMMIT، ROLLBACK، SAVEPOINT، لین_دین() wrapper
// ══════════════════════════════════════════════════════

درآمد { پوسٹ_گریس } سے "اردو/ڈیٹا_بیس";

فنکشن پاس(نام) { لکھو(`  ✓ ${نام}`); }
فنکشن ناکام(نام, وجہ) { لکھو(`  ✗ ${نام} — ${وجہ}`); }

متغیر db = نیا پوسٹ_گریس({
    میزبان:   "localhost",
    صارف:     "postgres",
    پاس_ورڈ: "root",
    ڈیٹا_بیس: "postgres",
    پورٹ:     5432
});

// ── شروعاتی ڈیٹا سیٹ کریں ──────────────────────────────
غیر_متزامن فنکشن شروع_کریں() {
    انتظار db.چلائیں("DELETE FROM pg_tx_کھاتے");
    انتظار db.چلائیں("INSERT INTO pg_tx_کھاتے (نام, بقیہ) VALUES (?, ?)", ["احمد", 10000]);
    انتظار db.چلائیں("INSERT INTO pg_tx_کھاتے (نام, بقیہ) VALUES (?, ?)", ["فاطمہ", 5000]);
}

غیر_متزامن فنکشن بقیہ_حاصل(نام) {
    متغیر نتیجہ = انتظار db.سوال("SELECT بقیہ FROM pg_tx_کھاتے WHERE نام = ?", [نام]);
    اگر (لمبائی(نتیجہ) > 0) { واپس نتیجہ[0].بقیہ; }
    واپس 0;
}

// ══════════════════════════════════════════════════════
// مرکزی جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن مرکز() {
    لکھو("══════════════════════════════════════════");
    لکھو("  پوسٹ_گریس — لین دین (Transaction) جانچ");
    لکھو("══════════════════════════════════════════");

    انتظار db.جوڑیں();

    // اسکیما اور جدول ایک بار بنائیں
    انتظار db.چلائیں("SET search_path TO public");
    انتظار db.چلائیں("DROP TABLE IF EXISTS pg_tx_کھاتے");
    انتظار db.چلائیں(`
        CREATE TABLE pg_tx_کھاتے (
            شناخت SERIAL PRIMARY KEY,
            نام    VARCHAR(100) NOT NULL,
            بقیہ   DECIMAL(10,2) DEFAULT 0
        )
    `);

    // ══════════════════════════════════════════════════
    // 1. کامیاب COMMIT
    // ══════════════════════════════════════════════════
    لکھو("\n╔════════════════════════════════════════╗");
    لکھو(  "║  1. کامیاب منتقلی — COMMIT             ║");
    لکھو(  "╚════════════════════════════════════════╝");

    انتظار شروع_کریں();
    انتظار db.لین_دین_شروع();
    انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [2000, "احمد"]);
    انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = بقیہ + ? WHERE نام = ?", [2000, "فاطمہ"]);
    انتظار db.کمٹ();

    متغیر احمد = انتظار بقیہ_حاصل("احمد");
    متغیر فاطمہ = انتظار بقیہ_حاصل("فاطمہ");
    اگر (احمد == 8000 && فاطمہ == 7000) {
        پاس(`COMMIT — احمد: ${احمد}، فاطمہ: ${فاطمہ}`);
    } ورنہ {
        ناکام("COMMIT", `احمد=${احمد}, فاطمہ=${فاطمہ}`);
    }

    // ══════════════════════════════════════════════════
    // 2. ROLLBACK — منتقلی منسوخ
    // ══════════════════════════════════════════════════
    لکھو("\n╔════════════════════════════════════════╗");
    لکھو(  "║  2. ROLLBACK — منتقلی منسوخ            ║");
    لکھو(  "╚════════════════════════════════════════╝");

    انتظار db.لین_دین_شروع();
    انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [9999, "احمد"]);
    // احمد کا بقیہ منفی ہو جاتا — منسوخ کریں
    انتظار db.واپسی();

    متغیر بعد_واپسی = انتظار بقیہ_حاصل("احمد");
    اگر (بعد_واپسی == 8000) {
        پاس(`ROLLBACK — احمد کا بقیہ محفوظ: ${بعد_واپسی}`);
    } ورنہ {
        ناکام("ROLLBACK", `بقیہ=${بعد_واپسی}`);
    }

    // ══════════════════════════════════════════════════
    // 3. لین_دین() — خودکار COMMIT/ROLLBACK
    // ══════════════════════════════════════════════════
    لکھو("\n╔════════════════════════════════════════╗");
    لکھو(  "║  3. لین_دین() خودکار COMMIT/ROLLBACK   ║");
    لکھو(  "╚════════════════════════════════════════╝");

    // کامیاب لین دین → خودکار COMMIT
    انتظار db.لین_دین(غیر_متزامن فنکشن() {
        انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = بقیہ + ? WHERE نام = ?", [500, "احمد"]);
        انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [500, "فاطمہ"]);
    });
    متغیر ا2 = انتظار بقیہ_حاصل("احمد");
    متغیر ف2 = انتظار بقیہ_حاصل("فاطمہ");
    اگر (ا2 == 8500 && ف2 == 6500) {
        پاس(`لین_دین() COMMIT — احمد: ${ا2}، فاطمہ: ${ف2}`);
    } ورنہ {
        ناکام("لین_دین() COMMIT", `احمد=${ا2}, فاطمہ=${ف2}`);
    }

    // غلطی پر خودکار ROLLBACK
    متغیر پہلے_احمد = انتظار بقیہ_حاصل("احمد");
    کوشش {
        انتظار db.لین_دین(غیر_متزامن فنکشن() {
            انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [1000, "احمد"]);
            پھینکو نیا غلطی("بینک سرور بند!");
        });
    } پکڑو (غ) {
        متغیر بعد_خطا = انتظار بقیہ_حاصل("احمد");
        اگر (بعد_خطا == پہلے_احمد) {
            پاس(`لین_دین() خودکار ROLLBACK — ${غ.پیغام}`);
        } ورنہ {
            ناکام("خودکار ROLLBACK", `بقیہ=${بعد_خطا}`);
        }
    }

    // ══════════════════════════════════════════════════
    // 4. SAVEPOINT / نقطہ محفوظ
    // ══════════════════════════════════════════════════
    لکھو("\n╔════════════════════════════════════════╗");
    لکھو(  "║  4. SAVEPOINT / نقطہ محفوظ             ║");
    لکھو(  "╚════════════════════════════════════════╝");

    انتظار db.لین_دین_شروع();

    انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = بقیہ + ? WHERE نام = ?", [1000, "احمد"]);
    متغیر بعد_پہلی = انتظار بقیہ_حاصل("احمد");
    انتظار db.نقطہ_محفوظ("نقطہ1");

    انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = بقیہ + ? WHERE نام = ?", [2000, "احمد"]);
    متغیر بعد_دوسری = انتظار بقیہ_حاصل("احمد");
    انتظار db.نقطہ_محفوظ("نقطہ2");

    انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = 0 WHERE نام = ?", ["احمد"]);
    متغیر بعد_غلطی = انتظار بقیہ_حاصل("احمد");

    // نقطہ2 پر واپس جائیں
    انتظار db.نقطہ_واپسی("نقطہ2");
    متغیر بعد_نقطہ2 = انتظار بقیہ_حاصل("احمد");

    انتظار db.نقطہ_چھوڑیں("نقطہ2");
    انتظار db.کمٹ();

    متغیر آخری = انتظار بقیہ_حاصل("احمد");
    لکھو(`  نقطہ1 کے بعد: ${بعد_پہلی}`);
    لکھو(`  نقطہ2 کے بعد: ${بعد_دوسری}`);
    لکھو(`  غلط آپریشن کے بعد: ${بعد_غلطی}`);
    لکھو(`  نقطہ2 واپسی کے بعد: ${بعد_نقطہ2}`);
    لکھو(`  COMMIT کے بعد (آخری): ${آخری}`);

    اگر (بعد_غلطی == 0 && بعد_نقطہ2 == بعد_دوسری && آخری == بعد_دوسری) {
        پاس("SAVEPOINT + ROLLBACK TO + RELEASE + COMMIT");
    } ورنہ {
        ناکام("SAVEPOINT", "توقع کے خلاف نتیجہ");
    }

    // ══════════════════════════════════════════════════
    // 5. نیسٹڈ SAVEPOINT
    // ══════════════════════════════════════════════════
    لکھو("\n╔════════════════════════════════════════╗");
    لکھو(  "║  5. نیسٹڈ SAVEPOINT                    ║");
    لکھو(  "╚════════════════════════════════════════╝");

    انتظار شروع_کریں();
    انتظار db.لین_دین_شروع();
    انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = 9000 WHERE نام = ?", ["احمد"]);
    انتظار db.نقطہ_محفوظ("ابتدا");
    انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = 7000 WHERE نام = ?", ["احمد"]);
    انتظار db.نقطہ_محفوظ("درمیان");
    انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = 1 WHERE نام = ?", ["احمد"]);
    // پہلے نقطے پر واپس — درمیان اور بعد کی تبدیلیاں ختم
    انتظار db.نقطہ_واپسی("ابتدا");
    انتظار db.کمٹ();

    متغیر نیسٹڈ = انتظار بقیہ_حاصل("احمد");
    اگر (نیسٹڈ == 9000) {
        پاس(`نیسٹڈ SAVEPOINT — ابتدا پر واپسی: ${نیسٹڈ}`);
    } ورنہ {
        ناکام("نیسٹڈ SAVEPOINT", `بقیہ=${نیسٹڈ}`);
    }

    // ══════════════════════════════════════════════════
    // 6. لین دین کے اندر READ
    // ══════════════════════════════════════════════════
    لکھو("\n╔════════════════════════════════════════╗");
    لکھو(  "║  6. لین دین کے اندر READ               ║");
    لکھو(  "╚════════════════════════════════════════╝");

    انتظار شروع_کریں();
    انتظار db.لین_دین_شروع();
    انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = 99999 WHERE نام = ?", ["احمد"]);
    متغیر اندرونی = انتظار بقیہ_حاصل("احمد");
    لکھو(`  لین دین کے اندر READ: ${اندرونی}`);
    انتظار db.واپسی();
    متغیر بعد_رول = انتظار بقیہ_حاصل("احمد");
    لکھو(`  ROLLBACK کے بعد READ: ${بعد_رول}`);

    اگر (اندرونی == 99999 && بعد_رول == 10000) {
        پاس("لین دین کے اندر تبدیلی نظر آتی ہے، ROLLBACK کے بعد واپس");
    } ورنہ {
        ناکام("READ in TX", `اندرونی=${اندرونی}, بعد=${بعد_رول}`);
    }

    // ══════════════════════════════════════════════════
    // 7. پوسٹ_گریس: ISOLATION LEVEL
    // ══════════════════════════════════════════════════
    لکھو("\n╔════════════════════════════════════════╗");
    لکھو(  "║  7. Isolation Level تبدیل کریں        ║");
    لکھو(  "╚════════════════════════════════════════╝");

    انتظار شروع_کریں();
    // SERIALIZABLE سطح — پوسٹ_گریس سپورٹ کرتا ہے
    انتظار db.چلائیں("BEGIN TRANSACTION ISOLATION LEVEL SERIALIZABLE");
    انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = بقیہ + ? WHERE نام = ?", [1000, "فاطمہ"]);
    انتظار db.کمٹ();

    متغیر ف_نئی = انتظار بقیہ_حاصل("فاطمہ");
    اگر (ف_نئی == 6000) {
        پاس(`SERIALIZABLE COMMIT — فاطمہ: ${ف_نئی}`);
    } ورنہ {
        ناکام("SERIALIZABLE", `بقیہ=${ف_نئی}`);
    }

    // READ COMMITTED (ڈیفالٹ)
    انتظار db.چلائیں("BEGIN TRANSACTION ISOLATION LEVEL READ COMMITTED");
    انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [500, "فاطمہ"]);
    انتظار db.کمٹ();

    متغیر ف_آخر = انتظار بقیہ_حاصل("فاطمہ");
    اگر (ف_آخر == 5500) {
        پاس(`READ COMMITTED COMMIT — فاطمہ: ${ف_آخر}`);
    } ورنہ {
        ناکام("READ COMMITTED", `بقیہ=${ف_آخر}`);
    }

    // ══════════════════════════════════════════════════
    // 8. خودکار واپسی (لین_دین میں غلط SQL)
    // ══════════════════════════════════════════════════
    لکھو("\n╔════════════════════════════════════════╗");
    لکھو(  "║  8. SQL غلطی پر خودکار واپسی          ║");
    لکھو(  "╚════════════════════════════════════════╝");

    انتظار شروع_کریں();
    متغیر پہلے = انتظار بقیہ_حاصل("احمد");
    کوشش {
        انتظار db.لین_دین(غیر_متزامن فنکشن() {
            انتظار db.چلائیں("UPDATE pg_tx_کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [100, "احمد"]);
            انتظار db.چلائیں("INSERT INTO غیر_موجود_جدول VALUES (1)");  // غلط جدول!
        });
    } پکڑو (غ) {
        متغیر بعد = انتظار بقیہ_حاصل("احمد");
        اگر (بعد == پہلے) {
            پاس(`SQL غلطی پر ROLLBACK — بقیہ محفوظ: ${بعد}`);
        } ورنہ {
            ناکام("SQL Error ROLLBACK", `بقیہ=${بعد}`);
        }
    }

    // ── صفائی ─────────────────────────────────────────
    انتظار db.چلائیں("DROP TABLE IF EXISTS pg_tx_کھاتے");
    انتظار db.منقطع();

    لکھو("\n══════════════════════════════════════════");
    لکھو("  پوسٹ_گریس لین دین جانچ مکمل ✓");
    لکھو("══════════════════════════════════════════");
}

مرکز();
