// ══════════════════════════════════════════════════════════════
// فائلیں جانچ — ZIP + Excel (openpyxl)
// ══════════════════════════════════════════════════════════════

درآمد { زپ_فائل, زپ_بناؤ, زپ_نکالو, زپ_فہرست,
         ایکسل_کتاب, ایکسل_پڑھو, ایکسل_لکھو } سے "اردو/فائلیں";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════════╗");
    لکھو("║  فائلیں جانچ — ZIP + Excel               ║");
    لکھو("╚══════════════════════════════════════════╝");

    // ─── 1. ZIP — بنانا (متن شامل) ───────────────────────────
    لکھو("\n─── ZIP بنانا ───");
    کوشش {
        متغیر زپ = نیا زپ_فائل("examples/test_archive.zip", "w");
        زپ.متن_شامل("خوش_آمدید.txt", "السلام علیکم!");
        زپ.متن_شامل("معلومات.txt", "یہ اردو پروگرامنگ زبان ہے۔");
        زپ.متن_شامل("اعداد.txt", "1, 2, 3, 4, 5");
        زپ.بند();
        جانچ("ZIP بنا", سچ);

        متغیر فہرست = زپ_فہرست("examples/test_archive.zip");
        جانچ("3 فائلیں", لمبائی(فہرست) == 3);
        لکھو(`  ⓘ فائلیں: ${فہرست[0]}, ${فہرست[1]}, ${فہرست[2]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ ZIP بنانے غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 2. ZIP — پڑھنا ──────────────────────────────────────
    لکھو("\n─── ZIP پڑھنا ───");
    کوشش {
        متغیر زپ = نیا زپ_فائل("examples/test_archive.zip", "r");
        متغیر فہرست = زپ.فہرست();
        جانچ("فہرست ملی", لمبائی(فہرست) == 3);

        متغیر متن = زپ.متن_پڑھو("خوش_آمدید.txt");
        جانچ("متن درست", متن == "السلام علیکم!");
        لکھو(`  ⓘ خوش_آمدید.txt: ${متن}`);

        متغیر معلومات = زپ.معلومات("خوش_آمدید.txt");
        جانچ("سائز > 0", معلومات["اصل_سائز"] > 0);
        لکھو(`  ⓘ سائز: ${معلومات["اصل_سائز"]} bytes`);
        زپ.بند();
    } پکڑو (غ) {
        لکھو(`  ✗ ZIP پڑھنے غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 3. ZIP — فائل شامل (موجودہ فائل سے) ────────────────
    لکھو("\n─── ZIP فائل شامل ───");
    کوشش {
        متغیر نتیجہ = زپ_بناؤ("examples/test_csv_zip.zip", [
            ["examples/test_data.csv", "data.csv"]
        ]);
        جانچ("فائل سے ZIP بنا", نتیجہ == "examples/test_csv_zip.zip");
        متغیر ف = زپ_فہرست("examples/test_csv_zip.zip");
        جانچ("data.csv اندر", لمبائی(ف) == 1);
        لکھو(`  ⓘ ZIP مواد: ${ف[0]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ ZIP شامل غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 4. ZIP — نکالنا ─────────────────────────────────────
    لکھو("\n─── ZIP نکالنا ───");
    کوشش {
        متغیر نکالی_فائلیں = زپ_نکالو("examples/test_archive.zip", "examples/unzipped");
        جانچ("فائلیں نکلیں", لمبائی(نکالی_فائلیں) == 3);
        لکھو(`  ⓘ نکالا: ${لمبائی(نکالی_فائلیں)} فائلیں`);
    } پکڑو (غ) {
        لکھو(`  ✗ ZIP نکالنے غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 5. Excel openpyxl — نئی کتاب ────────────────────────
    لکھو("\n─── Excel نئی کتاب ───");
    کوشش {
        متغیر کتاب = نیا ایکسل_کتاب();
        متغیر ورق = کتاب.ورق();
        جانچ("ورق ملا", ورق != خالی);

        ورق.خانہ_مقرر(1, 1, "نام");
        ورق.خانہ_مقرر(1, 2, "نمبر");
        ورق.خانہ_مقرر(2, 1, "احمد");
        ورق.خانہ_مقرر(2, 2, 88.5);
        ورق.خانہ_مقرر(3, 1, "فاطمہ");
        ورق.خانہ_مقرر(3, 2, 91.0);
        ورق.خانہ_مقرر(4, 1, "علی");
        ورق.خانہ_مقرر(4, 2, 75.5);

        کتاب.محفوظ("examples/test_openpyxl.xlsx");
        جانچ("کتاب محفوظ", سچ);
        لکھو(`  ⓘ Excel محفوظ: examples/test_openpyxl.xlsx`);
    } پکڑو (غ) {
        لکھو(`  ✗ Excel نئی کتاب غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 6. Excel openpyxl — پڑھنا ───────────────────────────
    لکھو("\n─── Excel پڑھنا ───");
    کوشش {
        متغیر کتاب = نیا ایکسل_کتاب("examples/test_openpyxl.xlsx");
        متغیر ورق = کتاب.ورق();

        جانچ("صفوں کی تعداد", ورق.صف_تعداد == 4);
        جانچ("کالموں کی تعداد", ورق.کالم_تعداد == 2);
        جانچ("A1 سرخی", ورق.خانہ(1, 1) == "نام");
        جانچ("B1 سرخی", ورق.خانہ(1, 2) == "نمبر");
        جانچ("A2 احمد", ورق.خانہ(2, 1) == "احمد");
        جانچ("B2 88.5", ورق.خانہ(2, 2) == 88.5);
        لکھو(`  ⓘ A2=${ورق.خانہ(2,1)}, B2=${ورق.خانہ(2,2)}`);
        کتاب.بند();
    } پکڑو (غ) {
        لکھو(`  ✗ Excel پڑھنے غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 7. Excel — قطار شامل / سب_ڈیٹا ──────────────────────
    لکھو("\n─── قطار شامل + سب_ڈیٹا ───");
    کوشش {
        متغیر کتاب = نیا ایکسل_کتاب();
        متغیر ورق = کتاب.ورق();
        ورق.قطار_شامل(["ID", "نام", "قیمت"]);
        ورق.قطار_شامل([1, "کتاب",  250]);
        ورق.قطار_شامل([2, "قلم",   50]);
        ورق.قطار_شامل([3, "بیگ",  800]);
        کتاب.محفوظ("examples/test_rows.xlsx");

        متغیر سب = ورق.سب_ڈیٹا();
        جانچ("4 قطاریں", لمبائی(سب) == 4);
        جانچ("سرخی درست", سب[0][0] == "ID");
        جانچ("دوسری قطار", سب[1][1] == "کتاب");
        لکھو(`  ⓘ قطار 2: ${سب[1][0]}, ${سب[1][1]}, ${سب[1][2]}`);
        کتاب.بند();
    } پکڑو (غ) {
        لکھو(`  ✗ قطار شامل غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 8. Excel — متعدد ورق ────────────────────────────────
    لکھو("\n─── Excel متعدد ورق ───");
    کوشش {
        متغیر کتاب = نیا ایکسل_کتاب();
        متغیر ورق1 = کتاب.ورق();
        ورق1.خانہ_مقرر(1, 1, "طلباء");

        متغیر ورق2 = کتاب.ورق_بنائیں("مضامین");
        ورق2.خانہ_مقرر(1, 1, "ریاضی");
        ورق2.خانہ_مقرر(1, 2, "سائنس");

        کتاب.محفوظ("examples/test_sheets.xlsx");
        متغیر فہرست = کتاب.ورق_فہرست();
        جانچ("2 ورق", لمبائی(فہرست) == 2);
        جانچ("ورق2 نام", فہرست[1] == "مضامین");
        لکھو(`  ⓘ ورق: ${فہرست[0]}, ${فہرست[1]}`);
        کتاب.بند();
    } پکڑو (غ) {
        لکھو(`  ✗ متعدد ورق غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 9. ایکسل_لکھو / ایکسل_پڑھو (helper) ───────────────
    لکھو("\n─── standalone Excel helpers ───");
    کوشش {
        متغیر ڈیٹا = [
            ["ID", "نام", "قیمت"],
            [1, "کتاب",  250],
            [2, "قلم",   50],
            [3, "بیگ",  800]
        ];
        متغیر راستہ = ایکسل_لکھو(ڈیٹا, "examples/test_helper.xlsx", "مصنوعات");
        جانچ("helper Excel لکھا", راستہ == "examples/test_helper.xlsx");

        متغیر پڑھا = ایکسل_پڑھو("examples/test_helper.xlsx", "مصنوعات");
        جانچ("4 قطاریں", لمبائی(پڑھا) == 4);
        جانچ("سرخی ID", پڑھا[0][0] == "ID");
        جانچ("تیسری قطار قلم", پڑھا[2][1] == "قلم");
        لکھو(`  ⓘ نتیجہ: ${پڑھا[1][0]}, ${پڑھا[1][1]}, ${پڑھا[1][2]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ helper غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    لکھو(`\n══════════════════════════════════════════`);
    لکھو(`  فائلیں جانچ — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════════`);
}

انتظار مرکز();
