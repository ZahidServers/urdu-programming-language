// ══════════════════════════════════════════════════════
// چیننگ جانچ — اردو طریقے
// ══════════════════════════════════════════════════════

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// ─── 1. متن (String) چیننگ ───────────────────────────
لکھو("\n─── متن چیننگ ───");

جانچ("چھاٹو + بڑے_حروف",
    "  سلام  ".چھاٹو().بڑے_حروف() == "سلام");

جانچ("چھوٹے_حروف",
    "HELLO".چھوٹے_حروف() == "hello");

جانچ("بدلو + چھاٹو",
    "  اردو  ".بدلو("اردو", "Python").چھاٹو() == "Python");

جانچ("تقسیم + جوڑو",
    "ا-ب-ج".split("-").جوڑو(", ") == "ا, ب, ج");

جانچ("چھوٹے_حروف + شامل_ہے",
    "HELLO".چھوٹے_حروف().شامل_ہے("ell") == سچ);

جانچ("شروع_ہے",
    "اردو پروگرامنگ".شروع_ہے("اردو") == سچ);

جانچ("ختم_ہے",
    "اردو پروگرامنگ".ختم_ہے("پروگرامنگ") == سچ);

جانچ("دہراؤ",
    "ہا".دہراؤ(3) == "ہاہاہا");

// ─── 2. فہرست (Array) چیننگ ──────────────────────────
لکھو("\n─── فہرست چیننگ ───");

جانچ("چھانو",
    [1,2,3,4,5].چھانو(x => x > 3).لمبائی == 2);

جانچ("تبدیل",
    [1,2,3,4].تبدیل(x => x * 2)[3] == 8);

جانچ("چھانو + تبدیل",
    [1,2,3,4,5].چھانو(x => x % 2 == 0).تبدیل(x => x * 10)[0] == 20);

جانچ("اکٹھا",
    [1,2,3,4].اکٹھا((جمع, x) => جمع + x, 0) == 10);

جانچ("چھانو + تبدیل + اکٹھا",
    [1,2,3,4,5,6].چھانو(x => x % 2 == 0).تبدیل(x => x * x).اکٹھا((a,b) => a+b, 0) == 56);

جانچ("حصہ + پلٹاؤ",
    [1,2,3,4,5].حصہ(1,4).پلٹاؤ()[0] == 4);

جانچ("ملاؤ + ترتیب_دو",
    [3,1].ملاؤ([4,1,5]).ترتیب_دو()[0] == 1);

جانچ("شامل_ہے (فہرست)",
    [1,2,3].شامل_ہے(2) == سچ);

جانچ("کوئی",
    [1,2,3,4].کوئی(x => x > 3) == سچ);

جانچ("سب",
    [2,4,6,8].سب(x => x % 2 == 0) == سچ);

جانچ("تلاش",
    [1,2,3,4].تلاش(x => x > 2) == 3);

// ─── 3. لمبائی خاصیت ─────────────────────────────────
لکھو("\n─── لمبائی خاصیت ───");

جانچ("متن.لمبائی",
    "سلام".لمبائی == 4);

جانچ("فہرست.لمبائی",
    [1,2,3,4,5].لمبائی == 5);

// ─── 4. کلاس Fluent چیننگ ────────────────────────────
لکھو("\n─── کلاس چیننگ ───");

کلاس سوال_ساز {
    تعمیر() {
        یہ.حصے = [];
    }
    شامل_کرو(حصہ) {
        یہ.حصے.شامل(حصہ);
        واپس یہ;
    }
    بناؤ() {
        واپس یہ.حصے.جوڑو(" ");
    }
}

متغیر جملہ = نیا سوال_ساز()
    .شامل_کرو("اردو")
    .شامل_کرو("پروگرامنگ")
    .شامل_کرو("زبان")
    .بناؤ();

جانچ("fluent chain", جملہ == "اردو پروگرامنگ زبان");

// ─── 5. اختیاری زنجیر ────────────────────────────────
لکھو("\n─── اختیاری زنجیر (?.) ───");

متغیر ش = { پتہ: { شہر: "لاہور" } };
جانچ("?.  موجود قدر", ش?.پتہ?.شہر == "لاہور");
جانچ("?.  غیر موجود", ش?.فون?.نمبر == خالی);

// ─── 6. Promise چیننگ ────────────────────────────────
لکھو("\n─── غیر متزامن زنجیر ───");

غیر_متزامن فنکشن async_test() {
    متغیر نتیجہ = انتظار Promise.resolve(5)
        .then(x => x * 2)
        .then(x => x + 1);
    جانچ("Promise زنجیر", نتیجہ == 11);
}

انتظار async_test();

// ─── نتیجہ ────────────────────────────────────────────
لکھو(`\n══════════════════════════════════════`);
لکھو(`  چیننگ — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
لکھو(`══════════════════════════════════════`);
