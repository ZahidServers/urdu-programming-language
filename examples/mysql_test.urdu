// ══════════════════════════════════════════════════════
// مائی_ایس_کیو_ایل مکمل جانچ — CRUD + Transactions
// ══════════════════════════════════════════════════════

درآمد { مائی_ایس_کیو_ایل } سے "اردو/ڈیٹا_بیس";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════╗");
    لکھو("║  مائی_ایس_کیو_ایل مکمل جانچ          ║");
    لکھو("╚══════════════════════════════════════╝");

    متغیر db = نیا مائی_ایس_کیو_ایل({
        "میزبان": "localhost",
        "صارف":   "root",
        "پاس_ورڈ": "",
        "پورٹ":   3306
    });

    کوشش {

        // ─── جڑنا ─────────────────────────────────────
        لکھو("\n─── جڑنا ───");
        انتظار db.جوڑیں();
        جانچ("جڑ گئے", db._connected == سچ);

        // ─── ڈیٹا بیس اور جدول بنائیں ───────────────
        لکھو("\n─── ترتیب ───");
        انتظار db.چلائیں("CREATE DATABASE IF NOT EXISTS urdu_mysql_test CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci");
        انتظار db.چلائیں("USE urdu_mysql_test");
        انتظار db.چلائیں("DROP TABLE IF EXISTS جانچ_جدول");
        انتظار db.چلائیں(`
            CREATE TABLE جانچ_جدول (
                id    INT AUTO_INCREMENT PRIMARY KEY,
                نام   VARCHAR(100) NOT NULL,
                عمر   INT,
                شہر   VARCHAR(50)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4
        `);
        جانچ("جدول بنا", سچ);

        // ─── INSERT ───────────────────────────────────
        لکھو("\n─── INSERT ───");
        انتظار db.چلائیں("INSERT INTO جانچ_جدول (نام, عمر, شہر) VALUES (?, ?, ?)", ["احمد", 25, "کراچی"]);
        انتظار db.چلائیں("INSERT INTO جانچ_جدول (نام, عمر, شہر) VALUES (?, ?, ?)", ["فاطمہ", 30, "لاہور"]);
        انتظار db.چلائیں("INSERT INTO جانچ_جدول (نام, عمر, شہر) VALUES (?, ?, ?)", ["علی", 22, "کراچی"]);
        انتظار db.چلائیں("INSERT INTO جانچ_جدول (نام, عمر, شہر) VALUES (?, ?, ?)", ["زینب", 27, "اسلام_آباد"]);

        متغیر سب = انتظار db.سوال("SELECT * FROM جانچ_جدول ORDER BY id");
        جانچ("4 قطاریں داخل", لمبائی(سب) == 4);
        جانچ("پہلا نام صحیح", سب[0]["نام"] == "احمد");
        جانچ("آخری نام صحیح", سب[3]["نام"] == "زینب");

        // ─── SELECT + WHERE ───────────────────────────
        لکھو("\n─── SELECT + WHERE ───");
        متغیر کراچی = انتظار db.سوال("SELECT * FROM جانچ_جدول WHERE شہر = ?", ["کراچی"]);
        جانچ("WHERE فلٹر — 2 نتائج", لمبائی(کراچی) == 2);

        متغیر بالغ = انتظار db.سوال("SELECT * FROM جانچ_جدول WHERE عمر > ?", [25]);
        جانچ("عمر > 25 — 2 نتائج", لمبائی(بالغ) == 2);

        // ─── UPDATE ───────────────────────────────────
        لکھو("\n─── UPDATE ───");
        انتظار db.چلائیں("UPDATE جانچ_جدول SET عمر = ? WHERE نام = ?", [26, "احمد"]);
        متغیر تازہ = انتظار db.سوال("SELECT عمر FROM جانچ_جدول WHERE نام = ?", ["احمد"]);
        جانچ("UPDATE — عمر تازہ ہوئی", تازہ[0]["عمر"] == 26);

        // ─── DELETE ───────────────────────────────────
        لکھو("\n─── DELETE ───");
        انتظار db.چلائیں("DELETE FROM جانچ_جدول WHERE نام = ?", ["علی"]);
        متغیر بعد_حذف = انتظار db.سوال("SELECT COUNT(*) AS تعداد FROM جانچ_جدول");
        جانچ("DELETE — 3 قطاریں باقی", بعد_حذف[0]["تعداد"] == 3);

        // ─── Aggregate ────────────────────────────────
        لکھو("\n─── Aggregate ───");
        متغیر اعداد = انتظار db.سوال("SELECT AVG(عمر) AS اوسط, MAX(عمر) AS زیادہ, MIN(عمر) AS کم FROM جانچ_جدول");
        جانچ("AVG صحیح", اعداد[0]["اوسط"] > 0);
        جانچ("MAX صحیح", اعداد[0]["زیادہ"] >= 30);
        جانچ("MIN صحیح", اعداد[0]["کم"] <= 30);

        // ─── Transaction COMMIT ───────────────────────
        لکھو("\n─── Transaction ───");
        انتظار db.لین_دین_شروع();
        انتظار db.چلائیں("INSERT INTO جانچ_جدول (نام, عمر, شہر) VALUES (?, ?, ?)", ["عمر", 35, "پشاور"]);
        انتظار db.کمٹ();
        متغیر بعد_commit = انتظار db.سوال("SELECT COUNT(*) AS تعداد FROM جانچ_جدول");
        جانچ("COMMIT — قطار شامل ہوئی", بعد_commit[0]["تعداد"] == 4);

        // ─── Transaction ROLLBACK ─────────────────────
        انتظار db.لین_دین_شروع();
        انتظار db.چلائیں("INSERT INTO جانچ_جدول (نام, عمر, شہر) VALUES (?, ?, ?)", ["عارضی", 99, "نامعلوم"]);
        انتظار db.واپسی();
        متغیر بعد_rollback = انتظار db.سوال("SELECT COUNT(*) AS تعداد FROM جانچ_جدول");
        جانچ("ROLLBACK — قطار واپس", بعد_rollback[0]["تعداد"] == 4);

        // ─── صفائی ────────────────────────────────────
        انتظار db.چلائیں("DROP TABLE IF EXISTS جانچ_جدول");
        انتظار db.چلائیں("DROP DATABASE IF EXISTS urdu_mysql_test");
        انتظار db.منقطع();
        جانچ("منقطع ہوئے", db._connected == جھوٹ);

    } پکڑو (غ) {
        لکھو(`\n  ✗ غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
        کوشش { انتظار db.منقطع(); } پکڑو (غ2) {}
    }

    لکھو(`\n══════════════════════════════════════`);
    لکھو(`  مائی_ایس_کیو_ایل — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════`);
}

انتظار مرکز();
