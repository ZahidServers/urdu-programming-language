// ══════════════════════════════════════════════════════
// Django مکمل جانچ — Views, URLs, JSON, TestClient
// ══════════════════════════════════════════════════════

درآمد { ڈجانگو, ڈجانگو_آزمائش,
         ڈجانگو_جواب, ڈجانگو_جیسن, ڈجانگو_رجوع } سے "اردو/ویب";
درآمد "json";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// ══════════════════════════════════════════════════════
// Views
// ══════════════════════════════════════════════════════

فنکشن نظارہ_جڑ(req) {
    واپس ڈجانگو_جیسن({ "پیغام": "خوش آمدید Django", "زبان": "اردو" });
}

فنکشن نظارہ_سلام(req, naam) {
    واپس ڈجانگو_جیسن({ "پیغام": `السلام ${naam}` });
}

فنکشن نظارہ_اشیاء(req) {
    اگر (req.method == "GET") {
        واپس ڈجانگو_جیسن([{ "id": 1, "عنوان": "آگ کا دریا" }, { "id": 2, "عنوان": "گلستان" }]);
    }
    متغیر باڈی = json.loads(req.body.decode("utf-8"));
    واپس ڈجانگو_جیسن({ "id": 10, "عنوان": باڈی["عنوان"] }, 201);
}

فنکشن نظارہ_صارف(req, sid) {
    اگر (req.method == "GET") {
        واپس ڈجانگو_جیسن({ "id": sid, "نام": "نمو��ہ صارف" });
    }
    اگر (req.method == "PUT") {
        واپس ڈجانگو_جیسن({ "id": sid, "حالت": "تازہ" });
    }
    اگر (req.method == "DELETE") {
        واپس ڈجانگو_جیسن({ "پیغام": `صارف ${sid} حذف` });
    }
    واپس ڈجانگو_جواب("", 405);
}

فنکشن نظارہ_متن(req) {
    واپس ڈجانگو_جواب("سادہ متن", 200, "text/plain; charset=utf-8");
}

فنکشن نظارہ_آگے(req) {
    واپس ڈجانگو_رجوع("/");
}

// ══════════════════════════════════════════════════════
// Django ترتیب + URLs
// ══════════════════════════════════════════════════════
متغیر dj = نیا ڈجانگو({ "ڈیٹا_بیس": ":memory:", "ڈیبگ": سچ });
dj.ترتیب_دیں();

dj.راستہ("", نظارہ_جڑ, { "نام": "جڑ" });
dj.راستہ("salam/<str:naam>/", نظارہ_سلام, { "نام": "سلام" });
dj.راستہ("ashiya/", نظارہ_اشیاء, { "نام": "اشیاء" });
dj.راستہ("sarif/<int:sid>/", نظارہ_صارف, { "نام": "صارف" });
dj.راستہ("matn/", نظارہ_متن, { "نام": "متن" });
dj.راستہ("forward/", نظارہ_آگے, { "نام": "آگے" });

// ══════════════════════════════════════════════════════
// جانچ
// ══════════════════════════════════════════════════════
فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════╗");
    لکھو("║  Django مکمل جانچ رپورٹ              ║");
    لکھو("╚══════════════════════════════════════╝");

    متغیر کلائنٹ = نیا ڈجانگو_آزمائش();

    // GET /
    لکھو("\n─── GET راستے ───");
    متغیر ج1 = کلائنٹ.حاصل("/");
    جانچ("GET / — 200", ج1["رمز"] == 200);
    جانچ("GET / — پیغام", ج1["json"]["پیغام"] == "خوش آمدید Django");
    جانچ("GET / — زبان", ج1["json"]["زبان"] == "اردو");

    // GET /salam/ahmed/
    متغیر ج2 = کلائنٹ.حاصل("/salam/ahmed/");
    جانچ("GET /salam/<naam>/ — 200", ج2["رمز"] == 200);
    جانچ("GET /salam/<naam>/ — پیغام", ج2["json"]["پیغام"] == "السلام ahmed");

    // GET /ashiya/
    متغیر ج3 = کلائنٹ.حاصل("/ashiya/");
    جانچ("GET /ashiya/ — 200", ج3["رمز"] == 200);
    جانچ("GET /ashiya/ — 2 اندراج", لمبائی(ج3["json"]) == 2);
    جانچ("GET /ashiya/ — پہلا", ج3["json"][0]["عنوان"] == "آگ کا دریا");

    // POST /ashiya/
    لکھو("\n─── POST / GET by id ───");
    متغیر ج4 = کلائنٹ.بھیجیں("/ashiya/", { "json": { "عنوان": "نئی کتاب" } });
    جانچ("POST /ashiya/ — 201", ج4["رمز"] == 201);
    جانچ("POST /ashiya/ — عنوان", ج4["json"]["عنوان"] == "نئی کتاب");

    // GET /sarif/42/
    متغیر ج5 = کلائنٹ.حاصل("/sarif/42/");
    جانچ("GET /sarif/<id>/ — 200", ج5["رمز"] == 200);
    جانچ("GET /sarif/<id>/ — id=42", ج5["json"]["id"] == 42);

    // Custom text
    لکھو("\n─── Custom Response + Redirect + 404 ───");
    متغیر ج6 = کلائنٹ.حاصل("/matn/");
    جانچ("text/plain — 200", ج6["رمز"] == 200);
    جانچ("text/plain — مواد", ج6["مواد"] == "سادہ متن");

    // Redirect
    متغیر ج7 = کلائنٹ.حاصل("/forward/");
    جانچ("Redirect — 302", ج7["رمز"] == 302);

    // 404
    متغیر ج8 = کلائنٹ.حاصل("/nahi_mila/");
    جانچ("404 Not Found", ج8["رمز"] == 404);

    لکھو(`\n══════════════════════════════════════`);
    لکھو(`  Django — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════`);
}

مرکز();
