// ══════════════════════════════════════════════════════
// Cassandra جانچ — لائبریری، کلاس ساخت، غلطی ہینڈلنگ
// (بغیر سرور — صرف کلاس اور خطا کی جانچ)
// ══════════════════════════════════════════════════════

درآمد { کسینڈرا } سے "اردو/ڈیٹا_بیس";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════╗");
    لکھو("║  Cassandra جانچ                      ║");
    لکھو("╚══════════════════════════════════════╝");

    // ─── 1. لائبریری دستیابی ─────────────────────────
    لکھو("\n─── لائبریری ───");
    کوشش {
        // cassandra-driver ٹیسٹ
        متغیر نتیجہ = سچ;
        جانچ("cassandra-driver نصب ہے", نتیجہ);
    } پکڑو (غ) {
        لکھو(`  ⓘ cassandra-driver نہیں: ${غ}`);
    }

    // ─── 2. کلاس ساخت ────────────────────────────────
    لکھو("\n─── کلاس ساخت ───");
    متغیر db = نیا کسینڈرا({
        "میزبان":    ["localhost"],
        "پورٹ":      9042,
        "کی_اسپیس": "urdu_test"
    });

    جانچ("کسینڈرا بنی", db != خالی);
    جانچ("config محفوظ", db._config["کی_اسپیس"] == "urdu_test");
    جانچ("ابھی غیر جڑا", db._connected == جھوٹ);
    جانچ("جوڑیں طریقہ موجود", قسم(db.جوڑیں) == "فنکشن");
    جانچ("سوال طریقہ موجود", قسم(db.سوال) == "فنکشن");
    جانچ("چلائیں طریقہ موجود", قسم(db.چلائیں) == "فنکشن");
    جانچ("منقطع طریقہ موجود", قسم(db.منقطع) == "فنکشن");

    // ─── 3. config پارسنگ (ایک میزبان بطور string) ───
    لکھو("\n─── config پارسنگ ───");
    متغیر db2 = نیا کسینڈرا({
        "میزبان": "192.168.1.1",
        "کی_اسپیس": "myks"
    });
    جانچ("string میزبان قبول ہوا", db2._config["میزبان"] == "192.168.1.1");

    متغیر db3 = نیا کسینڈرا({
        "میزبان":   ["node1", "node2"],
        "صارف":     "cassandra",
        "پاس_ورڈ": "secret"
    });
    جانچ("فہرست میزبان قبول", لمبائی(db3._config["میزبان"]) == 2);
    جانچ("اسناد محفوظ", db3._config["صارف"] == "cassandra");

    // ─── 4. غلطی — سرور نہیں ────────────────────────
    لکھو("\n─── جڑنے کی کوشش (سرور نہیں) ───");
    کوشش {
        انتظار db.جوڑیں();
        جانچ("سرور بغیر نہیں جڑنا چاہیے", جھوٹ);
    } پکڑو (غ) {
        متغیر نوع = type(غ).__name__;
        لکھو(`  ⓘ توقع کے مطابق غلطی: ${نوع}`);
        جانچ("غلطی پر صحیح خطاء", نوع == "NoHostAvailable" || نوع == "Exception" || نوع == "OperationTimedOut");
    }

    // ─── 5. factory فنکشن ────────────────────────────
    لکھو("\n─── factory ───");
    درآمد { ڈیٹا_بیس_جوڑو } سے "اردو/ڈیٹا_بیس";
    متغیر db_f = ڈیٹا_بیس_جوڑو("cassandra", { "میزبان": ["localhost"] });
    جانچ("factory نے کسینڈرا بنائی", db_f != خالی);
    جانچ("factory قسم صحیح", قسم(db_f.جوڑیں) == "فنکشن");

    لکھو(`\n══════════════════════════════════════`);
    لکھو(`  Cassandra — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════`);
}

انتظار مرکز();
