// ══════════════════════════════════════════════════════════════
// Firebase Admin SDK جانچ — Auth | RTDB | Firestore
// (سروس اکاؤنٹ کلید — مکمل ایڈمن رسائی)
// ══════════════════════════════════════════════════════════════

درآمد { فائر_بیس } سے "اردو/ڈیٹا_بیس";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// Admin SDK config — سروس اکاؤنٹ کلید
متغیر config = {
    "اسناد":      "examples/test-59571-firebase-adminsdk-fbsvc-7612663727.json",
    "منصوبہ":     "test-59571",
    "databaseURL": "https://test-59571-default-rtdb.firebaseio.com"
};

// Web config — ID ٹوکن حاصل کرنے کے لیے
متغیر web_config = {
    "apiKey":      "AIzaSyCk53jm5Fxg9O7EPAgt2Ab-jOuS8gSYpck",
    "projectId":   "test-59571",
    "databaseURL": "https://test-59571-default-rtdb.firebaseio.com"
};

غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════════════╗");
    لکھو("║  Firebase Admin SDK مکمل جانچ               ║");
    لکھو("╚══════════════════════════════════════════════╝");

    // ─── Admin SDK جڑنا ─────────────────────────────────────
    لکھو("\n─── Admin SDK جڑنا ───");
    متغیر ایڈمن = نیا فائر_بیس(config);
    کوشش {
        انتظار ایڈمن.جوڑیں();
        جانچ("Admin SDK جڑا", ایڈمن._connected == سچ);
    } پکڑو (غ) {
        لکھو(`  ✗ جڑنے کی غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
        واپس;
    }

    // ─── 1. Auth — صارف بنائیں ──────────────────────────────
    لکھو("\n─── Auth — صارف بنائیں ───");
    متغیر جانچ_ای_میل = "admin_sdk_test@example.com";
    متغیر جانچ_پاس   = "AdminTest2024!";
    متغیر نئے_صارف_uid = "";

    کوشش {
        // پہلے پرانا ٹیسٹ صارف صاف کریں (اگر موجود ہو)
        کوشش {
            متغیر پرانا = انتظار ایڈمن.ایڈمن_صارف_ای_میل(جانچ_ای_میل);
            انتظار ایڈمن.ایڈمن_صارف_حذف(پرانا["uid"]);
        } پکڑو (غ2) {}

        متغیر نئے_صارف = انتظار ایڈمن.ایڈمن_صارف_بنائیں(
            جانچ_ای_میل, جانچ_پاس, "اردو جانچ"
        );
        نئے_صارف_uid = نئے_صارف["uid"];
        جانچ("صارف بنا", لمبائی(نئے_صارف_uid) > 0);
        جانچ("ای_میل درست", نئے_صارف["email"] == جانچ_ای_میل);
        لکھو(`  ⓘ UID: ${نئے_صارف_uid}`);
    } پکڑو (غ) {
        لکھو(`  ✗ صارف بنانے کی غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 2. Auth — صارف حاصل کریں ──────────────────────────
    لکھو("\n─── Auth — صارف حاصل کریں ───");
    اگر (لمبائی(نئے_صارف_uid) > 0) {
        کوشش {
            متغیر صارف_UID = انتظار ایڈمن.ایڈمن_صارف_حاصل(نئے_صارف_uid);
            جانچ("UID سے صارف", صارف_UID["uid"] == نئے_صارف_uid);
            جانچ("displayName درست", صارف_UID["displayName"] == "اردو جانچ");

            متغیر صارف_ای_میل = انتظار ایڈمن.ایڈمن_صارف_ای_میل(جانچ_ای_میل);
            جانچ("ای_میل سے صارف", صارف_ای_میل["email"] == جانچ_ای_میل);
        } پکڑو (غ) {
            لکھو(`  ✗ صارف حاصل غلطی: ${غ}`);
            ن["ناکام"] = ن["ناکام"] + 1;
        }
    }

    // ─── 3. Auth — صارف تازہ کریں ───────────────────────────
    لکھو("\n─── Auth — صارف تازہ کریں ───");
    اگر (لمبائی(نئے_صارف_uid) > 0) {
        کوشش {
            انتظار ایڈمن.ایڈمن_دعوے_مقرر(نئے_صارف_uid, { "role": "tester", "level": 1 });
            جانچ("custom claims مقرر", سچ);

            متغیر custom_token = انتظار ایڈمن.ایڈمن_کسٹم_ٹوکن(نئے_صارف_uid);
            جانچ("custom token بنا", لمبائی(custom_token) > 50);
            لکھو(`  ⓘ token (پہلے 30): ${custom_token.slice(0, 30)}...`);
        } پکڑو (غ) {
            لکھو(`  ✗ تازہ کاری غلطی: ${غ}`);
            ن["ناکام"] = ن["ناکام"] + 1;
        }
    }

    // ─── 4. Auth — ID ٹوکن تصدیق ────────────────────────────
    لکھو("\n─── Auth — ID ٹوکن تصدیق ───");
    کوشش {
        // Web mode سے sign in کریں تاکہ ID token ملے
        متغیر web_db = نیا فائر_بیس(web_config);
        انتظار web_db.جوڑیں();
        انتظار web_db.ای_میل_داخل(جانچ_ای_میل, جانچ_پاس);
        متغیر id_token = web_db._id_token;
        جانچ("ID token حاصل ہوا", لمبائی(id_token) > 50);

        // Admin SDK سے verify کریں
        متغیر decoded = انتظار ایڈمن.ایڈمن_ٹوکن_تصدیق(id_token);
        جانچ("token تصدیق کامیاب", decoded["uid"] == نئے_صارف_uid);
        جانچ("token email درست", decoded["email"] == جانچ_ای_میل);
        لکھو(`  ⓘ verified UID: ${decoded["uid"]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ token تصدیق غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 5. Auth — صارفین فہرست ──────────────────────────────
    لکھو("\n─── Auth — صارفین فہرست ───");
    کوشش {
        متغیر فہرست = انتظار ایڈمن.ایڈمن_صارفین_فہرست(20);
        جانچ("فہرست خالی نہیں", لمبائی(فہرست) > 0);
        لکھو(`  ⓘ کل صارفین (پہلے 20): ${لمبائی(فہرست)}`);
    } پکڑو (غ) {
        لکھو(`  ✗ فہرست غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 6. Admin Realtime Database ──────────────────────────
    لکھو("\n─── Admin RTDB ───");
    کوشش {
        // لکھنا
        انتظار ایڈمن.ریئل_لکھو("admin_test/جانچ", {
            "عنوان": "اردو ایڈمن جانچ",
            "عدد":   42,
            "فہرست": [1, 2, 3]
        });
        جانچ("RTDB لکھا", سچ);

        // پڑھنا
        متغیر پڑھا = انتظار ایڈمن.ریئل_پڑھو("admin_test/جانچ");
        جانچ("RTDB پڑھا — عنوان", پڑھا["عنوان"] == "اردو ایڈمن جانچ");
        جانچ("RTDB پڑھا — عدد", پڑھا["عدد"] == 42);

        // تازہ کاری
        انتظار ایڈمن.ریئل_تازہ("admin_test/جانچ", { "عدد": 100, "تازہ": سچ });
        متغیر تازہ = انتظار ایڈمن.ریئل_پڑھو("admin_test/جانچ");
        جانچ("RTDB تازہ — عدد", تازہ["عدد"] == 100);
        جانچ("RTDB تازہ — نیا خانہ", تازہ["تازہ"] == سچ);

        // push
        متغیر push_key = انتظار ایڈمن.ریئل_شامل("admin_test/لاگ", { "واقعہ": "جانچ", "وقت": "ابھی" });
        جانچ("RTDB push key", لمبائی(متن(push_key)) > 0);

        // حذف
        انتظار ایڈمن.ریئل_حذف("admin_test/جانچ");
        متغیر حذف_چیک = انتظار ایڈمن.ریئل_پڑھو("admin_test/جانچ");
        جانچ("RTDB حذف کام کیا", حذف_چیک == خالی);

        // صفائی
        انتظار ایڈمن.ریئل_حذف("admin_test");
    } پکڑو (غ) {
        لکھو(`  ✗ RTDB غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 7. Admin Firestore ───────────────────────────────────
    لکھو("\n─── Admin Firestore ───");
    کوشش {
        متغیر مجموعہ = ایڈمن.مجموعہ("admin_janche");

        // اضافہ
        متغیر doc_id = انتظار مجموعہ.اضافہ({
            "عنوان":  "اردو ایڈمن دستاویز",
            "عدد":    99,
            "فعال":   سچ
        });
        جانچ("Firestore اضافہ", لمبائی(doc_id) > 0);
        لکھو(`  ⓘ doc: ${doc_id}`);

        // حاصل
        متغیر دستاویز = انتظار مجموعہ.حاصل(doc_id);
        جانچ("Firestore حاصل — عنوان", دستاویز["عنوان"] == "اردو ایڈمن دستاویز");
        جانچ("Firestore حاصل — عدد", دستاویز["عدد"] == 99);

        // مقرر (update)
        انتظار مجموعہ.مقرر(doc_id, { "عنوان": "تازہ دستاویز", "عدد": 200, "فعال": جھوٹ });
        متغیر تازہ_doc = انتظار مجموعہ.حاصل(doc_id);
        جانچ("Firestore مقرر — عدد تازہ", تازہ_doc["عدد"] == 200);

        // سبھی
        متغیر سبھی = انتظار مجموعہ.سبھی();
        جانچ("Firestore سبھی — کم از کم 1", لمبائی(سبھی) >= 1);

        // حذف
        انتظار مجموعہ.حذف(doc_id);
        متغیر حذف_doc = انتظار مجموعہ.حاصل(doc_id);
        جانچ("Firestore حذف کام کیا", حذف_doc == خالی);

    } پکڑو (غ) {
        لکھو(`  ✗ Firestore غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 8. صفائی — جانچ صارف حذف ───────────────────────────
    لکھو("\n─── صفائی ───");
    اگر (لمبائی(نئے_صارف_uid) > 0) {
        کوشش {
            انتظار ایڈمن.ایڈمن_صارف_حذف(نئے_صارف_uid);
            جانچ("جانچ صارف حذف", سچ);
        } پکڑو (غ) {
            لکھو(`  ⓘ صارف حذف: ${غ}`);
        }
    }
    انتظار ایڈمن.منقطع();

    لکھو(`\n══════════════════════════════════════════════`);
    لکھو(`  Firebase Admin — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════════════`);
}

انتظار مرکز();
