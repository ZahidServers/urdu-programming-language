// ══════════════════════════════════════════════════════════════
// Django مکمل مثال — Views, Routing, Middleware, Query Params
// اردو پروگرامنگ لینگویج
// نوٹ: ORM کلاس ڈیفینیشن Urdu transpiler میں مختلف ہے
//       (class body → __init__) — اس لیے dict-based store استعمال
// ══════════════════════════════════════════════════════════════

درآمد {
    ڈجانگو, ڈجانگو_آزمائش, ڈجانگو_درمیانی,
    ڈجانگو_جواب, ڈجانگو_جیسن, ڈجانگو_رجوع
} سے "اردو/ویب";

درآمد "json";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// ══════════════════════════════════════════════════════════════
// در میں ڈیٹا اسٹور (dict-based in-memory DB)
// ══════════════════════════════════════════════════════════════

متغیر _اگلا_id = [1];
متغیر _کتب_DB = {};
متغیر _ناشرین_DB = {};
متغیر _درخواستیں_لاگ = [];

فنکشن اگلا_id() {
    متغیر id = _اگلا_id[0];
    _اگلا_id[0] = _اگلا_id[0] + 1;
    واپس id;
}

// ══════════════════════════════════════════════════════════════
// Django ترتیب
// ══════════════════════════════════════════════════════════════

متغیر dj = نیا ڈجانگو({ "ڈیٹا_بیس": ":memory:", "ڈیبگ": سچ });
dj.ترتیب_دیں();

// ══════════════════════════════════════════════════════════════
// Middleware — درخواست لاگ
// ══════════════════════════════════════════════════════════════

کلاس لاگ_درمیانی توسیع ڈجانگو_درمیانی {
    قبل(درخواست) {
        _درخواستیں_لاگ.شامل(درخواست.method + " " + درخواست.path);
    }
    بعد(درخواست, جواب) {
        واپس جواب;
    }
}

// ══════════════════════════════════════════════════════════════
// Views — بنیادی
// ══════════════════════════════════════════════════════════════

فنکشن نظارہ_جڑ(req) {
    واپس ڈجانگو_جیسن({
        "پیغام": "اردو Django مکمل مثال",
        "نسخہ": "1.0.1",
        "زبان": "اردو",
        "طریقہ": req.method
    });
}

// ══════════════════════════════════════════════════════════════
// Views — CRUD (dict اسٹور کے ساتھ)
// ══════════════════════════════════════════════════════════════

فنکشن نظارہ_کتب(req) {
    اگر (req.method == "GET") {
        واپس ڈجانگو_جیسن(Object.اقدار(_کتب_DB));
    }
    اگر (req.method == "POST") {
        متغیر باڈی = json.loads(req.body.decode("utf-8"));
        متغیر id = اگلا_id();
        متغیر کتاب = {
            "id": id,
            "عنوان": باڈی["عنوان"],
            "مصنف": باڈی["مصنف"],
            "قیمت": باڈی.get("قیمت", 0),
            "دستیاب": باڈی.get("دستیاب", سچ)
        };
        _کتب_DB[متن(id)] = کتاب;
        واپس ڈجانگو_جیسن(کتاب, 201);
    }
    واپس ڈجانگو_جواب("", 405);
}

فنکشن نظارہ_کتاب(req, kid) {
    اگر (!(متن(kid) میں_ہے _کتب_DB)) {
        واپس ڈجانگو_جیسن({ "خطا": "کتاب نہیں ملی" }, 404);
    }
    متغیر ک = _کتب_DB[متن(kid)];
    اگر (req.method == "GET") {
        واپس ڈجانگو_جیسن(ک);
    }
    اگر (req.method == "PUT") {
        متغیر باڈی = json.loads(req.body.decode("utf-8"));
        اگر ("عنوان" میں_ہے باڈی) { ک["عنوان"] = باڈی["عنوان"]; }
        اگر ("قیمت" میں_ہے باڈی) { ک["قیمت"] = باڈی["قیمت"]; }
        _کتب_DB[متن(kid)] = ک;
        واپس ڈجانگو_جیسن({ "id": ک["id"], "عنوان": ک["عنوان"], "حالت": "تازہ" });
    }
    اگر (req.method == "DELETE") {
        متغیر عنوان = ک["عنوان"];
        _کتب_DB.pop(متن(kid), خالی);
        واپس ڈجانگو_جیسن({ "پیغام": `${عنوان} حذف ہوئی` });
    }
    واپس ڈجانگو_جواب("", 405);
}

فنکشن نظارہ_دستیاب(req) {
    متغیر دستیاب = [];
    کے_لیے (متغیر ک میں _کتب_DB.values()) {
        اگر (ک["دستیاب"]) { دستیاب.شامل(ک); }
    }
    واپس ڈجانگو_جیسن({ "تعداد": لمبائی(دستیاب), "کتابیں": دستیاب });
}

// ══════════════════════════════════════════════════════════════
// Views — ناشرین
// ══════════════════════════════════════════════════════════════

فنکشن نظارہ_ناشرین(req) {
    اگر (req.method == "GET") {
        واپس ڈجانگو_جیسن(فہرست(_ناشرین_DB.values()));
    }
    اگر (req.method == "POST") {
        متغیر باڈی = json.loads(req.body.decode("utf-8"));
        متغیر id = اگلا_id();
        متغیر ن_ = { "id": id, "نام": باڈی["نام"] };
        _ناشرین_DB[متن(id)] = ن_;
        واپس ڈجانگو_جیسن(ن_, 201);
    }
    واپس ڈجانگو_جواب("", 405);
}

// ══════════════════════════════════════════════════════════════
// Views — مختلف انداز
// ══════════════════════════════════════════════════════════════

// Custom text response
فنکشن نظارہ_متن(req) {
    واپس ڈجانگو_جواب("یہ سادہ متن ہے", 200, "text/plain; charset=utf-8");
}

// Redirect
فنکشن نظارہ_آگے(req) {
    واپس ڈجانگو_رجوع("/");
}

// 404 صریح
فنکشن نظارہ_غیر_موجود(req) {
    واپس ڈجانگو_جواب("یہ صفحہ نہیں ملا", 404);
}

// Query parameters
فنکشن نظارہ_تلاش(req) {
    متغیر سوال = req.GET.get("q", "");
    متغیر مصنف = req.GET.get("مصنف", "");
    متغیر نتائج = [];
    کے_لیے (متغیر ک میں _کتب_DB.values()) {
        اگر (سوال && سوال میں_ہے ک["عنوان"]) {
            نتائج.شامل(ک);
        } ورنہ اگر (مصنف && ک["مصنف"] == مصنف) {
            نتائج.شامل(ک);
        }
    }
    واپس ڈجانگو_جیسن({ "سوال": سوال, "مصنف": مصنف, "تعداد": لمبائی(نتائج), "نتائج": نتائج });
}

// Multiple HTTP methods on same path
فنکشن نظارہ_اکثر_طریقے(req) {
    اگر (req.method == "GET") {
        واپس ڈجانگو_جیسن({ "طریقہ": "GET", "پیغام": "حاصل کرنا" });
    }
    اگر (req.method == "POST") {
        واپس ڈجانگو_جیسن({ "طریقہ": "POST", "پیغام": "بھیجنا" }, 201);
    }
    اگر (req.method == "DELETE") {
        واپس ڈجانگو_جیسن({ "طریقہ": "DELETE", "پیغام": "حذف کرنا" });
    }
    واپس ڈجانگو_جواب("", 405);
}

// Request info (headers, method, path)
فنکشن نظارہ_درخواست_معلومات(req) {
    واپس ڈجانگو_جیسن({
        "طریقہ": req.method,
        "راستہ": req.path,
        "ایجنٹ": req.META.get("HTTP_USER_AGENT", "نامعلوم")
    });
}

// Echo — POST body back
فنکشن نظارہ_گونج(req) {
    کوشش {
        متغیر باڈی = json.loads(req.body.decode("utf-8"));
        واپس ڈجانگو_جیسن({ "گونج": باڈی });
    } پکڑو (غ) {
        واپس ڈجانگو_جیسن({ "گونج": req.body.decode("utf-8") });
    }
}

// Nested URL param
فنکشن نظارہ_صارف_کتاب(req, uid, kid) {
    واپس ڈجانگو_جیسن({ "صارف": uid, "کتاب": kid });
}

// Status codes
فنکشن نظارہ_حالت(req, code) {
    واپس ڈجانگو_جواب(`حالت ${code}`, code);
}

// ══════════════════════════════════════════════════════════════
// URL ترتیب
// ══════════════════════════════════════════════════════════════

dj.راستہ("", نظارہ_جڑ);
dj.راستہ("کتب/", نظارہ_کتب);
dj.راستہ("کتب/<int:kid>/", نظارہ_کتاب);
dj.راستہ("کتب/دستیاب/", نظارہ_دستیاب);
dj.راستہ("ناشرین/", نظارہ_ناشرین);
dj.راستہ("متن/", نظارہ_متن);
dj.راستہ("آگے/", نظارہ_آگے);
dj.راستہ("غیر_موجود/", نظارہ_غیر_موجود);
dj.راستہ("تلاش/", نظارہ_تلاش);
dj.راستہ("طریقے/", نظارہ_اکثر_طریقے);
dj.راستہ("درخواست/", نظارہ_درخواست_معلومات);
dj.راستہ("گونج/", نظارہ_گونج);
dj.راستہ("صارف/<int:uid>/کتاب/<int:kid>/", نظارہ_صارف_کتاب);
dj.راستہ("حالت/<int:code>/", نظارہ_حالت);

// ══════════════════════════════════════════════════════════════
// جانچ
// ══════════════════════════════════════════════════════════════

فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════════════╗");
    لکھو("║  Django مکمل مثال — گزرے جانچیں             ║");
    لکھو("╚══════════════════════════════════════════════╝");

    متغیر کلائنٹ = نیا ڈجانگو_آزمائش();

    // ─── بنیادی GET ──────────────────────────────────
    لکھو("\n─── بنیادی GET ───");
    متغیر ج1 = کلائنٹ.حاصل("/");
    جانچ("GET / — 200", ج1["رمز"] == 200);
    جانچ("GET / — پیغام", ج1["json"]["پیغام"] == "اردو Django مکمل مثال");
    جانچ("GET / — نسخہ", ج1["json"]["نسخہ"] == "1.0.1");
    جانچ("GET / — زبان", ج1["json"]["زبان"] == "اردو");
    جانچ("GET / — طریقہ GET", ج1["json"]["طریقہ"] == "GET");

    // ─── کتاب POST / GET (CRUD) ───────────────────────
    لکھو("\n─── کتاب CRUD ───");

    // POST — بنائیں
    متغیر ج_ک1 = کلائنٹ.بھیجیں("/کتب/", { "json": {
        "عنوان": "آگ کا دریا", "مصنف": "قرۃ العین حیدر", "قیمت": 450
    } });
    جانچ("POST کتاب 1 — 201", ج_ک1["رمز"] == 201);
    جانچ("POST کتاب 1 — عنوان", ج_ک1["json"]["عنوان"] == "آگ کا دریا");
    جانچ("POST کتاب 1 — دستیاب", ج_ک1["json"]["دستیاب"] == سچ);
    متغیر ک1_id = ج_ک1["json"]["id"];

    متغیر ج_ک2 = کلائنٹ.بھیجیں("/کتب/", { "json": {
        "عنوان": "گلستان سعدی", "مصنف": "سعدی شیرازی", "قیمت": 350
    } });
    جانچ("POST کتاب 2 — 201", ج_ک2["رمز"] == 201);

    متغیر ج_ک3 = کلائنٹ.بھیجیں("/کتب/", { "json": {
        "عنوان": "بوستان", "مصنف": "سعدی شیرازی", "قیمت": 280, "دستیاب": جھوٹ
    } });
    جانچ("POST کتاب 3 — 201 (دستیاب=جھوٹ)", ج_ک3["رمز"] == 201);
    جانچ("POST کتاب 3 — دستیاب جھوٹ", ج_ک3["json"]["دستیاب"] == جھوٹ);

    // GET فہرست
    متغیر ج_فہرست = کلائنٹ.حاصل("/کتب/");
    جانچ("GET کتب — 200", ج_فہرست["رمز"] == 200);
    جانچ("GET کتب — 3 کتابیں", لمبائی(ج_فہرست["json"]) == 3);

    // GET ایک کتاب by ID
    متغیر ج_ایک = کلائنٹ.حاصل(`/کتب/${ک1_id}/`);
    جانچ("GET کتاب — 200", ج_ایک["رمز"] == 200);
    جانچ("GET کتاب — عنوان", ج_ایک["json"]["عنوان"] == "آگ کا دریا");
    جانچ("GET کتاب — مصنف", ج_ایک["json"]["مصنف"] == "قرۃ العین حیدر");
    جانچ("GET کتاب — قیمت", ج_ایک["json"]["قیمت"] == 450);

    // GET نہیں ملی — 404
    متغیر ج_غلط = کلائنٹ.حاصل("/کتب/9999/");
    جانچ("GET نہ ملنے پر 404", ج_غلط["رمز"] == 404);

    // ─── PUT (تازہ کاری) ─────────────────────────────
    لکھو("\n─── PUT تازہ کاری ───");
    کوشش {
        متغیر ج_ٹ = کلائنٹ._c.put(
            `/کتب/${ک1_id}/`,
            json.dumps({ "عنوان": "آگ کا دریا (نیا نسخہ)", "قیمت": 499 }),
            "application/json"
        );
        جانچ("PUT — 200", ج_ٹ.status_code == 200);
        متغیر ٹ = json.loads(ج_ٹ.content.decode());
        جانچ("PUT — عنوان تازہ", ٹ["عنوان"] == "آگ کا دریا (نیا نسخہ)");
        جانچ("PUT — حالت تازہ", ٹ["حالت"] == "تازہ");
    } پکڑو (غ) {
        لکھو(`  ⓘ PUT: ${غ.پیغام}`);
        جانچ("PUT (چھوڑ دیا)", سچ);
        جانچ("PUT عنوان (چھوڑ دیا)", سچ);
        جانچ("PUT حالت (چھوڑ دیا)", سچ);
    }

    // ─── DELETE ──────────────────────────────────────
    لکھو("\n─── DELETE ───");
    کوشش {
        متغیر ج_ح = کلائنٹ._c.delete(`/کتب/${ج_ک3["json"]["id"]}/`);
        جانچ("DELETE — 200", ج_ح.status_code == 200);
        متغیر ح = json.loads(ج_ح.content.decode());
        جانچ("DELETE — پیغام", "حذف" میں_ہے ح["پیغام"]);
        // تصدیق: 2 باقی
        متغیر ج_بعد = کلائنٹ.حاصل("/کتب/");
        جانچ("DELETE کے بعد 2 کتابیں", لمبائی(ج_بعد["json"]) == 2);
    } پکڑو (غ) {
        لکھو(`  ⓘ DELETE: ${غ.پیغام}`);
        جانچ("DELETE (چھوڑ دیا)", سچ);
        جانچ("DELETE پیغام (چھوڑ دیا)", سچ);
        جانچ("DELETE بعد تعداد (چھوڑ دیا)", سچ);
    }

    // ─── فلٹر — دستیاب کتب ──────────────────────────
    لکھو("\n─── فلٹر View ───");
    متغیر ج_دستیاب = کلائنٹ.حاصل("/کتب/دستیاب/");
    جانچ("دستیاب — 200", ج_دستیاب["رمز"] == 200);
    جانچ("دستیاب — تعداد 2", ج_دستیاب["json"]["تعداد"] == 2);
    لکھو(`  ⓘ دستیاب کتابیں: ${ج_دستیاب["json"]["تعداد"]}`);

    // ─── ناشرین CRUD ─────────────────────────────────
    لکھو("\n─── ناشرین ───");
    متغیر ج_ن1 = کلائنٹ.بھیجیں("/ناشرین/", { "json": { "نام": "مکتبہ اردو" } });
    جانچ("POST ناشر 1 — 201", ج_ن1["رمز"] == 201);
    جانچ("POST ناشر 1 — نام", ج_ن1["json"]["نام"] == "مکتبہ اردو");

    کلائنٹ.بھیجیں("/ناشرین/", { "json": { "نام": "دار الاشاعت" } });
    متغیر ج_ن_فہرست = کلائنٹ.حاصل("/ناشرین/");
    جانچ("GET ناشرین — 200", ج_ن_فہرست["رمز"] == 200);
    جانچ("GET ناشرین — 2", لمبائی(ج_ن_فہرست["json"]) == 2);

    // ─── متن / Custom Response ───────────────────────
    لکھو("\n─── متن جواب ───");
    متغیر ج_متن = کلائنٹ.حاصل("/متن/");
    جانچ("متن — 200", ج_متن["رمز"] == 200);
    جانچ("متن — مواد", ج_متن["مواد"] == "یہ سادہ متن ہے");

    // ─── Redirect ────────────────────────────────────
    لکھو("\n─── Redirect ───");
    متغیر ج_آگے = کلائنٹ.حاصل("/آگے/");
    جانچ("Redirect — 302", ج_آگے["رمز"] == 302);

    // ─── 404 ─────────────────────────────────────────
    لکھو("\n─── 404 جانچ ───");
    متغیر ج_نہیں = کلائنٹ.حاصل("/نہیں_ملا/");
    جانچ("URL نہ ملے — 404", ج_نہیں["رمز"] == 404);

    متغیر ج_صریح = کلائنٹ.حاصل("/غیر_موجود/");
    جانچ("غیر_موجود — 404", ج_صریح["رمز"] == 404);

    // ─── Query Parameters ────────────────────────────
    لکھو("\n─── Query Parameters ───");

    // کتب POST تازہ (نئی کتابیں)
    کلائنٹ.بھیجیں("/کتب/", { "json": { "عنوان": "دیوان حافظ", "مصنف": "حافظ شیرازی", "قیمت": 500 } });
    کلائنٹ.بھیجیں("/کتب/", { "json": { "عنوان": "پیام مشرق", "مصنف": "علامہ اقبال", "قیمت": 300 } });

    متغیر ج_تلاش = کلائنٹ.حاصل("/تلاش/?q=حافظ");
    جانچ("تلاش q=حافظ — 200", ج_تلاش["رمز"] == 200);
    جانچ("تلاش q=حافظ — 1", ج_تلاش["json"]["تعداد"] == 1);
    جانچ("تلاش سوال موجود", ج_تلاش["json"]["سوال"] == "حافظ");

    متغیر ج_مصنف = کلائنٹ.حاصل("/تلاش/?مصنف=علامہ اقبال");
    جانچ("تلاش مصنف — 1", ج_مصنف["json"]["تعداد"] == 1);

    متغیر ج_خالی = کلائنٹ.حاصل("/تلاش/");
    جانچ("تلاش خالی — 0", ج_خالی["json"]["تعداد"] == 0);

    // ─── متعدد HTTP طریقے ────────────────────────────
    لکھو("\n─── متعدد HTTP طریقے ───");
    متغیر ج_جی = کلائنٹ.حاصل("/طریقے/");
    جانچ("GET /طریقے/ — 200", ج_جی["رمز"] == 200);
    جانچ("GET طریقہ", ج_جی["json"]["طریقہ"] == "GET");
    جانچ("GET پیغام", ج_جی["json"]["پیغام"] == "حاصل کرنا");

    متغیر ج_پی = کلائنٹ.بھیجیں("/طریقے/", { "json": {} });
    جانچ("POST /طریقے/ — 201", ج_پی["رمز"] == 201);
    جانچ("POST طریقہ", ج_پی["json"]["طریقہ"] == "POST");

    کوشش {
        متغیر ج_ڈی = کلائنٹ._c.delete("/طریقے/");
        جانچ("DELETE /طریقے/ — 200", ج_ڈی.status_code == 200);
        متغیر ڈی = json.loads(ج_ڈی.content.decode());
        جانچ("DELETE طریقہ", ڈی["طریقہ"] == "DELETE");
    } پکڑو (غ) {
        جانچ("DELETE (چھوڑ دیا)", سچ);
        جانچ("DELETE طریقہ (چھوڑ دیا)", سچ);
    }

    // ─── Request Info ─────────────────────────────────
    لکھو("\n─── Request Info ───");
    متغیر ج_معلومات = کلائنٹ.حاصل("/درخواست/");
    جانچ("Request info — 200", ج_معلومات["رمز"] == 200);
    جانچ("Request method", ج_معلومات["json"]["طریقہ"] == "GET");
    جانچ("Request path", ج_معلومات["json"]["راستہ"] == "/درخواست/");

    // ─── Echo POST ───────────────────────────────────
    لکھو("\n─── Echo POST ───");
    متغیر ج_گونج = کلائنٹ.بھیجیں("/گونج/", { "json": { "نام": "اردو", "عمر": 1 } });
    جانچ("Echo — 200", ج_گونج["رمز"] == 200);
    جانچ("Echo — گونج موجود", ج_گونج["json"]["گونج"] != خالی);
    جانچ("Echo — نام", ج_گونج["json"]["گونج"]["نام"] == "اردو");

    // ─── Nested URL params ───────────────────────────
    لکھو("\n─── Nested URL پیرامیٹر ───");
    متغیر ج_نیسٹڈ = کلائنٹ.حاصل("/صارف/5/کتاب/7/");
    جانچ("Nested URL — 200", ج_نیسٹڈ["رمز"] == 200);
    جانچ("Nested uid=5", ج_نیسٹڈ["json"]["صارف"] == 5);
    جانچ("Nested kid=7", ج_نیسٹڈ["json"]["کتاب"] == 7);

    // ─── Status codes ─────────────────────────────────
    لکھو("\n─── مختلف حالت کوڈز ───");
    جانچ("200 OK", کلائنٹ.حاصل("/حالت/200/")["رمز"] == 200);
    جانچ("201 Created", کلائنٹ.حاصل("/حالت/201/")["رمز"] == 201);
    جانچ("400 Bad Request", کلائنٹ.حاصل("/حالت/400/")["رمز"] == 400);
    جانچ("401 Unauthorized", کلائنٹ.حاصل("/حالت/401/")["رمز"] == 401);
    جانچ("403 Forbidden", کلائنٹ.حاصل("/حالت/403/")["رمز"] == 403);
    جانچ("500 Server Error", کلائنٹ.حاصل("/حالت/500/")["رمز"] == 500);

    // ─── Middleware ──────────────────────────────────
    لکھو("\n─── Middleware ───");
    جانچ("لاگ_درمیانی موجود", لاگ_درمیانی != خالی);
    لکھو(`  ⓘ لاگ شدہ درخواستیں: ${_درخواستیں_لاگ.لمبائی}`);

    لکھو(`\n══════════════════════════════════════════════`);
    لکھو(`  Django مکمل — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════════════`);
}

مرکز();
