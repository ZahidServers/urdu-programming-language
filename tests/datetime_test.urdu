// ══════════════════════════════════════════════════════
// اردو پروگرامنگ لینگویج — تاریخ / وقت جانچ
// عیسوی، ہجری، تبادلہ، حساب، فارمیٹنگ
// ══════════════════════════════════════════════════════

درآمد {
    تاریخ, وقت, تاریخ_وقت, مدت, ہجری, ٹائمر,
    آج, ابھی, مہر_وقت, مہر_سے_تاریخ, نیند,
    کبیسہ_سال, دنوں_کا_فرق,
    عیسوی_سے_ہجری, ہجری_سے_عیسوی,
    وقت_پیمائش, مہینہ_نام, دن_نام,
    ہجری_مہینے, عیسوی_مہینے, ہفتے_کے_دن
} سے "اردو/تاریخ";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// ══════════════════════════════════════════════════════
// 1. مدت (timedelta)
// ══════════════════════════════════════════════════════
لکھو("\n─── مدت (Duration) ───");

متغیر م1 = نیا مدت(دن=5);
متغیر م2 = نیا مدت(گھنٹے=2, منٹ=30);
متغیر م3 = نیا مدت(ہفتے=1);

جانچ("مدت.دن",          م1.دن == 5);
جانچ("مدت.کل_سیکنڈ",   م2.کل_سیکنڈ == 9000);
جانچ("مدت.کل_منٹ",     م2.کل_منٹ == 150);
جانچ("مدت.کل_گھنٹے",  م2.کل_گھنٹے == 2);
جانچ("ہفتے کی مدت",    م3.دن == 7);
جانچ("مدت جمع",        (م1 + م3).دن == 12);
جانچ("مدت گھٹاؤ",      (م3 - م1).دن == 2);
جانچ("مدت ضرب",        (م1 * 3).دن == 15);

// ══════════════════════════════════════════════════════
// 2. تاریخ (Gregorian Date)
// ══════════════════════════════════════════════════════
لکھو("\n─── تاریخ (Gregorian) ───");

متغیر ت1 = نیا تاریخ(2024, 3, 23);
متغیر ت2 = نیا تاریخ(2024, 1, 1);
متغیر ت_آج = آج();

جانچ("تاریخ.سال",         ت1.سال == 2024);
جانچ("تاریخ.مہینہ",       ت1.مہینہ == 3);
جانچ("تاریخ.دن",          ت1.دن == 23);
جانچ("تاریخ.مہینہ_نام",   ت1.مہینہ_نام == "مارچ");
جانچ("تاریخ.دن_نام",      ت1.دن_نام == "ہفتہ");
جانچ("تاریخ.کبیسہ (2024)", ت1.کبیسہ == سچ);
جانچ("تاریخ.کبیسہ (2023)", نیا تاریخ(2023, 6, 1).کبیسہ == جھوٹ);

// تاریخ حساب
متغیر ت3 = ت1 + نیا مدت(دن=10);
جانچ("تاریخ + مدت",        ت3.دن == 2 && ت3.مہینہ == 4);

متغیر ت4 = ت1 - نیا مدت(دن=23);
جانچ("تاریخ - مدت",        ت4.مہینہ == 2 && ت4.دن == 29);

متغیر فرق = ت1 - ت2;
جانچ("تاریخ فرق (مدت)",    فرق.دن == 82);

// تاریخ موازنہ
جانچ("تاریخ < تاریخ",     ت2 < ت1);
جانچ("تاریخ > تاریخ",     ت1 > ت2);
جانچ("تاریخ == تاریخ",    ت1 == نیا تاریخ(2024, 3, 23));

// فارمیٹنگ
جانچ("فارمیٹ (ISO)",       ت1.فارمیٹ() == "2024-03-23");
جانچ("فارمیٹ (اردو)",      ت1.اردو_فارمیٹ() == "23 مارچ 2024");
جانچ("فارمیٹ (دن مہینہ)", ت1.فارمیٹ("%d/%m/%Y") == "23/03/2024");

// پارس
متغیر پارس_شدہ = تاریخ.پارس("2025-06-15");
جانچ("تاریخ.پارس",         پارس_شدہ.سال == 2025 && پارس_شدہ.مہینہ == 6);

// آج کی تاریخ
جانچ("آج() کام کرتا ہے",  ت_آج.سال >= 2024);
جانچ("دنوں_کا_فرق",       دنوں_کا_فرق(ت1, ت2) == 82);

// ══════════════════════════════════════════════════════
// 3. وقت (Time)
// ══════════════════════════════════════════════════════
لکھو("\n─── وقت (Time) ───");

متغیر و1 = نیا وقت(14, 30, 45);
متغیر و2 = نیا وقت(9, 5, 0);
متغیر و_ابھی = وقت.ابھی();

جانچ("وقت.گھنٹہ",       و1.گھنٹہ == 14);
جانچ("وقت.منٹ",         و1.منٹ == 30);
جانچ("وقت.سیکنڈ",       و1.سیکنڈ == 45);
جانچ("وقت.فارمیٹ",      و1.فارمیٹ("%H:%M") == "14:30");
جانچ("وقت.فارمیٹ 12h",  و1.فارمیٹ("%I:%M %p") == "02:30 PM");
جانچ("اردو فارمیٹ دوپہر", و1.اردو_فارمیٹ() == "2:30:45 دوپہر");
جانچ("اردو فارمیٹ صبح",   و2.اردو_فارمیٹ() == "9:05:00 صبح");
جانچ("وقت < وقت",        و2 < و1);
جانچ("وقت == وقت",       و1 == نیا وقت(14, 30, 45));
جانچ("ابھی().گھنٹہ",     و_ابھی.گھنٹہ >= 0 && و_ابھی.گھنٹہ <= 23);

// پارس
متغیر پارس_وقت = وقت.پارس("08:15:00");
جانچ("وقت.پارس",         پارس_وقت.گھنٹہ == 8 && پارس_وقت.منٹ == 15);

// ══════════════════════════════════════════════════════
// 4. تاریخ_وقت (DateTime)
// ══════════════════════════════════════════════════════
لکھو("\n─── تاریخ_وقت (DateTime) ───");

متغیر دو1 = نیا تاریخ_وقت(2024, 12, 25, 8, 0, 0);
متغیر دو2 = نیا تاریخ_وقت(2024, 12, 25, 20, 30, 0);
متغیر دو_ابھی = تاریخ_وقت.ابھی();

جانچ("تاریخ_وقت.سال",       دو1.سال == 2024);
جانچ("تاریخ_وقت.گھنٹہ",    دو1.گھنٹہ == 8);
جانچ("تاریخ_وقت.دن_نام",   دو1.دن_نام == "بدھ");
جانچ("تاریخ_وقت.مہینہ_نام", دو1.مہینہ_نام == "دسمبر");

// حصے
جانچ("تاریخ_حصہ",           دو1.تاریخ_حصہ.دن == 25);
جانچ("وقت_حصہ",             دو1.وقت_حصہ.گھنٹہ == 8);

// حساب
متغیر دو3 = دو1 + نیا مدت(گھنٹے=3);
جانچ("تاریخ_وقت + مدت",    دو3.گھنٹہ == 11);

متغیر فرق_دو = دو2 - دو1;
جانچ("تاریخ_وقت فرق",      فرق_دو.کل_گھنٹے == 12);

// فارمیٹنگ
جانچ("فارمیٹ (ISO)",        دو1.فارمیٹ() == "2024-12-25 08:00:00");
جانچ("اردو فارمیٹ",         دو1.اردو_فارمیٹ() == "25 دسمبر 2024، 8:00 صبح");

// مہر وقت
متغیر مہر = مہر_وقت();
جانچ("مہر_وقت()",           مہر > 1000000000);

متغیر دو_مہر = مہر_سے_تاریخ(1700000000);
جانچ("مہر_سے_تاریخ",       دو_مہر.سال == 2023);

// موازنہ
جانچ("تاریخ_وقت < تاریخ_وقت", دو1 < دو2);
جانچ("تاریخ_وقت == تاریخ_وقت", دو1 == نیا تاریخ_وقت(2024, 12, 25, 8, 0, 0));

// پارس
متغیر پارس_دو = تاریخ_وقت.پارس("2025-03-15 10:30:00");
جانچ("تاریخ_وقت.پارس",     پارس_دو.سال == 2025 && پارس_دو.منٹ == 30);

// ══════════════════════════════════════════════════════
// 5. ہجری (Hijri Calendar)
// ══════════════════════════════════════════════════════
لکھو("\n─── ہجری (Islamic Calendar) ───");

// مشہور تاریخیں جن کا ہجری تبادلہ معلوم ہے
// 23 مارچ 2024 = 13 رمضان 1445 ہجری
متغیر ہ1 = نیا ہجری(1445, 9, 13);

جانچ("ہجری.سال",           ہ1.سال == 1445);
جانچ("ہجری.مہینہ",         ہ1.مہینہ == 9);
جانچ("ہجری.دن",            ہ1.دن == 13);
جانچ("ہجری.مہینہ_نام",     ہ1.مہینہ_نام == "رمضان");
جانچ("رمضان جانچ",         ہ1.کیا_رمضان() == سچ);
جانچ("ذوالحجہ جانچ",       ہ1.کیا_ذوالحجہ() == جھوٹ);

// ہجری فارمیٹنگ
جانچ("ہجری.فارمیٹ()",      ہ1.فارمیٹ() == "1445-09-13");
جانچ("ہجری.اردو_فارمیٹ()", ہ1.اردو_فارمیٹ() == "13 رمضان 1445 ہجری");
جانچ("ہجری.فارمیٹ (نمونہ)", ہ1.فارمیٹ("%d %B %Y") == "13 رمضان 1445");

// عیسوی سے ہجری تبادلہ
متغیر ت_مارچ = نیا تاریخ(2024, 3, 23);
متغیر ہ_مارچ = ت_مارچ.ہجری_میں();
جانچ("عیسوی → ہجری (سال)",    ہ_مارچ.سال == 1445);
جانچ("عیسوی → ہجری (مہینہ)",  ہ_مارچ.مہینہ == 9);
جانچ("عیسوی → ہجری (دن)",     ہ_مارچ.دن == 13);

// ہجری سے عیسوی تبادلہ
متغیر ت_واپس = ہ1.عیسوی_میں();
جانچ("ہجری → عیسوی (سال)",    ت_واپس.سال == 2024);
جانچ("ہجری → عیسوی (مہینہ)",  ت_واپس.مہینہ == 3);
جانچ("ہجری → عیسوی (دن)",     ت_واپس.دن == 23);

// utility functions
متغیر ہ_مدد = عیسوی_سے_ہجری(2024, 1, 1);
جانچ("عیسوی_سے_ہجری() فنکشن", ہ_مدد.سال == 1445 && ہ_مدد.مہینہ == 6);

متغیر ت_مدد = ہجری_سے_عیسوی(1446, 1, 1);
جانچ("ہجری_سے_عیسوی() فنکشن", ت_مدد.سال == 2024 && ت_مدد.مہینہ == 7);

// ہجری آج
متغیر ہ_آج = ہجری.آج();
جانچ("ہجری.آج() (سال > 1440)",  ہ_آج.سال >= 1440);

// ہجری سے تاریخ
متغیر ہ_سے = ہجری.سے_تاریخ(نیا تاریخ(2024, 3, 23));
جانچ("ہجری.سے_تاریخ()",        ہ_سے.مہینہ == 9);

// ہجری حساب (دن جمع/گھٹانا)
متغیر ہ2 = ہ1 + 10;
جانچ("ہجری + دن",               ہ2.دن == 23);

متغیر ہ3 = ہ1 - 3;
جانچ("ہجری - دن",               ہ3.دن == 10);

// ہجری موازنہ
جانچ("ہجری < ہجری",            ہ3 < ہ1);
جانچ("ہجری == ہجری",           ہ1 == نیا ہجری(1445, 9, 13));

// ہجری فرق (مدت)
متغیر فرق_ہجری = ہ2 - ہ3;
جانچ("ہجری فرق دن",            فرق_ہجری.دن == 13);

// ═══ کچھ مشہور اسلامی تاریخیں ═══
لکھو("\n─── مشہور ہجری تاریخیں ───");
// 1 محرم 1446 کی عیسوی تاریخ
متغیر محرم_1446 = ہجری_سے_عیسوی(1446, 1, 1);
لکھو(`  1 محرم 1446 ہجری = ${محرم_1446.اردو_فارمیٹ()}`);

// عید الفطر 1445 (1 شوال 1445)
متغیر عید_فطر_1445 = ہجری_سے_عیسوی(1445, 10, 1);
لکھو(`  عید الفطر 1445 = ${عید_فطر_1445.اردو_فارمیٹ()}`);

// عید الاضحیٰ 1445 (10 ذوالحجہ 1445)
متغیر عید_اضحی_1445 = ہجری_سے_عیسوی(1445, 12, 10);
لکھو(`  عید الاضحیٰ 1445 = ${عید_اضحی_1445.اردو_فارمیٹ()}`);

جانچ("1 محرم 1446 = جولائی 2024",  محرم_1446.مہینہ == 7 && محرم_1446.سال == 2024);
جانچ("1 شوال 1445 = اپریل 2024",   عید_فطر_1445.مہینہ == 4 && عید_فطر_1445.سال == 2024);

// ══════════════════════════════════════════════════════
// 6. مددگار افعال
// ══════════════════════════════════════════════════════
لکھو("\n─── مددگار افعال ───");

جانچ("کبیسہ_سال(2024)",  کبیسہ_سال(2024) == سچ);
جانچ("کبیسہ_سال(2023)",  کبیسہ_سال(2023) == جھوٹ);
جانچ("کبیسہ_سال(1900)",  کبیسہ_سال(1900) == جھوٹ);
جانچ("کبیسہ_سال(2000)",  کبیسہ_سال(2000) == سچ);

جانچ("مہینہ_نام(3)",          مہینہ_نام(3) == "مارچ");
جانچ("مہینہ_نام(9, ہجری)",   مہینہ_نام(9, سچ) == "رمضان");
جانچ("دن_نام(4)",             دن_نام(4) == "جمعہ");

جانچ("ہجری_مہینے[0]",        ہجری_مہینے[0] == "محرم");
جانچ("ہجری_مہینے[8]",        ہجری_مہینے[8] == "رمضان");
جانچ("عیسوی_مہینے[11]",      عیسوی_مہینے[11] == "دسمبر");
جانچ("ہفتے_کے_دن[4]",        ہفتے_کے_دن[4] == "جمعہ");

// ══════════════════════════════════════════════════════
// 7. ٹائمر (Stopwatch)
// ══════════════════════════════════════════════════════
لکھو("\n─── ٹائمر (Stopwatch) ───");

متغیر ت_گھڑی = نیا ٹائمر();
ت_گھڑی.شروع();
متغیر جمع_ٹ = 0;
کے_لیے (متغیر ی = 0; ی < 100000; ی = ی + 1) {
    جمع_ٹ = جمع_ٹ + ی;
}
ت_گھڑی.روکو();

جانچ("ٹائمر.گزرا_وقت > 0",       ت_گھڑی.گزرا_وقت > 0);
جانچ("ٹائمر.ملی_سیکنڈ > 0",     ت_گھڑی.ملی_سیکنڈ > 0);
لکھو(`  گنتی وقت: ${گول(ت_گھڑی.ملی_سیکنڈ, 2)} ms`);

// دوبارہ شروع
ت_گھڑی.دوبارہ_شروع();
ت_گھڑی.روکو();
جانچ("دوبارہ_شروع — وقت صفر سے",  ت_گھڑی.گزرا_وقت < 0.01);

// وقت_پیمائش
متغیر پیمائش = وقت_پیمائش(فنکشن() {
    متغیر م = 0;
    کے_لیے (متغیر ی = 0; ی < 10000; ی = ی + 1) { م = م + ی; }
});
جانچ("وقت_پیمائش() > 0",         پیمائش > 0);

// ══════════════════════════════════════════════════════
// 8. عملی منظر نامے
// ══════════════════════════════════════════════════════
لکھو("\n─── عملی منظر نامے ───");

// عمر حساب
متغیر پیدائش = نیا تاریخ(2000, 6, 15);
متغیر حوالہ  = نیا تاریخ(2025, 6, 15);
متغیر عمر_دن = (حوالہ - پیدائش).دن;
جانچ("عمر حساب (25 سال)",         عمر_دن == 9131);

// اگلا جمعہ
متغیر بنیاد = نیا تاریخ(2024, 3, 18);  // پیر
متغیر دن_باقی = (4 - بنیاد.دن_ہفتہ + 7) % 7;  // 4 = جمعہ
متغیر اگلا_جمعہ = بنیاد + نیا مدت(دن=دن_باقی);
جانچ("اگلا جمعہ",                  اگلا_جمعہ.دن_نام == "جمعہ");

// رمضان شروع 1446 (29 فروری 2025 سے تقریباً)
متغیر رمضان_1446 = ہجری_سے_عیسوی(1446, 9, 1);
لکھو(`  رمضان 1446 شروع: ${رمضان_1446.اردو_فارمیٹ()}`);
جانچ("رمضان 1446 سال",            رمضان_1446.سال == 2025);

// پاکستان کے مشہور دن
متغیر یوم_آزادی = نیا تاریخ(2025, 8, 14);
لکھو(`  یوم آزادی 2025: ${یوم_آزادی.دن_نام}، ${یوم_آزادی.اردو_فارمیٹ()}`);
جانچ("یوم آزادی اگست میں",        یوم_آزادی.مہینہ == 8);

// تاریخ_وقت کا تاریخ سے جوڑ
متغیر دو_ملا = تاریخ_وقت.تاریخ_اور_وقت(نیا تاریخ(2024, 6, 1), نیا وقت(10, 30, 0));
جانچ("تاریخ_اور_وقت()",           دو_ملا.گھنٹہ == 10 && دو_ملا.دن == 1);

// ══════════════════════════════════════════════════════
// نتیجہ
// ══════════════════════════════════════════════════════
لکھو(`\n══════════════════════════════════════`);
لکھو(`  تاریخ/وقت — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
لکھو(`══════════════════════════════════════`);
