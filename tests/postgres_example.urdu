// ══════════════════════════════════════════════════════
// اردو پروگرامنگ لینگویج — پوسٹ_گریس مثال
// مکمل CRUD آپریشنز
// ══════════════════════════════════════════════════════

درآمد { پوسٹ_گریس } سے "اردو/ڈیٹا_بیس";

// ─── پوسٹ_گریس سے جڑیں ──────────────────────────────
متغیر db = نیا پوسٹ_گریس({
    میزبان:   "localhost",
    صارف:     "postgres",
    پاس_ورڈ: "root",
    ڈیٹا_بیس: "postgres",
    پورٹ:     5432
});

غیر_متزامن فنکشن مرکز() {

    // ─── جڑیں ─────────────────────────────────────────
    انتظار db.جوڑیں();
    لکھو("✓ پوسٹ_گریس سے جڑ گئے\n");

    // ─── اسکیما بنائیں ────────────────────────────────
    انتظار db.چلائیں("DROP SCHEMA IF EXISTS urdu_pg_test CASCADE");
    انتظار db.چلائیں("CREATE SCHEMA urdu_pg_test");
    انتظار db.چلائیں("SET search_path TO urdu_pg_test");
    لکھو("✓ اسکیما 'urdu_pg_test' تیار");

    // ─── جدول بنائیں ──────────────────────────────────
    انتظار db.چلائیں(`
        CREATE TABLE ملازمین (
            شناخت   SERIAL PRIMARY KEY,
            نام      VARCHAR(100) NOT NULL,
            محکمہ    VARCHAR(50),
            تنخواہ   DECIMAL(10,2),
            شہر      VARCHAR(50),
            فعال     BOOLEAN DEFAULT TRUE
        )
    `);
    لکھو("✓ جدول 'ملازمین' بنایا گیا\n");

    // ─── ڈیٹا داخل کریں ───────────────────────────────
    لکھو("═══ ڈیٹا داخل کرنا ═══");
    متغیر ملازمین = [
        { نام: "احمد علی",    محکمہ: "انجینئرنگ",  تنخواہ: 85000, شہر: "کراچی"      },
        { نام: "فاطمہ خان",   محکمہ: "ڈیزائن",     تنخواہ: 72000, شہر: "لاہور"      },
        { نام: "محمد عمر",    محکمہ: "انجینئرنگ",  تنخواہ: 91000, شہر: "اسلام_آباد" },
        { نام: "عائشہ صدیق",  محکمہ: "HR",          تنخواہ: 68000, شہر: "کراچی"      },
        { نام: "بلال حسین",   محکمہ: "فروخت",       تنخواہ: 55000, شہر: "لاہور"      },
        { نام: "زینب میر",    محکمہ: "ڈیزائن",     تنخواہ: 78000, شہر: "کوئٹہ"      },
        { نام: "عمران شاہ",   محکمہ: "HR",          تنخواہ: 62000, شہر: "پشاور"      },
        { نام: "مریم اقبال",  محکمہ: "انجینئرنگ",  تنخواہ: 95000, شہر: "کراچی"      }
    ];

    کے_لیے (متغیر م میں ملازمین) {
        انتظار db.چلائیں(
            "INSERT INTO ملازمین (نام, محکمہ, تنخواہ, شہر) VALUES (?, ?, ?, ?)",
            [م.نام, م.محکمہ, م.تنخواہ, م.شہر]
        );
    }
    لکھو(`  ${لمبائی(ملازمین)} ملازمین کے ریکارڈ داخل کیے گئے ✓\n`);

    // ─── تمام ریکارڈ دیکھیں (ORDER BY) ───────────────
    لکھو("═══ تمام ملازمین (تنخواہ کے مطابق) ═══");
    متغیر سب = انتظار db.سوال("SELECT * FROM ملازمین ORDER BY تنخواہ DESC");
    کے_لیے (متغیر م میں سب) {
        لکھو(`  [${م.شناخت}] ${م.نام} | ${م.محکمہ} | Rs ${م.تنخواہ} | ${م.شہر}`);
    }

    // ─── WHERE فلٹر ────────────────────────────────────
    لکھو("\n═══ انجینئرنگ کے ملازمین ═══");
    متغیر انجینئرز = انتظار db.سوال(
        "SELECT نام, تنخواہ FROM ملازمین WHERE محکمہ = ? ORDER BY تنخواہ DESC",
        ["انجینئرنگ"]
    );
    کے_لیے (متغیر م میں انجینئرز) {
        لکھو(`  ${م.نام}: Rs ${م.تنخواہ}`);
    }

    // ─── GROUP BY / اجتماعی افعال ─────────────────────
    لکھو("\n═══ محکمہ وار اوسط تنخواہ ═══");
    متغیر گروپ = انتظار db.سوال(`
        SELECT محکمہ,
               COUNT(*) AS تعداد,
               AVG(تنخواہ)::NUMERIC(10,0) AS اوسط_تنخواہ,
               MAX(تنخواہ) AS زیادہ_تنخواہ
        FROM ملازمین
        GROUP BY محکمہ
        ORDER BY اوسط_تنخواہ DESC
    `);
    کے_لیے (متغیر ر میں گروپ) {
        لکھو(`  ${ر.محکمہ} | تعداد: ${ر.تعداد} | اوسط: Rs ${ر.اوسط_تنخواہ} | زیادہ: Rs ${ر.زیادہ_تنخواہ}`);
    }

    // ─── UPDATE ────────────────────────────────────────
    لکھو("\n═══ تنخواہ 10% بڑھانا (انجینئرنگ) ═══");
    متغیر متاثرہ = انتظار db.چلائیں(
        "UPDATE ملازمین SET تنخواہ = تنخواہ * 1.10 WHERE محکمہ = ?",
        ["انجینئرنگ"]
    );
    لکھو(`  ${متاثرہ} ملازمین کی تنخواہ بڑھائی گئی ✓`);

    متغیر بعد = انتظار db.سوال(
        "SELECT نام, تنخواہ FROM ملازمین WHERE محکمہ = ? ORDER BY تنخواہ DESC",
        ["انجینئرنگ"]
    );
    کے_لیے (متغیر م میں بعد) {
        لکھو(`  ${م.نام}: Rs ${م.تنخواہ}`);
    }

    // ─── DELETE ────────────────────────────────────────
    لکھو("\n═══ ریکارڈ حذف (سب سے کم تنخواہ) ═══");
    متغیر کم = انتظار db.سوال(
        "SELECT شناخت, نام, تنخواہ FROM ملازمین ORDER BY تنخواہ ASC LIMIT 1"
    );
    اگر (لمبائی(کم) > 0) {
        لکھو(`  حذف ہو رہا ہے: ${کم[0].نام} (Rs ${کم[0].تنخواہ})`);
        انتظار db.چلائیں("DELETE FROM ملازمین WHERE شناخت = ?", [کم[0].شناخت]);
        لکھو("  ✓ ریکارڈ حذف ہوا");
    }

    // ─── JOIN ──────────────────────────────────────────
    انتظار db.چلائیں(`
        CREATE TABLE محکمے (
            نام      VARCHAR(50) PRIMARY KEY,
            مینیجر  VARCHAR(100),
            بجٹ     DECIMAL(12,2)
        )
    `);
    انتظار db.چلائیں("INSERT INTO محکمے VALUES (?, ?, ?)", ["انجینئرنگ", "ڈاکٹر کریم",  5000000]);
    انتظار db.چلائیں("INSERT INTO محکمے VALUES (?, ?, ?)", ["ڈیزائن",     "سارہ نظامی",  3000000]);
    انتظار db.چلائیں("INSERT INTO محکمے VALUES (?, ?, ?)", ["HR",          "طارق محمود",  2000000]);
    انتظار db.چلائیں("INSERT INTO محکمے VALUES (?, ?, ?)", ["فروخت",      "نادیہ اکبر",  4000000]);

    لکھو("\n═══ JOIN: ملازمین اور ان کے محکمے ═══");
    متغیر جوائن = انتظار db.سوال(`
        SELECT م.نام, م.تنخواہ, م.شہر, د.مینیجر
        FROM ملازمین م
        INNER JOIN محکمے د ON م.محکمہ = د.نام
        ORDER BY م.تنخواہ DESC
    `);
    کے_لیے (متغیر ر میں جوائن) {
        لکھو(`  ${ر.نام} | مینیجر: ${ر.مینیجر} | Rs ${ر.تنخواہ}`);
    }

    // ─── LEFT JOIN (ملازم بغیر محکمہ) ─────────────────
    لکھو("\n═══ LEFT JOIN — تمام ملازمین (محکمہ سمیت) ═══");
    متغیر بائیں = انتظار db.سوال(`
        SELECT م.نام, COALESCE(د.مینیجر, 'نہیں') AS مینیجر
        FROM ملازمین م
        LEFT JOIN محکمے د ON م.محکمہ = د.نام
        ORDER BY م.نام
    `);
    کے_لیے (متغیر ر میں بائیں) {
        لکھو(`  ${ر.نام} — مینیجر: ${ر.مینیجر}`);
    }

    // ─── LIKE / تلاش ───────────────────────────────────
    لکھو("\n═══ کراچی کے ملازمین ═══");
    متغیر کراچی = انتظار db.سوال(
        "SELECT نام, محکمہ, تنخواہ FROM ملازمین WHERE شہر LIKE ?",
        ["%کراچی%"]
    );
    کے_لیے (متغیر م میں کراچی) {
        لکھو(`  ${م.نام} (${م.محکمہ}): Rs ${م.تنخواہ}`);
    }

    // ─── BETWEEN ───────────────────────────────────────
    لکھو("\n═══ تنخواہ 70000 سے 100000 کے درمیان ═══");
    متغیر درمیانہ = انتظار db.سوال(
        "SELECT نام, تنخواہ FROM ملازمین WHERE تنخواہ BETWEEN ? AND ? ORDER BY تنخواہ",
        [70000, 100000]
    );
    کے_لیے (متغیر م میں درمیانہ) {
        لکھو(`  ${م.نام}: Rs ${م.تنخواہ}`);
    }

    // ─── IN ────────────────────────────────────────────
    لکھو("\n═══ کراچی اور لاہور کے ملازمین ═══");
    متغیر شہری = انتظار db.سوال(
        "SELECT نام, شہر FROM ملازمین WHERE شہر IN (?, ?) ORDER BY شہر",
        ["کراچی", "لاہور"]
    );
    کے_لیے (متغیر م میں شہری) {
        لکھو(`  ${م.نام} — ${م.شہر}`);
    }

    // ─── DISTINCT ──────────────────────────────────────
    لکھو("\n═══ منفرد محکمے ═══");
    متغیر محکمہ_فہرست = انتظار db.سوال("SELECT DISTINCT محکمہ FROM ملازمین ORDER BY محکمہ");
    کے_لیے (متغیر م میں محکمہ_فہرست) {
        لکھو(`  - ${م.محکمہ}`);
    }

    // ─── Subquery ──────────────────────────────────────
    لکھو("\n═══ اوسط سے زیادہ تنخواہ والے ═══");
    متغیر اوسط_سے_زیادہ = انتظار db.سوال(`
        SELECT نام, تنخواہ
        FROM ملازمین
        WHERE تنخواہ > (SELECT AVG(تنخواہ) FROM ملازمین)
        ORDER BY تنخواہ DESC
    `);
    کے_لیے (متغیر م میں اوسط_سے_زیادہ) {
        لکھو(`  ${م.نام}: Rs ${م.تنخواہ}`);
    }

    // ─── RETURNING (پوسٹ_گریس خصوصی) ─────────────────
    لکھو("\n═══ RETURNING — نیا ریکارڈ ═══");
    متغیر نیا_ریکارڈ = انتظار db.سوال(`
        INSERT INTO ملازمین (نام, محکمہ, تنخواہ, شہر)
        VALUES (?, ?, ?, ?)
        RETURNING شناخت, نام, تنخواہ
    `, ["نئی رکن", "ڈیزائن", 70000, "لاہور"]);
    لکھو(`  نیا ملازم: شناخت=${نیا_ریکارڈ[0].شناخت}, نام=${نیا_ریکارڈ[0].نام}, تنخواہ=${نیا_ریکارڈ[0].تنخواہ} ✓`);

    // ─── کل اعداد و شمار ──────────────────────────────
    متغیر کل = انتظار db.سوال(`
        SELECT COUNT(*) AS تعداد,
               SUM(تنخواہ) AS کل_تنخواہ,
               AVG(تنخواہ)::NUMERIC(10,0) AS اوسط_تنخواہ,
               MIN(تنخواہ) AS کم_تنخواہ,
               MAX(تنخواہ) AS زیادہ_تنخواہ
        FROM ملازمین
    `);
    لکھو(`\nکل ملازمین: ${کل[0].تعداد}`);
    لکھو(`کل تنخواہ:   Rs ${کل[0].کل_تنخواہ}`);
    لکھو(`اوسط تنخواہ: Rs ${کل[0].اوسط_تنخواہ}`);
    لکھو(`کم تنخواہ:   Rs ${کل[0].کم_تنخواہ}`);
    لکھو(`زیادہ تنخواہ: Rs ${کل[0].زیادہ_تنخواہ}`);

    // ─── CTE (WITH) ────────────────────────────────────
    لکھو("\n═══ CTE — درجہ بندی ═══");
    متغیر درجہ = انتظار db.سوال(`
        WITH درجہ_بندی AS (
            SELECT نام, تنخواہ,
                   RANK() OVER (ORDER BY تنخواہ DESC) AS درجہ
            FROM ملازمین
        )
        SELECT نام, تنخواہ, درجہ
        FROM درجہ_بندی
        WHERE درجہ <= 3
    `);
    لکھو("  اعلیٰ 3 تنخواہیں:");
    کے_لیے (متغیر م میں درجہ) {
        لکھو(`  ${م.درجہ}. ${م.نام}: Rs ${م.تنخواہ}`);
    }

    // ─── صفائی اور بند ────────────────────────────────
    انتظار db.چلائیں("DROP SCHEMA urdu_pg_test CASCADE");
    لکھو("\n✓ اسکیما صاف کر دیا گیا");
    انتظار db.منقطع();
    لکھو("✓ پوسٹ_گریس بند ہوا");
}

مرکز();
