// ══════════════════════════════════════════════════════════════
// Firebase مکمل جانچ — Auth (ای_میل + فون) | Realtime DB | Firestore
// ══════════════════════════════════════════════════════════════

درآمد { فائر_بیس } سے "اردو/ڈیٹا_بیس";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// Firebase web config
متغیر config = {
    "apiKey":        "AIzaSyCk53jm5Fxg9O7EPAgt2Ab-jOuS8gSYpck",
    "projectId":     "test-59571",
    "databaseURL":   "https://test-59571-default-rtdb.firebaseio.com"
};

غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════════╗");
    لکھو("║  Firebase مکمل جانچ                      ║");
    لکھو("╚══════════════════════════════════════════╝");

    متغیر db = نیا فائر_بیس(config);
    انتظار db.جوڑیں();
    جانچ("web mode جڑا", db._connected == سچ);

    // ─── 1. ای_میل رجسٹریشن ─────────────────────────────────
    لکھو("\n─── ای_میل — رجسٹریشن ───");
    متغیر ای_میل = "urdu_test_user@example.com";
    متغیر پاس   = "UrduTest2024!";
    متغیر صارف;

    کوشش {
        صارف = انتظار db.ای_میل_رجسٹر(ای_میل, پاس);
        جانچ("نئی رجسٹریشن", لمبائی(صارف["localId"]) > 0);
        لکھو(`  ⓘ نیا صارف بنا: ${صارف["localId"]}`);
    } پکڑو (غ) {
        متغیر پیغام = متن(غ);
        اگر (پیغام.includes("EMAIL_EXISTS")) {
            لکھو("  ⓘ ای_میل پہلے سے موجود — داخلے کی کوشش");
            جانچ("EMAIL_EXISTS صحیح غلطی", سچ);
        } ورنہ {
            لکھو(`  ✗ رجسٹریشن غلطی: ${پیغام}`);
            ن["ناکام"] = ن["ناکام"] + 1;
        }
    }

    // ─── 2. ای_میل سائن ان ──────────────────────────────────
    لکھو("\n─── ای_میل — سائن ان ───");
    کوشش {
        صارف = انتظار db.ای_میل_داخل(ای_میل, پاس);
        جانچ("سائن ان کامیاب", لمبائی(db._id_token) > 10);
        جانچ("localId موجود", لمبائی(db._local_id) > 0);
        لکھو(`  ⓘ UID: ${db._local_id}`);
    } پکڑو (غ) {
        لکھو(`  ✗ سائن ان غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 3. صارف معلومات ────────────────────────────────────
    لکھو("\n─── صارف معلومات ───");
    کوشش {
        متغیر معلومات = انتظار db.صارف_معلومات();
        جانچ("ای_میل صحیح واپسی", معلومات["email"] == ای_میل);
        جانچ("emailVerified موجود", "emailVerified" میں_ہے معلومات);
    } پکڑو (غ) {
        لکھو(`  ✗ معلومات غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 4. فون — کوڈ بھیجو ─────────────────────────────────
    لکھو("\n─── فون — OTP بھیجو ───");
    متغیر session_info = "";
    کوشش {
        session_info = انتظار db.فون_کوڈ_بھیجو("+919769849163");
        جانچ("sessionInfo ملا", لمبائی(session_info) > 0);
        لکھو(`  ⓘ sessionInfo: ${session_info.slice(0, 30)}...`);
    } پکڑو (غ) {
        لکھو(`  ✗ فون کوڈ غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 5. فون — OTP تصدیق ──────────────────────────────────
    لکھو("\n─── فون — OTP تصدیق ───");
    اگر (لمبائی(session_info) > 0) {
        کوشش {
            متغیر فون_صارف = انتظار db.فون_تصدیق(session_info, "434343");
            جانچ("فون سائن ان کامیاب", لمبائی(db._id_token) > 10);
            جانچ("فون UID موجود", لمبائی(db._local_id) > 0);
            لکھو(`  ⓘ فون UID: ${db._local_id}`);
        } پکڑو (غ) {
            لکھو(`  ✗ فون تصدیق غلطی: ${غ}`);
            ن["ناکام"] = ن["ناکام"] + 1;
        }
    } ورنہ {
        لکھو("  ⓘ sessionInfo نہیں — فون تصدیق چھوڑی");
    }

    // ─── ای_میل واپس سائن ان (Realtime DB + Firestore کے لیے) ──
    انتظار db.ای_میل_داخل(ای_میل, پاس);

    // ─── 6. Realtime Database ────────────────────────────────
    لکھو("\n─── Realtime Database ───");
    کوشش {
        // لکھنا
        متغیر لکھا = انتظار db.ریئل_لکھو("urdu_test/اردو", {
            "نام":  "احمد",
            "عمر":  25,
            "شہر":  "کراچی"
        });
        جانچ("RTDB لکھا — نام صحیح", لکھا["نام"] == "احمد");

        // پڑھنا
        متغیر پڑھا = انتظار db.ریئل_پڑھو("urdu_test/اردو");
        جانچ("RTDB پڑھا — نام صحیح", پڑھا["نام"] == "احمد");
        جانچ("RTDB پڑھا — عمر صحیح", پڑھا["عمر"] == 25);

        // تازہ کاری
        متغیر تازہ = انتظار db.ریئل_تازہ("urdu_test/اردو", { "عمر": 30 });
        جانچ("RTDB تازہ — عمر بدلی", تازہ["عمر"] == 30);

        // شامل (push)
        متغیر شامل_id = انتظار db.ریئل_شامل("urdu_test/فہرست", { "آئٹم": "الف" });
        جانچ("RTDB push ID ملا", لمبائی(متن(شامل_id)) > 0);

        // حذف
        انتظار db.ریئل_حذف("urdu_test/اردو");
        متغیر حذف_نتیجہ = انتظار db.ریئل_پڑھو("urdu_test/اردو");
        جانچ("RTDB حذف کام کیا", حذف_نتیجہ == خالی);

    } پکڑو (غ) {
        لکھو(`  ✗ RTDB غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 7. Firestore CRUD ───────────────────────────────────
    لکھو("\n─── Firestore ───");
    کوشش {
        متغیر مجموعہ = db.مجموعہ("urdu_janche");

        // شامل کریں
        متغیر doc_id = انتظار مجموعہ.اضافہ({
            "نام":   "فاطمہ",
            "عمر":   28,
            "شہر":   "لاہور"
        });
        جانچ("Firestore شامل — ID ملا", لمبائی(doc_id) > 0);
        لکھو(`  ⓘ doc ID: ${doc_id}`);

        // پڑھیں
        متغیر دستاویز = انتظار مجموعہ.حاصل(doc_id);
        جانچ("Firestore حاصل — نام صحیح", دستاویز["نام"] == "فاطمہ");
        جانچ("Firestore حاصل — عمر صحیح", دستاویز["عمر"] == 28);

        // تازہ کریں
        انتظار مجموعہ.مقرر(doc_id, { "نام": "فاطمہ", "عمر": 29, "شہر": "لاہور" });
        متغیر تازہ_doc = انتظار مجموعہ.حاصل(doc_id);
        جانچ("Firestore مقرر — عمر تازہ", تازہ_doc["عمر"] == 29);

        // سبھی دستاویز
        متغیر سبھی = انتظار مجموعہ.سبھی();
        جانچ("Firestore سبھی — کم از کم 1", لمبائی(سبھی) >= 1);

        // حذف
        انتظار مجموعہ.حذف(doc_id);
        متغیر حذف_doc = انتظار مجموعہ.حاصل(doc_id);
        جانچ("Firestore حذف کام کیا", حذف_doc == خالی);

    } پکڑو (غ) {
        لکھو(`  ✗ Firestore غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 8. صفائی — test صارف حذف ───────────────────────────
    لکھو("\n─── صفائی ───");
    کوشش {
        انتظار db.ای_میل_داخل(ای_میل, پاس);
        انتظار db.صارف_حذف();
        لکھو("  ⓘ test صارف حذف ہوا");
        جانچ("صارف حذف کامیاب", db._id_token == خالی);
    } پکڑو (غ) {
        لکھو(`  ⓘ صارف پہلے ہی حذف یا موجود نہیں: ${غ}`);
    }

    انتظار db.منقطع();

    لکھو(`\n══════════════════════════════════════════`);
    لکھو(`  Firebase مکمل — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════════`);
}

انتظار مرکز();
