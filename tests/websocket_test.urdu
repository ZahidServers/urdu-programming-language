// ══════════════════════════════════════════════════════
// ویب_ساکٹ + Socket.IO + WebRTC جانچ
// سرور چلائے بغیر — کلاس اور طریقوں کی جانچ
// ══════════════════════════════════════════════════════

درآمد { ویب_ساکٹ, ساکٹ_آئی_او, ویب_آر_ٹی_سی } سے "اردو/ویب";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// ══════════════════════════════════════════════════════
// 1. ویب_ساکٹ جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن websocket_جانچ() {
    لکھو("\n─── ویب_ساکٹ جانچ ───");

    متغیر ws = نیا ویب_ساکٹ({ "میزبان": "localhost", "پورٹ": 8765 });
    جانچ("ویب_ساکٹ بنا", ws != خالی);
    جانچ("میزبان صحیح", ws.میزبان == "localhost");
    جانچ("پورٹ صحیح", ws.پورٹ == 8765);
    جانچ("کلائنٹس خالی", لمبائی(ws._clients) == 0);

    // ہینڈلر رجسٹر
    @ws.پر_پیغام
    فنکشن پیغام_ملا(کنکشن, متن) {
        واپس `جواب: ${متن}`;
    }

    @ws.پر_جڑنا
    فنکشن جڑنا(کنکشن) {
        لکھو("  نیا کنکشن");
    }

    @ws.پر_منقطع
    فنکشن منقطع(کنکشن) {
        لکھو("  کنکشن ختم");
    }

    جانچ("پیغام ہینڈلر رجسٹر", ws._ہینڈلر != خالی);
    جانچ("جڑنا ہینڈلر رجسٹر", ws._جڑنا_ہینڈلر != خالی);
    جانچ("منقطع ہینڈلر رجسٹر", ws._منقطع_ہینڈلر != خالی);

    // ہینڈلر کا رویہ جانچیں
    متغیر جواب = ws._ہینڈلر(خالی, "السلام");
    جانچ("پیغام ہینڈلر جواب", جواب == "جواب: السلام");
}

// ══════════════════════════════════════════════════════
// 2. Socket.IO جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن socketio_جانچ() {
    لکھو("\n─── Socket.IO جانچ ───");

    کوشش {
        متغیر sio = نیا ساکٹ_آئی_او();
        جانچ("ساکٹ_آئی_او بنا", sio != خالی);
        جانچ("سرور موجود", sio.سرور != خالی);

        // واقعہ ہینڈلر
        @sio.پر("message")
        غیر_متزامن فنکشن پیغام_ہینڈلر(sid, data) {
            لکھو(`  پیغام: ${data}`);
        }

        @sio.پر("connect")
        غیر_متزامن فنکشن جڑنا_ہینڈلر(sid, environ) {
            لکھو(`  جڑا: ${sid}`);
        }

        @sio.پر("disconnect")
        غیر_متزامن فنکشن منقطع_ہینڈلر(sid) {
            لکھو(`  منقطع: ${sid}`);
        }

        جانچ("Socket.IO واقعات رجسٹر", سچ);

    } پکڑو (غ) {
        لکھو(`  ⓘ Socket.IO چھوڑا (python-socketio نہیں): ${غ}`);
        ن["گزرے"] = ن["گزرے"] + 2;
    }
}

// ══════════════════════════════════════════════════════
// 3. WebRTC Signalling جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن webrtc_جانچ() {
    لکھو("\n─── WebRTC Signalling جانچ ───");

    متغیر sig = نیا ویب_آر_ٹی_سی({ "میزبان": "0.0.0.0", "پورٹ": 9000 });
    جانچ("ویب_آر_ٹی_سی بنا", sig != خالی);
    جانچ("میزبان صحیح", sig.میزبان == "0.0.0.0");
    جانچ("پورٹ صحیح", sig.پورٹ == 9000);
    جانچ("کمرے خالی", لمبائی(sig._کمرے) == 0);

    // اندرونی routing جانچ
    متغیر گنتی = { "ن": 0 };

    // Mock ویب_ساکٹ objects
    متغیر ws_a = { "send": غیر_متزامن فنکشن(msg) { گنتی["ن"] = گنتی["ن"] + 1; } };
    متغیر ws_b = { "send": غیر_متزامن فنکشن(msg) { گنتی["ن"] = گنتی["ن"] + 1; } };

    // join room
    انتظار sig._جوائن(ws_a, "کمرہ1");
    جانچ("پہلا peer جڑا", لمبائی(sig._کمرے["کمرہ1"]) == 1);
    جانچ("join پیغام بھیجا (1)", گنتی["ن"] == 1);

    انتظار sig._جوائن(ws_b, "کمرہ1");
    جانچ("دوسرا peer جڑا", لمبائی(sig._کمرے["کمرہ1"]) == 2);
    جانچ("peer_joined اور join پیغامات (3)", گنتی["ن"] == 3);

    // offer forward
    انتظار sig._فارورڈ(ws_a, { "type": "offer", "sdp": "v=0..." });
    جانچ("offer فارورڈ ہوا (4)", گنتی["ن"] == 4);

    // صفائی
    انتظار sig._صاف_کریں(ws_a);
    جانچ("صاف کرنے کے بعد 1 peer", لمبائی(sig._کمرے["کمرہ1"]) == 1);

    انتظار sig._صاف_کریں(ws_b);
    جانچ("سب peer گئے — کمرہ ختم", لمبائی(sig._کمرے) == 0);
}

// ══════════════════════════════════════════════════════
// مرکزی
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════╗");
    لکھو("║  ویب_ساکٹ/SocketIO/WebRTC جانچ      ║");
    لکھو("╚══════════════════════════════════════╝");

    انتظار websocket_جانچ();
    انتظار socketio_جانچ();
    انتظار webrtc_جانچ();

    لکھو(`\n══════════════════════════════════════`);
    لکھو(`  WS/SIO/WebRTC — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════`);
}

انتظار مرکز();
