// ══════════════════════════════════════════════════════
// ZahidAgent_v3.gguf — LLM جانچ
// ══════════════════════════════════════════════════════

درآمد { بڑا_لسانی_ماڈل } سے "اردو/ذہین";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════╗");
    لکھو("║   ZahidAgent_v3 LLM جانچ             ║");
    لکھو("╚══════════════════════════════════════╝");

    متغیر ماڈل_راستہ = "examples/ZahidAgent_v3.gguf";

    // ─── 1. ماڈل لوڈ ───
    لکھو("\n─── ماڈل لوڈ ───");
    متغیر llm = خالی;
    کوشش {
        llm = نیا بڑا_لسانی_ماڈل(ماڈل_راستہ, تھریڈ=4, طوالت=2048);
        جانچ("ماڈل لوڈ ہوا", llm != خالی);
    } پکڑو (غ) {
        لکھو(`  ✗ ماڈل لوڈ ناکام: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
        لکھو(`\n══════════════════════════════════════`);
        لکھو(`  LLM — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
        لکھو(`══════════════════════════════════════`);
        واپس;
    }

    // ─── 2. متن تکمیل ───
    لکھو("\n─── متن تکمیل ───");
    کوشش {
        متغیر جواب1 = llm.بات_کرو("Hello, my name is", زیادہ_ٹوکن=30, درجہ_حرارت=0.1);
        لکھو(`  جواب: ${جواب1}`);
        جانچ("متن تکمیل کام کیا", لمبائی(جواب1) > 0);
    } پکڑو (غ) {
        لکھو(`  ✗ متن تکمیل ناکام: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 3. سوال جواب ───
    لکھو("\n─── سوال جواب ───");
    کوشش {
        متغیر جواب2 = llm.بات_کرو("What is 2 + 2?", زیادہ_ٹوکن=20, درجہ_حرارت=0.1);
        لکھو(`  جواب: ${جواب2}`);
        جانچ("سوال جواب کام کیا", لمبائی(جواب2) > 0);
    } پکڑو (غ) {
        لکھو(`  ✗ سوال جواب ناکام: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 4. چیٹ ───
    لکھو("\n─── چیٹ تکمیل ───");
    کوشش {
        متغیر پیغامات = [
            { "role": "system", "content": "You are a helpful assistant." },
            { "role": "user", "content": "Say hello in one word." }
        ];
        متغیر چیٹ_جواب = llm.چیٹ(پیغامات, زیادہ_ٹوکن=20);
        لکھو(`  جواب: ${چیٹ_جواب}`);
        جانچ("چیٹ جواب ملا", لمبائی(چیٹ_جواب) > 0);
    } پکڑو (غ) {
        لکھو(`  ⓘ چیٹ: ${غ}`);
    }

    // ─── 5. ایمبیڈنگ ───
    لکھو("\n─── ایمبیڈنگ ───");
    کوشش {
        متغیر llm_emb = نیا بڑا_لسانی_ماڈل(ماڈل_راستہ, تھریڈ=4, طوالت=512, ایمبیڈنگ_موڈ=سچ);
        متغیر vec = llm_emb.ایمبیڈنگ("hello world");
        جانچ("ایمبیڈنگ ملی", لمبائی(vec) > 0);
        لکھو(`  ویکٹر طول: ${لمبائی(vec)}`);
    } پکڑو (غ) {
        لکھو(`  ⓘ ایمبیڈنگ: ${غ}`);
    }

    لکھو(`\n══════════════════════════════════════`);
    لکھو(`  LLM — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════`);
}

انتظار مرکز();
