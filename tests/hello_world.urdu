// ══════════════════════════════════════════════
// اردو پروگرامنگ لینگویج — مرحبا دنیا
// Hello World in Urdu Programming Language
// Developer: Mohammed Zahid Wadiwale
// ══════════════════════════════════════════════

لکھو("السلام علیکم، دنیا!");
لکھو("مرحبا اردو پروگرامنگ لینگویج میں!");

// متغیرات (Variables)
متغیر نام = "احمد";
مستقل عمر = 25;

لکھو(`میرا نام ${نام} ہے اور میری عمر ${عمر} سال ہے۔`);

// شرط (If-Else)
اگر (عمر >= 18) {
    لکھو("آپ بالغ ہیں۔");
} ورنہ {
    لکھو("آپ نابالغ ہیں۔");
}

// حلقہ (Loop)
لکھو("\nگنتی:");
کے_لیے (متغیر i = 1; i <= 5; i++) {
    لکھو(`  ${i}`);
}

// فنکشن (Function)
فنکشن جمع(الف، ب) {
    واپس الف + ب;
}

لکھو(`\n5 + 3 = ${جمع(5, 3)}`);

// فہرست (Array)
متغیر پھل = ["سیب", "کیلا", "آم", "انگور"];
لکھو("\nپھل:");
کے_لیے (متغیر پھل_ میں پھل) {
    لکھو(`  - ${پھل_}`);
}

// شے (Object)
متغیر طالب_علم = {
    نام: "فاطمہ",
    درجہ: "دسواں",
    نمبر: 95
};
لکھو(`\nطالب علم: ${طالب_علم.نام}, درجہ: ${طالب_علم.درجہ}, نمبر: ${طالب_علم.نمبر}`);

// استثناء (Exception handling)
کوشش {
    پھینکو نیا غلطی("یہ ایک آزمائشی غلطی ہے");
} پکڑو (غ) {
    لکھو(`\nغلطی پکڑی گئی: ${غ.پیغام}`);
} آخر {
    لکھو("آخر میں یہ ہمیشہ چلتا ہے۔");
}

لکھو("\nاردو پروگرامنگ لینگویج - نسخہ 1.0.1");
لکھو("ڈویلپر: Mohammed Zahid Wadiwale");
