// ══════════════════════════════════════════════════════════════
// پانڈاز جانچ — CSV + Excel پڑھنا / لکھنا
// ══════════════════════════════════════════════════════════════

درآمد { پانڈاز } سے "اردو/ذہین";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════════╗");
    لکھو("║  پانڈاز جانچ — CSV + Excel              ║");
    لکھو("╚══════════════════════════════════════════╝");

    متغیر pd = نیا پانڈاز();

    // ─── 1. DataFrame بنانا ──────────────────────────────────
    لکھو("\n─── DataFrame ───");
    کوشش {
        متغیر df = pd.جدول({
            "نام":    ["احمد", "فاطمہ", "علی", "زینب", "عمر"],
            "عمر":   [20, 22, 19, 21, 23],
            "شہر":   ["کراچی", "لاہور", "اسلام_آباد", "ملتان", "پشاور"],
            "نمبر":  [88.5, 91.0, 75.5, 83.0, 79.5]
        });
        جانچ("DataFrame بنا", df.empty == جھوٹ);
        جانچ("5 قطاریں", لمبائی(df) == 5);
        جانچ("4 ستون", لمبائی(df.columns.tolist()) == 4);
        لکھو(`  ⓘ شکل: ${df.shape[0]} x ${df.shape[1]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ DataFrame غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 2. CSV لکھنا ────────────────────────────────────────
    لکھو("\n─── CSV لکھنا ───");
    کوشش {
        متغیر df = pd.جدول({
            "naam":   ["Ahmad", "Fatima", "Ali", "Zainab", "Umar"],
            "umar":   [20, 22, 19, 21, 23],
            "shehar": ["Karachi", "Lahore", "Islamabad", "Multan", "Peshawar"],
            "number": [88.5, 91.0, 75.5, 83.0, 79.5]
        });
        متغیر راستہ = pd.csv_لکھو(df, "test_data.csv");
        جانچ("CSV لکھا", راستہ == "test_data.csv");
        لکھو(`  ⓘ CSV محفوظ: ${راستہ}`);
    } پکڑو (غ) {
        لکھو(`  ✗ CSV لکھنے غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 3. CSV پڑھنا ────────────────────────────────────────
    لکھو("\n─── CSV پڑھنا ───");
    کوشش {
        متغیر df = pd.csv_پڑھو("test_data.csv");
        جانچ("CSV پڑھا", df.empty == جھوٹ);
        جانچ("5 قطاریں ملیں", لمبائی(df) == 5);
        جانچ("4 ستون ملے", لمبائی(df.columns.tolist()) == 4);
        جانچ("پہلا نام", df["naam"][0] == "Ahmad");
        جانچ("پہلا نمبر", df["number"][0] == 88.5);
        لکھو(`  ⓘ CSV شکل: ${df.shape[0]} x ${df.shape[1]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ CSV پڑھنے غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 4. CSV — اردو انکوڈنگ ───────────────────────────────
    لکھو("\n─── CSV اردو انکوڈنگ ───");
    کوشش {
        متغیر df_اردو = pd.جدول({
            "نام":   ["احمد", "فاطمہ", "علی"],
            "شہر":   ["کراچی", "لاہور", "اسلام_آباد"]
        });
        pd.csv_لکھو(df_اردو, "test_urdu.csv", encoding="utf-8-sig");
        متغیر df_واپس = pd.csv_پڑھو("test_urdu.csv", encoding="utf-8-sig");
        جانچ("اردو CSV لکھا / پڑھا", لمبائی(df_واپس) == 3);
        جانچ("اردو نام محفوظ", df_واپس["نام"][0] == "احمد");
        لکھو(`  ⓘ اردو CSV: ${df_واپس["نام"][0]}, ${df_واپس["شہر"][0]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ اردو CSV غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 5. Excel لکھنا ─────────────────────────────────────
    لکھو("\n─── Excel لکھنا ───");
    کوشش {
        متغیر df = pd.csv_پڑھو("test_data.csv");
        متغیر excel_راستہ = pd.excel_لکھو(df, "test_data.xlsx");
        جانچ("Excel لکھا", excel_راستہ == "test_data.xlsx");
        لکھو(`  ⓘ Excel محفوظ: ${excel_راستہ}`);
    } پکڑو (غ) {
        لکھو(`  ✗ Excel لکھنے غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 6. Excel پڑھنا ─────────────────────────────────────
    لکھو("\n─── Excel پڑھنا ───");
    کوشش {
        متغیر df = pd.excel_پڑھو("test_data.xlsx");
        جانچ("Excel پڑھا", df.empty == جھوٹ);
        جانچ("5 قطاریں ملیں", لمبائی(df) == 5);
        جانچ("4 ستون ملے", لمبائی(df.columns.tolist()) == 4);
        جانچ("پہلا نام Excel", df["naam"][0] == "Ahmad");
        جانچ("آخری نمبر", df["number"][4] == 79.5);
        لکھو(`  ⓘ Excel شکل: ${df.shape[0]} x ${df.shape[1]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ Excel پڑھنے غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 7. Excel — متعدد ورق ────────────────────────────────
    لکھو("\n─── Excel متعدد ورق ───");
    کوشش {
        متغیر df1 = pd.جدول({ "x": [1, 2, 3], "y": [4, 5, 6] });
        متغیر df2 = pd.جدول({ "a": ["p", "q"], "b": [10, 20] });

        // ExcelWriter for multiple sheets
        متغیر writer = pd.ExcelWriter("test_multi.xlsx", engine="openpyxl");
        df1.to_excel(writer, sheet_name="ورق1", index=جھوٹ);
        df2.to_excel(writer, sheet_name="ورق2", index=جھوٹ);
        writer.close();

        متغیر df_back1 = pd.excel_پڑھو("test_multi.xlsx", sheet_name="ورق1");
        متغیر df_back2 = pd.excel_پڑھو("test_multi.xlsx", sheet_name="ورق2");
        جانچ("ورق1 پڑھا", لمبائی(df_back1) == 3);
        جانچ("ورق2 پڑھا", لمبائی(df_back2) == 2);
        لکھو(`  ⓘ ورق1: ${df_back1.shape[0]}q, ورق2: ${df_back2.shape[0]}q`);
    } پکڑو (غ) {
        لکھو(`  ✗ متعدد ورق غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 8. بنیادی تجزیہ ────────────────────────────────────
    لکھو("\n─── بنیادی تجزیہ ───");
    کوشش {
        متغیر df = pd.csv_پڑھو("test_data.csv");
        متغیر اوسط = df["number"].mean();
        جانچ("اوسط > 0", اوسط > 0);
        جانچ("زیادہ سے زیادہ صحیح", df["number"].max() == 91.0);
        جانچ("کم سے کم صحیح", df["number"].min() == 75.5);
        لکھو(`  ⓘ اوسط نمبر: ${round(اوسط, 2)}`);
    } پکڑو (غ) {
        لکھو(`  ✗ تجزیہ غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    لکھو(`\n══════════════════════════════════════════`);
    لکھو(`  پانڈاز جانچ — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════════`);
}

انتظار مرکز();
