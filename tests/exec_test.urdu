// ══════════════════════════════════════════════════════════════
// متحرک_چلاؤ جانچ — Python + Urdu کوڈ کی متحرک چلانا
// ══════════════════════════════════════════════════════════════

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════════╗");
    لکھو("║  متحرک_چلاؤ جانچ                         ║");
    لکھو("╚══════════════════════════════════════════╝");

    // ─── 1. سادہ Python کوڈ ─────────────────────────────────
    لکھو("\n─── Python کوڈ ───");
    کوشش {
        متغیر ماح = متحرک_چلاؤ("x = 2 + 3");
        جانچ("Python x = 5", ماح["x"] == 5);

        متغیر ماح2 = متحرک_چلاؤ("result = [i**2 for i in range(5)]");
        جانچ("list comprehension چلا", لمبائی(ماح2["result"]) == 5);
        جانچ("آخری قدر 16", ماح2["result"][4] == 16);
        لکھو(`  ⓘ result: ${ماح2["result"]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ Python کوڈ غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 2. ماحول میں متغیر پاس کرنا ───────────────────────
    لکھو("\n─── ماحول پاس کرنا ───");
    کوشش {
        متغیر ماح = { "a": 10, "b": 20 };
        متحرک_چلاؤ("total = a + b", ماح);
        جانچ("ماحول کے متغیر استعمال ہوئے", ماح["total"] == 30);
        لکھو(`  ⓘ total = ${ماح["total"]}`);

        متغیر ماح2 = { "a": 5, "b": 7 };
        متحرک_چلاؤ("product = a * b", ماح2);
        جانچ("ماحول نتیجہ واپس ملا", ماح2["product"] == 35);
        لکھو(`  ⓘ product = ${ماح2["product"]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ ماحول غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 3. Python فنکشن متحرک ──────────────────────────────
    لکھو("\n─── Python فنکشن ───");
    کوشش {
        متغیر ماح = متحرک_چلاؤ(`
def square(n):
    return n * n
result = square(7)
`);
        جانچ("Python فنکشن چلا", ماح["result"] == 49);
        لکھو(`  ⓘ square(7) = ${ماح["result"]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ Python فنکشن غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 4. اردو کوڈ متحرک ──────────────────────────────────
    لکھو("\n─── اردو کوڈ ───");
    کوشش {
        متغیر ماح = متحرک_چلاؤ("متغیر عدد = 42");
        جانچ("اردو متغیر بنا", ماح["عدد"] == 42);
        لکھو(`  ⓘ عدد = ${ماح["عدد"]}`);
    } پکڑو (غ) {
        لکھو(`  ✗ اردو کوڈ غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 5. غلطی سنبھالنا ───────────────────────────────────
    لکھو("\n─── غلطی سنبھالنا ───");
    کوشش {
        متحرک_چلاؤ("raise ValueError('test error')");
        جانچ("غلطی نہیں پکڑی", جھوٹ);
    } پکڑو (غ) {
        جانچ("ValueError پکڑی", سچ);
        لکھو(`  ⓘ غلطی: ${غ}`);
    }

    کوشش {
        متحرک_چلاؤ("x = 1 / 0");
        جانچ("ZeroDivision نہیں پکڑی", جھوٹ);
    } پکڑو (غ) {
        جانچ("ZeroDivision پکڑی", سچ);
        لکھو(`  ⓘ غلطی: ${غ}`);
    }

    لکھو(`\n══════════════════════════════════════════`);
    لکھو(`  متحرک_چلاؤ جانچ — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════════`);
}

انتظار مرکز();
