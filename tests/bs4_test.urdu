// ══════════════════════════════════════════════════════════════
// کھرچنی مکمل جانچ — HTML تجزیہ + ویب کھرچنی
// ══════════════════════════════════════════════════════════════

درآمد { صفحہ_بناؤ, کھرچو } سے "اردو/کھرچنی";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// ─── جانچ کے لیے HTML ────────────────────────────────────────
متغیر HTML = `
<html>
<head><title>اردو کھرچنی جانچ</title></head>
<body>
  <h1 id="سرخی" class="بڑا">خوش آمدید</h1>
  <div class="مواد" data-id="42">
    <p>پہلا پیرا گراف۔</p>
    <p class="نمایاں">دوسرا پیرا گراف۔</p>
    <ul id="فہرست">
      <li><a href="https://example.com" class="ربط">مثال ایک</a></li>
      <li><a href="https://urdu-lang.org" class="ربط">مثال دو</a></li>
      <li><a href="https://github.com" class="ربط">گٹ ہب</a></li>
    </ul>
  </div>
  <footer id="فوٹر">حقوق محفوظ 2025</footer>
</body>
</html>`;

غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════════╗");
    لکھو("║  کھرچنی مکمل جانچ                        ║");
    لکھو("╚══════════════════════════════════════════╝");

    // ─── 1. بنیادی تجزیہ ────────────────────────────────────
    لکھو("\n─── بنیادی تجزیہ ───");
    کوشش {
        متغیر سوپ = صفحہ_بناؤ(HTML);
        جانچ("صفحہ بنا", سوپ != خالی);
        جانچ("عنوان درست", سوپ.عنوان == "اردو کھرچنی جانچ");
        جانچ("html عنصر ملا", سوپ.تلاش("html") != خالی);
    } پکڑو (غ) {
        لکھو(`  ✗ بنیادی غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 2. تلاش — ٹیگ سے ──────────────────────────────────
    لکھو("\n─── تلاش (ٹیگ) ───");
    کوشش {
        متغیر سوپ = صفحہ_بناؤ(HTML);
        متغیر سرخی = سوپ.تلاش("h1");
        جانچ("h1 ملی", سرخی != خالی);
        جانچ("h1 متن", سرخی.صاف_متن == "خوش آمدید");
        جانچ("h1 id", سرخی.شناخت == "سرخی");
        جانچ("h1 ٹیگ نام", سرخی.ٹیگ == "h1");
    } پکڑو (غ) {
        لکھو(`  ✗ تلاش غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 3. سب_تلاش ─────────────────────────────────────────
    لکھو("\n─── سب_تلاش ───");
    کوشش {
        متغیر سوپ = صفحہ_بناؤ(HTML);
        متغیر روابط = سوپ.سب_تلاش("a");
        جانچ("3 روابط ملے", لمبائی(روابط) == 3);
        جانچ("پہلا href", روابط[0]["href"] == "https://example.com");
        جانچ("دوسرا متن", روابط[1].صاف_متن == "مثال دو");

        متغیر محدود = سوپ.سب_تلاش("a", خالی, 2);
        جانچ("حد=2 کام کرتی", لمبائی(محدود) == 2);
    } پکڑو (غ) {
        لکھو(`  ✗ سب_تلاش غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 4. CSS انتخاب ──────────────────────────────────────
    لکھو("\n─── CSS انتخاب ───");
    کوشش {
        متغیر سوپ = صفحہ_بناؤ(HTML);

        متغیر نمایاں = سوپ.ایک_چنو(".نمایاں");
        جانچ(".نمایاں ملا", نمایاں != خالی);
        جانچ(".نمایاں متن", نمایاں.صاف_متن == "دوسرا پیرا گراف۔");

        متغیر روابط = سوپ.چنو("#فہرست a");
        جانچ("#فہرست a گنتی", لمبائی(روابط) == 3);

        متغیر فوٹر = سوپ.ایک_چنو("#فوٹر");
        جانچ("footer id", فوٹر.شناخت == "فوٹر");

        متغیر div = سوپ.ایک_چنو("div.مواد");
        جانچ("div data-id", div["data-id"] == "42");
    } پکڑو (غ) {
        لکھو(`  ✗ CSS انتخاب غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 5. خصوصیات ─────────────────────────────────────────
    لکھو("\n─── خصوصیات ───");
    کوشش {
        متغیر سوپ = صفحہ_بناؤ(HTML);
        متغیر سرخی = سوپ.تلاش("h1");
        متغیر خ = سرخی.خصوصیات;
        جانچ("id خصوصیت", خ["id"] == "سرخی");
        جانچ("class خصوصیت", خ["class"] == "بڑا");
    } پکڑو (غ) {
        لکھو(`  ✗ خصوصیات غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 6. والد / بچے / اگلا ───────────────────────────────
    لکھو("\n─── سفر (والد / بچے / اگلا) ───");
    کوشش {
        متغیر سوپ = صفحہ_بناؤ(HTML);
        متغیر ul = سوپ.تلاش("ul");
        متغیر بچے_ul = ul.بچے;
        جانچ("ul کے 3 بچے", لمبائی(بچے_ul) == 3);
        جانچ("پہلا بچہ li", بچے_ul[0].ٹیگ == "li");

        متغیر پ = سوپ.تلاش("h1").والد;
        جانچ("h1 کا والد body", پ.ٹیگ == "body");

        متغیر پہلا_li = ul.تلاش("li");
        متغیر اگلا_li = پہلا_li.اگلا;
        جانچ("اگلا li ملا", اگلا_li != خالی);
        جانچ("اگلا ٹیگ li", اگلا_li.ٹیگ == "li");
    } پکڑو (غ) {
        لکھو(`  ✗ سفر غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 7. خصوصیات سے تلاش ──────────────────────────────────
    لکھو("\n─── خصوصیات سے تلاش ───");
    کوشش {
        متغیر سوپ = صفحہ_بناؤ(HTML);
        متغیر div = سوپ.تلاش("div", { "class": "مواد" });
        جانچ("class سے div ملا", div != خالی);
        جانچ("div data-id", div["data-id"] == "42");

        متغیر id_el = سوپ.تلاش(خالی, { "id": "فوٹر" });
        جانچ("id سے تلاش", id_el != خالی);
        جانچ("footer ٹیگ", id_el.ٹیگ == "footer");
    } پکڑو (غ) {
        لکھو(`  ✗ خصوصیات تلاش غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 8. HTML مواد ────────────────────────────────────────
    لکھو("\n─── HTML مواد ───");
    کوشش {
        متغیر سوپ = صفحہ_بناؤ(HTML);
        متغیر فوٹر = سوپ.تلاش("footer");
        جانچ("بیرونی html میں footer", فوٹر.بیرونی_html.indexOf("footer") >= 0);
        جانچ("اندرونی html میں حقوق", فوٹر.اندرونی_html.indexOf("حقوق") >= 0);
        جانچ("خوبصورت html", لمبائی(فوٹر.خوبصورت) > 0);
    } پکڑو (غ) {
        لکھو(`  ✗ HTML مواد غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 9. ویب کھرچنی (httpbin) ─────────────────────────────
    لکھو("\n─── ویب کھرچنی ───");
    کوشش {
        متغیر سوپ = انتظار کھرچو("https://httpbin.org/html");
        جانچ("صفحہ ملا", سوپ != خالی);
        متغیر h1 = سوپ.تلاش("h1");
        جانچ("h1 موجود", h1 != خالی);
        جانچ("h1 متن غیر خالی", لمبائی(h1.صاف_متن) > 0);
        لکھو(`  ⓘ عنوان: ${h1.صاف_متن}`);

        متغیر پیرے = سوپ.سب_تلاش("p");
        جانچ("پیرے موجود", لمبائی(پیرے) > 0);
        لکھو(`  ⓘ پیرے: ${لمبائی(پیرے)}`);
    } پکڑو (غ) {
        لکھو(`  ✗ ویب کھرچنی غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    // ─── 10. حقیقی سائٹ کھرچنی ─────────────────────────────
    لکھو("\n─── کتابوں کی سائٹ ───");
    کوشش {
        متغیر سوپ = انتظار کھرچو("https://books.toscrape.com");
        جانچ("سائٹ ملی", سوپ != خالی);
        متغیر عنوان_سائٹ = سوپ.عنوان;
        جانچ("عنوان موجود", لمبائی(عنوان_سائٹ) > 0);
        لکھو(`  ⓘ سائٹ عنوان: ${عنوان_سائٹ}`);

        متغیر کتابیں = سوپ.چنو("article.product_pod");
        جانچ("کتابیں ملیں", لمبائی(کتابیں) > 0);
        لکھو(`  ⓘ کتابیں: ${لمبائی(کتابیں)}`);

        متغیر پہلی_کتاب = کتابیں[0];
        متغیر کتاب_نام = پہلی_کتاب.تلاش("h3").تلاش("a");
        جانچ("کتاب نام موجود", کتاب_نام != خالی);
        لکھو(`  ⓘ پہلی کتاب: ${کتاب_نام["title"]}`);

        متغیر قیمتیں = سوپ.چنو(".price_color");
        جانچ("قیمتیں ملیں", لمبائی(قیمتیں) > 0);
        لکھو(`  ⓘ پہلی قیمت: ${قیمتیں[0].صاف_متن}`);
    } پکڑو (غ) {
        لکھو(`  ✗ کتابوں کی سائٹ غلطی: ${غ}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }

    لکھو(`\n══════════════════════════════════════════`);
    لکھو(`  کھرچنی جانچ — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════════`);
}

انتظار مرکز();
