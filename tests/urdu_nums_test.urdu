// ── اردو اعداد کی جانچ ──────────────────────────────────
لکھو("─── اردو اعداد ───");

// خالص اردو اعداد
متغیر عمر    = ۲۵;
متغیر سال    = ۲۰۲۴;
متغیر قیمت  = ۱۲۹۹;
متغیر صفر   = ۰;

لکھو(`عمر: ${عمر}`);
لکھو(`سال: ${سال}`);
لکھو(`قیمت: ${قیمت}`);
لکھو(`صفر: ${صفر}`);

// حساب
متغیر جمع  = ۱۰ + ۲۰;
متغیر ضرب  = ۵ * ۱۲;
متغیر تقسیم = ۱۰۰ / ۴;

لکھو(`۱۰ + ۲۰ = ${جمع}`);
لکھو(`۵ × ۱۲ = ${ضرب}`);
لکھو(`۱۰۰ ÷ ۴ = ${تقسیم}`);

// مخلوط — اردو اور انگریزی اعداد ساتھ
متغیر مخلوط = ۵۰ + 50;
لکھو(`۵۰ + 50 = ${مخلوط}`);

// عربی انڈک اعداد (٠١٢٣٤٥٦٧٨٩)
متغیر عربی = ١٢٣٤٥;
لکھو(`عربی اعداد: ${عربی}`);

// اعشاریہ
متغیر اعشاری = ۳.۱۴;
لکھو(`پائی: ${اعشاری}`);

// لوپ اردو اعداد سے
متغیر جمع_کل = ۰;
کے_لیے (متغیر i = ۱; i <= ۵; i++) {
    جمع_کل = جمع_کل + i;
}
لکھو(`۱ سے ۵ کا مجموعہ: ${جمع_کل}`);

لکھو("─── جانچ مکمل ✓ ───");
