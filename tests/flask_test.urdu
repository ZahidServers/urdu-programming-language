// ══════════════════════════════════════════════��═══════
// Flask مکمل جانچ — Routes, Blueprints, Error handlers,
//                    JSON, Request, Redirect, Before/After
// ══════════════════════════════════════════════════════

درآمد { فلاسک, بلیو_پرنٹ, فلاسک_جیسن, فلاسک_درخواست,
         فلاسک_رجوع, فلاسک_جواب, فلاسک_منسوخ } سے "اردو/ویب";
درآمد { Client } سے "flask.testing";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// ══════════════════════════════════════════════════════
// ایپ + راستے
// ══════════════════════════════════════════════════════
متغیر ایپ = نیا فلاسک();

// before_request hook
@ایپ.قبل_درخواست
فنکشن لاگ_درخواست() {
    // ہر درخواست سے پہلے چلتا ہے
}

// ─── GET ─────────────────────────────────────────────
@ایپ.حاصل("/")
فنکشن جڑ() {
    واپس فلاسک_جیسن({ "پیغام": "خوش آمدید Flask", "زبان": "اردو" });
}

// ─── GET path param ───────────────────────────────────
@ایپ.راستہ("/salam/<naam>", ["GET"])
فنکشن سلام(naam) {
    واپس فلاسک_جیسن({ "پیغام": `السلام ${naam}` });
}

// ─── POST JSON body ───────────────────────────────────
@ایپ.بھیجیں("/sarif")
فنکشن نیا_صارف() {
    متغیر req = فلاسک_درخواست();
    متغیر باڈی = req.get_json();
    واپس فلاسک_جیسن({ "شناخت": 1, "نام": باڈی["naam"], "ای_میل": باڈی["email"] }, 201);
}

// ─── GET + POST on same route ─────────────────────────
@ایپ.راستہ("/ashiya", ["GET", "POST"])
فنکشن اشیاء() {
    متغیر req = فلاسک_درخواست();
    اگر (req.method == "POST") {
        متغیر باڈی = req.get_json();
        واپس فلاسک_جیسن({ "اضافہ": باڈی["عنوان"], "پیغام": "شامل" }, 201);
    }
    واپس فلاسک_جیسن([{ "id": 1, "عنوان": "آگ کا دریا" }, { "id": 2, "عنوان": "گلستان" }]);
}

// ─── PUT ─────────────────────────────────────────────
@ایپ.راستہ("/sarif/<int:sid>", ["PUT"])
فنکشن صارف_تازہ(sid) {
    واپس فلاسک_جیسن({ "شناخت": sid, "حالت": "تازہ" });
}

// ─── DELETE ───────────────────────────────────────────
@ایپ.راستہ("/sarif/<int:sid>", ["DELETE"])
فنکشن صارف_حذف(sid) {
    واپس فلاسک_جیسن({ "پیغام": `صارف ${sid} حذف` });
}

// ─── Custom response ──────────────────────────────────
@ایپ.حاصل("/متن")
فنکشن متن_جواب() {
    واپس فلاسک_جواب("سادہ متن", 200, "text/plain; charset=utf-8");
}

// ─── Error handlers ───────────────────────────────────
@ایپ.غلطی(404)
فنکشن نہیں_ملا(e) {
    واپس فلاسک_جیسن({ "غلطی": "نہیں ملا", "رمز": 404 }, 404);
}

@ایپ.غلطی(405)
فنکشن غلط_طریقہ(e) {
    واپس فلاسک_جیسن({ "غلطی": "طریقہ غلط", "رمز": 405 }, 405);
}

// ══════════════════════════════════════════════════════
// Blueprint
// ══════════════════════════════════════════════════════
متغیر کتاب_bp = نیا بلیو_پرنٹ("کتابیں", { "سابقہ": "/kitabain" });

@کتاب_bp.حاصل("/")
فنکشن bp_کتابیں() {
    واپس فلاسک_جیسن([{ "id": 1, "عنوان": "فیض کا کلام" }, { "id": 2, "عنوان": "اداس نسلیں" }]);
}

@کتاب_bp.بھیجیں("/")
فنکشن bp_کتاب_شامل() {
    متغیر req = فلاسک_درخواست();
    متغیر باڈی = req.get_json();
    واپس فلاسک_جیسن({ "id": 10, "عنوان": باڈی["عنوان"] }, 201);
}

@کتاب_bp.راستہ("/<int:kid>", ["GET"])
فنکشن bp_کتاب_ایک(kid) {
    واپس فلاسک_جیسن({ "id": kid, "عنوان": "نمونہ کتاب" });
}

ایپ.بلیو_پرنٹ_شامل(کتاب_bp);

// ══════════════════════════════════════════════════════
// جانچ
// ══════════════════════════════════════════════════════
فنکشن مرکز() {
    لکھو("╔═══════════════════════════��══════════╗");
    لکھو("║  Flask مکمل جانچ رپورٹ               ║");
    لکھو("╚══════════════════════════════════════╝");

    ایپ.ترتیب_دیں("TESTING", سچ);
    ایپ.ترتیب_دیں("WTF_CSRF_ENABLED", جھوٹ);

    متغیر کلائنٹ = ایپ.ایپ.test_client();

    // ── GET ───────────────────────────────────────────
    لکھو("\n─── GET راستے ───");
    متغیر ج1 = کلائنٹ.get("/");
    جانچ("GET / — 200", ج1.status_code == 200);
    جانچ("GET / — پیغام", ج1.get_json()["پیغام"] == "خوش آمدید Flask");
    جانچ("GET / — زبان", ج1.get_json()["زبان"] == "اردو");

    متغیر ج2 = کلائنٹ.get("/salam/ahmed");
    جانچ("GET /salam/<naam> — 200", ج2.status_code == 200);
    جانچ("GET /salam/<naam> — پیغام", ج2.get_json()["پیغام"] == "السلام ahmed");

    متغیر ج3 = کلائنٹ.get("/ashiya");
    جانچ("GET /ashiya — 200", ج3.status_code == 200);
    جانچ("GET /ashiya — 2 اندراج", لمبائی(ج3.get_json()) == 2);

    // ── POST ──────────────────────────────────────────
    لکھو("\n─── POST / PUT / DELETE ───");
    متغیر ج4 = کلائنٹ.post("/sarif", json={"naam": "فاطمہ", "email": "f@t.com"}, content_type="application/json");
    جانچ("POST /sarif — 201", ج4.status_code == 201);
    جانچ("POST /sarif — نام", ج4.get_json()["نام"] == "فاطمہ");

    متغیر ج5 = کلائنٹ.post("/ashiya", json={"عنوان": "نئی کتاب"}, content_type="application/json");
    جانچ("POST /ashiya — 201", ج5.status_code == 201);
    جانچ("POST /ashiya — عنوان", ج5.get_json()["اضافہ"] == "نئی کتاب");

    متغیر ج6 = کلائنٹ.put("/sarif/7", json={}, content_type="application/json");
    جانچ("PUT /sarif/<id> — 200", ج6.status_code == 200);
    جانچ("PUT /sarif/<id> — حالت", ج6.get_json()["حالت"] == "تازہ");

    متغیر ج7 = کلائنٹ.delete("/sarif/7");
    جانچ("DELETE /sarif/<id> — 200", ج7.status_code == 200);

    // ── Custom response ───────────────────────────────
    لکھو("\n─── Custom Response + Error Handlers ───");
    متغیر ج8 = کلائنٹ.get("/متن");
    جانچ("Custom text/plain — 200", ج8.status_code == 200);
    جانچ("Custom text/plain — مواد", ج8.data.decode("utf-8") == "سادہ متن");

    // ── 404 error handler ─────────────────────────────
    متغیر ج9 = کلائنٹ.get("/غیر_موجود");
    جانچ("404 handler — رمز", ج9.status_code == 404);
    جانچ("404 handler — JSON", ج9.get_json()["رمز"] == 404);

    // ── Blueprint ─────────────────────────────────────
    لکھو("\n─── Blueprint (کتابیں) ───");
    متغیر ج10 = کلائنٹ.get("/kitabain/");
    جانچ("Blueprint GET / — 200", ج10.status_code == 200);
    جانچ("Blueprint GET / — 2 کتابیں", لمبائی(ج10.get_json()) == 2);
    جانچ("Blueprint GET / — عنوان", ج10.get_json()[0]["عنوان"] == "فیض کا کلام");

    متغیر ج11 = کلائنٹ.post("/kitabain/", json={"عنوان": "بوستان"}, content_type="application/json");
    جانچ("Blueprint POST / — 201", ج11.status_code == 201);
    جانچ("Blueprint POST / — عنوان", ج11.get_json()["عنوان"] == "بوستان");

    متغیر ج12 = کلائنٹ.get("/kitabain/3");
    جانچ("Blueprint GET /<id> — 200", ج12.status_code == 200);
    جانچ("Blueprint GET /<id> — id", ج12.get_json()["id"] == 3);

    لکھو(`\n══════════════════════════════════════`);
    لکھو(`  Flask — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════`);
}

مرکز();
