// ══════════════════════════════════════════════════════════════
// Django ORM جانچ — Models · CRUD · FK · Queries · Views
// ══════════════════════════════════════════════════════════════

درآمد {
    ڈجانگو, ڈجانگو_آزمائش, ڈجانگو_درمیانی,
    ڈجانگو_جواب, ڈجانگو_جیسن, ڈجانگو_رجوع,
    ڈجانگو_ماڈل,
    متن_خانہ, عدد_خانہ, اعشاریہ_خانہ, بولین_خانہ, غیر_ملکی_کلید,
    سب_حاصل, فلٹر, ایک_حاصل, بنائیں, حذف_کریں
} سے "اردو/ویب";

درآمد "json";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

لکھو("╔══════════════════════════════════════════════╗");
لکھو("║  Django ORM جانچ                            ║");
لکھو("╚══════════════════════════════════════════════╝");

// ══════════════════════════════════════════════════════════════
// Django ترتیب
// ══════════════════════════════════════════════════════════════

متغیر ایپ = نیا ڈجانگو({ "ڈیٹا_بیس": ":memory:", "ڈیبگ": سچ });
ایپ.ترتیب_دیں();

// ══════════════════════════════════════════════════════════════
// Models تعریف
// ══════════════════════════════════════════════════════════════

لکھو("\n─── Models تعریف ───");

کلاس ناشر توسیع ڈجانگو_ماڈل {
    جامد نام  = متن_خانہ(100)
    جامد شہر  = متن_خانہ(80)
}

کلاس کتاب توسیع ڈجانگو_ماڈل {
    جامد عنوان     = متن_خانہ(200)
    جامد مصنف      = متن_خانہ(100)
    جامد قیمت      = اعشاریہ_خانہ(10, 2)
    جامد دستیاب    = بولین_خانہ(ڈیفالٹ=سچ)
    جامد ناشر_کتاب = غیر_ملکی_کلید(ناشر, متعلقہ_نام="کتابیں")
}

جانچ("ناشر ماڈل بنا", ناشر != خالی);
جانچ("کتاب ماڈل بنا", کتاب != خالی);
جانچ("ناشر objects موجود", ناشر.objects != خالی);
جانچ("کتاب objects موجود", کتاب.objects != خالی);

// ══════════════════════════════════════════════════════════════
// میزیں بنائیں
// ══════════════════════════════════════════════════════════════

لکھو("\n─── میزیں بنانا ───");

کوشش {
    ایپ.میزیں_بنائیں();
    جانچ("میزیں بن گئیں", سچ);
} پکڑو (غ) {
    لکھو(`  ✗ میزیں: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ══════════════════════════════════════════════════════════════
// CREATE
// ══════════════════════════════════════════════════════════════

لکھو("\n─── CREATE (بنائیں) ───");

متغیر ن1 = بنائیں(ناشر, نام="مکتبہ اردو", شہر="لاہور");
متغیر ن2 = بنائیں(ناشر, نام="دار الاشاعت", شہر="کراچی");
متغیر ن3 = بنائیں(ناشر, نام="فیروز سنز", شہر="لاہور");

جانچ("ناشر 1 id موجود", ن1.id > 0);
جانچ("ناشر 1 نام", ن1.نام == "مکتبہ اردو");
جانچ("ناشر 1 شہر", ن1.شہر == "لاہور");

متغیر ک1 = بنائیں(کتاب, عنوان="آگ کا دریا", مصنف="قرۃ العین حیدر", قیمت=450, دستیاب=سچ, ناشر_کتاب=ن1);
متغیر ک2 = بنائیں(کتاب, عنوان="گلستان سعدی", مصنف="سعدی شیرازی", قیمت=350, دستیاب=سچ, ناشر_کتاب=ن2);
متغیر ک3 = بنائیں(کتاب, عنوان="بوستان سعدی", مصنف="سعدی شیرازی", قیمت=280, دستیاب=جھوٹ, ناشر_کتاب=ن2);
متغیر ک4 = بنائیں(کتاب, عنوان="دیوان حافظ", مصنف="حافظ شیرازی", قیمت=500, دستیاب=سچ, ناشر_کتاب=ن3);
متغیر ک5 = بنائیں(کتاب, عنوان="پیام مشرق", مصنف="علامہ اقبال", قیمت=300, دستیاب=سچ, ناشر_کتاب=ن1);

جانچ("کتاب 1 id موجود", ک1.id > 0);
جانچ("کتاب 1 عنوان", ک1.عنوان == "آگ کا دریا");
جانچ("کتاب 1 قیمت", متن(ک1.قیمت) == "450.00" || متن(ک1.قیمت) == "450");
جانچ("کتاب 3 دستیاب=جھوٹ", ک3.دستیاب == جھوٹ);

// ══════════════════════════════════════════════════════════════
// READ — سب_حاصل
// ══════════════════════════════════════════════════════════════

لکھو("\n─── READ — سب_حاصل ───");

متغیر سب_ناشر = سب_حاصل(ناشر);
جانچ("3 ناشر", سب_ناشر.count() == 3);

متغیر سب_کتاب = سب_حاصل(کتاب);
جانچ("5 کتابیں", سب_کتاب.count() == 5);

// ══════════════════════════════════════════════════════════════
// READ — ایک_حاصل
// ══════════════════════════════════════════════════════════════

لکھو("\n─── READ — ایک_حاصل ───");

متغیر حاصل_شدہ = ایک_حاصل(ناشر, id=ن1.id);
جانچ("ایک_حاصل نام", حاصل_شدہ.نام == "مکتبہ اردو");
جانچ("ایک_حاصل شہر", حاصل_شدہ.شہر == "لاہور");

// ══════════════════════════════════════════════════════════════
// READ — فلٹر
// ══════════════════════════════════════════════════════════════

لکھو("\n─── READ — فلٹر ───");

متغیر دستیاب_کتب = فلٹر(کتاب, دستیاب=سچ);
جانچ("دستیاب 4", دستیاب_کتب.count() == 4);

متغیر سعدی_کتب = فلٹر(کتاب, مصنف="سعدی شیرازی");
جانچ("سعدی کتابیں 2", سعدی_کتب.count() == 2);

متغیر لاہور_ناشر = فلٹر(ناشر, شہر="لاہور");
جانچ("لاہور ناشرین 2", لاہور_ناشر.count() == 2);

// ORM queryset chaining
متغیر مہنگی_دستیاب = کتاب.objects.filter(دستیاب=سچ).filter(قیمت__gte=400);
جانچ("مہنگی دستیاب (≥400) = 2", مہنگی_دستیاب.count() == 2);

// icontains search
متغیر تلاش = کتاب.objects.filter(عنوان__icontains="سعدی");
جانچ("عنوان سعدی = 2", تلاش.count() == 2);

// ══════════════════════════════════════════════════════════════
// FK Relations
// ══════════════════════════════════════════════════════════════

لکھو("\n─── FK Relations ───");

متغیر ک1_دوبارہ = ایک_حاصل(کتاب, id=ک1.id);
جانچ("FK ناشر نام", ک1_دوبارہ.ناشر_کتاب.نام == "مکتبہ اردو");
جانچ("FK ناشر شہر", ک1_دوبارہ.ناشر_کتاب.شہر == "لاہور");

// Reverse FK: ناشر → کتابیں
متغیر ن1_دوبارہ = ایک_حاصل(ناشر, id=ن1.id);
جانچ("Reverse FK تعداد", ن1_دوبارہ.کتابیں.count() == 2);

// select_related
متغیر qs = کتاب.objects.filter(id=ک2.id).select_related("ناشر_کتاب");
متغیر ک2_sr = qs[0];
جانچ("select_related ناشر", ک2_sr.ناشر_کتاب.نام == "دار الاشاعت");

// ══════════════════════════════════════════════════════════════
// UPDATE — save()
// ══════════════════════════════════════════════════════════════

لکھو("\n─── UPDATE ───");

ک1.عنوان = "آگ کا دریا (نیا نسخہ)";
ک1.قیمت  = 499;
ک1.save();

متغیر ک1_تازہ = ایک_حاصل(کتاب, id=ک1.id);
جانچ("UPDATE عنوان", ک1_تازہ.عنوان == "آگ کا دریا (نیا نسخہ)");
جانچ("UPDATE قیمت", متن(ک1_تازہ.قیمت) == "499.00" || متن(ک1_تازہ.قیمت) == "499");

// bulk update
کتاب.objects.filter(مصنف="سعدی شیرازی").update(قیمت=320);
متغیر سعدی_قیمت = ایک_حاصل(کتاب, id=ک2.id);
جانچ("bulk update", متن(سعدی_قیمت.قیمت) == "320.00" || متن(سعدی_قیمت.قیمت) == "320");

// ══════════════════════════════════════════════════════════════
// DELETE
// ══════════════════════════════════════════════════════════════

لکھو("\n─── DELETE ───");

متغیر تعداد_قبل = سب_حاصل(کتاب).count();
حذف_کریں(کتاب, id=ک3.id);
متغیر تعداد_بعد = سب_حاصل(کتاب).count();
جانچ("DELETE ایک کتاب", تعداد_بعد == تعداد_قبل - 1);

// ══════════════════════════════════════════════════════════════
// Aggregate
// ══════════════════════════════════════════════════════════════

لکھو("\n─── Aggregate ───");

متغیر کل = سب_حاصل(کتاب).count();
جانچ("باقی 4 کتابیں", کل == 4);

// ══════════════════════════════════════════════════════════════
// Views + ڈجانگو_آزمائش
// ══════════════════════════════════════════════════════════════

لکھو("\n─── Views + ڈجانگو_آزمائش ───");

فنکشن نظارہ_api_کتابیں(req) {
    متغیر qs = سب_حاصل(کتاب).select_related("ناشر_کتاب");
    متغیر نتیجہ = [];
    کے_لیے (متغیر ک کا qs) {
        نتیجہ.شامل({
            "id":      ک.id,
            "عنوان":   ک.عنوان,
            "مصنف":    ک.مصنف,
            "قیمت":    متن(ک.قیمت),
            "دستیاب":  ک.دستیاب,
            "ناشر":    ک.ناشر_کتاب.نام
        });
    }
    واپس ڈجانگو_جیسن(نتیجہ);
}

فنکشن نظارہ_api_ناشرین(req) {
    متغیر qs = سب_حاصل(ناشر);
    متغیر نتیجہ = [];
    کے_لیے (متغیر ن کا qs) {
        نتیجہ.شامل({ "id": ن.id, "نام": ن.نام, "شہر": ن.شہر, "کتابیں": ن.کتابیں.count() });
    }
    واپس ڈجانگو_جیسن(نتیجہ);
}

فنکشن نظارہ_api_کتاب_ایک(req, id) {
    کوشش {
        متغیر ک = ایک_حاصل(کتاب, id=id);
        واپس ڈجانگو_جیسن({ "id": ک.id, "عنوان": ک.عنوان, "ناشر": ک.ناشر_کتاب.نام });
    } پکڑو (غ) {
        واپس ڈجانگو_جیسن({ "خطا": "نہیں ملا" }, 404);
    }
}

فنکشن نظارہ_حالت(req, code) {
    واپس ڈجانگو_جواب(`حالت ${code}`, code);
}

ایپ.راستہ("api/کتابیں/",          نظارہ_api_کتابیں);
ایپ.راستہ("api/ناشرین/",          نظارہ_api_ناشرین);
ایپ.راستہ("api/کتاب/<int:id>/",   نظارہ_api_کتاب_ایک);
ایپ.راستہ("حالت/<int:code>/",     نظارہ_حالت);

متغیر کلائنٹ = نیا ڈجانگو_آزمائش();

// JSON API — کتابیں
متغیر ج_ک = کلائنٹ.حاصل("/api/کتابیں/");
جانچ("API کتابیں 200", ج_ک["رمز"] == 200);
جانچ("API 4 کتابیں", لمبائی(ج_ک["json"]) == 4);
جانچ("API پہلی کتاب مصنف موجود", ج_ک["json"][0]["مصنف"] != "");

// JSON API — ناشرین
متغیر ج_ن = کلائنٹ.حاصل("/api/ناشرین/");
جانچ("API ناشرین 200", ج_ن["رمز"] == 200);
جانچ("API 3 ناشرین", لمبائی(ج_ن["json"]) == 3);
جانچ("API ناشر شہر موجود", ج_ن["json"][0]["شہر"] != "");

// JSON API — ایک کتاب
متغیر ج_ایک = کلائنٹ.حاصل(`/api/کتاب/${ک1.id}/`);
جانچ("API ایک کتاب 200", ج_ایک["رمز"] == 200);
جانچ("API ناشر نام", ج_ایک["json"]["ناشر"] == "مکتبہ اردو");

// JSON API — 404
متغیر ج_غلط = کلائنٹ.حاصل("/api/کتاب/9999/");
جانچ("API 404", ج_غلط["رمز"] == 404);

// مختلف حالت کوڈ
جانچ("200 OK",        کلائنٹ.حاصل("/حالت/200/")["رمز"] == 200);
جانچ("201 Created",   کلائنٹ.حاصل("/حالت/201/")["رمز"] == 201);
جانچ("400 Bad Req",   کلائنٹ.حاصل("/حالت/400/")["رمز"] == 400);
جانچ("500 Server Err",کلائنٹ.حاصل("/حالت/500/")["رمز"] == 500);

// ══════════════════════════════════════════════════════════════
// Middleware
// ══════════════════════════════════════════════════════════════

لکھو("\n─── Middleware ───");

کلاس جانچ_درمیانی توسیع ڈجانگو_درمیانی {
    قبل(req) {
        // middleware runs
    }
    بعد(req, res) {
        واپس res;
    }
}

جانچ("Middleware کلاس بنا", جانچ_درمیانی != خالی);

// ══════════════════════════════════════════════════════════════
// نتیجہ
// ══════════════════════════════════════════════════════════════

لکھو(`\n══════════════════════════════════════════════`);
لکھو(`  Django ORM — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
لکھو(`══════════════════════════════════════════════`);
