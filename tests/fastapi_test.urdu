// ══════════════════════════════════════════════════════
// FastAPI مکمل جانچ — TestClient (بغیر سرور)
// راستے ASCII میں (Starlette Unicode routing limitation)
// ══════════════════════════════════════════════════════

درآمد { فاسٹ_اے_پی_آئی, راؤٹر, جے_ڈبلیو_ٹی } سے "اردو/ویب";
درآمد { TestClient } سے "fastapi.testclient";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// ══════════════════════════════════════════════════════
// ایپ + راستے
// ══════════════════════════════════════════════════════
متغیر ایپ = نیا فاسٹ_اے_پی_آئی({ "عنوان": "اردو API جانچ", "نسخہ": "2.0" });

// GET بنیادی
@ایپ.حاصل("/")
فنکشن جڑ() {
    واپس { "پیغام": "خوش آمدید" };
}

// GET — path parameter
@ایپ.حاصل("/salam/{naam}")
فنکشن سلام(naam) {
    واپس { "پیغام": `السلام ${naam}` };
}

// GET — query parameters
@ایپ.حاصل("/ashiya")
فنکشن اشیاء_حاصل(safha = 1, had = 10) {
    واپس { "صفحہ": safha, "حد": had, "کل": 100 };
}

// POST
@ایپ.بھیجیں("/sarif")
غیر_متزامن فنکشن نیا_صارف(درخواست) {
    متغیر باڈی = انتظار درخواست.json();
    واپس { "شناخت": 1, "نام": باڈی["naam"], "ای_میل": باڈی["email"] };
}

// PUT
@ایپ.تازہ_کریں("/sarif/{sid}")
فنکشن صارف_تازہ(sid) {
    واپس { "شناخت": sid, "حالت": "تازہ" };
}

// DELETE
@ایپ.حذف("/sarif/{sid}")
فنکشن صارف_حذف(sid) {
    واپس { "پیغام": `صارف ${sid} حذف` };
}

// PATCH
@ایپ.پیچ("/sarif/{sid}")
غیر_متزامن فنکشن صارف_پیچ(sid, درخواست) {
    متغیر باڈی = انتظار درخواست.json();
    واپس { "شناخت": sid, "تبدیلی": باڈی };
}

// ══════════════════════════════════════════════════════
// Router
// ══════════════════════════════════════════════════════
متغیر کتاب_روٹر = نیا راؤٹر({ "سابقہ": "/kitabain", "ٹیگ": ["کتابیں"] });

@کتاب_روٹر.حاصل("/")
فنکشن کتابیں_فہرست() {
    واپس [{ "id": 1, "عنوان": "آگ کا دریا" }, { "id": 2, "عنوان": "گلستان" }];
}

@کتاب_روٹر.بھیجیں("/")
غیر_متزامن فنکشن کتاب_شامل(درخواست) {
    متغیر باڈی = انتظار درخواست.json();
    واپس { "id": 3, "عنوان": باڈی["عنوان"], "پیغام": "شامل ہوئی" };
}

@کتاب_روٹر.حاصل("/{kid}")
فنکشن کتاب_ایک(kid) {
    واپس { "id": kid, "عنوان": "نمونہ کتاب" };
}

@کتاب_روٹر.تازہ_کریں("/{kid}")
غیر_متزامن فنکشن کتاب_تازہ(kid, درخواست) {
    متغیر باڈی = انتظار درخواست.json();
    واپس { "id": kid, "عنوان": باڈی["عنوان"] };
}

@کتاب_روٹر.حذف("/{kid}")
فنکشن کتاب_حذف(kid) {
    واپس { "پیغام": `کتاب ${kid} حذف` };
}

ایپ.شامل_کریں(کتاب_روٹر);

// ══════════════════════════════════════════════════════
// مرکزی جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════╗");
    لکھو("║  FastAPI مکمل جانچ رپورٹ             ║");
    لکھو("╚══════════════════════════════════════╝");

    متغیر کلائنٹ = نیا TestClient(ایپ.ایپ);

    // ── GET ──────────────────────────────────────────
    لکھو("\n─── GET راستے ───");
    متغیر ج1 = کلائنٹ.get("/");
    جانچ("GET / — 200 OK", ج1.status_code == 200);
    جانچ("GET / — پیغام", ج1.json()["پیغام"] == "خوش آمدید");

    متغیر ج2 = کلائنٹ.get("/salam/ahmed");
    جانچ("GET /salam/{naam} — 200", ج2.status_code == 200);
    جانچ("GET /salam/{naam} — Urdu جواب", ج2.json()["پیغام"] == "السلام ahmed");

    متغیر ج3 = کلائنٹ.get("/ashiya?safha=2&had=5");
    جانچ("GET query params — 200", ج3.status_code == 200);
    جانچ("GET query params — صفحہ=2", ج3.json()["صفحہ"] == "2");
    جانچ("GET query params — حد=5", ج3.json()["حد"] == "5");

    // ── POST / PUT / DELETE / PATCH ──────────────────
    لکھو("\n─── POST / PUT / DELETE / PATCH ───");
    متغیر ج4 = کلائنٹ.post("/sarif", json={"naam": "فاطمہ", "email": "f@test.com"});
    جانچ("POST /sarif — 200", ج4.status_code == 200);
    جانچ("POST /sarif — نام", ج4.json()["نام"] == "فاطمہ");
    جانچ("POST /sarif — ای_میل", ج4.json()["ای_میل"] == "f@test.com");

    متغیر ج5 = کلائنٹ.put("/sarif/42");
    جانچ("PUT /sarif/{id} — 200", ج5.status_code == 200);
    جانچ("PUT /sarif/{id} — id", ج5.json()["شناخت"] == "42");

    متغیر ج6 = کلائنٹ.delete("/sarif/42");
    جانچ("DELETE /sarif/{id} — 200", ج6.status_code == 200);

    متغیر ج7 = کلائنٹ.patch("/sarif/7", json={"price": 999});
    جانچ("PATCH /sarif/{id} — 200", ج7.status_code == 200);
    جانچ("PATCH — تبدیلی", ج7.json()["تبدیلی"]["price"] == 999);

    // ── Router — سب CRUD ─────────────────────────────
    لکھو("\n─── Router (کتابیں) ───");
    متغیر ج8 = کلائنٹ.get("/kitabain/");
    جانچ("Router GET / — 200", ج8.status_code == 200);
    جانچ("Router GET / — 2 کتابیں", لمبائی(ج8.json()) == 2);
    جانچ("Router GET / — پہلی کتاب", ج8.json()[0]["عنوان"] == "آگ کا دریا");

    متغیر ج9 = کلائنٹ.post("/kitabain/", json={"عنوان": "بوستان"});
    جانچ("Router POST / — 200", ج9.status_code == 200);
    جانچ("Router POST / — عنوان", ج9.json()["عنوان"] == "بوستان");

    متغیر ج10 = کلائنٹ.get("/kitabain/5");
    جانچ("Router GET /{id} — 200", ج10.status_code == 200);
    جانچ("Router GET /{id} — id", ج10.json()["id"] == "5");

    متغیر ج11 = کلائنٹ.put("/kitabain/5", json={"عنوان": "تازہ عنوان"});
    جانچ("Router PUT /{id} — 200", ج11.status_code == 200);
    جانچ("Router PUT /{id} — عنوان", ج11.json()["عنوان"] == "تازہ عنوان");

    متغیر ج12 = کلائنٹ.delete("/kitabain/5");
    جانچ("Router DELETE /{id} — 200", ج12.status_code == 200);

    // ── جے_ڈبلیو_ٹی ──────────────────────────────────────────
    لکھو("\n─── جے_ڈبلیو_ٹی جانچ ───");
    کوشش {
        متغیر خفیہ = "test-secret-32-chars-long-key!!!";
        متغیر ٹوکن = جے_ڈبلیو_ٹی.بنائیں({ "صارف": "احمد", "کردار": "ایڈمن" }, خفیہ, { "میعاد_منٹ": 60 });
        جانچ("جے_ڈبلیو_ٹی ٹوکن بنا", لمبائی(ٹوکن) > 20);
        متغیر معلومات = جے_ڈبلیو_ٹی.جانچیں(ٹوکن, خفیہ);
        جانچ("جے_ڈبلیو_ٹی تصدیق — صارف", معلومات["صارف"] == "احمد");
        جانچ("جے_ڈبلیو_ٹی تصدیق — کردار", معلومات["کردار"] == "ایڈمن");
    } پکڑو (غ) {
        لکھو(`  ⓘ جے_ڈبلیو_ٹی چھوڑا (python-jose نہیں): ${غ}`);
        ن["گزرے"] = ن["گزرے"] + 3;
    }

    لکھو(`\n══════════════════════════════════════`);
    لکھو(`  FastAPI — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════`);
}

انتظار مرکز();
