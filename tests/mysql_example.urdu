// ══════════════════════════════════════════════════════
// اردو پروگرامنگ لینگویج — مائی_ایس_کیو_ایل / MariaDB مثال
// WAMP Server پر مکمل CRUD آپریشنز
// ══════════════════════════════════════════════════════

درآمد { مائی_ایس_کیو_ایل } سے "اردو/ڈیٹا_بیس";

// ─── مائی_ایس_کیو_ایل سے جڑیں (root / خالی پاس ورڈ) ─────────────
متغیر db = نیا مائی_ایس_کیو_ایل({
    میزبان:    "localhost",
    صارف:      "root",
    پاس_ورڈ:  "",
    پورٹ:      3306
});

غیر_متزامن فنکشن مرکز() {

    // ─── جڑیں ─────────────────────────────────────────
    انتظار db.جوڑیں();
    لکھو("✓ مائی_ایس_کیو_ایل / MariaDB سے جڑ گئے\n");

    // ─── ڈیٹا بیس اور جدول بنائیں ────────────────────
    انتظار db.چلائیں("CREATE DATABASE IF NOT EXISTS urdu_test CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci");
    انتظار db.چلائیں("USE urdu_test");
    لکھو("✓ ڈیٹا بیس 'urdu_test' تیار");

    انتظار db.چلائیں("DROP TABLE IF EXISTS ملازمین");
    انتظار db.چلائیں(`
        CREATE TABLE ملازمین (
            شناخت     INT AUTO_INCREMENT PRIMARY KEY,
            نام        VARCHAR(100) NOT NULL,
            محکمہ      VARCHAR(50),
            تنخواہ     DECIMAL(10,2),
            شہر        VARCHAR(50),
            فعال       TINYINT(1) DEFAULT 1
        )
    `);
    لکھو("✓ جدول 'ملازمین' بنایا گیا\n");

    // ─── ڈیٹا داخل کریں ───────────────────────────────
    لکھو("═══ ڈیٹا داخل کرنا ═══");
    متغیر ملازمین = [
        { نام: "احمد علی",    محکمہ: "انجینئرنگ",  تنخواہ: 85000, شہر: "کراچی"  },
        { نام: "فاطمہ خان",   محکمہ: "ڈیزائن",     تنخواہ: 72000, شہر: "لاہور"  },
        { نام: "محمد عمر",    محکمہ: "انجینئرنگ",  تنخواہ: 91000, شہر: "اسلام_آباد" },
        { نام: "عائشہ صدیق",  محکمہ: "HR",          تنخواہ: 68000, شہر: "کراچی"  },
        { نام: "بلال حسین",   محکمہ: "فروخت",       تنخواہ: 55000, شہر: "لاہور"  },
        { نام: "زینب میر",    محکمہ: "ڈیزائن",     تنخواہ: 78000, شہر: "کوئٹہ"  },
        { نام: "عمران شاہ",   محکمہ: "HR",          تنخواہ: 62000, شہر: "پشاور" },
        { نام: "مریم اقبال",  محکمہ: "انجینئرنگ",  تنخواہ: 95000, شہر: "کراچی"  },
    ];

    کے_لیے (متغیر م میں ملازمین) {
        انتظار db.چلائیں(
            "INSERT INTO ملازمین (نام, محکمہ, تنخواہ, شہر) VALUES (?, ?, ?, ?)",
            [م.نام, م.محکمہ, م.تنخواہ, م.شہر]
        );
    }
    لکھو(`  ${لمبائی(ملازمین)} ملازمین کے ریکارڈ داخل کیے گئے ✓\n`);

    // ─── تمام ریکارڈ دیکھیں ───────────────────────────
    لکھو("═══ تمام ملازمین (تنخواہ کے مطابق) ═══");
    متغیر سب = انتظار db.سوال("SELECT * FROM ملازمین ORDER BY تنخواہ DESC");
    کے_لیے (متغیر م میں سب) {
        لکھو(`  [${م.شناخت}] ${م.نام.ljust(15)} | ${م.محکمہ.ljust(12)} | Rs ${م.تنخواہ} | ${م.شہر}`);
    }

    // ─── WHERE فلٹر ────────────────────────────────────
    لکھو("\n═══ انجینئرنگ کے ملازمین ═══");
    متغیر انجینئرز = انتظار db.سوال(
        "SELECT نام, تنخواہ FROM ملازمین WHERE محکمہ = ? ORDER BY تنخواہ DESC",
        ["انجینئرنگ"]
    );
    کے_لیے (متغیر م میں انجینئرز) {
        لکھو(`  ${م.نام}: Rs ${م.تنخواہ}`);
    }

    // ─── GROUP BY / اجتماعی افعال ─────────────────────
    لکھو("\n═══ محکمہ وار اوسط تنخواہ ═══");
    متغیر گروپ = انتظار db.سوال(`
        SELECT محکمہ,
               COUNT(*) AS تعداد,
               AVG(تنخواہ) AS اوسط_تنخواہ,
               MAX(تنخواہ) AS زیادہ_تنخواہ
        FROM ملازمین
        GROUP BY محکمہ
        ORDER BY اوسط_تنخواہ DESC
    `);
    کے_لیے (متغیر ر میں گروپ) {
        لکھو(`  ${ر.محکمہ.ljust(14)} | تعداد: ${ر.تعداد} | اوسط: Rs ${گول(ر.اوسط_تنخواہ, 0)} | زیادہ: Rs ${ر.زیادہ_تنخواہ}`);
    }

    // ─── ریکارڈ اپ ڈیٹ ────────────────────────────────
    لکھو("\n═══ تنخواہ 10% بڑھانا (انجینئرنگ) ═══");
    متغیر متاثرہ = انتظار db.چلائیں(
        "UPDATE ملازمین SET تنخواہ = تنخواہ * 1.10 WHERE محکمہ = ?",
        ["انجینئرنگ"]
    );
    لکھو(`  ${متاثرہ} ملازمین کی تنخواہ بڑھائی گئی ✓`);

    // اپ ڈیٹ کے بعد دوبارہ دیکھیں
    متغیر بعد = انتظار db.سوال(
        "SELECT نام, تنخواہ FROM ملازمین WHERE محکمہ = ?",
        ["انجینئرنگ"]
    );
    کے_لیے (متغیر م میں بعد) {
        لکھو(`  ${م.نام}: Rs ${م.تنخواہ}`);
    }

    // ─── ایک ریکارڈ حذف ───────────────────────────────
    لکھو("\n═══ ریکارڈ حذف (سب سے کم تنخواہ) ═══");
    متغیر کم = انتظار db.سوال(
        "SELECT شناخت, نام, تنخواہ FROM ملازمین ORDER BY تنخواہ ASC LIMIT 1"
    );
    اگر (لمبائی(کم) > 0) {
        لکھو(`  حذف ہو رہا ہے: ${کم[0].نام} (Rs ${کم[0].تنخواہ})`);
        انتظار db.چلائیں("DELETE FROM ملازمین WHERE شناخت = ?", [کم[0].شناخت]);
        لکھو("  ✓ ریکارڈ حذف ہوا");
    }

    // ─── JOIN مثال ─────────────────────────────────────
    // پہلے محکمہ جدول بنائیں
    انتظار db.چلائیں("DROP TABLE IF EXISTS محکمے");
    انتظار db.چلائیں(`
        CREATE TABLE محکمے (
            نام     VARCHAR(50) PRIMARY KEY,
            مینیجر  VARCHAR(100),
            بجٹ     DECIMAL(12,2)
        )
    `);
    انتظار db.چلائیں("INSERT INTO محکمے VALUES ('انجینئرنگ', 'ڈاکٹر کریم', 5000000)");
    انتظار db.چلائیں("INSERT INTO محکمے VALUES ('ڈیزائن', 'سارہ نظامی', 3000000)");
    انتظار db.چلائیں("INSERT INTO محکمے VALUES ('HR', 'طارق محمود', 2000000)");
    انتظار db.چلائیں("INSERT INTO محکمے VALUES ('فروخت', 'نادیہ اکبر', 4000000)");

    لکھو("\n═══ JOIN: ملازمین اور ان کے محکمے ═══");
    متغیر جوائن = انتظار db.سوال(`
        SELECT م.نام, م.تنخواہ, م.شہر, د.مینیجر, د.بجٹ
        FROM ملازمین م
        INNER JOIN محکمے د ON م.محکمہ = د.نام
        ORDER BY م.تنخواہ DESC
    `);
    کے_لیے (متغیر ر میں جوائن) {
        لکھو(`  ${ر.نام.ljust(15)} | مینیجر: ${ر.مینیجر} | Rs ${ر.تنخواہ}`);
    }

    // ─── LIKE / تلاش ───────────────────────────────────
    لکھو("\n═══ کراچی کے ملازمین ═══");
    متغیر کراچی = انتظار db.سوال(
        "SELECT نام, محکمہ, تنخواہ FROM ملازمین WHERE شہر LIKE ?",
        ["%کراچی%"]
    );
    کے_لیے (متغیر م میں کراچی) {
        لکھو(`  ${م.نام} (${م.محکمہ}): Rs ${م.تنخواہ}`);
    }

    // ─── کل تنخواہ ─────────────────────────────────────
    متغیر کل = انتظار db.سوال("SELECT SUM(تنخواہ) AS کل_تنخواہ, COUNT(*) AS تعداد FROM ملازمین");
    لکھو(`\nکل ملازمین: ${کل[0].تعداد} | کل تنخواہ: Rs ${کل[0].کل_تنخواہ}`);

    // ─── صفائی اور بند ────────────────────────────────
    انتظار db.چلائیں("DROP TABLE IF EXISTS ملازمین");
    انتظار db.چلائیں("DROP TABLE IF EXISTS محکمے");
    انتظار db.چلائیں("DROP DATABASE IF EXISTS urdu_test");
    لکھو("\n✓ ٹیسٹ ڈیٹا بیس صاف کر دیا گیا");
    انتظار db.منقطع();
    لکھو("✓ مائی_ایس_کیو_ایل بند ہوا");
}

مرکز();
