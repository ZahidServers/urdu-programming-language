// ══════════════════════════════════════════════
// اردو/ڈھانچے — Data Structures Library Test
// ══════════════════════════════════════════════

درآمد { مربوط_فہرست, ڈھیر, قطار, دوطرفہ_قطار, ترجیحی_قطار, بائنری_تلاش_درخت, گراف } سے "اردو/ڈھانچے";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// ─── مربوط فہرست ─────────────────────────────
لکھو("\n─── مربوط_فہرست ───");

متغیر ف = نیا مربوط_فہرست();
ف.شامل_کریں(10);
ف.شامل_کریں(20);
ف.شامل_کریں(30);
جانچ("شامل_کریں تعداد", ف.فہرست().لمبائی == 3);
جانچ("فہرست ترتیب", ف.فہرست()[0] == 10 && ف.فہرست()[2] == 30);
جانچ("موجود_ہے", ف.موجود_ہے(20));
جانچ("موجود نہیں", !ف.موجود_ہے(99));
ف.شروع_میں_شامل(5);
جانچ("شروع_میں_شامل", ف.فہرست()[0] == 5);
ف.نکالیں(20);
جانچ("نکالیں", !ف.موجود_ہے(20));
ف.الٹا_کریں();
جانچ("الٹا_کریں", ف.فہرست()[0] == 30);

// ─── ڈھیر ────────────────────────────────────
لکھو("\n─── ڈھیر (Stack) ───");

متغیر س = نیا ڈھیر();
جانچ("خالی شروع", س.خالی_ہے());
س.دھکیلیں(1);
س.دھکیلیں(2);
س.دھکیلیں(3);
جانچ("جھانکیں", س.جھانکیں() == 3);
جانچ("نکالیں LIFO", س.نکالیں() == 3);
جانچ("تعداد", س.خالی_ہے() == جھوٹ);

// ─── قطار ────────────────────────────────────
لکھو("\n─── قطار (Queue) ───");

متغیر ق = نیا قطار();
جانچ("خالی شروع", ق.خالی_ہے());
ق.شامل_کریں("الف");
ق.شامل_کریں("ب");
ق.شامل_کریں("ج");
جانچ("اگلا", ق.اگلا() == "الف");
جانچ("نکالیں FIFO", ق.نکالیں() == "الف");
جانچ("تعداد", ق.خالی_ہے() == جھوٹ);

// ─── دوطرفہ قطار ─────────────────────────────
لکھو("\n─── دوطرفہ_قطار (Deque) ───");

متغیر د = نیا دوطرفہ_قطار();
د.دائیں_شامل(2);
د.بائیں_شامل(1);
د.دائیں_شامل(3);
جانچ("بائیں_جھانکیں", د.بائیں_جھانکیں() == 1);
جانچ("دائیں_جھانکیں", د.دائیں_جھانکیں() == 3);
جانچ("بائیں_نکالیں", د.بائیں_نکالیں() == 1);
جانچ("دائیں_نکالیں", د.دائیں_نکالیں() == 3);

// ─── ترجیحی قطار ─────────────────────────────
لکھو("\n─── ترجیحی_قطار (Min-Heap) ───");

متغیر پ = نیا ترجیحی_قطار();
پ.شامل_کریں("کام_ج", ترجیح=3);
پ.شامل_کریں("کام_الف", ترجیح=1);
پ.شامل_کریں("کام_ب", ترجیح=2);
جانچ("سب سے پہلے کم ترجیح", پ.نکالیں() == "کام_الف");
جانچ("پھر دوسری ترجیح", پ.نکالیں() == "کام_ب");

متغیر زیادہ = نیا ترجیحی_قطار(زیادہ_سے_زیادہ=سچ);
زیادہ.شامل_کریں("کم", ترجیح=1);
زیادہ.شامل_کریں("زیادہ", ترجیح=10);
جانچ("Max-Heap", زیادہ.نکالیں() == "زیادہ");

// ─── بائنری تلاش درخت ────────────────────────
لکھو("\n─── بائنری_تلاش_درخت ───");

متغیر بت = نیا بائنری_تلاش_درخت();
کے_لیے (متغیر v میں [5, 3, 7, 1, 4, 6, 8]) {
    بت.داخل_کریں(v);
}
جانچ("ترتیب_سے", بت.ترتیب_سے()[0] == 1 && بت.ترتیب_سے()[6] == 8);
جانچ("موجود_ہے 4", بت.موجود_ہے(4));
جانچ("موجود نہیں 9", !بت.موجود_ہے(9));
جانچ("سب_سے_چھوٹا", بت.سب_سے_چھوٹا() == 1);
جانچ("سب_سے_بڑا", بت.سب_سے_بڑا() == 8);
بت.نکالیں(3);
جانچ("نکالیں پھر تلاش", !بت.موجود_ہے(3));
جانچ("ترتیب برقرار", بت.ترتیب_سے()[0] == 1);

// ─── گراف ────────────────────────────────────
لکھو("\n─── گراف ───");

متغیر گ = نیا گراف();
گ.کنارہ_شامل_کریں("A", "B");
گ.کنارہ_شامل_کریں("B", "C");
گ.کنارہ_شامل_کریں("A", "C", 10);
جانچ("BFS", گ.چوڑائی_تلاش("A")[0] == "A");
جانچ("DFS", گ.گہرائی_تلاش("A")[0] == "A");
جانچ("راستہ_ہے", گ.راستہ_ہے("A", "C"));
متغیر ہدایت = نیا گراف(ہدایت_یافتہ=سچ);
ہدایت.کنارہ_شامل_کریں("X", "Y");
جانچ("راستہ نہیں (ہدایت)", !ہدایت.راستہ_ہے("Y", "X"));
متغیر راستہ = گ.مختصر_راستہ("A", "C");
جانچ("مختصر_راستہ ملا", راستہ != خالی);

متغیر دجک = نیا گراف(ہدایت_یافتہ=جھوٹ);
دجک.کنارہ_شامل_کریں("X", "Y", 4);
دجک.کنارہ_شامل_کریں("Y", "Z", 2);
دجک.کنارہ_شامل_کریں("X", "Z", 10);
متغیر ر = دجک.مختصر_راستہ("X", "Z");
جانچ("Dijkstra کم وزن راستہ", ر[0] == "X" && ر[2] == "Z");

// ─── نتیجہ ────────────────────────────────────
لکھو(`\n══════════════════════════════════════`);
لکھو(`  ڈھانچے جانچ — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
لکھو(`══════════════════════════════════════`);
