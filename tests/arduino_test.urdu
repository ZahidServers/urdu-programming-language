// ══════════════════════════════════════════════
// اردو/آردوینو — Arduino Library Test
// (بغیر حقیقی بورڈ کے: ثابتوں، سیریل، اور API جانچ)
// ══════════════════════════════════════════════

درآمد {
    اونچا, نیچا,
    ان_پٹ, ان_پٹ_پل_اپ, آؤٹ_پٹ,
    PWM_موڈ, سرو_موڈ_نام, اینالاگ_موڈ,
    پورٹ_فہرست
} سے "اردو/آردوینو";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

لکھو("╔══════════════════════════════════════╗");
لکھو("║  آردوینو جانچ                        ║");
لکھو("╚══════════════════════════════════════╝");

// ─── ثابت قدریں ──────────────────────────────
لکھو("\n─── ثابت قدریں ───");

جانچ("اونچا = 1", اونچا == 1);
جانچ("نیچا = 0", نیچا == 0);
جانچ("ان_پٹ = 0", ان_پٹ == 0);
جانچ("آؤٹ_پٹ = 1", آؤٹ_پٹ == 1);
جانچ("ان_پٹ_پل_اپ = 11", ان_پٹ_پل_اپ == 11);
جانچ("PWM_موڈ = 3", PWM_موڈ == 3);
جانچ("سرو_موڈ_نام = 4", سرو_موڈ_نام == 4);
جانچ("اینالاگ_موڈ = 2", اینالاگ_موڈ == 2);
جانچ("اونچا نیچا مختلف", اونچا != نیچا);

// ─── پورٹ_فہرست ──────────────────────────────
لکھو("\n─── پورٹ_فہرست ───");

کوشش {
    متغیر پورٹس = پورٹ_فہرست();
    جانچ("پورٹ_فہرست فہرست ہے", پورٹس != خالی);
    لکھو(`  ⓘ دستیاب پورٹس: ${پورٹس.لمبائی}`);
    اگر (پورٹس.لمبائی > 0) {
        لکھو(`  ⓘ پہلا پورٹ: ${پورٹس[0]}`);
    } ورنہ {
        لکھو("  ⓘ کوئی سیریل پورٹ نہیں (عام طور پر بغیر بورڈ کے)");
    }
} پکڑو (غ) {
    لکھو(`  ✗ پورٹ_فہرست غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ─── سیریل — غلط پورٹ پر غلطی ───────────────
لکھو("\n─── سیریل غلطی سنبھالنا ───");

کوشش {
    درآمد { سیریل } سے "اردو/آردوینو";
    متغیر پورٹ = نیا سیریل("COM_غیر_موجود_999", 9600);
    لکھو("  ⓘ پورٹ کھلا (غیر متوقع)");
} پکڑو (غ) {
    جانچ("غلط پورٹ پر غلطی آئی", سچ);
    لکھو(`  ⓘ غلطی (متوقع): ${غ.پیغام}`);
}

// ─── آردوینو کلاس — بغیر بورڈ کے غلطی ─────────
لکھو("\n─── آردوینو کلاس (pyfirmata2 غیر موجود یا بورڈ نہیں) ───");

کوشش {
    درآمد { آردوینو } سے "اردو/آردوینو";
    متغیر بورڈ = نیا آردوینو("COM_غیر_موجود");
    لکھو("  ⓘ بورڈ کھلا (غیر متوقع)");
} پکڑو (غ) {
    جانچ("آردوینو — بورڈ نہیں: غلطی آئی", سچ);
    لکھو(`  ⓘ غلطی (متوقع): ${غ.پیغام}`);
}

// ─── سیریل_آردوینو — غلط پورٹ پر غلطی ──────
لکھو("\n─── سیریل_آردوینو غلطی ───");

کوشش {
    درآمد { سیریل_آردوینو } سے "اردو/آردوینو";
    متغیر س = نیا سیریل_آردوینو("COM_غیر_موجود");
    لکھو("  ⓘ پورٹ کھلا (غیر متوقع)");
} پکڑو (غ) {
    جانچ("سیریل_آردوینو — غلط پورٹ: غلطی آئی", سچ);
    لکھو(`  ⓘ غلطی (متوقع): ${غ.پیغام}`);
}

// ─── I2C_آلہ کلاس موجود ──────────────────────
لکھو("\n─── کلاس درآمد جانچ ───");

کوشش {
    درآمد { I2C_آلہ, آردوینو_میگا, آردوینو_نانو, آردوینو_ڈیو } سے "اردو/آردوینو";
    جانچ("I2C_آلہ موجود", I2C_آلہ != خالی);
    جانچ("آردوینو_میگا موجود", آردوینو_میگا != خالی);
    جانچ("آردوینو_نانو موجود", آردوینو_نانو != خالی);
    جانچ("آردوینو_ڈیو موجود", آردوینو_ڈیو != خالی);
} پکڑو (غ) {
    لکھو(`  ✗ کلاس درآمد غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

لکھو(`\n══════════════════════════════════════`);
لکھو(`  آردوینو جانچ — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
لکھو(`  (حقیقی آردوینو بورڈ کے بغیر بیشتر جانچیں ممکن نہیں)`);
لکھو(`══════════════════════════════════════`);
