// ══════════════════════════════════════════════
// اردو/الگورتھم — Algorithms Library Test
// ══════════════════════════════════════════════

درآمد {
    بلبلہ_ترتیب, انتخاب_ترتیب, اندراج_ترتیب,
    ضم_ترتیب, تیز_ترتیب, ڈھیر_ترتیب,
    خطی_تلاش, دوئی_تلاش,
    ہیش_جدول,
    اعظم_مشترک_قاسم, اقل_مشترک_ضرب,
    فیبوناچی, فیبوناچی_سلسلہ, فیکٹوریل,
    عدد_زائی_ہے, اعداد_زائیہ, اعداد_زائیہ_عوامل,
    لمبی_مشترک_ذیل_ترتیب, لیوینشٹین_فاصلہ, کے_ایم_پی_تلاش
} سے "اردو/الگورتھم";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

متغیر بے_ترتیب = [64, 34, 25, 12, 22, 11, 90];
متغیر ترتیب_شدہ = [11, 12, 22, 25, 34, 64, 90];

// ─── ترتیب الگورتھم ─────────────────────────
لکھو("\n─── ترتیب الگورتھم ───");

متغیر نتیجہ = بلبلہ_ترتیب(بے_ترتیب);
جانچ("بلبلہ_ترتیب", نتیجہ[0] == 11 && نتیجہ[6] == 90);

نتیجہ = انتخاب_ترتیب(بے_ترتیب);
جانچ("انتخاب_ترتیب", نتیجہ[0] == 11 && نتیجہ[6] == 90);

نتیجہ = اندراج_ترتیب(بے_ترتیب);
جانچ("اندراج_ترتیب", نتیجہ[0] == 11 && نتیجہ[6] == 90);

نتیجہ = ضم_ترتیب(بے_ترتیب);
جانچ("ضم_ترتیب", نتیجہ[0] == 11 && نتیجہ[6] == 90);

نتیجہ = تیز_ترتیب(بے_ترتیب);
جانچ("تیز_ترتیب", نتیجہ[0] == 11 && نتیجہ[6] == 90);

نتیجہ = ڈھیر_ترتیب(بے_ترتیب);
جانچ("ڈھیر_ترتیب", نتیجہ[0] == 11 && نتیجہ[6] == 90);

جانچ("اصل فہرست محفوظ", بے_ترتیب[0] == 64);

// ─── تلاش ────────────────────────────────────
لکھو("\n─── تلاش ───");

جانچ("خطی_تلاش ملا", خطی_تلاش(بے_ترتیب, 25) == 2);
جانچ("خطی_تلاش نہیں ملا", خطی_تلاش(بے_ترتیب, 99) == -1);
جانچ("دوئی_تلاش ملا", دوئی_تلاش(ترتیب_شدہ, 25) == 3);
جانچ("دوئی_تلاش نہیں ملا", دوئی_تلاش(ترتیب_شدہ, 99) == -1);
جانچ("دوئی_تلاش پہلا", دوئی_تلاش(ترتیب_شدہ, 11) == 0);
جانچ("دوئی_تلاش آخری", دوئی_تلاش(ترتیب_شدہ, 90) == 6);

// ─── ہیش جدول ────────────────────────────────
لکھو("\n─── ہیش_جدول ───");

متغیر ج = نیا ہیش_جدول();
ج["نام"] = "علی";
ج["عمر"] = 25;
ج["شہر"] = "کراچی";
جانچ("قدر محفوظ", ج["نام"] == "علی");
جانچ("قدر تازہ", ج["عمر"] == 25);
جانچ("موجود_ہے", ج.موجود_ہے("شہر"));
جانچ("موجود نہیں", !ج.موجود_ہے("ملک"));
ج["نام"] = "احمد";
جانچ("قدر بدلی", ج["نام"] == "احمد");
جانچ("حاصل_کریں ڈیفالٹ", ج.حاصل_کریں("ملک", "پاکستان") == "پاکستان");

// ─── ریاضی ───────────────────────────────────
لکھو("\n─── ریاضی ───");

جانچ("GCD(12, 8)", اعظم_مشترک_قاسم(12, 8) == 4);
جانچ("GCD(100, 75)", اعظم_مشترک_قاسم(100, 75) == 25);
جانچ("LCM(4, 6)", اقل_مشترک_ضرب(4, 6) == 12);
جانچ("فیبوناچی(0)", فیبوناچی(0) == 0);
جانچ("فیبوناچی(1)", فیبوناچی(1) == 1);
جانچ("فیبوناچی(10)", فیبوناچی(10) == 55);
متغیر سلسلہ = فیبوناچی_سلسلہ(6);
جانچ("فیبوناچی_سلسلہ", سلسلہ[5] == 5);
جانچ("فیکٹوریل(5)", فیکٹوریل(5) == 120);
جانچ("فیکٹوریل(0)", فیکٹوریل(0) == 1);
جانچ("عدد_زائی 2", عدد_زائی_ہے(2));
جانچ("عدد_زائی 17", عدد_زائی_ہے(17));
جانچ("غیر_زائی 1", !عدد_زائی_ہے(1));
جانچ("غیر_زائی 9", !عدد_زائی_ہے(9));
متغیر زائیہ = اعداد_زائیہ(20);
جانچ("چھلنی تعداد", زائیہ.لمبائی == 8);
جانچ("چھلنی پہلا", زائیہ[0] == 2);
متغیر عوامل = اعداد_زائیہ_عوامل(36);
جانچ("عوامل 36", عوامل[0] == 2 && عوامل.لمبائی == 4);

// ─── متن الگورتھم ─────────────────────────────
لکھو("\n─── متن الگورتھم ───");

جانچ("LCS اردو", لمبی_مشترک_ذیل_ترتیب("ABCBDAB", "BDCAB") == "BCAB" || لمبی_مشترک_ذیل_ترتیب("ABCBDAB", "BDCAB").لمبائی == 4);
جانچ("Levenshtein ایک جیسا", لیوینشٹین_فاصلہ("کتاب", "کتاب") == 0);
جانچ("Levenshtein فرق", لیوینشٹین_فاصلہ("کتاب", "کتابیں") == 2);
متغیر مقامات = کے_ایم_پی_تلاش("ab", "ababab");
جانچ("KMP مقامات", مقامات.لمبائی == 3);
جانچ("KMP پہلا مقام", مقامات[0] == 0);
جانچ("KMP نہیں ملا", کے_ایم_پی_تلاش("xyz", "ababab").لمبائی == 0);

// ─── نتیجہ ────────────────────────────────────
لکھو(`\n══════════════════════════════════════`);
لکھو(`  الگورتھم جانچ — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
لکھو(`══════════════════════════════════════`);
