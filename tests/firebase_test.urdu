// ══════════════════════════════════════════════════════
// Firebase / Firestore جانچ
// (بغیر سرور — کلاس ساخت، غلطی ہینڈلنگ، mock ڈیٹا)
// ══════════════════════════════════════════════════════

درآمد { فائر_بیس } سے "اردو/ڈیٹا_بیس";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════╗");
    لکھو("║  Firebase / Firestore جانچ           ║");
    لکھو("╚══════════════════════════════════════╝");

    // ─── 1. لائبریری دستیابی ─────────────────────────
    لکھو("\n─── لائبریری ───");
    جانچ("firebase-admin نصب ہے", سچ);

    // ─── 2. کلاس ساخت ────────────────────────────────
    لکھو("\n─── کلاس ساخت ───");
    متغیر db = نیا فائر_بیس({
        "اسناد":   "serviceAccountKey.json",
        "منصوبہ":  "my-urdu-project"
    });

    جانچ("فائر_بیس بنی", db != خالی);
    جانچ("config محفوظ", db._config["منصوبہ"] == "my-urdu-project");
    جانچ("ابھی غیر جڑا", db._connected == جھوٹ);
    جانچ("جوڑیں طریقہ موجود", قسم(db.جوڑیں) == "فنکشن");
    جانچ("مجموعہ طریقہ موجود", قسم(db.مجموعہ) == "فنکشن");
    جانچ("منقطع طریقہ موجود", قسم(db.منقطع) == "فنکشن");
    جانچ("لین_دین طریقہ موجود", قسم(db.لین_دین) == "فنکشن");

    // ─── 3. اسناد فائل نہ ہو — صحیح غلطی ────────────
    لکھو("\n─── غلط اسناد فائل ───");
    متغیر db2 = نیا فائر_بیس({ "اسناد": "/fake/path/credentials.json" });
    کوشش {
        انتظار db2.جوڑیں();
        جانچ("جعلی فائل قبول نہیں ہونی چاہیے", جھوٹ);
    } پکڑو (غ) {
        متغیر پیغام = متن(غ);
        لکھو(`  ⓘ توقع کے مطابق غلطی: ${type(غ).__name__}`);
        جانچ("فائل غلطی پر خطاء ملی", لمبائی(پیغام) > 0);
    }

    // ─── 4. اسناد فائل خالی — صحیح غلطی ────────────
    لکھو("\n─── خالی config ───");
    متغیر db3 = نیا فائر_بیس({});
    جانچ("خالی config بنا", db3 != خالی);
    جانچ("پہلے سے نہیں جڑا", db3._connected == جھوٹ);

    // ─── 5. factory فنکشن ────────────────────────────
    لکھو("\n─── factory ───");
    درآمد { ڈیٹا_بیس_جوڑو } سے "اردو/ڈیٹا_بیس";
    متغیر db_f = ڈیٹا_بیس_جوڑو("firebase", { "اسناد": "key.json" });
    جانچ("factory نے فائر_بیس بنائی", db_f != خالی);

    متغیر db_fs = ڈیٹا_بیس_جوڑو("firestore", { "اسناد": "key.json" });
    جانچ("factory firestore بھی کام کرتی ہے", db_fs != خالی);

    // ─── 6. منقطع (بغیر جڑے) ─────────────────────────
    لکھو("\n─── منقطع بغیر جڑے ───");
    کوشش {
        انتظار db.منقطع();
        جانچ("منقطع بغیر جڑے — ٹھیک", سچ);
    } پکڑو (غ) {
        جانچ("منقطع بغیر جڑے — ٹھیک", جھوٹ);
    }

    لکھو(`\n══════════════════════════════════════`);
    لکھو(`  Firebase — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════`);
}

انتظار مرکز();
