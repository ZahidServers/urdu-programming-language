// ══════════════════════════════════════════════
// اردو/متن — Text Library Test
// ══════════════════════════════════════════════

درآمد {
    بڑے_حروف, چھوٹے_حروف, عنوانی, الٹا_کریں,
    تراشو, بائیں_تراشو, دائیں_تراشو,
    تقسیم, سطر_تقسیم, ملائیں, بدلیں,
    گنو, موجود_ہے, شروع_سے, آخر_سے,
    خالی_ہے, صرف_اعداد, صرف_حروف, لمبائی,
    پیڈ_بائیں, پیڈ_دائیں, پیڈ_وسط, صفر_بھریں,
    ذیل_متن, تلاش_کریں,
    اعراب_ہٹائیں, نستعلیق_معیاری,
    الفاظ, اردو_حروف_ہیں,
    ہندی_اعداد, ہندی_اعداد_میں,
    اردو_میں_گنتی, مماثلت, ایک_جیسا_ہے,
    ریجیکس_تمام, دہرائیں
} سے "اردو/متن";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// ─── بنیادی متن ─────────────────────────────
لکھو("\n─── بنیادی متن ───");

جانچ("بڑے_حروف", بڑے_حروف("hello") == "HELLO");
جانچ("چھوٹے_حروف", چھوٹے_حروف("WORLD") == "world");
جانچ("عنوانی", عنوانی("urdu language") == "Urdu Language");
جانچ("الٹا_کریں", الٹا_کریں("abc") == "cba");
جانچ("تراشو", تراشو("  hello  ") == "hello");
جانچ("بائیں_تراشو", بائیں_تراشو("  hi") == "hi");
جانچ("دائیں_تراشو", دائیں_تراشو("hi  ") == "hi");

// ─── تقسیم/ملائیں ────────────────────────────
لکھو("\n─── تقسیم / ملائیں ───");

متغیر حصے = تقسیم("الف-ب-ج", "-");
جانچ("تقسیم", حصے.لمبائی == 3 && حصے[0] == "الف");
جانچ("ملائیں", ملائیں(", ", ["ایک", "دو", "تین"]) == "ایک, دو, تین");
متغیر سطریں = سطر_تقسیم("سطر1\nسطر2\nسطر3");
جانچ("سطر_تقسیم", سطریں.لمبائی == 3);
جانچ("بدلیں", بدلیں("hello world", "world", "اردو") == "hello اردو");

// ─── جانچ فنکشن ─────────────────────────────
لکھو("\n─── جانچ افعال ───");

جانچ("گنو", گنو("abababab", "ab") == 4);
جانچ("موجود_ہے سچ", موجود_ہے("اردو زبان", "اردو"));
جانچ("موجود_ہے جھوٹ", !موجود_ہے("اردو زبان", "عربی"));
جانچ("شروع_سے", شروع_سے("اردو پروگرامنگ", "اردو"));
جانچ("آخر_سے", آخر_سے("پروگرامنگ زبان", "زبان"));
جانچ("خالی_ہے سچ", خالی_ہے("   "));
جانچ("خالی_ہے جھوٹ", !خالی_ہے("کچھ"));
جانچ("صرف_اعداد سچ", صرف_اعداد("12345"));
جانچ("صرف_اعداد جھوٹ", !صرف_اعداد("123a"));
جانچ("صرف_حروف سچ", صرف_حروف("hello"));
جانچ("لمبائی", لمبائی("اردو") == 4);

// ─── پیڈنگ ───────────────────────────────────
لکھو("\n─── پیڈنگ ───");

جانچ("پیڈ_بائیں", پیڈ_بائیں("hi", 6) == "hi    ");
جانچ("پیڈ_دائیں", پیڈ_دائیں("hi", 6) == "    hi");
جانچ("پیڈ_وسط", پیڈ_وسط("hi", 6) == "  hi  ");
جانچ("صفر_بھریں", صفر_بھریں("42", 5) == "00042");
جانچ("ذیل_متن", ذیل_متن("اردو زبان", 0, 4) == "اردو");
جانچ("تلاش_کریں", تلاش_کریں("hello world", "world") == 6);
جانچ("تلاش_نہیں", تلاش_کریں("hello", "xyz") == -1);
جانچ("دہرائیں", دہرائیں("اردو ", 3) == "اردو اردو اردو ");

// ─── اردو مخصوص ──────────────────────────────
لکھو("\n─── اردو مخصوص ───");

جانچ("اعراب_ہٹائیں", اعراب_ہٹائیں("كِتَابٌ") == "كتاب");
متغیر معیاری = نستعلیق_معیاری("ك");
جانچ("نستعلیق_معیاری ك→ک", معیاری == "ک");

متغیر الفاظ_فہرست = الفاظ("میرا نام علی ہے");
جانچ("الفاظ تعداد", الفاظ_فہرست.لمبائی == 4);
جانچ("الفاظ پہلا", الفاظ_فہرست[0] == "میرا");

جانچ("اردو_حروف_ہیں سچ", اردو_حروف_ہیں("یہ اردو ہے"));
جانچ("اردو_حروف_ہیں جھوٹ", !اردو_حروف_ہیں("this is english"));

// ─── اعداد تبدیلی ─────────────────────────────
لکھو("\n─── اعداد تبدیلی ───");

جانچ("ہندی_اعداد ۰-۹", ہندی_اعداد("۱۲۳۴۵") == "12345");
جانچ("ہندی_اعداد_میں گول چکر", ہندی_اعداد(ہندی_اعداد_میں("67890")) == "67890");

لکھو("\n─── اردو_میں_گنتی ───");
جانچ("صفر", اردو_میں_گنتی(0) == "صفر");
جانچ("ایک", اردو_میں_گنتی(1) == "ایک");
جانچ("بیس", اردو_میں_گنتی(20) == "بیس");
جانچ("بیالیس", اردو_میں_گنتی(42) == "بیالیس");
جانچ("ایک سو", اردو_میں_گنتی(100) == "ایک سو");
جانچ("پانچ سو پچاس", اردو_میں_گنتی(550) == "پانچ سو پچاس");
جانچ("ایک ہزار", اردو_میں_گنتی(1000) == "ایک ہزار");
جانچ("منفی", اردو_میں_گنتی(-5) == "منفی پانچ");
لکھو(`  1,000,000 = ${اردو_میں_گنتی(1000000)}`);
لکھو(`  42 = ${اردو_میں_گنتی(42)}`);

// ─── مماثلت ───────────────────────────────────
لکھو("\n─── مماثلت ───");

جانچ("مماثلت ایک جیسا", مماثلت("abc", "abc") == 1.0);
جانچ("مماثلت مختلف", مماثلت("abc", "xyz") == 0.0);
متغیر م = مماثلت("کتاب", "کتابیں");
جانچ("مماثلت جزوی (>0.5)", م > 0.5);
جانچ("ایک_جیسا_ہے حساس", ایک_جیسا_ہے("ABC", "abc") == جھوٹ);
جانچ("ایک_جیسا_ہے بے_حساس", ایک_جیسا_ہے("ABC", "abc", حساسیت=جھوٹ));

// ─── ریجیکس ───────────────────────────────────
لکھو("\n─── ریجیکس ───");

متغیر اعداد_فہرست = ریجیکس_تمام("\\d+", "abc 123 def 456");
جانچ("ریجیکس_تمام", اعداد_فہرست.لمبائی == 2 && اعداد_فہرست[0] == "123");

// ─── نتیجہ ────────────────────────────────────
لکھو(`\n══════════════════════════════════════`);
لکھو(`  متن جانچ — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
لکھو(`══════════════════════════════════════`);
