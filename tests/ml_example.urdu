// ══════════════════════════════════════════════
// اردو پروگرامنگ لینگویج — مشین لرننگ مثال
// Machine Learning Example
// ══════════════════════════════════════════════

درآمد { درجہ_بندی, ریگریشن, ڈیٹا } سے "اردو/ذہین";

غیر_متزامن فنکشن مرکز() {
    لکھو("═══ مشین لرننگ مثال ═══\n");

    // سادہ درجہ بندی مثال (scikit-learn)
    کوشش {
        // ڈیٹا بنائیں
        متغیر X = [
            [1, 2], [2, 3], [3, 4], [4, 5],
            [10, 11], [11, 12], [12, 13], [13, 14]
        ];
        متغیر y = [0, 0, 0, 0, 1, 1, 1, 1];

        // ماڈل بنائیں
        متغیر ماڈل = نیا درجہ_بندی("random_forest");

        // سیکھیں
        ماڈل.سیکھیں(X, y);
        لکھو("ماڈل نے سیکھ لیا ✓");

        // پیش گوئی
        متغیر ٹیسٹ = [[2, 3], [11, 12]];
        متغیر پیش_گوئیاں = ماڈل.پیش_گوئی(ٹیسٹ);
        لکھو(`پیش گوئیاں: ${پیش_گوئیاں}`);

        // درستگی
        متغیر درستگی = ماڈل.درستگی(X, y);
        لکھو(`درستگی: ${گول(درستگی * 100, 1)}%`);

    } پکڑو (غ) {
        لکھو(`scikit-learn دستیاب نہیں: ${غ.پیغام}`);
        لکھو("نصب کریں: pip install scikit-learn");
    }

    // ریگریشن
    کوشش {
        متغیر X_reg = [[1], [2], [3], [4], [5], [6], [7], [8]];
        متغیر y_reg = [2, 4, 6, 8, 10, 12, 14, 16];

        متغیر reg_ماڈل = نیا ریگریشن("linear");
        reg_ماڈل.سیکھیں(X_reg, y_reg);

        متغیر پیش_گوئی = reg_ماڈل.پیش_گوئی([[10]]);
        لکھو(`\nخطی ریگریشن - 10 کی پیش گوئی: ${گول(پیش_گوئی[0], 2)}`);

    } پکڑو (غ) {
        لکھو(`ریگریشن غلطی: ${غ.پیغام}`);
    }

    // TensorFlow/Keras
    کوشش {
        درآمد { ترتیبی_ماڈل, گھنی } سے "اردو/ذہین";

        متغیر keras_ماڈل = نیا ترتیبی_ماڈل([
            نیا گھنی(64, فعالیت="relu", input_shape=[2]),
            نیا گھنی(32, فعالیت="relu"),
            نیا گھنی(1, فعالیت="sigmoid")
        ]);

        keras_ماڈل.مرتب_کریں(
            مرتب_کنندہ="adam",
            نقصان="binary_crossentropy",
            پیمانے=["accuracy"]
        );

        keras_ماڈل.خلاصہ();
        لکھو("Keras ماڈل بنایا گیا ✓");

    } پکڑو (غ) {
        لکھو(`TensorFlow دستیاب نہیں: ${غ.پیغام}`);
        لکھو("نصب کریں: pip install tensorflow");
    }

    لکھو("\nمشین لرننگ مثال مکمل!");
}

مرکز();
