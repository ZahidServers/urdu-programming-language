// ══════════════════════════════════════════════
// اردو پروگرامنگ لینگویج — ڈیٹا بیس مثال
// Database Example (ایس_کیو_لائٹ built-in)
// ══════════════════════════════════════════════

درآمد { ایس_کیو_لائٹ } سے "اردو/ڈیٹا_بیس";

// ایس_کیو_لائٹ ڈیٹا بیس (کوئی انسٹال نہیں چاہیے)
متغیر db = نیا ایس_کیو_لائٹ(":memory:");  // عارضی ڈیٹا بیس (RAM میں)

غیر_متزامن فنکشن مرکز() {
    // ڈیٹا بیس سے جڑیں
    انتظار db.جوڑیں();
    لکھو("ڈیٹا بیس سے جڑ گئے ✓");

    // جدول بنائیں
    انتظار db.جدول_بنائیں("طلبہ", {
        شناخت: "INTEGER PRIMARY KEY AUTOINCREMENT",
        نام: "TEXT NOT NULL",
        عمر: "INTEGER",
        درجہ: "TEXT",
        نمبر: "REAL"
    });
    لکھو("جدول بنایا گیا ✓");

    // ریکارڈ داخل کریں
    متغیر طلبہ = [
        { نام: "احمد علی",   عمر: 15, درجہ: "دسواں",    نمبر: 92.5 },
        { نام: "فاطمہ خان",  عمر: 16, درجہ: "گیارہویں", نمبر: 88.0 },
        { نام: "محمد عمر",   عمر: 14, درجہ: "نواں",     نمبر: 95.3 },
        { نام: "عائشہ صدیق", عمر: 15, درجہ: "دسواں",    نمبر: 79.8 },
        { نام: "بلال حسین",  عمر: 17, درجہ: "بارہویں",  نمبر: 85.5 },
    ];

    کے_لیے (متغیر طالب میں طلبہ) {
        انتظار db.چلائیں(
            "INSERT INTO طلبہ (نام, عمر, درجہ, نمبر) VALUES (?, ?, ?, ?)",
            [طالب.نام, طالب.عمر, طالب.درجہ, طالب.نمبر]
        );
    }
    لکھو("ریکارڈ داخل کیے ✓");

    // تمام ریکارڈ دیکھیں
    متغیر تمام = انتظار db.سوال("SELECT * FROM طلبہ ORDER BY نمبر DESC");
    لکھو("\n═══ تمام طلبہ (نمبروں کے مطابق) ═══");
    کے_لیے (متغیر طالب میں تمام) {
        لکھو(`  ${طالب.نام} | درجہ: ${طالب.درجہ} | نمبر: ${طالب.نمبر}`);
    }

    // فلٹر کریں
    متغیر دسویں = انتظار db.سوال(
        "SELECT * FROM طلبہ WHERE درجہ = ?",
        ["دسواں"]
    );
    لکھو(`\n═══ دسویں درجہ کے طلبہ (${لمبائی(دسویں)}) ═══`);
    کے_لیے (متغیر طالب میں دسویں) {
        لکھو(`  ${طالب.نام}: ${طالب.نمبر}`);
    }

    // اوسط نمبر
    متغیر اوسط = انتظار db.سوال("SELECT AVG(نمبر) as اوسط FROM طلبہ");
    لکھو(`\nاوسط نمبر: ${گول(اوسط[0].اوسط, 1)}`);

    // ریکارڈ تازہ کریں
    انتظار db.چلائیں(
        "UPDATE طلبہ SET نمبر = نمبر + 2 WHERE درجہ = ?",
        ["دسواں"]
    );
    لکھو("\nدسویں درجہ کو 2 نمبر اضافہ ملا ✓");

    // ڈیٹا بیس بند کریں
    انتظار db.منقطع();
    لکھو("ڈیٹا بیس بند ہوا ✓");
}

// مونگو_ڈی_بی مثال (اگر نصب ہو)
غیر_متزامن فنکشن mongo_مثال() {
    کوشش {
        درآمد { مونگو_ڈی_بی } سے "اردو/ڈیٹا_بیس";
        متغیر mongo = نیا مونگو_ڈی_بی({
            میزبان: "localhost",
            پورٹ: 27017,
            ڈیٹا_بیس: "اردو_ٹیسٹ"
        });
        انتظار mongo.جوڑیں();
        متغیر col = mongo.مجموعہ("صارفین");
        انتظار col.داخل({ نام: "احمد", عمر: 25 });
        متغیر نتائج = انتظار col.تلاش({});
        لکھو("مونگو_ڈی_بی نتائج:", نتائج);
        انتظار mongo.منقطع();
    } پکڑو (غ) {
        لکھو("مونگو_ڈی_بی دستیاب نہیں:", غ.پیغام);
    }
}

مرکز();
