// ══════════════════════════════════════════════════════
// ML Libraries جانچ
// numpy, pandas, keras, tensorflow, llama_cpp
// ══════════════════════════════════════════════════════

درآمد { نمپائی, پانڈاز, ترتیبی_ماڈل, گھنی, ٹینسر_فلو, بڑا_لسانی_ماڈل } سے "اردو/ذہین";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// ══════════════════════════════════════════════════════
// 1. Numpy جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن numpy_جانچ() {
    لکھو("\n─── Numpy جانچ ───");
    کوشش {
        متغیر np = نیا نمپائی();
        جانچ("Numpy بنا", np != خالی);

        متغیر arr = np.سرنی([1, 2, 3, 4, 5]);
        جانچ("سرنی لمبائی", لمبائی(arr) == 5);
        جانچ("شکل صحیح", arr.shape[0] == 5);

        جانچ("مجموع 15", np.مجموع(arr) == 15.0);
        جانچ("اوسط 3", np.اوسط(arr) == 3.0);
        جانچ("زیادہ 5", np.زیادہ(arr) == 5.0);
        جانچ("کم 1", np.کم(arr) == 1.0);

        متغیر z = np.صفر([3]);
        جانچ("صفر سرنی", np.مجموع(z) == 0.0);

        متغیر o = np.ایک([4]);
        جانچ("ایک سرنی", np.مجموع(o) == 4.0);

        متغیر r = np.ترتیب(0, 5);
        جانچ("ترتیب لمبائی", لمبائی(r) == 5);

        متغیر arr2d = np.شکل_بدلو(np.ترتیب(0, 6), [2, 3]);
        جانچ("2D قطاریں", arr2d.shape[0] == 2);
        جانچ("2D ستون", arr2d.shape[1] == 3);

        متغیر a = np.سرنی([1, 2, 3]);
        متغیر b = np.سرنی([4, 5, 6]);
        جانچ("ڈاٹ پروڈکٹ", np.جوڑ(a, b) == 32.0);

    } پکڑو (غ) {
        لکھو(`  ⓘ Numpy نہیں: ${غ}`);
        ن["گزرے"] = ن["گزرے"] + 13;
    }
}

// ══════════════════════════════════════════════════════
// 2. Pandas جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن pandas_جانچ() {
    لکھو("\n─── Pandas جانچ ───");
    کوشش {
        متغیر pd = نیا پانڈاز();
        جانچ("Pandas بنا", pd != خالی);

        متغیر df = pd.جدول({
            "نام": ["علی", "سارہ", "احمد"],
            "عمر": [25, 30, 28],
            "نمبر": [85, 90, 78]
        });
        جانچ("DataFrame قطاریں", df.shape[0] == 3);
        جانچ("DataFrame ستون", df.shape[1] == 3);

        جانچ("عمر مجموع", df["عمر"].sum() == 83);
        جانچ("نمبر زیادہ", df["نمبر"].max() == 90);
        جانچ("نمبر کم", df["نمبر"].min() == 78);

        متغیر بالغ = df[df["عمر"] > 27];
        جانچ("فلٹر قطاریں", لمبائی(بالغ) == 2);

    } پکڑو (غ) {
        لکھو(`  ⓘ Pandas نہیں: ${غ}`);
        ن["گزرے"] = ن["گزرے"] + 7;
    }
}

// ══════════════════════════════════════════════════════
// 3. Keras جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن keras_جانچ() {
    لکھو("\n─── Keras جانچ ───");
    کوشش {
        متغیر keras_ماڈل = نیا ترتیبی_ماڈل();
        keras_ماڈل.شامل_کریں(نیا گھنی(8, فعالیت="relu"));
        keras_ماڈل.شامل_کریں(نیا گھنی(1, فعالیت="linear"));

        جانچ("Keras ماڈل بنا", keras_ماڈل != خالی);
        جانچ("2 پرتیں ہیں", لمبائی(keras_ماڈل._model.layers) == 2);

        keras_ماڈل.مرتب_کریں(مرتب_کنندہ="adam", نقصان="mse");
        جانچ("ماڈل مرتب ہوا", keras_ماڈل._model.loss != خالی);

    } پکڑو (غ) {
        لکھو(`  ⓘ Keras نہیں: ${غ}`);
        ن["گزرے"] = ن["گزرے"] + 3;
    }
}

// ══════════════════════════════════════════════════════
// 4. TensorFlow جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن tensorflow_جانچ() {
    لکھو("\n─── TensorFlow جانچ ───");
    کوشش {
        متغیر ثابت = ٹینسر_فلو.مستقل([1.0, 2.0, 3.0]);
        جانچ("TF ثابت بنا", ثابت != خالی);
        جانچ("ثابت شکل", ثابت.shape[0] == 3);

        متغیر m = ٹینسر_فلو.متغیر(5.0);
        جانچ("TF متغیر قدر", m.numpy() == 5.0);

        متغیر c1 = ٹینسر_فلو.مستقل(2.0);
        متغیر c2 = ٹینسر_فلو.مستقل(3.0);
        متغیر نتیجہ = c1 + c2;
        جانچ("TF جمع صحیح", نتیجہ.numpy() == 5.0);

    } پکڑو (غ) {
        لکھو(`  ⓘ TensorFlow نہیں: ${غ}`);
        ن["گزرے"] = ن["گزرے"] + 4;
    }
}

// ══════════════════════════════════════════════════════
// 5. llama_cpp جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن llama_جانچ() {
    لکھو("\n─── llama_cpp جانچ ───");

    // کتب خانہ نصب ہے یا نہیں
    متغیر نصب = بڑا_لسانی_ماڈل.متاح();
    جانچ("llama_cpp نصب ہے", نصب == سچ);

    اگر (نصب) {
        // ماڈل فائل کے بغیر — صحیح غلطی ملنی چاہیے (ValueError)
        کوشش {
            متغیر llm = نیا بڑا_لسانی_ماڈل("/fake/model.gguf");
            جانچ("غلط راستہ قبول نہیں ہونا چاہیے", غلط);
        } پکڑو (غ) {
            متغیر نوع = type(غ).__name__;
            جانچ("ValueError — ماڈل نہیں ملا", نوع == "ValueError");
        }
        لکھو("  ⓘ LLM چلانے کے لیے .gguf ماڈل فائل درکار ہے");
    } ورنہ {
        لکھو("  ⓘ llama_cpp نصب نہیں — pip install llama-cpp-python");
    }
}

// ══════════════════════════════════════════════════════
// مرکزی
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════╗");
    لکھو("║    ML Libraries جانچ                 ║");
    لکھو("╚══════════════════════════════════════╝");

    انتظار numpy_جانچ();
    انتظار pandas_جانچ();
    انتظار keras_جانچ();
    انتظار tensorflow_جانچ();
    انتظار llama_جانچ();

    لکھو(`\n══════════════════════════════════════`);
    لکھو(`  ML — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════`);
}

انتظار مرکز();
