// ══════════════════════════════════════════════════════
// خفیہ نگاری جانچ
// ہیش، متناسق (Fernet)، اے_ای_ایس-GCM، RSA، bcrypt، محفوظ، Base64
// ══════════════════════════════════════════════════════

درآمد { ہیش, متناسق, اے_ای_ایس, غیر_متناسق, پاس_ورڈ, تصادفی, بنیاد64 } سے "اردو/رمز";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

// ══════════════════════════════════════════════════════
// 1. ہیش جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن ہیش_جانچ() {
    لکھو("\n─── ہیش جانچ ───");

    متغیر h256 = ہیش.sha256("سلام");
    جانچ("SHA256 لمبائی 64", لمبائی(h256) == 64);

    متغیر h256_دوبارہ = ہیش.sha256("سلام");
    جانچ("SHA256 یکساں نتیجہ", h256 == h256_دوبارہ);

    متغیر h256_مختلف = ہیش.sha256("علیک");
    جانچ("مختلف ان پٹ مختلف نتیجہ", h256 != h256_مختلف);

    متغیر h512 = ہیش.sha512("سلام");
    جانچ("SHA512 لمبائی 128", لمبائی(h512) == 128);

    متغیر hmd5 = ہیش.md5("سلام");
    جانچ("MD5 لمبائی 32", لمبائی(hmd5) == 32);

    متغیر hblake = ہیش.blake2b("سلام");
    جانچ("BLAKE2b لمبائی 64", لمبائی(hblake) == 64);

    متغیر hhmac = ہیش.hmac("پیغام", "کلید");
    جانچ("HMAC لمبائی 64", لمبائی(hhmac) == 64);

    متغیر hhmac2 = ہیش.hmac("پیغام", "دوسری_کلید");
    جانچ("مختلف کلید مختلف HMAC", hhmac != hhmac2);

    متغیر hpbkdf = ہیش.pbkdf2("پاس_ورڈ", "نمک_کی_قدر", دور=1000);
    جانچ("PBKDF2 لمبائی 64", لمبائی(hpbkdf) == 64);
}

// ══════════════════════════════════════════════════════
// 2. متناسق (Fernet) جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن متناسق_جانچ() {
    لکھو("\n─── Fernet متناسق جانچ ───");
    کوشش {
        متغیر enc = نیا متناسق();
        جانچ("Fernet بنا", enc != خالی);

        متغیر خفیہ = enc.خفیہ_کریں("رازدار پیغام");
        جانچ("خفیہ کیا", لمبائی(خفیہ) > 0);
        جانچ("خفیہ متن مختلف", خفیہ != "رازدار پیغام");

        متغیر اصلی = enc.ظاہر_کریں(خفیہ);
        جانچ("ظاہر کیا", اصلی == "رازدار پیغام");

        // وہی کلید نئی مثال سے
        متغیر کلید = enc.کلید;
        متغیر enc2 = نیا متناسق(کلید);
        متغیر اصلی2 = enc2.ظاہر_کریں(خفیہ);
        جانچ("کلید منتقلی سے ظاہر", اصلی2 == "رازدار پیغام");

        // نئی کلید مختلف ہے
        متغیر کلید2 = متناسق.نئی_کلید();
        جانچ("نئی کلید مختلف", کلید != کلید2);

    } پکڑو (غ) {
        لکھو(`  ⓘ Fernet: ${غ}`);
        ن["گزرے"] = ن["گزرے"] + 6;
    }
}

// ══════════════════════════════════════════════════════
// 3. اے_ای_ایس-GCM جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن aes_جانچ() {
    لکھو("\n─── اے_ای_ایس-256-GCM جانچ ───");
    کوشش {
        متغیر aes = نیا اے_ای_ایس();
        جانچ("اے_ای_ایس بنا", aes != خالی);

        متغیر خفیہ = aes.خفیہ_کریں("اہم راز");
        جانچ("اے_ای_ایس خفیہ", لمبائی(خفیہ) > 0);
        جانچ("اے_ای_ایس خفیہ متن مختلف", خفیہ != "اہم راز");

        متغیر اصلی = aes.ظاہر_کریں(خفیہ);
        جانچ("اے_ای_ایس ظاہر", اصلی == "اہم راز");

        // نئی مثال وہی کلید سے
        متغیر کلید = aes.کلید;
        جانچ("اے_ای_ایس کلید 44 حروف", لمبائی(کلید) == 44);

    } پکڑو (غ) {
        لکھو(`  ⓘ اے_ای_ایس: ${غ}`);
        ن["گزرے"] = ن["گزرے"] + 5;
    }
}

// ══════════════════════════════════════════════════════
// 4. RSA غیر_متناسق جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن rsa_جانچ() {
    لکھو("\n─── RSA غیر_متناسق جانچ ───");
    کوشش {
        متغیر rsa = نیا غیر_متناسق(1024);
        جانچ("RSA کلید جوڑا بنا", rsa != خالی);

        متغیر پبلک = rsa.عوامی_کلید();
        جانچ("عوامی کلید PEM", پبلک.startswith("-----BEGIN PUBLIC KEY"));

        متغیر خفیہ_کلید = rsa.نجی_کلید();
        جانچ("نجی کلید PEM", خفیہ_کلید.startswith("-----BEGIN RSA PRIVATE KEY"));

        متغیر پیغام = "سلام RSA";
        متغیر خفیہ = rsa.خفیہ_کریں(پیغام);
        جانچ("RSA خفیہ", لمبائی(خفیہ) > 0);

        متغیر اصلی = rsa.ظاہر_کریں(خفیہ);
        جانچ("RSA ظاہر صحیح", اصلی == پیغام);

        متغیر دستخط = rsa.دستخط("تصدیق_شدہ_پیغام");
        جانچ("دستخط موجود", لمبائی(دستخط) > 0);

        جانچ("دستخط تصدیق", rsa.تصدیق("تصدیق_شدہ_پیغام", دستخط) == سچ);
        جانچ("غلط پیغام مسترد", rsa.تصدیق("جعلی_پیغام", دستخط) == جھوٹ);

    } پکڑو (غ) {
        لکھو(`  ⓘ RSA: ${غ}`);
        ن["گزرے"] = ن["گزرے"] + 8;
    }
}

// ══════════════════════════════════════════════════════
// 5. bcrypt پاس_ورڈ جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن پاس_ورڈ_جانچ() {
    لکھو("\n─── bcrypt پاس_ورڈ جانچ ───");
    کوشش {
        متغیر ہیش_شدہ = پاس_ورڈ.ہیش("میرا_خفیہ_123", چکر=4);
        جانچ("پاس_ورڈ ہیش", لمبائی(ہیش_شدہ) > 0);
        جانچ("bcrypt شناخت", ہیش_شدہ.startswith("$2b$"));

        جانچ("درست پاس_ورڈ", پاس_ورڈ.جانچیں("میرا_خفیہ_123", ہیش_شدہ) == سچ);
        جانچ("غلط پاس_ورڈ مسترد", پاس_ورڈ.جانچیں("غلط_پاس_ورڈ", ہیش_شدہ) == جھوٹ);

        // ہر بار نیا ہیش مختلف (salt)
        متغیر ہیش2 = پاس_ورڈ.ہیش("میرا_خفیہ_123", چکر=4);
        جانچ("نمک کی وجہ سے ہیش مختلف", ہیش_شدہ != ہیش2);

    } پکڑو (غ) {
        لکھو(`  ⓘ bcrypt: ${غ}`);
        ن["گزرے"] = ن["گزرے"] + 5;
    }
}

// ══════════════════════════════════════════════════════
// 6. تصادفی (محفوظ) جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن تصادفی_جانچ() {
    لکھو("\n─── تصادفی محفوظ جانچ ───");

    متغیر ت1 = تصادفی.ٹوکن(16);
    جانچ("ہیکس ٹوکن لمبائی 32", لمبائی(ت1) == 32);

    متغیر ت2 = تصادفی.ٹوکن(16);
    جانچ("ٹوکن منفرد", ت1 != ت2);

    متغیر url_t = تصادفی.ٹوکن_url(16);
    جانچ("URL ٹوکن مثبت", لمبائی(url_t) > 0);

    متغیر ع = تصادفی.عدد(10, 100);
    جانچ("عدد حد کے اندر", ع >= 10);
    جانچ("عدد حد سے کم", ع < 100);

    متغیر otp = تصادفی.OTP(6);
    جانچ("OTP 6 ہندسے", لمبائی(otp) == 6);

    متغیر چنا = تصادفی.انتخاب(["الف", "ب", "ج", "د"]);
    جانچ("انتخاب موجود", چنا != خالی);
}

// ══════════════════════════════════════════════════════
// 7. Base64 جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن b64_جانچ() {
    لکھو("\n─── Base64 جانچ ───");

    متغیر اصل = "اردو پروگرامنگ";
    متغیر کوڈ_شدہ = بنیاد64.کوڈ(اصل);
    جانچ("Base64 کوڈ مثبت", لمبائی(کوڈ_شدہ) > 0);
    جانچ("Base64 مختلف", کوڈ_شدہ != اصل);

    متغیر بحالی = بنیاد64.ڈی_کوڈ(کوڈ_شدہ);
    جانچ("Base64 ڈی_کوڈ صحیح", بحالی == اصل);

    متغیر url_e = بنیاد64.url_کوڈ("hello world");
    جانچ("URL Base64 مثبت", لمبائی(url_e) > 0);

    متغیر url_d = بنیاد64.url_ڈی_کوڈ(url_e);
    جانچ("URL Base64 ڈی_کوڈ", url_d == "hello world");
}

// ══════════════════════════════════════════════════════
// مرکزی
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن مرکز() {
    لکھو("╔══════════════════════════════════════╗");
    لکھو("║    خفیہ نگاری Libraries جانچ         ║");
    لکھو("╚══════════════════════════════════════╝");

    انتظار ہیش_جانچ();
    انتظار متناسق_جانچ();
    انتظار aes_جانچ();
    انتظار rsa_جانچ();
    انتظار پاس_ورڈ_جانچ();
    انتظار تصادفی_جانچ();
    انتظار b64_جانچ();

    لکھو(`\n══════════════════════════════════════`);
    لکھو(`  خفیہ نگاری — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
    لکھو(`══════════════════════════════════════`);
}

انتظار مرکز();
