// ══════════════════════════════════════════════════════
// اردو پروگرامنگ لینگویج — لین دین (Transaction) جانچ
// ایس_کیو_لائٹ اور مائی_ایس_کیو_ایل میں COMMIT، ROLLBACK، SAVEPOINT
// ══════════════════════════════════════════════════════

درآمد { ایس_کیو_لائٹ, مائی_ایس_کیو_ایل } سے "اردو/ڈیٹا_بیس";

فنکشن پاس(نام) { لکھو(`  ✓ ${نام}`); }
فنکشن ناکام(نام, وجہ) { لکھو(`  ✗ ${نام} — ${وجہ}`); }

// ══════════════════════════════════════════════════════
// مددگار: جدول بنائیں اور شروعاتی ڈیٹا
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن شروع_کریں(db) {
    انتظار db.چلائیں(`CREATE TABLE IF NOT EXISTS کھاتے (
        شناخت   INTEGER PRIMARY KEY AUTOINCREMENT,
        نام      TEXT NOT NULL,
        بقیہ     REAL DEFAULT 0
    )`);
    انتظار db.چلائیں("DELETE FROM کھاتے");
    انتظار db.چلائیں("INSERT INTO کھاتے (نام, بقیہ) VALUES (?, ?)", ["احمد", 10000]);
    انتظار db.چلائیں("INSERT INTO کھاتے (نام, بقیہ) VALUES (?, ?)", ["فاطمہ", 5000]);
}

غیر_متزامن فنکشن بقیہ_حاصل(db, نام) {
    متغیر نتیجہ = انتظار db.سوال("SELECT بقیہ FROM کھاتے WHERE نام = ?", [نام]);
    اگر (لمبائی(نتیجہ) > 0) { واپس نتیجہ[0].بقیہ; }
    واپس 0;
}

// ══════════════════════════════════════════════════════
// ایس_کیو_لائٹ لین دین جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن sqlite_لین_دین() {
    لکھو("\n╔════════════════════════════════════════╗");
    لکھو(  "║   ایس_کیو_لائٹ — لین دین جانچ               ║");
    لکھو(  "╚════════════════════════════════════════╝");

    متغیر db = نیا ایس_کیو_لائٹ(":memory:");
    انتظار db.جوڑیں();
    انتظار شروع_کریں(db);

    // ── 1. کامیاب COMMIT ──────────────────────────────
    لکھو("\n  ─ 1. کامیاب منتقلی (COMMIT) ─");
    انتظار db.لین_دین_شروع();
    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [2000, "احمد"]);
    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ + ? WHERE نام = ?", [2000, "فاطمہ"]);
    انتظار db.کمٹ();

    متغیر احمد = انتظار بقیہ_حاصل(db, "احمد");
    متغیر فاطمہ = انتظار بقیہ_حاصل(db, "فاطمہ");
    اگر (احمد == 8000 && فاطمہ == 7000) {
        پاس(`COMMIT — احمد: ${احمد}، فاطمہ: ${فاطمہ}`);
    } ورنہ {
        ناکام("COMMIT", `احمد=${احمد}, فاطمہ=${فاطمہ}`);
    }

    // ── 2. ROLLBACK ────────────────────────────────────
    لکھو("\n  ─ 2. ROLLBACK — منتقلی منسوخ ─");
    انتظار db.لین_دین_شروع();
    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [9999, "احمد"]);
    // احمد کا بقیہ منفی ہو جاتا — منسوخ کریں
    انتظار db.واپسی();

    متغیر بعد_واپسی = انتظار بقیہ_حاصل(db, "احمد");
    اگر (بعد_واپسی == 8000) {
        پاس(`ROLLBACK — احمد کا بقیہ محفوظ: ${بعد_واپسی}`);
    } ورنہ {
        ناکام("ROLLBACK", `بقیہ=${بعد_واپسی}`);
    }

    // ── 3. لین_دین() خودکار wrapper ────────────────────
    لکھو("\n  ─ 3. لین_دین() خودکار COMMIT/ROLLBACK ─");
    انتظار db.لین_دین(غیر_متزامن فنکشن() {
        انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ + ? WHERE نام = ?", [500, "احمد"]);
        انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [500, "فاطمہ"]);
    });
    متغیر ا2 = انتظار بقیہ_حاصل(db, "احمد");
    متغیر ف2 = انتظار بقیہ_حاصل(db, "فاطمہ");
    اگر (ا2 == 8500 && ف2 == 6500) {
        پاس(`لین_دین() COMMIT — احمد: ${ا2}، فاطمہ: ${ف2}`);
    } ورنہ {
        ناکام("لین_دین() COMMIT", `احمد=${ا2}, فاطمہ=${ف2}`);
    }

    // غلطی پر خودکار ROLLBACK
    متغیر پہلے = انتظار بقیہ_حاصل(db, "احمد");
    کوشش {
        انتظار db.لین_دین(غیر_متزامن فنکشن() {
            انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [1000, "احمد"]);
            پھینکو نیا غلطی("جعلی نیٹ ورک خطا!");  // ← غلطی پھینکیں
        });
    } پکڑو (غ) {
        متغیر بعد_خطا = انتظار بقیہ_حاصل(db, "احمد");
        اگر (بعد_خطا == پہلے) {
            پاس(`لین_دین() خودکار ROLLBACK — بقیہ محفوظ: ${بعد_خطا}`);
        } ورنہ {
            ناکام("خودکار ROLLBACK", `بقیہ=${بعد_خطا} (ہونا چاہیے ${پہلے})`);
        }
    }

    // ── 4. SAVEPOINT ──────────────────────────────────
    لکھو("\n  ─ 4. SAVEPOINT / نقطہ محفوظ ─");
    انتظار db.لین_دین_شروع();

    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ + ? WHERE نام = ?", [1000, "احمد"]);
    متغیر بعد_پہلی = انتظار بقیہ_حاصل(db, "احمد");
    انتظار db.نقطہ_محفوظ("نقطہ1");  // ← یہاں محفوظ کریں

    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ + ? WHERE نام = ?", [2000, "احمد"]);
    متغیر بعد_دوسری = انتظار بقیہ_حاصل(db, "احمد");
    انتظار db.نقطہ_محفوظ("نقطہ2");  // ← دوسرا نقطہ

    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = 0 WHERE نام = ?", ["احمد"]);  // غلط آپریشن!
    متغیر بعد_غلطی = انتظار بقیہ_حاصل(db, "احمد");

    // نقطہ2 پر واپس جائیں (غلط آپریشن منسوخ)
    انتظار db.نقطہ_واپسی("نقطہ2");
    متغیر بعد_نقطہ2 = انتظار بقیہ_حاصل(db, "احمد");

    انتظار db.نقطہ_چھوڑیں("نقطہ2");  // نقطہ2 ختم کریں
    انتظار db.کمٹ();  // نقطہ1 تک کی تبدیلیاں محفوظ

    متغیر آخری = انتظار بقیہ_حاصل(db, "احمد");
    لکھو(`  SAVEPOINT نقطہ1 کے بعد: ${بعد_پہلی}`);
    لکھو(`  SAVEPOINT نقطہ2 کے بعد: ${بعد_دوسری}`);
    لکھو(`  غلط آپریشن کے بعد: ${بعد_غلطی}`);
    لکھو(`  نقطہ2 واپسی کے بعد: ${بعد_نقطہ2}`);
    لکھو(`  COMMIT کے بعد (آخری): ${آخری}`);
    اگر (بعد_غلطی == 0 && بعد_نقطہ2 == بعد_دوسری && آخری == بعد_دوسری) {
        پاس("SAVEPOINT + ROLLBACK TO + RELEASE + COMMIT");
    } ورنہ {
        ناکام("SAVEPOINT", "توقع کے خلاف نتیجہ");
    }

    // ── 5. بیک وقت متعدد SAVEPOINT ────────────────────
    لکھو("\n  ─ 5. نیسٹڈ SAVEPOINT (پہلے نقطے پر واپسی) ─");
    انتظار شروع_کریں(db);  // ڈیٹا ری سیٹ
    انتظار db.لین_دین_شروع();
    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = 9000 WHERE نام = ?", ["احمد"]);
    انتظار db.نقطہ_محفوظ("ابتدا");
    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = 7000 WHERE نام = ?", ["احمد"]);
    انتظار db.نقطہ_محفوظ("درمیان");
    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = 1 WHERE نام = ?", ["احمد"]);
    // پہلے نقطے پر واپس
    انتظار db.نقطہ_واپسی("ابتدا");
    انتظار db.کمٹ();
    متغیر نیسٹڈ = انتظار بقیہ_حاصل(db, "احمد");
    اگر (نیسٹڈ == 9000) {
        پاس(`نیسٹڈ SAVEPOINT — ابتدا پر واپسی: ${نیسٹڈ}`);
    } ورنہ {
        ناکام("نیسٹڈ SAVEPOINT", `بقیہ=${نیسٹڈ}`);
    }

    انتظار db.منقطع();
    لکھو("  ─── ایس_کیو_لائٹ: تمام لین دین پاس ───");
}

// ══════════════════════════════════════════════════════
// مائی_ایس_کیو_ایل لین دین جانچ
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن mysql_لین_دین() {
    لکھو("\n╔════════════════════════════════════════╗");
    لکھو(  "║   مائی_ایس_کیو_ایل/MariaDB — لین دین جانچ        ║");
    لکھو(  "╚════════════════════════════════════════╝");

    متغیر db = نیا مائی_ایس_کیو_ایل({ میزبان: "localhost", صارف: "root", پاس_ورڈ: "" });
    انتظار db.جوڑیں();
    انتظار db.چلائیں("CREATE DATABASE IF NOT EXISTS tx_test CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci");
    انتظار db.چلائیں("USE tx_test");
    انتظار db.چلائیں("DROP TABLE IF EXISTS کھاتے");
    انتظار db.چلائیں(`CREATE TABLE کھاتے (
        شناخت INT AUTO_INCREMENT PRIMARY KEY,
        نام    VARCHAR(100) NOT NULL,
        بقیہ   DECIMAL(10,2) DEFAULT 0
    )`);
    انتظار db.چلائیں("INSERT INTO کھاتے (نام, بقیہ) VALUES (?, ?)", ["احمد", 10000]);
    انتظار db.چلائیں("INSERT INTO کھاتے (نام, بقیہ) VALUES (?, ?)", ["فاطمہ", 5000]);

    // ── 1. کامیاب COMMIT ──────────────────────────────
    لکھو("\n  ─ 1. کامیاب منتقلی (COMMIT) ─");
    انتظار db.لین_دین_شروع();
    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [3000, "احمد"]);
    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ + ? WHERE نام = ?", [3000, "فاطمہ"]);
    انتظار db.کمٹ();

    متغیر ر1 = انتظار db.سوال("SELECT بقیہ FROM کھاتے WHERE نام = ?", ["احمد"]);
    متغیر ر2 = انتظار db.سوال("SELECT بقیہ FROM کھاتے WHERE نام = ?", ["فاطمہ"]);
    اگر (ر1[0].بقیہ == 7000 && ر2[0].بقیہ == 8000) {
        پاس(`COMMIT — احمد: ${ر1[0].بقیہ}، فاطمہ: ${ر2[0].بقیہ}`);
    } ورنہ {
        ناکام("COMMIT", `احمد=${ر1[0].بقیہ}, فاطمہ=${ر2[0].بقیہ}`);
    }

    // ── 2. ROLLBACK ────────────────────────────────────
    لکھو("\n  ─ 2. ROLLBACK ─");
    انتظار db.لین_دین_شروع();
    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [6000, "احمد"]);
    متغیر درمیان = انتظار db.سوال("SELECT بقیہ FROM کھاتے WHERE نام = ?", ["احمد"]);
    لکھو(`  لین دین میں احمد کا بقیہ: ${درمیان[0].بقیہ} (ابھی کمٹ نہیں)`);
    انتظار db.واپسی();
    متغیر رول_بعد = انتظار db.سوال("SELECT بقیہ FROM کھاتے WHERE نام = ?", ["احمد"]);
    اگر (رول_بعد[0].بقیہ == 7000) {
        پاس(`ROLLBACK — احمد کا بقیہ بحال: ${رول_بعد[0].بقیہ}`);
    } ورنہ {
        ناکام("ROLLBACK", `بقیہ=${رول_بعد[0].بقیہ}`);
    }

    // ── 3. لین_دین() wrapper ──────────────────────────
    لکھو("\n  ─ 3. لین_دین() خودکار ─");
    انتظار db.لین_دین(غیر_متزامن فنکشن() {
        انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [1000, "احمد"]);
        انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ + ? WHERE نام = ?", [1000, "فاطمہ"]);
    });
    متغیر ا3 = انتظار db.سوال("SELECT بقیہ FROM کھاتے WHERE نام = ?", ["احمد"]);
    متغیر ف3 = انتظار db.سوال("SELECT بقیہ FROM کھاتے WHERE نام = ?", ["فاطمہ"]);
    اگر (ا3[0].بقیہ == 6000 && ف3[0].بقیہ == 9000) {
        پاس(`لین_دین() COMMIT — احمد: ${ا3[0].بقیہ}، فاطمہ: ${ف3[0].بقیہ}`);
    } ورنہ {
        ناکام("لین_دین() COMMIT", `احمد=${ا3[0].بقیہ}, فاطمہ=${ف3[0].بقیہ}`);
    }

    // خودکار ROLLBACK
    متغیر پہلے = ا3[0].بقیہ;
    کوشش {
        انتظار db.لین_دین(غیر_متزامن فنکشن() {
            انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ - ? WHERE نام = ?", [500, "احمد"]);
            پھینکو نیا غلطی("بینک سرور بند!");
        });
    } پکڑو (غ) {
        متغیر بعد = انتظار db.سوال("SELECT بقیہ FROM کھاتے WHERE نام = ?", ["احمد"]);
        اگر (بعد[0].بقیہ == پہلے) {
            پاس(`لین_دین() خودکار ROLLBACK — ${غ.پیغام}`);
        } ورنہ {
            ناکام("خودکار ROLLBACK", `بقیہ=${بعد[0].بقیہ}`);
        }
    }

    // ── 4. SAVEPOINT ──────────────────────────────────
    لکھو("\n  ─ 4. SAVEPOINT / نقطہ محفوظ ─");
    انتظار db.لین_دین_شروع();
    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ + ? WHERE نام = ?", [2000, "احمد"]);
    انتظار db.نقطہ_محفوظ("sp_a");

    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = بقیہ + ? WHERE نام = ?", [3000, "احمد"]);
    متغیر سپ_بعد = انتظار db.سوال("SELECT بقیہ FROM کھاتے WHERE نام = ?", ["احمد"]);
    لکھو(`  sp_a کے بعد مزید 3000 جمع: ${سپ_بعد[0].بقیہ}`);

    // sp_a پر واپس
    انتظار db.نقطہ_واپسی("sp_a");
    متغیر سپ_واپس = انتظار db.سوال("SELECT بقیہ FROM کھاتے WHERE نام = ?", ["احمد"]);
    لکھو(`  ROLLBACK TO sp_a: ${سپ_واپس[0].بقیہ}`);

    انتظار db.نقطہ_چھوڑیں("sp_a");
    انتظار db.کمٹ();

    متغیر آخری = انتظار db.سوال("SELECT بقیہ FROM کھاتے WHERE نام = ?", ["احمد"]);
    لکھو(`  آخری بقیہ (COMMIT): ${آخری[0].بقیہ}`);
    اگر (آخری[0].بقیہ == 8000) {
        پاس("مائی_ایس_کیو_ایل SAVEPOINT + ROLLBACK TO + RELEASE + COMMIT");
    } ورنہ {
        ناکام("مائی_ایس_کیو_ایل SAVEPOINT", `بقیہ=${آخری[0].بقیہ}`);
    }

    // ── 5. مائی_ایس_کیو_ایل: READ UNCOMMITTED (dirty read دکھانا) ─
    لکھو("\n  ─ 5. لین دین کے دوران READ (uncommitted) ─");
    انتظار db.لین_دین_شروع();
    انتظار db.چلائیں("UPDATE کھاتے SET بقیہ = 99999 WHERE نام = ?", ["احمد"]);
    متغیر اندرونی = انتظار db.سوال("SELECT بقیہ FROM کھاتے WHERE نام = ?", ["احمد"]);
    لکھو(`  لین دین کے اندر READ: ${اندرونی[0].بقیہ}`);
    انتظار db.واپسی();
    متغیر بعد_رول = انتظار db.سوال("SELECT بقیہ FROM کھاتے WHERE نام = ?", ["احمد"]);
    لکھو(`  ROLLBACK کے بعد READ: ${بعد_رول[0].بقیہ}`);
    اگر (اندرونی[0].بقیہ == 99999 && بعد_رول[0].بقیہ == 8000) {
        پاس("لین دین کے اندر تبدیلی نظر آتی ہے، ROLLBACK کے بعد واپس");
    } ورنہ {
        ناکام("READ UNCOMMITTED", "توقع کے مطابق نہیں");
    }

    // صفائی
    انتظار db.چلائیں("DROP TABLE کھاتے");
    انتظار db.چلائیں("DROP DATABASE tx_test");
    انتظار db.منقطع();
    لکھو("  ─── مائی_ایس_کیو_ایل: تمام لین دین پاس ───");
}

// ══════════════════════════════════════════════════════
// مرکزی
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن مرکز() {
    لکھو("══════════════════════════════════════════");
    لکھو("  اردو DB — لین دین (Transaction) جانچ");
    لکھو("══════════════════════════════════════════");

    انتظار sqlite_لین_دین();
    انتظار mysql_لین_دین();

    لکھو("\n══════════════════════════════════════════");
    لکھو("  تمام لین دین جانچ کامیاب ✓");
    لکھو("══════════════════════════════════════════");
}

مرکز();
