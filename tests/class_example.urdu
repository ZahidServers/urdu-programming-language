// ══════════════════════════════════════════════
// اردو پروگرامنگ لینگویج — آبجیکٹ اوریینٹیڈ مثال
// OOP Example — Classes, Inheritance, Polymorphism
// ══════════════════════════════════════════════

// بنیادی کلاس (Base Class)
کلاس جاندار {
    تعمیر(نام، عمر) {
        یہ.نام = نام;
        یہ.عمر = عمر;
    }

    بولو() {
        لکھو(`${یہ.نام} کچھ آواز نکالتا ہے`);
    }

    تعارف() {
        لکھو(`نام: ${یہ.نام} | عمر: ${یہ.عمر} سال`);
    }

    جامد بنائیں(نام، عمر) {
        واپس نیا جاندار(نام, عمر);
    }
}

// وراثت (Inheritance)
کلاس کتا توسیع جاندار {
    تعمیر(نام، نسل) {
        سپر(نام, 3);
        یہ.نسل = نسل;
    }

    بولو() {
        لکھو(`${یہ.نام}: بھونک! بھونک! 🐕`);
    }

    معلومات() {
        سپر.تعارف();
        لکھو(`نسل: ${یہ.نسل}`);
    }
}

کلاس بلی توسیع جاندار {
    تعمیر(نام) {
        سپر(نام, 2);
        یہ.اندر = سچ;
    }

    بولو() {
        لکھو(`${یہ.نام}: میاؤں! 🐈`);
    }
}

// کثیر اشکالی (Polymorphism)
فنکشن سب_بولیں(جانور_فہرست) {
    کے_لیے (متغیر جانور میں جانور_فہرست) {
        جانور.بولو();
    }
}

// نجی اور عوامی ارکان (Private & Public)
کلاس بنک_کھاتہ {
    نجی بقیہ = 0;
    نجی مالک;

    تعمیر(مالک، ابتدائی_رقم) {
        یہ.مالک = مالک;
        یہ.بقیہ = ابتدائی_رقم || 0;
    }

    جمع_کریں(رقم) {
        اگر (رقم <= 0) {
            پھینکو نیا غلطی("رقم مثبت ہونی چاہیے");
        }
        یہ.بقیہ += رقم;
        لکھو(`${رقم} روپے جمع۔ نیا بقیہ: ${یہ.بقیہ}`);
    }

    نکالیں(رقم) {
        اگر (رقم > یہ.بقیہ) {
            پھینکو نیا غلطی("ناکافی بقیہ");
        }
        یہ.بقیہ -= رقم;
        لکھو(`${رقم} روپے نکالے۔ بقایا: ${یہ.بقیہ}`);
    }

    بقیہ_دیکھیں() {
        لکھو(`${یہ.مالک} کا بقیہ: ${یہ.بقیہ} روپے`);
        واپس یہ.بقیہ;
    }
}

// ═══ ٹیسٹ ═══
لکھو("═══ جانوروں کا ٹیسٹ ═══");
متغیر میرا_کتا = نیا کتا("ٹومی", "جرمن شیفرڈ");
متغیر میری_بلی = نیا بلی("مشری");
متغیر جانور_فہرست = [میرا_کتا, میری_بلی, نیا جاندار("طوطا", 5)];

کے_لیے (متغیر ج میں جانور_فہرست) {
    ج.تعارف();
}
لکھو("");
سب_بولیں(جانور_فہرست);

لکھو("\n═══ بنک کھاتہ ═══");
متغیر کھاتہ = نیا بنک_کھاتہ("علی احمد", 5000);
کھاتہ.بقیہ_دیکھیں();
کھاتہ.جمع_کریں(2000);
کھاتہ.نکالیں(1500);

کوشش {
    کھاتہ.نکالیں(99999);
} پکڑو (غ) {
    لکھو(`غلطی: ${غ.پیغام}`);
}

// جیٹر/سیٹر (Getter/Setter)
کلاس دائرہ {
    تعمیر(رداس) {
        یہ._رداس = رداس;
    }

    حاصل_کرو رداس() {
        واپس یہ._رداس;
    }

    مقرر_کرو رداس(قدر) {
        اگر (قدر < 0) پھینکو نیا غلطی("رداس منفی نہیں ہو سکتا");
        یہ._رداس = قدر;
    }

    حاصل_کرو رقبہ() {
        واپس ریاضی.PI * یہ._رداس ** 2;
    }

    حاصل_کرو محیط() {
        واپس 2 * ریاضی.PI * یہ._رداس;
    }
}

لکھو("\n═══ دائرہ ═══");
متغیر د = نیا دائرہ(7);
لکھو(`رداس: ${د.رداس}`);
لکھو(`رقبہ: ${گول(د.رقبہ, 2)}`);
لکھو(`محیط: ${گول(د.محیط, 2)}`);
