// ══════════════════════════════════════════════════════
// مکمل CRUD جانچ — ایس_کیو_لائٹ، مائی_ایس_کیو_ایل، مونگو_ڈی_بی
// ══════════════════════════════════════════════════════

درآمد { ایس_کیو_لائٹ, مائی_ایس_کیو_ایل, مونگو_ڈی_بی } سے "اردو/ڈیٹا_بیس";

// ─── مددگار فنکشن ──────────────────────────────────────
فنکشن نتیجہ(نام, کامیاب) {
    اگر (کامیاب) {
        لکھو(`  ✓ ${نام}`);
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
    }
}

// ══════════════════════════════════════════════════════
// 1. ایس_کیو_لائٹ CRUD
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن جانچ_sqlite() {
    لکھو("\n╔══════════════════════════════╗");
    لکھو(  "║  ایس_کیو_لائٹ مکمل CRUD جانچ      ║");
    لکھو(  "╚══════════════════════════════╝");

    متغیر db = نیا ایس_کیو_لائٹ(":memory:");
    انتظار db.جوڑیں();

    // CREATE
    انتظار db.جدول_بنائیں("مصنوعات", {
        شناخت: "INTEGER PRIMARY KEY AUTOINCREMENT",
        نام:   "TEXT NOT NULL",
        قیمت:  "REAL",
        تعداد: "INTEGER DEFAULT 0"
    });
    نتیجہ("CREATE — جدول بنایا", سچ);

    // INSERT
    انتظار db.چلائیں("INSERT INTO مصنوعات (نام, قیمت, تعداد) VALUES (?, ?, ?)", ["چائے", 120.0, 50]);
    انتظار db.چلائیں("INSERT INTO مصنوعات (نام, قیمت, تعداد) VALUES (?, ?, ?)", ["کافی", 250.0, 30]);
    انتظار db.چلائیں("INSERT INTO مصنوعات (نام, قیمت, تعداد) VALUES (?, ?, ?)", ["دودھ", 80.0, 100]);
    متغیر تمام = انتظار db.سوال("SELECT * FROM مصنوعات");
    نتیجہ("INSERT — 3 ریکارڈ داخل", لمبائی(تمام) == 3);

    // READ (SELECT + WHERE + ORDER)
    متغیر ایک = انتظار db.سوال("SELECT * FROM مصنوعات WHERE نام = ?", ["کافی"]);
    نتیجہ("READ — نام سے تلاش", لمبائی(ایک) == 1 && ایک[0].نام == "کافی");

    متغیر ترتیب = انتظار db.سوال("SELECT * FROM مصنوعات ORDER BY قیمت DESC");
    نتیجہ("READ — قیمت کے مطابق ترتیب", ترتیب[0].نام == "کافی");

    متغیر جمع = انتظار db.سوال("SELECT SUM(قیمت) as کل FROM مصنوعات");
    نتیجہ("READ — SUM جمع", جمع[0].کل == 450.0);

    // UPDATE
    انتظار db.چلائیں("UPDATE مصنوعات SET قیمت = ? WHERE نام = ?", [140.0, "چائے"]);
    متغیر بعد = انتظار db.سوال("SELECT قیمت FROM مصنوعات WHERE نام = ?", ["چائے"]);
    نتیجہ("UPDATE — قیمت تبدیل", بعد[0].قیمت == 140.0);

    متغیر متاثرہ = انتظار db.چلائیں("UPDATE مصنوعات SET تعداد = تعداد + 10 WHERE قیمت > ?", [100.0]);
    نتیجہ("UPDATE — شرط سے متعدد ریکارڈ", متاثرہ == 2);

    // DELETE
    انتظار db.چلائیں("DELETE FROM مصنوعات WHERE نام = ?", ["دودھ"]);
    متغیر باقی = انتظار db.سوال("SELECT COUNT(*) as گنتی FROM مصنوعات");
    نتیجہ("DELETE — ایک ریکارڈ حذف", باقی[0].گنتی == 2);

    انتظار db.چلائیں("DELETE FROM مصنوعات");
    متغیر صفر_جانچ = انتظار db.سوال("SELECT COUNT(*) as گنتی FROM مصنوعات");
    نتیجہ("DELETE — تمام ریکارڈ حذف", صفر_جانچ[0].گنتی == 0);

    انتظار db.منقطع();
    لکھو("  ─── ایس_کیو_لائٹ: تمام CRUD پاس ───");
}

// ══════════════════════════════════════════════════════
// 2. مائی_ایس_کیو_ایل / MariaDB CRUD
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن جانچ_mysql() {
    لکھو("\n╔══════════════════════════════╗");
    لکھو(  "║  مائی_ایس_کیو_ایل/MariaDB مکمل CRUD جانچ ║");
    لکھو(  "╚══════════════════════════════╝");

    متغیر db = نیا مائی_ایس_کیو_ایل({ میزبان: "localhost", صارف: "root", پاس_ورڈ: "" });
    انتظار db.جوڑیں();

    // ڈیٹا بیس تیار کریں
    انتظار db.چلائیں("CREATE DATABASE IF NOT EXISTS crud_test CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci");
    انتظار db.چلائیں("USE crud_test");
    انتظار db.چلائیں("DROP TABLE IF EXISTS مصنوعات");

    // CREATE
    انتظار db.چلائیں(`
        CREATE TABLE مصنوعات (
            شناخت INT AUTO_INCREMENT PRIMARY KEY,
            نام    VARCHAR(100) NOT NULL,
            قیمت   DECIMAL(8,2),
            تعداد  INT DEFAULT 0,
            فعال   TINYINT(1) DEFAULT 1
        )
    `);
    نتیجہ("CREATE — جدول بنایا", سچ);

    // INSERT
    انتظار db.چلائیں("INSERT INTO مصنوعات (نام, قیمت, تعداد) VALUES (?, ?, ?)", ["چائے", 120.0, 50]);
    انتظار db.چلائیں("INSERT INTO مصنوعات (نام, قیمت, تعداد) VALUES (?, ?, ?)", ["کافی", 250.0, 30]);
    انتظار db.چلائیں("INSERT INTO مصنوعات (نام, قیمت, تعداد) VALUES (?, ?, ?)", ["دودھ", 80.0, 100]);
    متغیر تمام = انتظار db.سوال("SELECT * FROM مصنوعات");
    نتیجہ("INSERT — 3 ریکارڈ داخل", لمبائی(تمام) == 3);

    // داخل() مددگار فنکشن (shortcut)
    انتظار db.داخل("مصنوعات", { نام: "جوس", قیمت: 60.0, تعداد: 200 });
    متغیر چار = انتظار db.سوال("SELECT COUNT(*) as گنتی FROM مصنوعات");
    نتیجہ("INSERT — داخل() شارٹ کٹ", چار[0].گنتی == 4);

    // READ
    متغیر ایک = انتظار db.سوال("SELECT * FROM مصنوعات WHERE نام = ?", ["کافی"]);
    نتیجہ("READ — WHERE فلٹر", لمبائی(ایک) == 1 && ایک[0].نام == "کافی");

    متغیر ترتیب = انتظار db.سوال("SELECT * FROM مصنوعات ORDER BY قیمت DESC LIMIT 1");
    نتیجہ("READ — ORDER BY + LIMIT", ترتیب[0].نام == "کافی");

    متغیر جمع = انتظار db.سوال("SELECT SUM(قیمت) as کل, AVG(قیمت) as اوسط FROM مصنوعات");
    نتیجہ("READ — SUM + AVG جمع", جمع[0].کل == 510.0);

    متغیر گروپ = انتظار db.سوال("SELECT COUNT(*) as تعداد FROM مصنوعات WHERE قیمت > ?", [100.0]);
    نتیجہ("READ — COUNT + شرط", گروپ[0].تعداد == 2);

    // UPDATE
    متغیر اپ = انتظار db.چلائیں("UPDATE مصنوعات SET قیمت = ? WHERE نام = ?", [140.0, "چائے"]);
    متغیر نئی = انتظار db.سوال("SELECT قیمت FROM مصنوعات WHERE نام = ?", ["چائے"]);
    نتیجہ("UPDATE — قیمت تبدیل", نئی[0].قیمت == 140.0);

    متغیر کئی = انتظار db.چلائیں("UPDATE مصنوعات SET فعال = 0 WHERE قیمت < ?", [100.0]);
    نتیجہ("UPDATE — متعدد ریکارڈ", کئی == 2);

    // DELETE
    انتظار db.چلائیں("DELETE FROM مصنوعات WHERE نام = ?", ["جوس"]);
    متغیر باقی = انتظار db.سوال("SELECT COUNT(*) as گنتی FROM مصنوعات");
    نتیجہ("DELETE — ایک ریکارڈ حذف", باقی[0].گنتی == 3);

    انتظار db.چلائیں("DELETE FROM مصنوعات WHERE فعال = 0");
    متغیر فعال = انتظار db.سوال("SELECT COUNT(*) as گنتی FROM مصنوعات WHERE فعال = 1");
    نتیجہ("DELETE — شرط سے حذف", فعال[0].گنتی == 2);

    // صفائی
    انتظار db.چلائیں("DROP TABLE مصنوعات");
    انتظار db.چلائیں("DROP DATABASE crud_test");
    انتظار db.منقطع();
    لکھو("  ─── مائی_ایس_کیو_ایل: تمام CRUD پاس ───");
}

// ══════════════════════════════════════════════════════
// 3. مونگو_ڈی_بی CRUD
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن جانچ_mongodb() {
    لکھو("\n╔══════════════════════════════╗");
    لکھو(  "║  مونگو_ڈی_بی مکمل CRUD جانچ      ║");
    لکھو(  "╚══════════════════════════════╝");

    متغیر mongo = نیا مونگو_ڈی_بی({ میزبان: "localhost", پورٹ: 27017, ڈیٹا_بیس: "crud_test" });
    انتظار mongo.جوڑیں();
    متغیر col = mongo.مجموعہ("مصنوعات");

    // پرانا ڈیٹا صاف
    انتظار col.حذف({});

    // CREATE (insert)
    متغیر id1 = انتظار col.داخل({ نام: "چائے",  قیمت: 120, تعداد: 50,  فعال: سچ });
    متغیر id2 = انتظار col.داخل({ نام: "کافی",  قیمت: 250, تعداد: 30,  فعال: سچ });
    متغیر id3 = انتظار col.داخل({ نام: "دودھ",  قیمت: 80,  تعداد: 100, فعال: سچ });
    متغیر گنتی1 = انتظار col.گنتی({});
    نتیجہ("CREATE — داخل() ایک دستاویز", گنتی1 == 3);

    // بہت_داخل (insertMany)
    انتظار col.بہت_داخل([
        { نام: "جوس",   قیمت: 60,  تعداد: 200, فعال: سچ },
        { نام: "پانی",  قیمت: 20,  تعداد: 500, فعال: سچ },
    ]);
    متغیر گنتی2 = انتظار col.گنتی({});
    نتیجہ("CREATE — بہت_داخل() متعدد", گنتی2 == 5);

    // READ
    متغیر تمام = انتظار col.تلاش({});
    نتیجہ("READ — تلاش() سب", لمبائی(تمام) == 5);

    متغیر ایک = انتظار col.ایک_تلاش({ نام: "کافی" });
    نتیجہ("READ — ایک_تلاش() ایک دستاویز", ایک != خالی && ایک.نام == "کافی");

    متغیر محدود = انتظار col.تلاش({}, { حد: 2 });
    نتیجہ("READ — تلاش() حد (limit)", لمبائی(محدود) == 2);

    متغیر مہنگے = انتظار col.تلاش({ قیمت: { "$gte": 100 } });
    نتیجہ("READ — تلاش() آپریٹر ($gte)", لمبائی(مہنگے) == 2);

    متغیر گنتی3 = انتظار col.گنتی({ فعال: سچ });
    نتیجہ("READ — گنتی() شرط سے", گنتی3 == 5);

    // UPDATE
    متغیر تازہ1 = انتظار col.تازہ_کاری({ نام: "چائے" }, { قیمت: 150 });
    متغیر تصدیق = انتظار col.ایک_تلاش({ نام: "چائے" });
    نتیجہ("UPDATE — تازہ_کاری() ایک", تصدیق.قیمت == 150);

    متغیر تازہ2 = انتظار col.تازہ_کاری({ قیمت: { "$lt": 100 } }, { فعال: جھوٹ });
    متغیر غیرفعال = انتظار col.گنتی({ فعال: جھوٹ });
    نتیجہ("UPDATE — تازہ_کاری() متعدد ($lt)", غیرفعال == 3);

    // DELETE
    متغیر حذف1 = انتظار col.حذف({ نام: "پانی" });
    نتیجہ("DELETE — حذف() ایک", حذف1 == 1);

    متغیر حذف2 = انتظار col.حذف({ فعال: جھوٹ });
    متغیر باقی = انتظار col.گنتی({});
    نتیجہ("DELETE — حذف() شرط سے متعدد", باقی == 2);

    متغیر سب = انتظار col.حذف({});
    نتیجہ("DELETE — حذف({}) سب صاف", انتظار col.گنتی({}) == 0);

    انتظار mongo.منقطع();
    لکھو("  ─── مونگو_ڈی_بی: تمام CRUD پاس ───");
}

// ══════════════════════════════════════════════════════
// مرکزی: تینوں چلائیں
// ══════════════════════════════════════════════════════
غیر_متزامن فنکشن مرکز() {
    لکھو("══════════════════════════════════════");
    لکھو("   اردو DB — مکمل CRUD جانچ رپورٹ");
    لکھو("══════════════════════════════════════");

    انتظار جانچ_sqlite();
    انتظار جانچ_mysql();
    انتظار جانچ_mongodb();

    لکھو("\n══════════════════════════════════════");
    لکھو("   تمام ڈیٹا بیس CRUD کامیاب ✓");
    لکھو("══════════════════════════════════════");
}

مرکز();
