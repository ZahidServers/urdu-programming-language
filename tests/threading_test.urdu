// ══════════════════════════════════════════════
// اردو/دھاگہ — Threading & Futures Library Test
// ══════════════════════════════════════════════

درآمد {
    دھاگہ, دھاگہ_تالاب,
    تالہ, واقعہ, سیمافور,
    قطار, ترجیحی_قطار,
    ٹائمر, مستقبل, مقامی_ذخیرہ
} سے "اردو/دھاگہ";

متغیر ن = { "گزرے": 0, "ناکام": 0 };

فنکشن جانچ(نام, شرط) {
    اگر (شرط) {
        لکھو(`  ✓ ${نام}`);
        ن["گزرے"] = ن["گزرے"] + 1;
    } ورنہ {
        لکھو(`  ✗ ${نام}`);
        ن["ناکام"] = ن["ناکام"] + 1;
    }
}

لکھو("╔══════════════════════════════════════╗");
لکھو("║  دھاگہ و مستقبل جانچ                ║");
لکھو("╚══════════════════════════════════════╝");

// ─── دھاگہ (Thread) ──────────────────────────
لکھو("\n─── دھاگہ ───");

متغیر نتیجہ_دھاگہ = [0];

فنکشن کام_دھاگہ() {
    نتیجہ_دھاگہ[0] = 42;
}

کوشش {
    متغیر دھ = نیا دھاگہ(کام_دھاگہ);
    دھ.شروع();
    دھ.انتظار(5.0);
    جانچ("دھاگہ شروع/انتظار", نتیجہ_دھاگہ[0] == 42);
    جانچ("دھاگہ رکا", !دھ.چل_رہا());
} پکڑو (غ) {
    لکھو(`  ✗ دھاگہ غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ─── دھاگہ_تالاب + مستقبل ────────────────────
لکھو("\n─── دھاگہ_تالاب + مستقبل ───");

فنکشن جمع_کرو(الف, ب) {
    واپس الف + ب;
}

کوشش {
    متغیر تالاب = نیا دھاگہ_تالاب(2);
    متغیر م = تالاب.جمع_کرو_مستقبل(جمع_کرو, 10, 20);

    جانچ("مستقبل بنا", م != خالی);
    متغیر نتیجہ = م.نتیجہ(5.0);
    جانچ("مستقبل نتیجہ 30", نتیجہ == 30);
    جانچ("مستقبل مکمل", م.مکمل());
    تالاب.بند();
} پکڑو (غ) {
    لکھو(`  ✗ تالاب+مستقبل غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ─── دھاگہ_تالاب نقشہ ────────────────────────
لکھو("\n─── دھاگہ_تالاب نقشہ ───");

فنکشن مربع(ع) {
    واپس ع * ع;
}

کوشش {
    متغیر تالاب = نیا دھاگہ_تالاب(4);
    متغیر نتائج = تالاب.نقشہ(مربع, [1, 2, 3, 4, 5]);
    جانچ("نقشہ 5 نتائج", نتائج.لمبائی == 5);
    جانچ("نقشہ 1→1", نتائج[0] == 1);
    جانچ("نقشہ 3→9", نتائج[2] == 9);
    جانچ("نقشہ 5→25", نتائج[4] == 25);
    تالاب.بند();
} پکڑو (غ) {
    لکھو(`  ✗ نقشہ غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ─── تالہ (Lock) ─────────────────────────────
لکھو("\n─── تالہ (Lock) ───");

متغیر مشترک_گنتی = [0];

فنکشن بڑھاؤ_محفوظ(قفل, تعداد) {
    کے_لیے (متغیر i = 0; i < تعداد; i++) {
        قفل.قبضہ();
        مشترک_گنتی[0] = مشترک_گنتی[0] + 1;
        قفل.چھوڑو();
    }
}

کوشش {
    متغیر قفل = نیا تالہ();
    جانچ("تالہ بنا", قفل != خالی);

    متغیر دھ1 = نیا دھاگہ(بڑھاؤ_محفوظ, قفل, 100);
    متغیر دھ2 = نیا دھاگہ(بڑھاؤ_محفوظ, قفل, 100);
    دھ1.شروع();
    دھ2.شروع();
    دھ1.انتظار(10.0);
    دھ2.انتظار(10.0);

    جانچ("تالہ کے ساتھ 200", مشترک_گنتی[0] == 200);
} پکڑو (غ) {
    لکھو(`  ✗ تالہ غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ─── واقعہ (Event) ───────────────────────────
لکھو("\n─── واقعہ (Event) ───");

کوشش {
    متغیر واق = نیا واقعہ();
    جانچ("واقعہ ابتدا بند", !واق.لگا_ہوا());

    واق.مقرر();
    جانچ("واقعہ مقرر ہوا", واق.لگا_ہوا());

    متغیر انتظار_نتیجہ = واق.انتظار(0.1);
    جانچ("واقعہ انتظار سچ", انتظار_نتیجہ == سچ);

    واق.صاف();
    جانچ("واقعہ صاف ہوا", !واق.لگا_ہوا());

    متغیر ٹائم_آؤٹ = واق.انتظار(0.05);
    جانچ("واقعہ ٹائم آؤٹ جھوٹ", ٹائم_آؤٹ == جھوٹ);
} پکڑو (غ) {
    لکھو(`  ✗ واقعہ غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ─── دھاگے + واقعہ ───────────────────────────
لکھو("\n─── دھاگے + واقعہ ───");

متغیر اشارہ = نیا واقعہ();
متغیر سیگ_نتیجہ = [0];

فنکشن انتظار_کرو(واق) {
    واق.انتظار(5.0);
    سیگ_نتیجہ[0] = 99;
}

کوشش {
    متغیر دھ = نیا دھاگہ(انتظار_کرو, اشارہ);
    دھ.شروع();
    اشارہ.مقرر();
    دھ.انتظار(5.0);
    جانچ("واقعہ کے ذریعے اشارہ", سیگ_نتیجہ[0] == 99);
} پکڑو (غ) {
    لکھو(`  ✗ دھاگے+واقعہ غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ─── قطار (Queue) ────────────────────────────
لکھو("\n─── قطار ───");

کوشش {
    متغیر ق = نیا قطار();
    جانچ("قطار خالی", ق.خالی());

    ق.ڈالو("پہلا");
    ق.ڈالو("دوسرا");
    ق.ڈالو("تیسرا");

    جانچ("قطار 3 آئٹم", ق.لمبائی == 3);
    جانچ("قطار خالی نہیں", !ق.خالی());

    متغیر آئٹم1 = ق.نکالو();
    جانچ("FIFO — پہلا", آئٹم1 == "پہلا");

    متغیر آئٹم2 = ق.نکالو();
    جانچ("FIFO — دوسرا", آئٹم2 == "دوسرا");

    جانچ("قطار 1 آئٹم بچا", ق.لمبائی == 1);
} پکڑو (غ) {
    لکھو(`  ✗ قطار غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ─── قطار — ڈالو/نکالو بین الدھاگے ──────────
لکھو("\n─── قطار بین الدھاگے ───");

کوشش {
    متغیر چینل = نیا قطار();
    متغیر وصول = [0];

    فنکشن صارف(ق) {
        متغیر قدر = ق.نکالو(5.0);
        وصول[0] = قدر;
    }

    متغیر دھ = نیا دھاگہ(صارف, چینل);
    دھ.شروع();
    چینل.ڈالو(777);
    دھ.انتظار(5.0);
    جانچ("قطار بین الدھاگے 777", وصول[0] == 777);
} پکڑو (غ) {
    لکھو(`  ✗ قطار بین الدھاگے غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ─── ترجیحی_قطار ─────────────────────────────
لکھو("\n─── ترجیحی_قطار ───");

کوشش {
    متغیر تق = نیا ترجیحی_قطار();
    تق.ڈالو(3, "کم ترجیح");
    تق.ڈالو(1, "زیادہ ترجیح");
    تق.ڈالو(2, "درمیانی ترجیح");

    متغیر ت1 = تق.نکالو();
    متغیر ت2 = تق.نکالو();
    متغیر ت3 = تق.نکالو();

    جانچ("ترجیح 1 پہلے", ت1[1] == "زیادہ ترجیح");
    جانچ("ترجیح 2 دوسرے", ت2[1] == "درمیانی ترجیح");
    جانچ("ترجیح 3 آخر", ت3[1] == "کم ترجیح");
} پکڑو (غ) {
    لکھو(`  ✗ ترجیحی_قطار غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ─── سیمافور ─────────────────────────────────
لکھو("\n─── سیمافور ───");

کوشش {
    متغیر سیم = نیا سیمافور(2);
    جانچ("سیمافور بنا", سیم != خالی);

    متغیر ح1 = سیم.حاصل(0.1);
    متغیر ح2 = سیم.حاصل(0.1);
    جانچ("دو اجازتیں ملیں", ح1 == سچ && ح2 == سچ);

    متغیر ح3 = سیم.حاصل(0.05);
    جانچ("تیسری اجازت نہ ملی (ٹائم آؤٹ)", ح3 == جھوٹ);

    سیم.چھوڑو();
    سیم.چھوڑو();
} پکڑو (غ) {
    لکھو(`  ✗ سیمافور غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ─── مستقبل — منسوخ جانچ ─────────────────────
لکھو("\n─── مستقبل — غلطی جانچ ───");

فنکشن غلطی_والا_کام() {
    پھینکو نیا غلطی("جان بوجھ کر غلطی");
}

کوشش {
    متغیر تالاب = نیا دھاگہ_تالاب(1);
    متغیر م = تالاب.جمع_کرو_مستقبل(غلطی_والا_کام);
    کوشش {
        م.نتیجہ(5.0);
    } پکڑو (غ) {
        جانچ("مستقبل غلطی پکڑی گئی", سچ);
        لکھو(`  ⓘ غلطی: ${غ.پیغام}`);
    }
    جانچ("مستقبل مکمل (غلطی کے بعد)", م.مکمل());
    تالاب.بند();
} پکڑو (غ) {
    لکھو(`  ✗ مستقبل غلطی جانچ میں خرابی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ─── مقامی_ذخیرہ ─────────────────────────────
لکھو("\n─── مقامی_ذخیرہ ───");

کوشش {
    متغیر ذخ = نیا مقامی_ذخیرہ();
    ذخ.مقرر("صارف", "احمد");
    ذخ.مقرر("عمر", 25);

    جانچ("مقامی_ذخیرہ مقرر/حاصل", ذخ.حاصل("صارف") == "احمد");
    جانچ("مقامی_ذخیرہ عدد", ذخ.حاصل("عمر") == 25);
    جانچ("مقامی_ذخیرہ ڈیفالٹ", ذخ.حاصل("غیر_موجود", "ڈیفالٹ") == "ڈیفالٹ");
} پکڑو (غ) {
    لکھو(`  ✗ مقامی_ذخیرہ غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

// ─── متوازی جمع (parallel sum) ───────────────
لکھو("\n─── متوازی جمع (4 دھاگے) ───");

کوشش {
    متغیر تالاب = نیا دھاگہ_تالاب(4);

    فنکشن ذیلی_جمع(فہرست) {
        متغیر مجموع = 0;
        کے_لیے (متغیر ع میں فہرست) {
            مجموع = مجموع + ع;
        }
        واپس مجموع;
    }

    متغیر م1 = تالاب.جمع_کرو_مستقبل(ذیلی_جمع, [1, 2, 3, 4, 5]);
    متغیر م2 = تالاب.جمع_کرو_مستقبل(ذیلی_جمع, [6, 7, 8, 9, 10]);
    متغیر م3 = تالاب.جمع_کرو_مستقبل(ذیلی_جمع, [11, 12, 13, 14, 15]);
    متغیر م4 = تالاب.جمع_کرو_مستقبل(ذیلی_جمع, [16, 17, 18, 19, 20]);

    متغیر مجموع = م1.نتیجہ(5.0) + م2.نتیجہ(5.0) + م3.نتیجہ(5.0) + م4.نتیجہ(5.0);
    جانچ("متوازی جمع 1-20 = 210", مجموع == 210);
    لکھو(`  ⓘ مجموع 1..20 = ${مجموع}`);
    تالاب.بند();
} پکڑو (غ) {
    لکھو(`  ✗ متوازی جمع غلطی: ${غ}`);
    ن["ناکام"] = ن["ناکام"] + 1;
}

لکھو(`\n══════════════════════════════════════`);
لکھو(`  دھاگہ و مستقبل جانچ — گزرے: ${ن["گزرے"]}  ناکام: ${ن["ناکام"]}`);
لکھو(`══════════════════════════════════════`);
