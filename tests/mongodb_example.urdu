// ══════════════════════════════════════════════════════
// اردو پروگرامنگ لینگویج — مونگو_ڈی_بی مثال
// مکمل CRUD + تلاش + اجتماعی آپریشنز
// ══════════════════════════════════════════════════════

درآمد { مونگو_ڈی_بی } سے "اردو/ڈیٹا_بیس";

متغیر mongo = نیا مونگو_ڈی_بی({
    میزبان:    "localhost",
    پورٹ:      27017,
    ڈیٹا_بیس: "urdu_test"
});

غیر_متزامن فنکشن مرکز() {

    // ─── جڑیں ─────────────────────────────────────────
    انتظار mongo.جوڑیں();
    لکھو("✓ مونگو_ڈی_بی سے جڑ گئے\n");

    متغیر کتابیں = mongo.مجموعہ("کتابیں");
    متغیر صارفین = mongo.مجموعہ("صارفین");

    // ─── پہلے پرانا ڈیٹا صاف کریں ───────────────────
    انتظار کتابیں.حذف({});
    انتظار صارفین.حذف({});

    // ─── کتابیں داخل کریں ─────────────────────────────
    لکھو("═══ کتابیں داخل کرنا ═══");
    متغیر کتب_فہرست = [
        { عنوان: "گلستان سعدی",    مصنف: "سعدی شیرازی",    صنف: "شاعری",   صفحات: 312, سال: 1258, قیمت: 850  },
        { عنوان: "فیض کا کلام",     مصنف: "فیض احمد فیض",  صنف: "شاعری",   صفحات: 256, سال: 1941, قیمت: 650  },
        { عنوان: "آگ کا دریا",      مصنف: "قرة العین حیدر", صنف: "ناول",    صفحات: 543, سال: 1959, قیمت: 1200 },
        { عنوان: "اداس نسلیں",      مصنف: "عبداللہ حسین",   صنف: "ناول",    صفحات: 421, سال: 1963, قیمت: 980  },
        { عنوان: "زندگی نامہ",      مصنف: "جوش ملیح آبادی", صنف: "سوانح",   صفحات: 689, سال: 1970, قیمت: 1500 },
        { عنوان: "انار کلی",        مصنف: "امتیاز علی تاج", صنف: "ڈراما",   صفحات: 198, سال: 1932, قیمت: 450  },
        { عنوان: "شاہ نامہ",        مصنف: "فردوسی",          صنف: "شاعری",   صفحات: 890, سال: 1010, قیمت: 2200 },
        { عنوان: "بوستان سعدی",     مصنف: "سعدی شیرازی",    صنف: "شاعری",   صفحات: 278, سال: 1257, قیمت: 800  },
    ];

    متغیر ڈالے_گئے = انتظار کتابیں.بہت_داخل(کتب_فہرست);
    لکھو(`  ${لمبائی(ڈالے_گئے)} کتابیں داخل کی گئیں`);
    لکھو(`  پہلی ID: ${ڈالے_گئے[0]}\n`);

    // ─── تمام دستاویزات دیکھیں ────────────────────────
    لکھو("═══ تمام کتابیں ═══");
    متغیر سب = انتظار کتابیں.تلاش({});
    کے_لیے (متغیر ک میں سب) {
        لکھو(`  ${ک.عنوان.ljust(20)} | ${ک.مصنف.ljust(20)} | ${ک.صنف} | Rs ${ک.قیمت}`);
    }

    // ─── ایک دستاویز تلاش ─────────────────────────────
    لکھو("\n═══ ایک کتاب تلاش (آگ کا دریا) ═══");
    متغیر ایک = انتظار کتابیں.ایک_تلاش({ عنوان: "آگ کا دریا" });
    اگر (ایک) {
        لکھو(`  عنوان : ${ایک.عنوان}`);
        لکھو(`  مصنف  : ${ایک.مصنف}`);
        لکھو(`  صفحات : ${ایک.صفحات}`);
        لکھو(`  سال   : ${ایک.سال}`);
        لکھو(`  قیمت  : Rs ${ایک.قیمت}`);
    }

    // ─── فلٹر کریں (صنف = شاعری) ─────────────────────
    لکھو("\n═══ شاعری کی کتابیں ═══");
    متغیر شاعری = انتظار کتابیں.تلاش({ صنف: "شاعری" });
    کے_لیے (متغیر ک میں شاعری) {
        لکھو(`  ${ک.عنوان} از ${ک.مصنف} (${ک.سال})`);
    }

    // ─── حد کے ساتھ تلاش (مہنگی کتابیں) ─────────────
    لکھو("\n═══ 3 مہنگی ترین کتابیں ═══");
    متغیر مہنگی = انتظار کتابیں.تلاش({}, { حد: 3 });
    کے_لیے (متغیر ک میں مہنگی) {
        لکھو(`  ${ک.عنوان}: Rs ${ک.قیمت}`);
    }

    // ─── تازہ کاری ────────────────────────────────────
    لکھو("\n═══ تمام شاعری 20% سستی کرنا ═══");
    متغیر تازہ = انتظار کتابیں.تازہ_کاری(
        { صنف: "شاعری" },
        {}
    );
    // JavaScript-style: قیمت کو خود اپ ڈیٹ کریں
    متغیر شاعری2 = انتظار کتابیں.تلاش({ صنف: "شاعری" });
    کے_لیے (متغیر ک میں شاعری2) {
        متغیر نئی_قیمت = گول(ک.قیمت * 0.8, 0);
        انتظار کتابیں.تازہ_کاری({ عنوان: ک.عنوان }, { قیمت: نئی_قیمت });
        لکھو(`  ${ک.عنوان}: Rs ${ک.قیمت} → Rs ${نئی_قیمت}`);
    }

    // ─── گنتی ─────────────────────────────────────────
    لکھو("\n═══ گنتی ═══");
    متغیر کل_کتب   = انتظار کتابیں.گنتی({});
    متغیر کل_شاعری = انتظار کتابیں.گنتی({ صنف: "شاعری" });
    متغیر کل_ناول  = انتظار کتابیں.گنتی({ صنف: "ناول" });
    لکھو(`  کل کتابیں   : ${کل_کتب}`);
    لکھو(`  شاعری کتابیں : ${کل_شاعری}`);
    لکھو(`  ناول          : ${کل_ناول}`);

    // ─── صارفین مجموعہ ────────────────────────────────
    لکھو("\n═══ صارفین داخل کرنا ═══");
    انتظار صارفین.داخل({ نام: "احمد علی",   ای_میل: "ahmed@test.com", پسندیدہ_صنف: "شاعری",  خریدیں: 5 });
    انتظار صارفین.داخل({ نام: "فاطمہ خان",  ای_میل: "fatima@test.com", پسندیدہ_صنف: "ناول",   خریدیں: 8 });
    انتظار صارفین.داخل({ نام: "محمد عمر",   ای_میل: "omar@test.com",  پسندیدہ_صنف: "شاعری",  خریدیں: 3 });
    انتظار صارفین.داخل({ نام: "عائشہ بیگم", ای_میل: "ayesha@test.com", پسندیدہ_صنف: "سوانح",  خریدیں: 12 });
    لکھو(`  صارفین داخل کیے: ${انتظار صارفین.گنتی({})}`);

    // ─── تمام صارفین ──────────────────────────────────
    لکھو("\n═══ تمام صارفین ═══");
    متغیر سب_صارفین = انتظار صارفین.تلاش({});
    کے_لیے (متغیر ص میں سب_صارفین) {
        لکھو(`  ${ص.نام.ljust(15)} | ${ص.ای_میل.ljust(20)} | خریداری: ${ص.خریدیں}`);
    }

    // ─── زیادہ خریدنے والے ────────────────────────────
    لکھو("\n═══ 5 سے زیادہ خریداری ═══");
    متغیر فعال = انتظار صارفین.تلاش({ خریدیں: { "$gt": 5 } });
    کے_لیے (متغیر ص میں فعال) {
        لکھو(`  ${ص.نام}: ${ص.خریدیں} کتابیں`);
    }

    // ─── ایک صارف حذف ─────────────────────────────────
    لکھو("\n═══ صارف حذف (کم خریداری) ═══");
    متغیر حذف_شدہ = انتظار صارفین.حذف({ خریدیں: { "$lt": 4 } });
    لکھو(`  ${حذف_شدہ} صارف حذف ہوئے`);
    لکھو(`  باقی صارفین: ${انتظار صارفین.گنتی({})}`);

    // ─── بند کریں ─────────────────────────────────────
    انتظار mongo.منقطع();
    لکھو("\n✓ مونگو_ڈی_بی بند ہوا");
}

مرکز();
