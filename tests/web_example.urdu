// ══════════════════════════════════════════════
// اردو پروگرامنگ لینگویج — ویب API مثال
// FastAPI Web Server Example
// چلانے کے لیے: pip install fastapi uvicorn
// ══════════════════════════════════════════════

درآمد { فاسٹ_اے_پی_آئی, جیسن_جواب } سے "اردو/ویب";

متغیر ایپ = نیا فاسٹ_اے_پی_آئی(
    عنوان="اردو طلبہ API",
    نسخہ="1.0.0",
    تفصیل="اردو پروگرامنگ لینگویج سے بنی API"
);

// فرضی ڈیٹابیس
متغیر طلبہ = [
    { شناخت: 1, نام: "احمد علی",   درجہ: "دسواں",    نمبر: 92 },
    { شناخت: 2, نام: "فاطمہ خان",  درجہ: "گیارہویں", نمبر: 88 },
    { شناخت: 3, نام: "محمد عمر",   درجہ: "نواں",     نمبر: 95 },
];

// GET /
ایپ.حاصل("/")(
    غیر_متزامن فنکشن صفحہ_اول() {
        واپس {
            پیغام: "السلام علیکم! اردو API میں خوش آمدید",
            نسخہ: "1.0.0",
            ڈویلپر: "Mohammed Zahid Wadiwale"
        };
    }
);

// GET /طلبہ
ایپ.حاصل("/طلبہ")(
    غیر_متزامن فنکشن سبھی_طلبہ() {
        واپس { گنتی: لمبائی(طلبہ), طلبہ: طلبہ };
    }
);

// GET /طالب/{شناخت}
ایپ.حاصل("/طالب/{شناخت}")(
    غیر_متزامن فنکشن ایک_طالب(شناخت) {
        متغیر نتیجہ = طلبہ.find(فنکشن(ط) { واپس ط.شناخت == عدد(شناخت); });
        اگر (!نتیجہ) {
            واپس نیا جیسن_جواب({ غلطی: "طالب علم نہیں ملا" }, 404);
        }
        واپس نتیجہ;
    }
);

// GET /نمبر/اوسط
ایپ.حاصل("/نمبر/اوسط")(
    غیر_متزامن فنکشن اوسط_نمبر() {
        متغیر کل = مجموع(نقشہ(فنکشن(ط) { واپس ط.نمبر; }, طلبہ));
        واپس { اوسط: گول(کل / لمبائی(طلبہ), 2) };
    }
);

// POST /طالب/شامل
ایپ.بھیجیں("/طالب/شامل")(
    غیر_متزامن فنکشن طالب_شامل(درخواست) {
        متغیر ڈیٹا = انتظار درخواست.json();
        متغیر نیا_طالب = {
            شناخت: لمبائی(طلبہ) + 1,
            نام: ڈیٹا.نام || "نامعلوم",
            درجہ: ڈیٹا.درجہ || "نامعلوم",
            نمبر: ڈیٹا.نمبر || 0
        };
        طلبہ.push(نیا_طالب);
        واپس { پیغام: "طالب علم شامل ہوا", طالب: نیا_طالب };
    }
);

// DELETE /طالب/{شناخت}
ایپ.حذف("/طالب/{شناخت}")(
    غیر_متزامن فنکشن طالب_حذف(شناخت) {
        متغیر اشاریہ = طلبہ.findIndex(فنکشن(ط) { واپس ط.شناخت == عدد(شناخت); });
        اگر (اشاریہ == -1) {
            واپس نیا جیسن_جواب({ غلطی: "نہیں ملا" }, 404);
        }
        طلبہ.splice(اشاریہ, 1);
        واپس { پیغام: "حذف ہوگیا" };
    }
);

// سرور چلائیں
لکھو("اردو FastAPI سرور شروع ہو رہا ہے...");
لکھو("براؤزر میں کھولیں: http://localhost:8000");
لکھو("API دستاویز: http://localhost:8000/docs");
ایپ.چلائیں(میزبان="0.0.0.0", پورٹ=8000, دوبارہ_لوڈ=جھوٹ);
